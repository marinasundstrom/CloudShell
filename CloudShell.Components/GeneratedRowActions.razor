<div class="@CssClass">
    @ChildContent
</div>

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string CssClass =>
        string.IsNullOrWhiteSpace(Class)
            ? "generated-row-actions"
            : $"generated-row-actions {Class}";
}
