<div class="resource-identity-fields">
    <label for="@ResourceIdInputId">@ResourceIdLabel</label>
    <FluentTextField Id="@ResourceIdInputId"
                     Value="@ResourceId"
                     ValueChanged="@ResourceIdChanged"
                     Disabled="@ResourceIdDisabled"
                     Placeholder="@ResourceIdPlaceholder" />

    @if (EnableDisplayNames)
    {
        <label for="@DisplayNameInputId">@DisplayNameLabel</label>
        <FluentTextField Id="@DisplayNameInputId"
                         Value="@DisplayName"
                         ValueChanged="@DisplayNameChanged"
                         Placeholder="@DisplayNamePlaceholder" />
    }
</div>

@code {
    public const string DisplayNamesEnabledCascadingParameterName =
        "ResourceManagerEnableDisplayNames";

    [CascadingParameter(Name = DisplayNamesEnabledCascadingParameterName)]
    public bool EnableDisplayNames { get; set; } = true;

    [Parameter]
    public string ResourceIdInputId { get; set; } = "resource-id";

    [Parameter]
    public string DisplayNameInputId { get; set; } = "resource-display-name";

    [Parameter]
    public string ResourceIdLabel { get; set; } = "Resource ID";

    [Parameter]
    public string DisplayNameLabel { get; set; } = "Display name (optional)";

    [Parameter]
    public string? ResourceIdPlaceholder { get; set; }

    [Parameter]
    public bool ResourceIdDisabled { get; set; }

    [Parameter]
    public string? DisplayNamePlaceholder { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public EventCallback<string?> ResourceIdChanged { get; set; }

    [Parameter]
    public string? DisplayName { get; set; }

    [Parameter]
    public EventCallback<string?> DisplayNameChanged { get; set; }
}
