@inject IResourceManager ResourceManager
@inject IServiceProvider Services

@if (EntryManager is null)
{
    <EmptyState Title="Setting management unavailable"
                Message="This UI host does not have access to the Configuration Store runtime manager." />
}
else if (Resource is null)
{
    <EmptyState Title="Configuration Store is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Settings</h3>
                <p>@GetSettingSummary()</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ProcedureMessage Message="@ErrorMessage" />
        }

        <ResourceEditorSection Class="configuration-store-entry-editor">
            <Actions>
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="new Icons.Regular.Size20.Add()"
                              OnClick="AddSetting">
                    Add setting
                </FluentButton>
            </Actions>
            <ChildContent>
                @foreach (var entry in Entries)
                {
                    <div class="environment-row configuration-entry-row configuration-entry-runtime-row">
                        <FluentTextField AriaLabel="Configuration setting name"
                                         Placeholder="Name"
                                         @bind-Value="entry.Name" />
                        <FluentTextField AriaLabel="Configuration setting value"
                                         Placeholder="Value"
                                         @bind-Value="entry.Value" />
                        <FluentButton Appearance="Appearance.Neutral"
                                      IconStart="new Icons.Regular.Size20.Delete()"
                                      OnClick="() => RemoveSetting(entry)">
                            Remove
                        </FluentButton>
                    </div>
                }
            </ChildContent>
        </ResourceEditorSection>
    </section>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private CloudShell.Abstractions.ResourceManager.Resource? Resource { get; set; }
    private IConfigurationStoreRuntimeEntryManager? EntryManager { get; set; }
    private List<EntryInput> Entries { get; } = [];
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        EntryManager = Services.GetService(typeof(IConfigurationStoreRuntimeEntryManager))
            as IConfigurationStoreRuntimeEntryManager;
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);

        Entries.Clear();
        if (EntryManager is not null && Resource is not null)
        {
            var entries = await EntryManager.ListEntriesAsync(Resource.Id);
            Entries.AddRange(entries.Select(EntryInput.FromEntry));
        }

        if (Entries.Count == 0)
        {
            Entries.Add(new());
        }

        RegisterApplyHandler();
    }

    private void RegisterApplyHandler()
    {
        if (Configuration is not null &&
            EntryManager is not null &&
            Resource is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private string GetSettingSummary()
    {
        var count = Entries.Count(entry => !string.IsNullOrWhiteSpace(entry.Name));
        return count == 1
            ? "1 runtime setting is configured for this store."
            : $"{count} runtime settings are configured for this store.";
    }

    private void AddSetting()
    {
        Entries.Add(new());
        ErrorMessage = null;
    }

    private void RemoveSetting(EntryInput entry)
    {
        Entries.Remove(entry);
        if (Entries.Count == 0)
        {
            Entries.Add(new());
        }

        ErrorMessage = null;
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (EntryManager is null || Resource is null)
        {
            return ResourceProcedureResult.Completed("Configuration Store setting management is unavailable.");
        }

        var entries = BuildEntries();
        if (entries is null)
        {
            return ResourceProcedureResult.Completed(ErrorMessage ?? "Configuration Store settings were not updated.");
        }

        await EntryManager.UpdateEntriesAsync(
            CreateRuntimeContext(Resource),
            entries,
            cancellationToken);
        ErrorMessage = null;
        return ResourceProcedureResult.Completed("Configuration Store settings updated.");
    }

    private IReadOnlyList<ConfigurationStoreRuntimeEntry>? BuildEntries()
    {
        var entries = Entries
            .Where(entry => !string.IsNullOrWhiteSpace(entry.Name))
            .Select(entry => new ConfigurationStoreRuntimeEntry(
                entry.Name!.Trim(),
                entry.Value ?? string.Empty))
            .ToArray();

        var duplicate = entries
            .GroupBy(entry => entry.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault(group => group.Count() > 1)
            ?.Key;
        if (!string.IsNullOrWhiteSpace(duplicate))
        {
            ErrorMessage = $"Configuration setting '{duplicate}' is defined more than once.";
            return null;
        }

        return entries;
    }

    private static ProviderRuntimeResourceContext CreateRuntimeContext(
        CloudShell.Abstractions.ResourceManager.Resource resource) =>
        new(
            resource.Id,
            resource.Name,
            resource.EffectiveDisplayName,
            resource.ResourceAttributes.GetValueOrDefault(
                ConfigurationStoreResourceTypeProvider.Attributes.Endpoint.ToString()));

    private sealed class EntryInput
    {
        public string? Name { get; set; }

        public string? Value { get; set; }

        public static EntryInput FromEntry(ConfigurationStoreRuntimeEntry entry) =>
            new()
            {
                Name = entry.Name,
                Value = entry.Value
            };
    }
}
