@inject IResourceManager ResourceManager
@inject IServiceProvider Services

@if (SettingManager is null)
{
    <EmptyState Title="Setting management unavailable"
                Message="This UI host cannot manage settings for this Configuration Store." />
}
else if (Resource is null)
{
    <EmptyState Title="Configuration Store is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Settings</h3>
                <p>@GetSettingSummary()</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ProcedureMessage Message="@ErrorMessage" />
        }
        @if (RemovedExistingSettings.Count > 0)
        {
            <ProcedureMessage Compact="true" Severity="ResourceSignalSeverity.Warning" Role="status">
                @GetRemovedSettingSummary()
            </ProcedureMessage>
        }

        <ResourceEditorSection Class="configuration-store-setting-editor">
            <Actions>
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="new Icons.Regular.Size20.Add()"
                              OnClick="AddSetting">
                    Add setting
                </FluentButton>
            </Actions>
            <ChildContent>
                @foreach (var setting in Settings)
                {
                    <div class="environment-row configuration-setting-row configuration-setting-runtime-row">
                        <FluentTextField AriaLabel="Configuration setting name"
                                         Placeholder="Name"
                                         @bind-Value="setting.Name" />
                        <FluentTextField AriaLabel="Configuration setting value"
                                         Placeholder="Value"
                                         @bind-Value="setting.Value" />
                        <FluentButton Appearance="Appearance.Neutral"
                                      IconStart="new Icons.Regular.Size20.Delete()"
                                      OnClick="() => RemoveSetting(setting)">
                            Remove
                        </FluentButton>
                    </div>
                }
            </ChildContent>
        </ResourceEditorSection>
    </section>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private CloudShell.Abstractions.ResourceManager.Resource? Resource { get; set; }
    private IConfigurationStoreRuntimeSettingManager? SettingManager { get; set; }
    private List<SettingInput> Settings { get; } = [];
    private List<string> RemovedExistingSettings { get; } = [];
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        SettingManager = Services.GetService(typeof(IConfigurationStoreRuntimeSettingManager))
            as IConfigurationStoreRuntimeSettingManager;
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);

        Settings.Clear();
        RemovedExistingSettings.Clear();
        if (SettingManager is not null && Resource is not null)
        {
            var settings = await SettingManager.ListSettingsAsync(Resource.Id);
            Settings.AddRange(settings.Select(SettingInput.FromSetting));
        }

        if (Settings.Count == 0)
        {
            Settings.Add(new());
        }

        RegisterApplyHandler();
    }

    private void RegisterApplyHandler()
    {
        if (Configuration is not null &&
            SettingManager is not null &&
            Resource is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private string GetSettingSummary()
    {
        var count = Settings.Count(setting => !string.IsNullOrWhiteSpace(setting.Name));
        return count == 1
            ? "1 setting is configured for this store."
            : $"{count} settings are configured for this store.";
    }

    private void AddSetting()
    {
        Settings.Add(new());
        ErrorMessage = null;
    }

    private void RemoveSetting(SettingInput setting)
    {
        Settings.Remove(setting);
        TrackRemovedSetting(setting);
        if (Settings.Count == 0)
        {
            Settings.Add(new());
        }

        ErrorMessage = null;
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (SettingManager is null || Resource is null)
        {
            return ResourceProcedureResult.Completed("Configuration Store settings cannot be managed from this UI host.");
        }

        var settings = BuildSettings();
        if (settings is null)
        {
            return ResourceProcedureResult.Completed(ErrorMessage ?? "Configuration Store settings were not updated.");
        }

        await SettingManager.UpdateSettingsAsync(
            CreateRuntimeContext(Resource),
            settings,
            cancellationToken);
        ErrorMessage = null;
        RemovedExistingSettings.Clear();
        return ResourceProcedureResult.Completed("Configuration Store settings updated.");
    }

    private void TrackRemovedSetting(SettingInput setting)
    {
        if (!setting.IsExisting || string.IsNullOrWhiteSpace(setting.Name))
        {
            return;
        }

        var label = setting.Name.Trim();
        if (!RemovedExistingSettings.Contains(label, StringComparer.OrdinalIgnoreCase))
        {
            RemovedExistingSettings.Add(label);
        }
    }

    private string GetRemovedSettingSummary()
    {
        var names = string.Join(", ", RemovedExistingSettings.Order(StringComparer.OrdinalIgnoreCase));
        return RemovedExistingSettings.Count == 1
            ? $"Setting {names} will be deleted when you apply changes."
            : $"Settings {names} will be deleted when you apply changes.";
    }

    private IReadOnlyList<ConfigurationStoreRuntimeSetting>? BuildSettings()
    {
        var settings = Settings
            .Where(setting => !string.IsNullOrWhiteSpace(setting.Name))
            .Select(setting => new ConfigurationStoreRuntimeSetting(
                setting.Name!.Trim(),
                setting.Value ?? string.Empty))
            .ToArray();

        var duplicate = settings
            .GroupBy(setting => setting.Name, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault(group => group.Count() > 1)
            ?.Key;
        if (!string.IsNullOrWhiteSpace(duplicate))
        {
            ErrorMessage = $"Configuration setting '{duplicate}' is defined more than once.";
            return null;
        }

        return settings;
    }

    private static ProviderRuntimeResourceContext CreateRuntimeContext(
        CloudShell.Abstractions.ResourceManager.Resource resource) =>
        new(
            resource.Id,
            resource.Name,
            resource.EffectiveDisplayName,
            resource.ResourceAttributes.GetValueOrDefault(
                ConfigurationStoreResourceTypeProvider.Attributes.Endpoint.ToString()));

    private sealed class SettingInput
    {
        public string? Name { get; set; }

        public string? Value { get; set; }

        public bool IsExisting { get; set; }

        public static SettingInput FromSetting(ConfigurationStoreRuntimeSetting setting) =>
            new()
            {
                Name = setting.Name,
                Value = setting.Value,
                IsExisting = true
            };
    }
}
