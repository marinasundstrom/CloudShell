@using System.Globalization
@using System.Security.Cryptography
@using System.Security.Cryptography.X509Certificates
@inject IResourceManager ResourceManager
@inject IServiceProvider Services

@if (SecretManager is null)
{
    <EmptyState Title="Certificate management unavailable"
                Message="This UI host does not have access to the Secrets Vault runtime manager." />
}
else if (Resource is null)
{
    <EmptyState Title="Secrets Vault is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Certificates</h3>
                <p>@GetCertificateSummary()</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ProcedureMessage Message="@ErrorMessage" />
        }

        <ResourceEditorSection Class="secrets-vault-certificate-editor">
            <Actions>
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="new Icons.Regular.Size20.Add()"
                              OnClick="AddCertificate">
                    Add certificate
                </FluentButton>
            </Actions>
            <ChildContent>
                @foreach (var certificate in Certificates)
                {
                    <div class="environment-row configuration-secret-row">
                        <FluentTextField AriaLabel="Certificate name"
                                         Placeholder="Name"
                                         @bind-Value="certificate.Name" />
                        <FluentTextField AriaLabel="Certificate version"
                                         Placeholder="Version (auto)"
                                         @bind-Value="certificate.Version" />
                        <FluentTextField AriaLabel="Certificate content type"
                                         Placeholder="Content type"
                                         @bind-Value="certificate.ContentType" />
                        @if (certificate.IsExisting)
                        {
                            <span class="configuration-secret-placeholder">@CreateMask(certificate.CurrentValue)</span>
                        }
                        else
                        {
                            <span class="configuration-secret-placeholder">New</span>
                        }
                        <InputFile OnChange="args => UploadCertificateAsync(certificate, args)" />
                        <FluentButton Appearance="Appearance.Neutral"
                                      IconStart="new Icons.Regular.Size20.Certificate()"
                                      OnClick="() => GenerateCertificate(certificate)">
                            Generate
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Neutral"
                                      IconStart="new Icons.Regular.Size20.Delete()"
                                      OnClick="() => RemoveCertificate(certificate)">
                            Remove
                        </FluentButton>
                    </div>
                    <div class="environment-row configuration-secret-row">
                        <FluentTextField AriaLabel="Certificate subject"
                                         Placeholder="Subject"
                                         @bind-Value="certificate.Subject" />
                        <FluentTextField AriaLabel="Certificate thumbprint"
                                         Placeholder="Thumbprint"
                                         @bind-Value="certificate.Thumbprint" />
                        <FluentTextField AriaLabel="Certificate not before"
                                         Placeholder="Not before"
                                         @bind-Value="certificate.NotBefore" />
                        <FluentTextField AriaLabel="Certificate expires"
                                         Placeholder="Expires"
                                         @bind-Value="certificate.Expires" />
                        <FluentCheckbox @bind-Value="certificate.HasPrivateKey">
                            Private key
                        </FluentCheckbox>
                    </div>
                    <div class="environment-row configuration-secret-row">
                        <FluentTextArea AriaLabel="Certificate value"
                                        Placeholder="Paste PEM, base64 PFX, or leave unchanged"
                                        Rows="4"
                                        @bind-Value="certificate.Value" />
                    </div>
                }
            </ChildContent>
        </ResourceEditorSection>
    </section>
}

@code {
    private const long MaxCertificateUploadBytes = 1024 * 1024;

    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private CloudShell.Abstractions.ResourceManager.Resource? Resource { get; set; }
    private ISecretsVaultRuntimeSecretManager? SecretManager { get; set; }
    private List<CertificateInput> Certificates { get; } = [];
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        SecretManager = Services.GetService(typeof(ISecretsVaultRuntimeSecretManager))
            as ISecretsVaultRuntimeSecretManager;
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);

        Certificates.Clear();
        if (SecretManager is not null && Resource is not null)
        {
            var certificates = await SecretManager.ListCertificatesAsync(Resource.Id);
            Certificates.AddRange(certificates.Select(CertificateInput.FromCertificate));
        }

        if (Certificates.Count == 0)
        {
            Certificates.Add(new());
        }

        RegisterApplyHandler();
    }

    private void RegisterApplyHandler()
    {
        if (Configuration is not null &&
            SecretManager is not null &&
            Resource is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private string GetCertificateSummary()
    {
        var count = Certificates.Count(certificate => !string.IsNullOrWhiteSpace(certificate.Name));
        return count == 1
            ? "1 runtime certificate is configured for this vault."
            : $"{count} runtime certificates are configured for this vault.";
    }

    private void AddCertificate()
    {
        Certificates.Add(new());
        ErrorMessage = null;
    }

    private void RemoveCertificate(CertificateInput certificate)
    {
        Certificates.Remove(certificate);
        if (Certificates.Count == 0)
        {
            Certificates.Add(new());
        }

        ErrorMessage = null;
    }

    private async Task UploadCertificateAsync(
        CertificateInput certificate,
        InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file.Size > MaxCertificateUploadBytes)
        {
            ErrorMessage = "Certificate files must be 1 MB or smaller.";
            return;
        }

        await using var stream = file.OpenReadStream(MaxCertificateUploadBytes);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);
        var bytes = memory.ToArray();
        var contentType = string.IsNullOrWhiteSpace(file.ContentType)
            ? GuessContentType(file.Name)
            : file.ContentType;

        certificate.Name ??= Path.GetFileNameWithoutExtension(file.Name);
        certificate.ContentType = contentType;
        certificate.Value = IsTextCertificate(contentType, file.Name)
            ? System.Text.Encoding.UTF8.GetString(bytes)
            : Convert.ToBase64String(bytes);
        ErrorMessage = null;
    }

    private void GenerateCertificate(CertificateInput certificate)
    {
        var name = string.IsNullOrWhiteSpace(certificate.Name)
            ? "development-tls"
            : certificate.Name.Trim();
        var subjectName = string.IsNullOrWhiteSpace(certificate.Subject)
            ? $"CN={name}"
            : certificate.Subject.Trim();
        var notBefore = DateTimeOffset.UtcNow.AddDays(-1);
        var expires = notBefore.AddYears(1);

        try
        {
            using var rsa = RSA.Create(2048);
            var request = new CertificateRequest(
                subjectName,
                rsa,
                HashAlgorithmName.SHA256,
                RSASignaturePadding.Pkcs1);
            request.CertificateExtensions.Add(new X509BasicConstraintsExtension(false, false, 0, false));
            request.CertificateExtensions.Add(new X509KeyUsageExtension(
                X509KeyUsageFlags.DigitalSignature | X509KeyUsageFlags.KeyEncipherment,
                false));

            var san = new SubjectAlternativeNameBuilder();
            san.AddDnsName(name);
            san.AddDnsName("localhost");
            request.CertificateExtensions.Add(san.Build());

            using var generated = request.CreateSelfSigned(notBefore, expires);
            certificate.Name = name;
            certificate.Value = $"{rsa.ExportPkcs8PrivateKeyPem()}{generated.ExportCertificatePem()}";
            certificate.ContentType = "application/x-pem-file";
            certificate.Subject = generated.Subject;
            certificate.Thumbprint = generated.Thumbprint;
            certificate.NotBefore = notBefore.ToString("O", CultureInfo.InvariantCulture);
            certificate.Expires = expires.ToString("O", CultureInfo.InvariantCulture);
            certificate.HasPrivateKey = true;
            ErrorMessage = null;
        }
        catch (ArgumentException ex)
        {
            ErrorMessage = $"Certificate generation failed: {ex.Message}";
        }
        catch (CryptographicException ex)
        {
            ErrorMessage = $"Certificate generation failed: {ex.Message}";
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (SecretManager is null || Resource is null)
        {
            return ResourceProcedureResult.Completed("Secrets Vault certificate management is unavailable.");
        }

        var certificates = BuildCertificates();
        if (certificates is null)
        {
            return ResourceProcedureResult.Completed(ErrorMessage ?? "Secrets Vault certificates were not updated.");
        }

        await SecretManager.UpdateCertificatesAsync(
            CreateRuntimeContext(Resource),
            certificates,
            cancellationToken);
        ErrorMessage = null;
        return ResourceProcedureResult.Completed("Secrets Vault certificates updated.");
    }

    private IReadOnlyList<SecretsVaultRuntimeCertificate>? BuildCertificates()
    {
        var certificates = new List<SecretsVaultRuntimeCertificate>();
        foreach (var certificate in Certificates.Where(certificate =>
            !string.IsNullOrWhiteSpace(certificate.Name)))
        {
            if (!TryParseDate(certificate.NotBefore, "not before", out var notBefore) ||
                !TryParseDate(certificate.Expires, "expires", out var expires))
            {
                return null;
            }

            certificates.Add(new SecretsVaultRuntimeCertificate(
                certificate.Name!.Trim(),
                ResolveCertificateValue(certificate),
                string.IsNullOrWhiteSpace(certificate.Version) ? null : certificate.Version.Trim(),
                string.IsNullOrWhiteSpace(certificate.ContentType) ? null : certificate.ContentType.Trim(),
                string.IsNullOrWhiteSpace(certificate.Thumbprint) ? null : certificate.Thumbprint.Trim(),
                string.IsNullOrWhiteSpace(certificate.Subject) ? null : certificate.Subject.Trim(),
                notBefore,
                expires,
                certificate.HasPrivateKey));
        }

        var duplicate = certificates
            .GroupBy(certificate => $"{certificate.Name}\u001f{certificate.Version}", StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault(group => group.Count() > 1)
            ?.First();
        if (duplicate is not null)
        {
            ErrorMessage = string.IsNullOrWhiteSpace(duplicate.Version)
                ? $"Certificate '{duplicate.Name}' is defined more than once."
                : $"Certificate '{duplicate.Name}' version '{duplicate.Version}' is defined more than once.";
            return null;
        }

        return certificates;
    }

    private bool TryParseDate(
        string? value,
        string label,
        out DateTimeOffset? result)
    {
        result = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (DateTimeOffset.TryParse(
                value,
                CultureInfo.InvariantCulture,
                DateTimeStyles.AssumeUniversal,
                out var parsed))
        {
            result = parsed;
            return true;
        }

        ErrorMessage = $"Certificate {label} value '{value}' is not a valid date.";
        return false;
    }

    private static string ResolveCertificateValue(CertificateInput certificate) =>
        !string.IsNullOrEmpty(certificate.Value)
            ? certificate.Value
            : certificate.CurrentValue ?? string.Empty;

    private static ProviderRuntimeResourceContext CreateRuntimeContext(
        CloudShell.Abstractions.ResourceManager.Resource resource) =>
        new(
            resource.Id,
            resource.Name,
            resource.EffectiveDisplayName,
            resource.ResourceAttributes.GetValueOrDefault(
                SecretsVaultResourceTypeProvider.Attributes.Endpoint.ToString()));

    private static string CreateMask(string? value)
    {
        var length = string.IsNullOrEmpty(value)
            ? 8
            : Math.Clamp(value.Length, 8, 16);
        return new string('*', length);
    }

    private static string GuessContentType(string fileName) =>
        Path.GetExtension(fileName).ToLowerInvariant() switch
        {
            ".pem" or ".crt" or ".cer" or ".key" => "application/x-pem-file",
            ".pfx" or ".p12" => "application/x-pkcs12",
            _ => "application/octet-stream"
        };

    private static bool IsTextCertificate(string? contentType, string fileName) =>
        contentType?.Contains("pem", StringComparison.OrdinalIgnoreCase) == true ||
        Path.GetExtension(fileName).Equals(".pem", StringComparison.OrdinalIgnoreCase) ||
        Path.GetExtension(fileName).Equals(".crt", StringComparison.OrdinalIgnoreCase) ||
        Path.GetExtension(fileName).Equals(".cer", StringComparison.OrdinalIgnoreCase) ||
        Path.GetExtension(fileName).Equals(".key", StringComparison.OrdinalIgnoreCase);

    private sealed class CertificateInput
    {
        public string? Name { get; set; }

        public string? Version { get; set; }

        public string? ContentType { get; set; }

        public string? Value { get; set; }

        public string? CurrentValue { get; set; }

        public string? Thumbprint { get; set; }

        public string? Subject { get; set; }

        public string? NotBefore { get; set; }

        public string? Expires { get; set; }

        public bool HasPrivateKey { get; set; }

        public bool IsExisting { get; set; }

        public static CertificateInput FromCertificate(SecretsVaultRuntimeCertificate certificate) =>
            new()
            {
                Name = certificate.Name,
                Version = certificate.Version,
                ContentType = certificate.ContentType,
                CurrentValue = certificate.Value,
                Thumbprint = certificate.Thumbprint,
                Subject = certificate.Subject,
                NotBefore = certificate.NotBefore?.ToString("O", CultureInfo.InvariantCulture),
                Expires = certificate.Expires?.ToString("O", CultureInfo.InvariantCulture),
                HasPrivateKey = certificate.HasPrivateKey.GetValueOrDefault(),
                IsExisting = true
            };
    }
}
