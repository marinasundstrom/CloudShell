@inject IResourceManager ResourceManager
@inject IServiceProvider Services

@if (SecretManager is null)
{
    <EmptyState Title="Secret management unavailable"
                Message="This UI host cannot manage secrets for this Secrets Vault." />
}
else if (Resource is null)
{
    <EmptyState Title="Secrets Vault is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Secrets</h3>
                <p>@GetSecretSummary()</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ProcedureMessage Message="@ErrorMessage" />
        }
        @if (RemovedExistingSecrets.Count > 0)
        {
            <ProcedureMessage Compact="true" Severity="ResourceSignalSeverity.Warning" Role="status">
                @GetRemovedSecretSummary()
            </ProcedureMessage>
        }

        <ResourceEditorSection Class="secrets-vault-secret-editor">
            <Actions>
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="new Icons.Regular.Size20.Add()"
                              OnClick="AddSecret">
                    Add secret
                </FluentButton>
            </Actions>
            <ChildContent>
                @foreach (var secret in Secrets)
                {
                    <div class="environment-row configuration-secret-row">
                        <FluentTextField AriaLabel="Secret name"
                                         Placeholder="Name"
                                         @bind-Value="secret.Name" />
                        <FluentTextField AriaLabel="Secret version"
                                         Placeholder="Version (auto)"
                                         @bind-Value="secret.Version" />
                        @if (secret.IsExisting)
                        {
                            <span class="configuration-secret-placeholder">@CreateMask(secret.CurrentValue)</span>
                        }
                        else
                        {
                            <span class="configuration-secret-placeholder">New</span>
                        }
                        <FluentTextField AriaLabel="Secret value"
                                         Placeholder="@(secret.IsExisting ? "Leave unchanged" : "Value")"
                                         TextFieldType="TextFieldType.Password"
                                         @bind-Value="secret.Value" />
                        <FluentButton Appearance="Appearance.Neutral"
                                      IconStart="new Icons.Regular.Size20.Delete()"
                                      OnClick="() => RemoveSecret(secret)">
                            Remove
                        </FluentButton>
                    </div>
                }
            </ChildContent>
        </ResourceEditorSection>
    </section>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private CloudShell.Abstractions.ResourceManager.Resource? Resource { get; set; }
    private ISecretsVaultRuntimeSecretManager? SecretManager { get; set; }
    private List<SecretInput> Secrets { get; } = [];
    private List<string> RemovedExistingSecrets { get; } = [];
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        SecretManager = Services.GetService(typeof(ISecretsVaultRuntimeSecretManager))
            as ISecretsVaultRuntimeSecretManager;
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);

        Secrets.Clear();
        RemovedExistingSecrets.Clear();
        if (SecretManager is not null && Resource is not null)
        {
            var secrets = await SecretManager.ListSecretsAsync(Resource.Id);
            Secrets.AddRange(secrets.Select(SecretInput.FromSecret));
        }

        if (Secrets.Count == 0)
        {
            Secrets.Add(new());
        }

        RegisterApplyHandler();
    }

    private void RegisterApplyHandler()
    {
        if (Configuration is not null &&
            SecretManager is not null &&
            Resource is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private string GetSecretSummary()
    {
        var count = Secrets.Count(secret => !string.IsNullOrWhiteSpace(secret.Name));
        return count == 1
            ? "1 secret is stored in this vault."
            : $"{count} secrets are stored in this vault.";
    }

    private void AddSecret()
    {
        Secrets.Add(new());
        ErrorMessage = null;
    }

    private void RemoveSecret(SecretInput secret)
    {
        Secrets.Remove(secret);
        TrackRemovedSecret(secret);
        if (Secrets.Count == 0)
        {
            Secrets.Add(new());
        }

        ErrorMessage = null;
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (SecretManager is null || Resource is null)
        {
            return ResourceProcedureResult.Completed("Secrets Vault secrets cannot be managed from this UI host.");
        }

        var secrets = BuildSecrets();
        if (secrets is null)
        {
            return ResourceProcedureResult.Completed(ErrorMessage ?? "Secrets Vault secrets were not updated.");
        }

        await SecretManager.UpdateSecretsAsync(
            CreateRuntimeContext(Resource),
            secrets,
            cancellationToken);
        ErrorMessage = null;
        RemovedExistingSecrets.Clear();
        return ResourceProcedureResult.Completed("Secrets Vault secrets updated.");
    }

    private void TrackRemovedSecret(SecretInput secret)
    {
        if (!secret.IsExisting || string.IsNullOrWhiteSpace(secret.Name))
        {
            return;
        }

        var label = string.IsNullOrWhiteSpace(secret.Version)
            ? secret.Name.Trim()
            : $"{secret.Name.Trim()} ({secret.Version.Trim()})";
        if (!RemovedExistingSecrets.Contains(label, StringComparer.OrdinalIgnoreCase))
        {
            RemovedExistingSecrets.Add(label);
        }
    }

    private string GetRemovedSecretSummary()
    {
        var names = string.Join(", ", RemovedExistingSecrets.Order(StringComparer.OrdinalIgnoreCase));
        return RemovedExistingSecrets.Count == 1
            ? $"Secret {names} will be deleted when you apply changes."
            : $"Secrets {names} will be deleted when you apply changes.";
    }

    private IReadOnlyList<SecretsVaultRuntimeSecret>? BuildSecrets()
    {
        var secrets = Secrets
            .Where(secret => !string.IsNullOrWhiteSpace(secret.Name))
            .Select(secret => new SecretsVaultRuntimeSecret(
                secret.Name!.Trim(),
                ResolveSecretValue(secret),
                string.IsNullOrWhiteSpace(secret.Version) ? null : secret.Version.Trim()))
            .ToArray();

        var duplicate = secrets
            .GroupBy(secret => $"{secret.Name}\u001f{secret.Version}", StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault(group => group.Count() > 1)
            ?.First();
        if (duplicate is not null)
        {
            ErrorMessage = string.IsNullOrWhiteSpace(duplicate.Version)
                ? $"Secret '{duplicate.Name}' is defined more than once."
                : $"Secret '{duplicate.Name}' version '{duplicate.Version}' is defined more than once.";
            return null;
        }

        return secrets;
    }

    private static string ResolveSecretValue(SecretInput secret) =>
        !string.IsNullOrEmpty(secret.Value)
            ? secret.Value
            : secret.CurrentValue ?? string.Empty;

    private static ProviderRuntimeResourceContext CreateRuntimeContext(
        CloudShell.Abstractions.ResourceManager.Resource resource) =>
        new(
            resource.Id,
            resource.Name,
            resource.EffectiveDisplayName,
            resource.ResourceAttributes.GetValueOrDefault(
                SecretsVaultResourceTypeProvider.Attributes.Endpoint.ToString()));

    private static string CreateMask(string? _) => "********";

    private sealed class SecretInput
    {
        public string? Name { get; set; }

        public string? Version { get; set; }

        public string? Value { get; set; }

        public string? CurrentValue { get; set; }

        public bool IsExisting { get; set; }

        public static SecretInput FromSecret(SecretsVaultRuntimeSecret secret) =>
            new()
            {
                Name = secret.Name,
                Version = secret.Version,
                CurrentValue = secret.Value,
                IsExisting = true
            };
    }
}
