@using Microsoft.JSInterop
@using System.Globalization
@inject IResourceDeploymentManager DeploymentManager
@inject IResourceManager ResourceManager
@inject IResourceEventManager ResourceEvents
@inject IJSRuntime JS

@if (Resource is null)
{
    <EmptyState Title="Container app deployment is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Current image</h3>
                <p>@GetCurrentDeploymentSummary()</p>
            </div>
            <span class="@GetDeploymentStatusCssClass()">
                @GetDeploymentStatusLabel()
            </span>
        </div>

        <div class="container-app-deployment-summary">
            <div class="container-app-deployment-primary">
                <small>Running image</small>
                <strong>@GetCurrentContainerImage()</strong>
                <span>@GetLatestDeploymentLine()</span>
            </div>
            <dl class="container-app-deployment-metrics">
                <div>
                    <dt>Capacity</dt>
                    <dd>@GetDeploymentCapacity()</dd>
                </div>
                <div>
                    <dt>Mode</dt>
                    <dd>@GetScalingMode()</dd>
                </div>
                <div>
                    <dt>Running</dt>
                    <dd>@GetMaterializedSummary()</dd>
                </div>
            </dl>
        </div>

        @if (GetDeploymentStatusDescription() is { Length: > 0 } statusDescription)
        {
            <ProcedureMessage Message="@statusDescription"
                              Compact="true" />
        }
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Deploy image</h3>
                <p>@GetDeploymentActionSummary(Resource)</p>
            </div>
        </div>
        <div class="generated-deploy-form">
            <label for="application-deploy-image">Image</label>
            <FluentTextField Id="application-deploy-image"
                             @bind-Value="DeploymentImage"
                             Immediate="true"
                             Placeholder="example/api:20260608"
                             Disabled="@(!CanEditDeployment)" />
            @if (Resource is not null && IsReplicaModeEnabled(Resource))
            {
                <label for="application-deploy-replicas">Requested replicas</label>
                <FluentNumberField TValue="int"
                                   Id="application-deploy-replicas"
                                   Min="1"
                                   Disabled="@(!CanEditDeployment)"
                                   @bind-Value="DeploymentRequestedReplicas" />
            }

            @if (GetDeploymentReadiness() is { } readiness)
            {
                <div class="generated-list">
                    <div class="@readiness.CssClass">
                        <FluentIcon Value="@GetSeverityIcon(readiness.Severity)" />
                        <div class="generated-diagnostic-content">
                            <strong>@readiness.Status</strong>
                            <span>@readiness.Message</span>
                            <small>@readiness.Context</small>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(ImageDeploymentMessage))
            {
                <ProcedureMessage Message="@ImageDeploymentMessage"
                                  Compact="true" />
            }

            <FormPrimaryAction Text="@(IsDeploying ? "Deploying" : "Deploy")"
                               IconStart="@(new Icons.Regular.Size20.ArrowUpload())"
                               Disabled="@(!CanSubmitImageDeployment)"
                               OnClick="DeployImage" />
        </div>
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Runtime details</h3>
                <p>Replica and routing details for this app.</p>
            </div>
        </div>
        <dl class="detail-list">
            <dt>Requested replicas</dt>
            <dd>@GetDeploymentRequestedReplicas()</dd>
            <dt>Running replicas</dt>
            <dd>@GetDeploymentMaterializedReplicas()</dd>
            <dt>Orchestrator service</dt>
            <dd>@GetDeploymentService()</dd>
            <dt>Replica group</dt>
            <dd>@GetReplicaGroup()</dd>
        </dl>
    </section>

    @if (DeploymentEvents.Count > 0)
    {
        <section class="blade-section">
            <div class="blade-section-header">
                <div>
                    <h3>Deployment events</h3>
                    <p>Recent apply, readiness, routing, rollback, and cleanup activity.</p>
                </div>
            </div>
            <div class="container-app-deployment-timeline">
                @foreach (var resourceEvent in DeploymentEvents)
                {
                    <div class="@GetDeploymentEventCssClass(resourceEvent)">
                        <FluentIcon Value="@GetSeverityIcon(resourceEvent.Severity)" />
                        <div class="generated-diagnostic-content">
                            <strong>@GetDeploymentEventTitle(resourceEvent.EventType)</strong>
                            <span>@resourceEvent.Message</span>
                            <small>@FormatDeploymentEventMetadata(resourceEvent)</small>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private IReadOnlyList<ResourceDeploymentRecord> DeploymentRecords { get; set; } = [];
    private IReadOnlyList<ResourceEvent> DeploymentEvents { get; set; } = [];
    private IReadOnlyList<Resource> MaterializedReplicas { get; set; } = [];
    private Resource? Resource { get; set; }
    private ResourceOperationCapabilities Capabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private string? CurrentDeploymentResourceId { get; set; }
    private string? DeploymentImage { get; set; }
    private int DeploymentRequestedReplicas { get; set; } = 1;
    private string? ImageDeploymentMessage { get; set; }
    private bool IsDeploying { get; set; }

    private ResourceDeploymentRecord? LatestDeployment => DeploymentRecords.FirstOrDefault();

    private ResourceDeploymentRecord? ActiveDeployment =>
        DeploymentRecords.FirstOrDefault(record => record.Status == ResourceOrchestratorDeploymentStatus.Active);

    private bool CanEditDeployment =>
        Resource is not null &&
        Capabilities.CanManage &&
        !IsDeploying;

    private bool CanSubmitImageDeployment =>
        CanEditDeployment &&
        !string.IsNullOrWhiteSpace(DeploymentImage) &&
        GetDeploymentReadiness()?.BlocksSubmit != true;

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        DeploymentRecords = string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : await LoadDeploymentRecordsAsync(ResourceId);
        DeploymentEvents = string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : await LoadDeploymentEventsAsync(ResourceId);
        MaterializedReplicas = Resource is null
            ? []
            : await LoadMaterializedReplicasAsync(Resource.Id);
        Capabilities = Resource is null
            ? ResourceOperationCapabilities.None(ResourceId ?? string.Empty)
            : await ResourceManager.GetResourceOperationCapabilitiesAsync(Resource);
        InitializeDeploymentImage();
    }

    private void InitializeDeploymentImage()
    {
        if (Resource is null)
        {
            CurrentDeploymentResourceId = null;
            DeploymentImage = null;
            DeploymentRequestedReplicas = 1;
            ImageDeploymentMessage = null;
            return;
        }

        if (string.Equals(CurrentDeploymentResourceId, Resource.Id, StringComparison.OrdinalIgnoreCase) &&
            !string.IsNullOrWhiteSpace(DeploymentImage))
        {
            return;
        }

        CurrentDeploymentResourceId = Resource.Id;
        DeploymentImage = GetRequestedContainerImage(Resource);
        DeploymentRequestedReplicas = GetDeploymentRequestedReplicasValue(Resource);
        ImageDeploymentMessage = null;
    }

    private async Task DeployImage()
    {
        if (!CanSubmitImageDeployment || Resource is null)
        {
            if (!Capabilities.CanManage)
            {
                ImageDeploymentMessage = "You do not have permission to deploy images for this resource.";
            }

            return;
        }

        var requestedImage = await ReadDeploymentImageAsync();
        if (string.IsNullOrWhiteSpace(requestedImage))
        {
            return;
        }

        DeploymentImage = requestedImage;
        IsDeploying = true;
        ImageDeploymentMessage = null;
        try
        {
            var result = await ResourceManager.UpdateResourceImageAsync(
                Resource,
                requestedImage,
                restartIfRunning: false,
                triggeredBy: "Resource Manager",
                requestedReplicas: IsReplicaModeEnabled(Resource) ? DeploymentRequestedReplicas : null);
            ImageDeploymentMessage = result.Message;

            var updatedResource = await ResourceManager.GetResourceAsync(Resource.Id);
            if (updatedResource is not null)
            {
                Resource = updatedResource;
                DeploymentRecords = await LoadDeploymentRecordsAsync(updatedResource.Id);
                DeploymentEvents = await LoadDeploymentEventsAsync(updatedResource.Id);
                MaterializedReplicas = await LoadMaterializedReplicasAsync(updatedResource.Id);
                DeploymentImage = GetRequestedContainerImage(Resource);
                DeploymentRequestedReplicas = GetDeploymentRequestedReplicasValue(Resource);
                CurrentDeploymentResourceId = Resource.Id;
            }
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ImageDeploymentMessage = FormatImageDeploymentFailure(exception);
        }
        finally
        {
            IsDeploying = false;
        }
    }

    private string GetLatestDeploymentLine()
    {
        var latest = LatestDeployment;
        if (latest is null)
        {
            return MaterializedReplicas.Count > 0
                ? "Running replicas are available; no deployment record is available."
                : "No image deployment has been recorded yet.";
        }

        var actor = string.IsNullOrWhiteSpace(latest.TriggeredBy ?? latest.ProvisionedBy)
            ? "system"
            : latest.TriggeredBy ?? latest.ProvisionedBy;
        var timestamp = latest.CompletedAt ?? latest.StartedAt;
        return string.Create(
            CultureInfo.CurrentCulture,
            $"Last deployment {FormatDeploymentStatus(latest.Status).ToLowerInvariant()} {timestamp.ToLocalTime():g} by {actor}.");
    }

    private string GetCurrentDeploymentSummary() =>
        Resource is not null && IsReplicaModeEnabled(Resource)
            ? "This app is served by an active replica group. Revision and replica details are available when needed."
            : "This app is served by a single runtime instance. Revision details are available when needed.";

    private static string GetDeploymentActionSummary(Resource resource) =>
        IsReplicaModeEnabled(resource)
            ? "Deploy a new image and optionally change requested capacity for the next running state."
            : "Deploy a new image for this app without treating the update as a manual restart.";

    private string GetCurrentContainerImage() =>
        GetDeploymentImage(ActiveDeployment) ??
        (Resource is null ? null : GetRequestedContainerImage(Resource)) ??
        GetDeploymentImage(LatestDeployment) ??
        string.Empty;

    private static string GetRequestedContainerImage(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerImage) ?? string.Empty;

    private string GetDeploymentService() =>
        ActiveDeployment?.ServiceId ??
        LatestDeployment?.ServiceId ??
        Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentServiceId) ??
        GetMaterializedReplicaAttribute(ResourceAttributeNames.DeploymentServiceId) ??
        GetInferredDeploymentServiceId() ??
        "Not reported";

    private string GetReplicaGroup() =>
        ActiveDeployment?.ReplicaGroup?.Id ??
        LatestDeployment?.ReplicaGroup?.Id ??
        Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentReplicaGroupId) ??
        GetMaterializedReplicaAttribute(ResourceAttributeNames.DeploymentReplicaGroupId) ??
        GetInferredReplicaGroupId() ??
        "Not reported";

    private string? GetMaterializedReplicaAttribute(string attributeName) =>
        MaterializedReplicas
            .Select(replica => replica.ResourceAttributes.GetValueOrDefault(attributeName))
            .FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private string? GetInferredDeploymentServiceId() =>
        Resource is not null && MaterializedReplicas.Count > 0
            ? ResourceOrchestratorReplicaGroups.CreateDefaultServiceName(Resource.Id)
            : null;

    private string? GetInferredReplicaGroupId()
    {
        var serviceId = GetInferredDeploymentServiceId();
        if (string.IsNullOrWhiteSpace(serviceId))
        {
            return null;
        }

        return ResourceOrchestratorReplicaGroups.CreateReplicaGroupId(
            serviceId,
            GetInferredRuntimeRevisionId());
    }

    private string? GetInferredRuntimeRevisionId() =>
        GetMaterializedReplicaAttribute(ResourceAttributeNames.RuntimeRevision) ??
        Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentRevision) ??
        Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerRevision);

    private string GetScalingMode() =>
        Resource is not null && IsReplicaModeEnabled(Resource) ? "Replicated" : "Single instance";

    private string GetDeploymentCapacity() =>
        Resource is not null && IsReplicaModeEnabled(Resource)
            ? $"{GetDeploymentMaterializedReplicas()} of {GetDeploymentRequestedReplicas()} replica slots occupied"
            : "Single instance";

    private string GetMaterializedSummary() =>
        Resource is not null && IsReplicaModeEnabled(Resource)
            ? GetDeploymentMaterializedReplicas()
            : GetSingleInstanceMaterializedSummary();

    private string GetSingleInstanceMaterializedSummary() =>
        Resource?.State switch
        {
            ResourceState.Running or ResourceState.Starting => "1",
            _ => "0"
        };

    private string GetDeploymentRequestedReplicas() =>
        Resource is not null && IsReplicaModeEnabled(Resource)
            ? GetDeploymentRequestedReplicasValue(Resource).ToString(CultureInfo.InvariantCulture)
            : "not enabled";

    private int GetDeploymentRequestedReplicasValue(Resource resource) =>
        ActiveDeployment?.ReplicaGroup?.RequestedReplicas ??
        LatestDeployment?.ReplicaGroup?.RequestedReplicas ??
        GetRequestedReplicasFromDefinition(ActiveDeployment) ??
        GetRequestedReplicasFromDefinition(LatestDeployment) ??
        TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentRequestedReplicaSlots) ??
        TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentRequestedReplicas) ??
        TryGetReplicaCount(resource, ResourceAttributeNames.ContainerReplicas) ??
        1;

    private static int? TryGetReplicaCount(Resource? resource, string attributeName) =>
        resource is not null &&
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var replicas)
            ? Math.Max(1, replicas)
            : null;

    private string GetDeploymentMaterializedReplicas() =>
        Resource is not null && IsReplicaModeEnabled(Resource)
            ? GetDeploymentMaterializedReplicaCount().ToString(CultureInfo.InvariantCulture)
            : "not enabled";

    private int GetDeploymentMaterializedReplicaCount()
    {
        if (MaterializedReplicas.Count > 0)
        {
            return MaterializedReplicas.Count;
        }

        return ActiveDeployment?.ReplicaGroup?.MaterializedReplicas ??
            LatestDeployment?.ReplicaGroup?.MaterializedReplicas ??
            TryGetReplicaCount(Resource, ResourceAttributeNames.DeploymentMaterializedReplicas, 0) ??
            TryGetReplicaCount(Resource, ResourceAttributeNames.DeploymentProjectedReplicas, 0) ??
            0;
    }

    private static int? TryGetReplicaCount(Resource? resource, string attributeName, int minimumCount) =>
        resource is not null &&
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var replicas)
            ? Math.Max(minimumCount, replicas)
            : null;

    private static bool IsReplicaModeEnabled(Resource resource) =>
        string.Equals(
            resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerReplicasEnabled),
            "true",
            StringComparison.OrdinalIgnoreCase);

    private string GetDeploymentStatusLabel()
    {
        if (LatestDeployment is not null)
        {
            return FormatDeploymentStatus(LatestDeployment.Status);
        }

        if (MaterializedReplicas.Count > 0)
        {
            return "Running";
        }

        var projectedStatus = Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus);
        if (!string.IsNullOrWhiteSpace(projectedStatus))
        {
            return projectedStatus switch
            {
                "active" => "Running",
                "applying" => "Deploying",
                "failed" => "Needs attention",
                "deleted" => "Removed",
                "pending" => "Not running",
                _ => "Not deployed"
            };
        }

        return Resource?.State switch
        {
            ResourceState.Running => "Running",
            ResourceState.Starting => "Deploying",
            ResourceState.Degraded => "Needs attention",
            ResourceState.Stopped => "Not running",
            ResourceState.Stopping => "Stopping",
            _ => "Not deployed"
        };
    }

    private string GetDeploymentStatusCssClass()
    {
        if (LatestDeployment is not null)
        {
            return LatestDeployment.Status switch
            {
                ResourceOrchestratorDeploymentStatus.Active => "container-app-status-pill success",
                ResourceOrchestratorDeploymentStatus.Applying => "container-app-status-pill info",
                ResourceOrchestratorDeploymentStatus.Failed => "container-app-status-pill error",
                ResourceOrchestratorDeploymentStatus.Pending => "container-app-status-pill warning",
                _ => "container-app-status-pill"
            };
        }

        if (MaterializedReplicas.Count > 0)
        {
            return "container-app-status-pill success";
        }

        var projectedStatus = Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus);
        if (!string.IsNullOrWhiteSpace(projectedStatus))
        {
            return projectedStatus switch
            {
                "active" => "container-app-status-pill success",
                "applying" => "container-app-status-pill info",
                "failed" => "container-app-status-pill error",
                "pending" => "container-app-status-pill warning",
                _ => "container-app-status-pill"
            };
        }

        return Resource?.State switch
        {
            ResourceState.Running => "container-app-status-pill success",
            ResourceState.Starting or ResourceState.Stopping => "container-app-status-pill info",
            ResourceState.Degraded => "container-app-status-pill error",
            ResourceState.Stopped => "container-app-status-pill warning",
            _ => "container-app-status-pill"
        };
    }

    private string GetDeploymentStatusDescription()
    {
        if (LatestDeployment is not null)
        {
            return LatestDeployment.Status switch
            {
                ResourceOrchestratorDeploymentStatus.Active => string.Empty,
                ResourceOrchestratorDeploymentStatus.Applying => "CloudShell is applying this image to the selected container host.",
                ResourceOrchestratorDeploymentStatus.Failed => LatestDeployment.Error ??
                    "The latest image deployment failed. Check deployment events and logs for details.",
                ResourceOrchestratorDeploymentStatus.Pending => "Start the app to create running instances.",
                ResourceOrchestratorDeploymentStatus.Deleted => "The current deployment state has been removed.",
                _ => string.Empty
            };
        }

        if (MaterializedReplicas.Count > 0)
        {
            return string.Empty;
        }

        var projectedStatus = Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus);
        if (!string.IsNullOrWhiteSpace(projectedStatus))
        {
            return projectedStatus switch
            {
                "active" => string.Empty,
                "applying" => "CloudShell is applying this image to the selected container host.",
                "failed" => "The latest image deployment failed. Check deployment events and logs for details.",
                "pending" => "Start the app to create running instances.",
                "deleted" => "The current deployment state has been removed.",
                _ => "No deployment state is available for this app yet."
            };
        }

        return Resource?.State switch
        {
            ResourceState.Running => string.Empty,
            ResourceState.Starting => "CloudShell is starting this container app.",
            ResourceState.Stopping => "CloudShell is stopping this container app.",
            ResourceState.Stopped => "Start the app to create running instances.",
            ResourceState.Degraded => "The app is degraded. Check deployment events, health, and logs for details.",
            _ => "No deployment state is available for this app yet."
        };
    }

    private DeploymentReadinessView? GetDeploymentReadiness()
    {
        if (Resource is null)
        {
            return null;
        }

        if (!Capabilities.CanManage)
        {
            return DeploymentReadinessView.Blocked(
                "Cannot deploy",
                "The current user cannot deploy images for this resource.",
                "Missing resource manage permission");
        }

        var requestedImage = DeploymentImage?.Trim();
        if (string.IsNullOrWhiteSpace(requestedImage))
        {
            return DeploymentReadinessView.Blocked(
                "Image required",
                "Enter a container image before deploying.",
                "Image deployment preflight");
        }

        var currentImage = GetCurrentContainerImage();
        var replicaChangeRequested =
            IsReplicaModeEnabled(Resource) &&
            DeploymentRequestedReplicas != GetDeploymentRequestedReplicasValue(Resource);
        if (string.Equals(currentImage, requestedImage, StringComparison.Ordinal) &&
            !replicaChangeRequested)
        {
            return DeploymentReadinessView.Blocked(
                "No deployment change",
                "The app is already using this image and requested capacity.",
                "Image deployment preflight");
        }

        if (IsReplicaModeEnabled(Resource) && DeploymentRequestedReplicas < 1)
        {
            return DeploymentReadinessView.Blocked(
                "Replica count unavailable",
                "Requested replicas must be greater than or equal to 1.",
                "Image deployment preflight");
        }

        return DeploymentReadinessView.Ready(
            "Ready to deploy",
            "CloudShell will apply the requested image and activate it after the app is updated.",
            "Image deployment preflight");
    }

    private static string FormatImageDeploymentFailure(Exception exception) =>
        exception switch
        {
            HttpRequestException => "CloudShell could not reach the Control Plane while requesting the deployment. Check connectivity and try again.",
            _ => "CloudShell could not request the image deployment. Check deployment readiness, events, and logs before trying again."
        };

    private async Task<string> ReadDeploymentImageAsync()
    {
        var fieldValue = await JS.InvokeAsync<string?>(
            "cloudShellForms.getValue",
            "application-deploy-image");
        return (string.IsNullOrWhiteSpace(fieldValue)
            ? DeploymentImage
            : fieldValue)?.Trim() ?? string.Empty;
    }

    private async Task<IReadOnlyList<ResourceDeploymentRecord>> LoadDeploymentRecordsAsync(string resourceId)
    {
        var records = await DeploymentManager.ListResourceDeploymentsAsync(new ResourceDeploymentQuery(
            SourceResourceId: resourceId,
            MaxRecords: 20));
        return records
            .OrderByDescending(record => record.StartedAt)
            .ToArray();
    }

    private async Task<IReadOnlyList<Resource>> LoadMaterializedReplicasAsync(string resourceId) =>
        (await ResourceManager.ListResourceChildrenAsync(resourceId))
            .Where(IsReplicaResource)
            .OrderBy(GetReplicaOrdinal)
            .ThenBy(ResourceDisplayLabels.GetQualifiedLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private async Task<IReadOnlyList<ResourceEvent>> LoadDeploymentEventsAsync(string resourceId)
    {
        var events = await ResourceEvents.ListResourceEventsAsync(new ResourceEventQuery(
            ResourceId: resourceId,
            MaxEvents: 50));
        return events
            .Where(IsDeploymentDiagnosticEvent)
            .Take(20)
            .ToArray();
    }

    private static bool IsDeploymentDiagnosticEvent(ResourceEvent resourceEvent) =>
        resourceEvent.EventType.StartsWith(ResourceEventTypes.Events.Deployment.Prefix, StringComparison.OrdinalIgnoreCase) ||
        resourceEvent.EventType.Contains(".container.instance.readiness.", StringComparison.OrdinalIgnoreCase);

    private static string FormatDeploymentEventMetadata(ResourceEvent resourceEvent)
    {
        var triggeredBy = string.IsNullOrWhiteSpace(resourceEvent.TriggeredBy)
            ? "Triggered by system"
            : $"Triggered by {resourceEvent.TriggeredBy}";
        return string.Create(
            CultureInfo.CurrentCulture,
            $"{resourceEvent.Timestamp.ToLocalTime():g} | {resourceEvent.EventType} | {triggeredBy}");
    }

    private static string GetDeploymentEventTitle(string eventType) =>
        eventType switch
        {
            ResourceEventTypes.Events.Deployment.ImageUpdated => "Image updated",
            ResourceEventTypes.Events.Deployment.ReplicasUpdated => "Replicas updated",
            ResourceEventTypes.Events.Deployment.Applying => "Deployment started",
            ResourceEventTypes.Events.Deployment.ServiceReconciling => "Service preparing",
            ResourceEventTypes.Events.Deployment.ServiceReconciled => "Service prepared",
            ResourceEventTypes.Events.Deployment.ReplicaMaterializing => "Replica starting",
            ResourceEventTypes.Events.Deployment.ReplicaMaterialized => "Replica ready",
            ResourceEventTypes.Events.Deployment.RoutingUpdating => "Routing updating",
            ResourceEventTypes.Events.Deployment.RoutingUpdated => "Routing updated",
            ResourceEventTypes.Events.Deployment.RollingBack => "Rollback running",
            ResourceEventTypes.Events.Deployment.RolledBack => "Rollback completed",
            ResourceEventTypes.Events.Deployment.RollbackFailed => "Rollback failed",
            ResourceEventTypes.Events.Deployment.CleanupRunning => "Cleanup running",
            ResourceEventTypes.Events.Deployment.CleanupCompleted => "Cleanup completed",
            ResourceEventTypes.Events.Deployment.CleanupWarning => "Cleanup warning",
            ResourceEventTypes.Events.Deployment.Applied => "Deployment applied",
            ResourceEventTypes.Events.Deployment.Failed => "Deployment failed",
            _ when eventType.Contains(".container.instance.readiness.", StringComparison.OrdinalIgnoreCase) =>
                "Readiness check",
            _ => "Deployment activity"
        };

    private static string FormatDeploymentStatus(ResourceOrchestratorDeploymentStatus status) =>
        status switch
        {
            ResourceOrchestratorDeploymentStatus.Active => "Running",
            ResourceOrchestratorDeploymentStatus.Applying => "Deploying",
            ResourceOrchestratorDeploymentStatus.Failed => "Needs attention",
            ResourceOrchestratorDeploymentStatus.Deleted => "Removed",
            ResourceOrchestratorDeploymentStatus.Pending => "Not running",
            _ => "Unknown"
        };

    private static string GetDeploymentEventCssClass(ResourceEvent resourceEvent) =>
        resourceEvent.Severity switch
        {
            ResourceSignalSeverity.Error => "generated-diagnostic error",
            ResourceSignalSeverity.Warning => "generated-diagnostic warning",
            _ => "generated-diagnostic info"
        };

    private static Icon GetSeverityIcon(ResourceSignalSeverity severity) =>
        severity switch
        {
            ResourceSignalSeverity.Success => new Icons.Regular.Size20.CheckmarkCircle(),
            ResourceSignalSeverity.Error => new Icons.Regular.Size20.ErrorCircle(),
            ResourceSignalSeverity.Warning => new Icons.Regular.Size20.Warning(),
            _ => new Icons.Regular.Size20.Info()
        };

    private static string? GetDeploymentImage(ResourceDeploymentRecord? deployment)
    {
        var service = deployment?.Definition?.DeploymentServices.FirstOrDefault();
        if (service?.ServiceAttributes.TryGetValue(ResourceAttributeNames.ContainerImage, out var image) == true &&
            !string.IsNullOrWhiteSpace(image))
        {
            return image;
        }

        return null;
    }

    private static int? GetRequestedReplicasFromDefinition(ResourceDeploymentRecord? deployment)
    {
        var replicas = deployment?.Definition?.DeploymentServices
            .SelectMany(service => service.ReplicaGroupDefinitions)
            .Select(definition => definition.RequestedReplicas)
            .FirstOrDefault(replicas => replicas > 0);
        return replicas is > 0 ? replicas : null;
    }

    private static bool IsReplicaResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, "runtime.container", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(
            GetAttribute(resource, ResourceAttributeNames.RuntimeKind, string.Empty),
            "containerReplica",
            StringComparison.OrdinalIgnoreCase);

    private static int GetReplicaOrdinal(Resource resource) =>
        int.TryParse(
            GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, string.Empty),
            out var ordinal)
            ? ordinal
            : int.MaxValue;

    private static string GetAttribute(Resource resource, string key, string fallback) =>
        resource.ResourceAttributes.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private sealed record DeploymentReadinessView(
        string Status,
        string Message,
        string Context,
        bool BlocksSubmit,
        string CssClass,
        ResourceSignalSeverity Severity)
    {
        public static DeploymentReadinessView Ready(
            string status,
            string message,
            string context) =>
            new(status, message, context, false, "generated-diagnostic info", ResourceSignalSeverity.Info);

        public static DeploymentReadinessView Blocked(
            string status,
            string message,
            string context) =>
            new(status, message, context, true, "generated-diagnostic warning", ResourceSignalSeverity.Warning);
    }
}
