@using CloudShell.Abstractions.Observability
@using System.Globalization
@implements IDisposable
@inject IResourceManager ResourceManager
@inject IResourceMonitoringManager MonitoringManager

@if (Application is null)
{
    <EmptyState Title="Monitoring is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (!BuiltInProviderResourceUiTypes.IsContainerApplication(Application.EffectiveTypeId))
{
    <EmptyState Title="Monitoring is not supported"
                Message="This view is available for container app resources." />
}
else
{
    <section class="blade-section">
        <div class="resource-activity-header">
            <div>
                <h3>Monitoring</h3>
                <span>@GetStatusText()</span>
            </div>
            <div class="resource-monitoring-actions">
                <FluentCheckbox @bind-Value="AutoRefresh">
                    Auto-refresh
                </FluentCheckbox>
                @if (!AutoRefresh)
                {
                    <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                                  Disabled="@IsLoading" OnClick="RefreshAsync">
                        @(IsLoading ? "Refreshing" : "Refresh")
                    </FluentButton>
                }
            </div>
        </div>

        <dl class="detail-list">
            <dt>Mode</dt>
            <dd>@(IsReplicaModeEnabled(Application) ? "Replicated" : "Single instance")</dd>
            <dt>Configured replicas</dt>
            <dd>@GetConfiguredReplicas(Application)</dd>
            <dt>Running replicas</dt>
            <dd>@Replicas.Count</dd>
            <dt>Observed replicas</dt>
            <dd>@ObservedReplicaCount</dd>
            <dt>Revision</dt>
            <dd>@GetCurrentRevision(Application)</dd>
        </dl>
    </section>

    @if (!IsReplicaModeEnabled(Application))
    {
        <section class="blade-section">
            <h3>Resource metrics</h3>
            @if (ApplicationSnapshot is null)
            {
                <EmptyState Title="No monitoring snapshot"
                            Message="The provider did not return a resource monitoring snapshot for this container app."
                            Compact="true" />
            }
            else if (ApplicationSnapshot.Metrics.Count == 0)
            {
                <EmptyState Title="No metrics available"
                            Message="@(ApplicationSnapshot.Message ?? "Container app metrics are not available for this snapshot.")"
                            Compact="true" />
            }
            else
            {
                <SummaryMetricGrid AriaLabel="Container app resource metrics">
                    @foreach (var metric in ApplicationSnapshot.Metrics)
                    {
                        <SummaryMetricCard Title="@(metric.DisplayName ?? metric.Name)"
                                           Value="@FormatValue(metric.Value, metric.Unit)"
                                           Summary="@(metric.Description ?? metric.Name)"
                                           Compact="true" />
                    }
                </SummaryMetricGrid>
            }
        </section>
    }
    else
    {
        <section class="blade-section">
            <h3>Replica summary</h3>
            @if (Rows.Count == 0)
            {
                <EmptyState Title="No running replicas"
                            Message="CloudShell has not observed running replicas for this app."
                            Compact="true" />
            }
            else
            {
                <SummaryMetricGrid AriaLabel="Container app replica metrics">
                    <SummaryMetricCard Title="CPU usage"
                                       Value="@FormatOptionalSumMetric(CpuUsageMetricName, PercentUnit, NotCollected)"
                                       Summary="Sum of observed replica CPU usage."
                                       Compact="true" />
                    <SummaryMetricCard Title="Memory usage"
                                       Value="@FormatOptionalSumMetric(MemoryUsageMetricNames, BytesUnit, NotCollected)"
                                       Summary="Sum of observed replica memory usage."
                                       Compact="true" />
                    <SummaryMetricCard Title="Network received"
                                       Value="@FormatOptionalSumMetric(NetworkReceivedMetricName, BytesUnit, NotCollected)"
                                       Summary="Total observed replica network bytes received."
                                       Compact="true" />
                    <SummaryMetricCard Title="Network sent"
                                       Value="@FormatOptionalSumMetric(NetworkSentMetricName, BytesUnit, NotCollected)"
                                       Summary="Total observed replica network bytes sent."
                                       Compact="true" />
                    <SummaryMetricCard Title="Process count"
                                       Value="@FormatOptionalSumMetric(ProcessCountMetricName, CountUnit, NotCollected)"
                                       Summary="Sum of observed replica process counts."
                                       Compact="true" />
                </SummaryMetricGrid>
            }
        </section>

        <section class="blade-section">
            <h3>Replicas</h3>
            @if (Rows.Count == 0)
            {
                <EmptyState Title="No running replicas"
                            Message="Replica monitoring will appear after CloudShell observes running replicas."
                            Compact="true" />
            }
            else
            {
                <ResourceTable>
                        <thead>
                            <tr>
                                <th>Replica</th>
                                <th>State</th>
                                <th>Monitoring</th>
                                <th>CPU</th>
                                <th>Memory</th>
                                <th>Network</th>
                                <th>Processes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Rows)
                            {
                                <tr>
                                    <td>
                                        <ResourceTableIdentity IconName="replica"
                                                               IconTitle="Replica"
                                                               Summary="@FormatReplicaOrdinal(row.Resource)">
                                            <TitleContent>
                                                <FluentAnchor Href="@ResourceManagerRoutes.ResourceDetails(row.Resource.Id)">
                                                    @ResourceDisplayLabels.GetQualifiedLabel(row.Resource)
                                                </FluentAnchor>
                                            </TitleContent>
                                        </ResourceTableIdentity>
                                    </td>
                                    <td>
                                        <ResourceStateIndicator State="row.Resource.State" Variant="pill" />
                                    </td>
                                    <td>
                                        <strong>@FormatMonitoringStatus(row.Snapshot)</strong>
                                        <span>@GetMonitoringMessage(row)</span>
                                    </td>
                                    <td>@FormatMetric(row, CpuUsageMetricName, NotCollected)</td>
                                    <td>@FormatMetric(row, MemoryUsageMetricNames, NotCollected)</td>
                                    <td>
                                        <strong>@FormatMetric(row, NetworkReceivedMetricName, NotCollected)</strong>
                                        <span>Sent @FormatMetric(row, NetworkSentMetricName, NotCollected)</span>
                                    </td>
                                    <td>@FormatMetric(row, ProcessCountMetricName, NotCollected)</td>
                                </tr>
                            }
                        </tbody>
                </ResourceTable>
            }
        </section>
    }
}

@code {
    private static readonly TimeSpan AutoRefreshInterval = TimeSpan.FromSeconds(5);
    private const string CpuUsageMetricName = "resource.cpu.usage";
    private static readonly string[] MemoryUsageMetricNames =
    [
        "resource.memory.usage",
        "resource.memory.workingSet",
        "resource.memory.private"
    ];
    private const string NetworkReceivedMetricName = "resource.network.rxBytes";
    private const string NetworkSentMetricName = "resource.network.txBytes";
    private const string ProcessCountMetricName = "resource.process.count";
    private const string PercentUnit = "%";
    private const string BytesUnit = "bytes";
    private const string CountUnit = "count";
    private const string NotCollected = "Not collected";

    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Application { get; set; }
    private ResourceMonitoringSnapshot? ApplicationSnapshot { get; set; }
    private IReadOnlyList<Resource> Replicas { get; set; } = [];
    private IReadOnlyList<ReplicaMonitoringRow> Rows { get; set; } = [];
    private System.Threading.Timer? RefreshTimer { get; set; }
    private bool IsLoading { get; set; }
    private bool IsDisposed { get; set; }
    private bool AutoRefresh { get; set; } = true;

    private int ObservedReplicaCount =>
        Rows.Count(row => IsAvailable(row.Snapshot));

    private string GetCurrentRevision(Resource resource) =>
        GetAttribute(resource, ResourceAttributeNames.DeploymentRevision, string.Empty) is { Length: > 0 } revision
            ? revision
            : Replicas
                .Select(replica => GetAttribute(replica, ResourceAttributeNames.RuntimeRevision, string.Empty))
                .FirstOrDefault(value => !string.IsNullOrWhiteSpace(value)) ??
                resource.Version;

    protected override void OnInitialized()
    {
        RefreshTimer = new System.Threading.Timer(
            _ =>
            {
                if (!IsDisposed && AutoRefresh)
                {
                    _ = InvokeAsync(RefreshAsync);
                }
            },
            null,
            AutoRefreshInterval,
            AutoRefreshInterval);
    }

    protected override Task OnParametersSetAsync() => RefreshAsync();

    private async Task RefreshAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId) || IsLoading || IsDisposed)
        {
            return;
        }

        IsLoading = true;
        try
        {
            Application = await ResourceManager.GetResourceAsync(ResourceId);
            ApplicationSnapshot = null;
            Replicas = [];
            Rows = [];

            if (Application is null ||
                !BuiltInProviderResourceUiTypes.IsContainerApplication(Application.EffectiveTypeId))
            {
                return;
            }

            if (!IsReplicaModeEnabled(Application))
            {
                ApplicationSnapshot = await MonitoringManager.GetResourceMonitoringAsync(Application.Id);
                return;
            }

            Replicas = (await ResourceManager.ListResourceChildrenAsync(Application.Id))
                .Where(IsReplicaResource)
                .OrderBy(GetReplicaOrdinal)
                .ThenBy(ResourceDisplayLabels.GetQualifiedLabel, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            var rows = new List<ReplicaMonitoringRow>();
            foreach (var replica in Replicas)
            {
                var snapshot = replica.HasCapability(ResourceCapabilityIds.Monitoring)
                    ? await MonitoringManager.GetResourceMonitoringAsync(replica.Id)
                    : null;
                rows.Add(new ReplicaMonitoringRow(replica, snapshot));
            }

            Rows = rows;
        }
        finally
        {
            IsLoading = false;
            if (!IsDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    public void Dispose()
    {
        IsDisposed = true;
        RefreshTimer?.Dispose();
    }

    private string GetStatusText()
    {
        if (Application is null)
        {
            return "Provider-observed resource metrics";
        }

        if (!IsReplicaModeEnabled(Application))
        {
            if (ApplicationSnapshot is null)
            {
                return "Provider-observed resource metrics";
            }

            var updated = ApplicationSnapshot.Timestamp.ToLocalTime().ToString("HH:mm:ss", CultureInfo.CurrentCulture);
            return string.IsNullOrWhiteSpace(ApplicationSnapshot.Status)
                ? $"Updated {updated}"
                : $"{ApplicationSnapshot.Status} / updated {updated}";
        }

        return Rows.Count == 0
            ? "Replica resource metrics"
            : $"{ObservedReplicaCount} of {Rows.Count} replicas observed";
    }

    private double SumMetric(string name) =>
        Rows.Sum(row => GetMetricValue(row.Snapshot, name));

    private double SumMetric(IReadOnlyList<string> names) =>
        Rows.Sum(row => GetMetricValue(row.Snapshot, names));

    private string FormatOptionalSumMetric(string name, string unit, string fallback) =>
        Rows.Any(row => HasMetric(row.Snapshot, name))
            ? FormatValue(SumMetric(name), unit)
            : fallback;

    private string FormatOptionalSumMetric(IReadOnlyList<string> names, string unit, string fallback) =>
        Rows.Any(row => HasMetric(row.Snapshot, names))
            ? FormatValue(SumMetric(names), unit)
            : fallback;

    private static string FormatMetric(ReplicaMonitoringRow row, string name, string fallback)
    {
        var metric = row.Snapshot?.Metrics.FirstOrDefault(metric =>
            string.Equals(metric.Name, name, StringComparison.OrdinalIgnoreCase));
        return metric is null
            ? fallback
            : FormatValue(metric.Value, metric.Unit);
    }

    private static string FormatMetric(ReplicaMonitoringRow row, IReadOnlyList<string> names, string fallback)
    {
        var metric = FindMetric(row.Snapshot, names);
        return metric is null
            ? fallback
            : FormatValue(metric.Value, metric.Unit);
    }

    private static double GetMetricValue(ResourceMonitoringSnapshot? snapshot, string name) =>
        snapshot?.Metrics.FirstOrDefault(metric =>
            string.Equals(metric.Name, name, StringComparison.OrdinalIgnoreCase))?.Value ?? 0;

    private static double GetMetricValue(ResourceMonitoringSnapshot? snapshot, IReadOnlyList<string> names) =>
        FindMetric(snapshot, names)?.Value ?? 0;

    private static bool HasMetric(ResourceMonitoringSnapshot? snapshot, string name) =>
        snapshot?.Metrics.Any(metric =>
            string.Equals(metric.Name, name, StringComparison.OrdinalIgnoreCase)) == true;

    private static bool HasMetric(ResourceMonitoringSnapshot? snapshot, IReadOnlyList<string> names) =>
        snapshot?.Metrics.Any(metric =>
            names.Any(name => string.Equals(metric.Name, name, StringComparison.OrdinalIgnoreCase))) == true;

    private static ResourceMetricSample? FindMetric(ResourceMonitoringSnapshot? snapshot, IReadOnlyList<string> names) =>
        snapshot?.Metrics.FirstOrDefault(metric =>
            names.Any(name => string.Equals(metric.Name, name, StringComparison.OrdinalIgnoreCase)));

    private static string GetMonitoringMessage(ReplicaMonitoringRow row)
    {
        if (row.Snapshot is null)
        {
            return "No snapshot";
        }

        if (!string.IsNullOrWhiteSpace(row.Snapshot.Message))
        {
            return row.Snapshot.Message;
        }

        return row.Snapshot.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.CurrentCulture);
    }

    private static string FormatMonitoringStatus(ResourceMonitoringSnapshot? snapshot) =>
        snapshot?.Status switch
        {
            null => "Unavailable",
            var status when string.Equals(status, "Available", StringComparison.OrdinalIgnoreCase) => "Available",
            var status when string.Equals(status, "Unavailable", StringComparison.OrdinalIgnoreCase) => "Unavailable",
            { Length: > 0 } => "Unknown",
            _ => "Unknown"
        };

    private static bool IsAvailable(ResourceMonitoringSnapshot? snapshot) =>
        string.Equals(snapshot?.Status, "Available", StringComparison.OrdinalIgnoreCase) &&
        snapshot?.Metrics.Count > 0;

    private static bool IsReplicaResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, "runtime.container", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(
            GetAttribute(resource, ResourceAttributeNames.RuntimeKind, string.Empty),
            "containerReplica",
            StringComparison.OrdinalIgnoreCase);

    private static int GetConfiguredReplicas(Resource resource) =>
        TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentRequestedReplicaSlots) ??
        TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentRequestedReplicas) ??
        TryGetReplicaCount(resource, ResourceAttributeNames.ContainerReplicas) ??
        1;

    private static int? TryGetReplicaCount(Resource resource, string attributeName) =>
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var replicas)
            ? Math.Max(1, replicas)
            : null;

    private static bool IsReplicaModeEnabled(Resource resource) =>
        string.Equals(
            GetAttribute(resource, ResourceAttributeNames.ContainerReplicasEnabled, "false"),
            "true",
            StringComparison.OrdinalIgnoreCase);

    private static int GetReplicaOrdinal(Resource resource) =>
        int.TryParse(
            GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, string.Empty),
            out var ordinal)
            ? ordinal
            : int.MaxValue;

    private static string FormatReplicaOrdinal(Resource resource)
    {
        var ordinal = GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, "?");
        var count = GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaCount, "?");
        return $"{ordinal} of {count}";
    }

    private static string GetAttribute(Resource resource, string key, string fallback) =>
        resource.ResourceAttributes.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static string FormatValue(double value, string unit) =>
        string.Equals(unit, "bytes", StringComparison.OrdinalIgnoreCase)
            ? FormatBytes(value)
            : string.Equals(unit, "%", StringComparison.Ordinal)
                ? $"{value.ToString("0.##", CultureInfo.InvariantCulture)}%"
                : string.Equals(unit, CountUnit, StringComparison.OrdinalIgnoreCase)
                    ? value.ToString("0.###", CultureInfo.InvariantCulture)
                    : $"{value.ToString("0.###", CultureInfo.InvariantCulture)} {unit}".TrimEnd();

    private static string FormatBytes(double value)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var unitIndex = 0;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return $"{value.ToString(unitIndex == 0 ? "0" : "0.##", CultureInfo.InvariantCulture)} {units[unitIndex]}";
    }

    private sealed record ReplicaMonitoringRow(
        Resource Resource,
        ResourceMonitoringSnapshot? Snapshot);
}
