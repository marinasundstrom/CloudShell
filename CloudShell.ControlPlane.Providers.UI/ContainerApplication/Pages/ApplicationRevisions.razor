@using System.Globalization
@inject IResourceDeploymentManager DeploymentManager
@inject IResourceManager ResourceManager

@if (Resource is null)
{
    <EmptyState Title="Container app revisions are unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (Revisions.Count == 0)
{
    <EmptyState Title="No revisions recorded"
                Message="Revisions will appear after the app is deployed or materialized." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Current revision</h3>
                <p>The active materialized state produced by the latest successful deployment.</p>
            </div>
            <span class="@GetRevisionStatusCssClass(CurrentRevision)">
                @GetRevisionStatus(CurrentRevision)
            </span>
        </div>

        @if (CurrentRevision is null)
        {
            <ProcedureMessage Message="No active revision is currently recorded for this app."
                              Compact="true" />
        }
        else
        {
            <div class="container-app-deployment-summary">
                <div class="container-app-deployment-primary">
                    <small>Image</small>
                    <strong>@GetRevisionImage(CurrentRevision)</strong>
                    <span>@FormatRevisionCreated(CurrentRevision)</span>
                </div>
                <dl class="container-app-deployment-metrics">
                    <div>
                        <dt>Requested replicas</dt>
                        <dd>@GetRequestedReplicas(CurrentRevision).ToString(CultureInfo.InvariantCulture)</dd>
                    </div>
                    <div>
                        <dt>Change</dt>
                        <dd>@FormatChangeKind(CurrentRevision)</dd>
                    </div>
                    <div>
                        <dt>Revision</dt>
                        <dd>@FormatRevisionNumber(CurrentRevision)</dd>
                    </div>
                    <div>
                        <dt>Provisioned by</dt>
                        <dd>@FormatProvisionedBy(CurrentRevision)</dd>
                    </div>
                </dl>
            </div>
        }
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Revision history</h3>
                <p>Current and previous materialized app states.</p>
            </div>
        </div>
        <div class="generated-list">
            @foreach (var revision in Revisions)
            {
                <div class="@GetRevisionCssClass(revision)">
                    <FluentIcon Value="@GetSeverityIcon(GetRevisionSeverity(revision))" />
                    <div class="generated-diagnostic-content">
                        <strong>@FormatRevisionNumber(revision)</strong>
                        <span>@FormatRevisionHeadline(revision)</span>
                        <small>@FormatRevisionMetadata(revision)</small>
                    </div>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<ResourceDeploymentRecord> Revisions { get; set; } = [];

    private ResourceDeploymentRecord? CurrentRevision =>
        Revisions.FirstOrDefault(revision =>
            revision.EnvironmentRevisionStatus == ResourceOrchestratorRevisionStatus.Active ||
            revision.Status == ResourceOrchestratorDeploymentStatus.Active) ??
        Revisions.FirstOrDefault(revision =>
            string.Equals(revision.RuntimeRevisionId, GetDeploymentRevision(Resource), StringComparison.OrdinalIgnoreCase) ||
            string.Equals(revision.EnvironmentRevisionId, GetDeploymentRevision(Resource), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        Revisions = string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : await LoadRevisionsAsync(ResourceId);
    }

    private async Task<IReadOnlyList<ResourceDeploymentRecord>> LoadRevisionsAsync(string resourceId)
    {
        var records = await DeploymentManager.ListResourceDeploymentsAsync(new ResourceDeploymentQuery(
            SourceResourceId: resourceId,
            MaxRecords: 50));
        return records
            .OrderByDescending(record => record.EnvironmentRevisionCreatedAt ?? record.CompletedAt ?? record.StartedAt)
            .ToArray();
    }

    private static string GetDeploymentRevision(Resource? resource) =>
        resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentRevision) ??
        resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerRevision) ??
        string.Empty;

    private static string FormatRevisionHeadline(ResourceDeploymentRecord revision) =>
        string.Create(
            CultureInfo.CurrentCulture,
            $"{GetRevisionStatus(revision)} revision from {GetRevisionTimestamp(revision).ToLocalTime():g}");

    private static string FormatRevisionMetadata(ResourceDeploymentRecord revision)
    {
        var parts = new List<string>
        {
            $"Requested replicas: {GetRequestedReplicas(revision).ToString(CultureInfo.InvariantCulture)}",
            $"Change: {FormatChangeKind(revision)}",
            $"Runtime revision: {revision.RuntimeRevisionId}"
        };
        if (revision.EnvironmentRevisionNumber is > 0)
        {
            parts.Add($"Revision number: {revision.EnvironmentRevisionNumber.Value.ToString(CultureInfo.InvariantCulture)}");
        }
        if (!string.IsNullOrWhiteSpace(revision.BasedOnEnvironmentRevisionId))
        {
            parts.Add($"Based on: {revision.BasedOnEnvironmentRevisionId}");
        }
        if (!string.IsNullOrWhiteSpace(revision.ProvisionedBy))
        {
            parts.Add($"Provisioned by: {revision.ProvisionedBy}");
        }
        if (!string.IsNullOrWhiteSpace(revision.DeploymentId))
        {
            parts.Add($"Deployment: {revision.DeploymentId}");
        }

        return string.Join(" | ", parts);
    }

    private static string FormatRevisionCreated(ResourceDeploymentRecord revision)
    {
        var actor = string.IsNullOrWhiteSpace(revision.ProvisionedBy)
            ? "system"
            : revision.ProvisionedBy;
        return string.Create(
            CultureInfo.CurrentCulture,
            $"Created {GetRevisionTimestamp(revision).ToLocalTime():g}. Provisioned by {actor}.");
    }

    private static string FormatRevisionNumber(ResourceDeploymentRecord revision) =>
        revision.EnvironmentRevisionNumber is > 0
            ? string.Create(CultureInfo.InvariantCulture, $"Revision {revision.EnvironmentRevisionNumber.Value}")
            : revision.EnvironmentRevisionId ?? revision.RuntimeRevisionId;

    private static string FormatProvisionedBy(ResourceDeploymentRecord revision) =>
        string.IsNullOrWhiteSpace(revision.ProvisionedBy)
            ? "system"
            : revision.ProvisionedBy;

    private static string FormatChangeKind(ResourceDeploymentRecord revision) =>
        revision.Status switch
        {
            ResourceOrchestratorDeploymentStatus.Active => "Deployment",
            ResourceOrchestratorDeploymentStatus.Applying => "Deployment applying",
            ResourceOrchestratorDeploymentStatus.Failed => "Deployment failed",
            ResourceOrchestratorDeploymentStatus.Deleted => "Deployment removed",
            _ => "Deployment"
        };

    private static string GetRevisionStatus(ResourceDeploymentRecord? revision) =>
        revision?.EnvironmentRevisionStatus switch
        {
            ResourceOrchestratorRevisionStatus.Active => "Active",
            ResourceOrchestratorRevisionStatus.Superseded => "Previous",
            ResourceOrchestratorRevisionStatus.Failed => "Failed",
            ResourceOrchestratorRevisionStatus.Deleted => "Removed",
            ResourceOrchestratorRevisionStatus.Pending => "Pending",
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Active => "Active",
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Applying => "Pending",
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Failed => "Failed",
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Deleted => "Removed",
            null => "Unavailable",
            _ => revision.EnvironmentRevisionStatus.Value.ToString()
        };

    private static string GetRevisionCssClass(ResourceDeploymentRecord revision) =>
        GetRevisionSeverity(revision) switch
        {
            ResourceSignalSeverity.Success => "generated-diagnostic success",
            ResourceSignalSeverity.Error => "generated-diagnostic error",
            ResourceSignalSeverity.Warning => "generated-diagnostic warning",
            _ => "generated-diagnostic info"
        };

    private static string GetRevisionStatusCssClass(ResourceDeploymentRecord? revision) =>
        GetRevisionSeverity(revision) switch
        {
            ResourceSignalSeverity.Success => "container-app-status-pill success",
            ResourceSignalSeverity.Error => "container-app-status-pill error",
            ResourceSignalSeverity.Warning => "container-app-status-pill warning",
            _ => "container-app-status-pill"
        };

    private static ResourceSignalSeverity GetRevisionSeverity(ResourceDeploymentRecord? revision) =>
        revision?.EnvironmentRevisionStatus switch
        {
            ResourceOrchestratorRevisionStatus.Active => ResourceSignalSeverity.Success,
            ResourceOrchestratorRevisionStatus.Failed => ResourceSignalSeverity.Error,
            ResourceOrchestratorRevisionStatus.Pending => ResourceSignalSeverity.Warning,
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Active => ResourceSignalSeverity.Success,
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Failed => ResourceSignalSeverity.Error,
            null when revision?.Status == ResourceOrchestratorDeploymentStatus.Applying => ResourceSignalSeverity.Warning,
            _ => ResourceSignalSeverity.Info
        };

    private static DateTimeOffset GetRevisionTimestamp(ResourceDeploymentRecord revision) =>
        revision.EnvironmentRevisionCreatedAt ?? revision.CompletedAt ?? revision.StartedAt;

    private static int GetRequestedReplicas(ResourceDeploymentRecord revision)
    {
        if (revision.ReplicaGroup?.RequestedReplicas is { } requestedReplicas)
        {
            return requestedReplicas;
        }

        var definitionReplicas = revision.Definition?.DeploymentServices
            .SelectMany(service => service.ReplicaGroupDefinitions)
            .Select(definition => definition.RequestedReplicas)
            .FirstOrDefault(replicas => replicas > 0);
        return definitionReplicas is > 0 ? definitionReplicas.Value : 1;
    }

    private static string GetRevisionImage(ResourceDeploymentRecord? revision)
    {
        if (revision is null)
        {
            return string.Empty;
        }

        var service = revision.Definition?.DeploymentServices.FirstOrDefault();
        return service?.ServiceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerImage) ??
            string.Empty;
    }

    private static Icon GetSeverityIcon(ResourceSignalSeverity severity) =>
        severity switch
        {
            ResourceSignalSeverity.Success => new Icons.Regular.Size20.CheckmarkCircle(),
            ResourceSignalSeverity.Error => new Icons.Regular.Size20.ErrorCircle(),
            ResourceSignalSeverity.Warning => new Icons.Regular.Size20.Warning(),
            _ => new Icons.Regular.Size20.Info()
        };

}
