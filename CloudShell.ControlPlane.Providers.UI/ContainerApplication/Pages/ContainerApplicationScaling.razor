@using System.Globalization
@using CloudShell.ControlPlane.Providers
@implements IDisposable
@inject IResourceReplicaSlotStateManager ReplicaSlotStateManager
@inject IResourceManager ResourceManager
@inject IResourceTemplateManager Templates

@if (Resource is null)
{
    <EmptyState Title="Scaling is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (!BuiltInProviderResourceUiTypes.IsContainerApplication(Resource.EffectiveTypeId))
{
    <EmptyState Title="Scale and replicas are not supported"
                Message="This resource type does not expose container app scale controls." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Scale and replicas</h3>
            </div>
            <GeneratedRowActions>
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                              Disabled="@IsRefreshing"
                              OnClick="RefreshAsync">
                    @(IsRefreshing ? "Refreshing" : "Refresh")
                </FluentButton>
            </GeneratedRowActions>
        </div>

        <dl class="detail-list">
            <dt>Mode</dt>
            <dd>@GetModeLabel()</dd>
            <dt>Requested replica slots</dt>
            <dd>@RequestedReplicaSlots.ToString(CultureInfo.InvariantCulture)</dd>
            <dt>Replica slots</dt>
            <dd>@ReplicaSlots.Count.ToString(CultureInfo.InvariantCulture)</dd>
            <dt>Occupied slots</dt>
            <dd>@OccupiedReplicaSlots.ToString(CultureInfo.InvariantCulture)</dd>
            <dt>Materialized slots</dt>
            <dd>@GetMaterializedSlotsLabel()</dd>
            <dt>Slot state</dt>
            <dd>@GetReplicaSlotStateSummary()</dd>
            <dt>Session affinity</dt>
            <dd>@GetSessionAffinityLabel(Resource)</dd>
            <dt>Resource type</dt>
            <dd>@Resource.EffectiveTypeId</dd>
        </dl>

        <label for="graph-container-app-replicas">Replicas</label>
        <FluentNumberField TValue="int"
                           Id="graph-container-app-replicas"
                           Min="1"
                           Disabled="@IsReadOnly"
                           @bind-Value="Replicas" />
        <GeneratedRowActions>
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size20.ArrowSyncCircle())"
                          Disabled="@(!CanUpdateReplicaCount)"
                          OnClick="UpdateReplicasAsync">
                @(IsUpdatingReplicas ? "Updating replicas" : "Update replicas")
            </FluentButton>
        </GeneratedRowActions>

        @if (!string.IsNullOrWhiteSpace(ReplicaUpdateMessage))
        {
            <ProcedureMessage Compact="true"
                              Severity="@ReplicaUpdateSeverity"
                              Role="status">
                @ReplicaUpdateMessage
            </ProcedureMessage>
        }
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Routing</h3>
            </div>
        </div>

        <label for="container-app-session-affinity">Session affinity</label>
        <FluentSelect TOption="string"
                      Id="container-app-session-affinity"
                      Disabled="@IsReadOnly"
                      @bind-Value="SessionAffinityMode"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="None">None</FluentOption>
            <FluentOption TOption="string" Value="Cookie">Cookie</FluentOption>
            <FluentOption TOption="string" Value="ClientIp">Client IP</FluentOption>
        </FluentSelect>

        @if (IsCookieSessionAffinity)
        {
            <label for="container-app-session-affinity-cookie">Cookie name</label>
            <FluentTextField Id="container-app-session-affinity-cookie"
                             Disabled="@IsReadOnly"
                             @bind-Value="SessionAffinityCookieName"
                             Placeholder="CloudShellReplica" />

            <label for="container-app-session-affinity-duration">Duration seconds</label>
            <FluentNumberField TValue="int"
                               Id="container-app-session-affinity-duration"
                               Min="1"
                               Disabled="@IsReadOnly"
                               @bind-Value="SessionAffinityDurationSeconds" />
        }

        <GeneratedRowActions>
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size20.Save())"
                          Disabled="@(!CanUpdateRouting)"
                          OnClick="UpdateRoutingAsync">
                @(IsUpdatingRouting ? "Updating routing" : "Update routing")
            </FluentButton>
        </GeneratedRowActions>

        @if (!string.IsNullOrWhiteSpace(RoutingUpdateMessage))
        {
            <ProcedureMessage Compact="true"
                              Severity="@RoutingUpdateSeverity"
                              Role="status">
                @RoutingUpdateMessage
            </ProcedureMessage>
        }
    </section>

    @if (Resource is not null && RequestedReplicaSlots > 1)
    {
        <section class="blade-section">
            <h3>Replica slots</h3>
            @if (ReplicaSlots.Count == 0)
            {
                <EmptyState Title="No replica slots are materialized"
                            Message="No requested replica slots are materialized for this app yet." />
            }
            else
            {
                <ResourceTable>
                    <thead>
                        <tr>
                            <th>Slot</th>
                            <th>Occupant</th>
                            <th>State</th>
                            <th>Revision</th>
                            <th>Container</th>
                            <th>Materialization</th>
                            <th>Reconciliation</th>
                            <th>Host</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var slot in ReplicaSlots)
                        {
                            var replica = slot.Occupant;
                            var slotState = GetSlotState(slot);
                            <tr>
                                <td>
                                    <ResourceTableIdentity IconName="replica"
                                                           IconTitle="Replica slot"
                                                           Title="@slot.Label"
                                                           Summary="@GetSlotSummary(slot)" />
                                </td>
                                <td>
                                    @if (replica is null)
                                    {
                                        <strong>Vacant</strong>
                                        <div class="table-subtext">No active replica</div>
                                    }
                                    else
                                    {
                                        <strong>
                                            <FluentAnchor Href="@ResourceManagerRoutes.ResourceDetails(replica.Id)">
                                                @ResourceDisplayLabels.GetQualifiedLabel(replica)
                                            </FluentAnchor>
                                        </strong>
                                        <div class="table-subtext">@FormatReplicaOrdinal(replica)</div>
                                    }
                                </td>
                                <td>
                                    @if (replica is null)
                                    {
                                        <span class="table-subtext">Vacant</span>
                                    }
                                    else
                                    {
                                        <ResourceStateIndicator State="replica.State" Variant="pill" />
                                    }
                                </td>
                                <td>@(replica is null ? "not materialized" : GetAttribute(replica, ResourceAttributeNames.RuntimeRevision, replica.Version))</td>
                                <td>
                                    <strong>@(replica is null ? "not materialized" : GetAttribute(replica, ResourceAttributeNames.RuntimeContainerName, replica.Name))</strong>
                                </td>
                                <td>@(replica is null ? "vacant slot" : GetMaterializationLabel(replica))</td>
                                <td>
                                    @GetReplicaSlotStatusLabel(slotState)
                                    <div class="table-subtext">@GetReplicaSlotStateDetail(slotState)</div>
                                </td>
                                <td>@(replica is null ? "not assigned" : GetAttribute(replica, ResourceAttributeNames.ContainerHostId, "default host"))</td>
                            </tr>
                        }
                    </tbody>
                </ResourceTable>
            }
        </section>
    }
}

@code {
    [CascadingParameter(Name = ResourceManagerCascadingParameterNames.ReadOnly)]
    public bool IsReadOnly { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<Resource> MaterializedReplicas { get; set; } = [];
    private IReadOnlyList<ResourceReplicaSlotState> ReplicaSlotStates { get; set; } = [];
    private IReadOnlyList<ReplicaSlotView> ReplicaSlots { get; set; } = [];
    private int RequestedReplicaSlots { get; set; } = 1;
    private int Replicas { get; set; } = 1;
    private bool IsRefreshing { get; set; }
    private bool IsUpdatingReplicas { get; set; }
    private bool IsDisposed { get; set; }
    private string? ReplicaUpdateMessage { get; set; }
    private ResourceSignalSeverity? ReplicaUpdateSeverity { get; set; }
    private string SessionAffinityMode { get; set; } = "None";
    private string? SessionAffinityCookieName { get; set; }
    private int SessionAffinityDurationSeconds { get; set; } = 3600;
    private bool IsUpdatingRouting { get; set; }
    private string? RoutingUpdateMessage { get; set; }
    private ResourceSignalSeverity? RoutingUpdateSeverity { get; set; }

    private bool CanUpdateReplicaCount =>
        !IsReadOnly &&
        !IsUpdatingReplicas &&
        Resource is not null &&
        BuiltInProviderResourceUiTypes.IsContainerApplication(Resource.EffectiveTypeId) &&
        Math.Max(1, Replicas) != Math.Max(1, RequestedReplicaSlots);

    private bool IsCookieSessionAffinity =>
        string.Equals(
            SessionAffinityMode,
            ResourceOrchestratorSessionAffinityMode.Cookie.ToString(),
            StringComparison.OrdinalIgnoreCase);

    private bool CanUpdateRouting =>
        !IsReadOnly &&
        !IsUpdatingRouting &&
        Resource is not null &&
        BuiltInProviderResourceUiTypes.IsContainerApplication(Resource.EffectiveTypeId) &&
        (!IsCookieSessionAffinity || !string.IsNullOrWhiteSpace(SessionAffinityCookieName));

    protected override Task OnParametersSetAsync() => RefreshAsync();

    private async Task RefreshAsync()
    {
        if (IsDisposed || IsRefreshing)
        {
            return;
        }

        IsRefreshing = true;
        try
        {
            Resource = string.IsNullOrWhiteSpace(ResourceId)
                ? null
                : await ResourceManager.GetResourceAsync(ResourceId);
            MaterializedReplicas = Resource is null
                ? []
                : (await ResourceManager.ListResourceChildrenAsync(Resource.Id))
                    .Where(IsReplicaResource)
                    .OrderBy(GetReplicaOrdinal)
                    .ThenBy(ResourceDisplayLabels.GetQualifiedLabel, StringComparer.OrdinalIgnoreCase)
                    .ToArray();
            ReplicaSlotStates = Resource is null
                ? []
                : await ReplicaSlotStateManager.ListReplicaSlotStatesAsync(new ResourceReplicaSlotStateQuery(
                    ResourceId: Resource.Id,
                    MaxRecords: 100));
            RequestedReplicaSlots = Math.Max(1, GetReplicaCount(Resource));
            ReplicaSlots = CreateReplicaSlots(RequestedReplicaSlots, MaterializedReplicas);
            Replicas = RequestedReplicaSlots;
            InitializeRoutingFields();
        }
        finally
        {
            IsRefreshing = false;
            if (!IsDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task UpdateReplicasAsync()
    {
        if (IsUpdatingReplicas)
        {
            return;
        }

        if (IsReadOnly)
        {
            ReplicaUpdateSeverity = ResourceSignalSeverity.Warning;
            ReplicaUpdateMessage = "Resource Manager is in read-only mode.";
            return;
        }

        if (Resource is null || !BuiltInProviderResourceUiTypes.IsContainerApplication(Resource.EffectiveTypeId))
        {
            ReplicaUpdateSeverity = ResourceSignalSeverity.Warning;
            ReplicaUpdateMessage = "Scaling is not supported for this resource.";
            return;
        }

        IsUpdatingReplicas = true;
        ReplicaUpdateMessage = null;
        ReplicaUpdateSeverity = null;
        try
        {
            var result = await ResourceManager.UpdateResourceReplicasAsync(
                Resource.Id,
                Math.Max(1, Replicas),
                restartIfRunning: false,
                triggeredBy: "resource-manager-ui");
            var requiresFollowUp = result.RestartRequired || result.RuntimeReconciliationRequired;
            var followUpMessage = result.RestartRequired
                ? result.RestartMessage
                : result.RuntimeReconciliationMessage;
            ReplicaUpdateSeverity = requiresFollowUp
                ? ResourceSignalSeverity.Warning
                : ResourceSignalSeverity.Success;
            ReplicaUpdateMessage = requiresFollowUp && !string.IsNullOrWhiteSpace(followUpMessage)
                ? $"{result.Message} {followUpMessage}"
                : result.Message;
            await RefreshAsync();
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ReplicaUpdateSeverity = ResourceSignalSeverity.Error;
            ReplicaUpdateMessage = $"Replica update failed: {exception.Message}";
        }
        finally
        {
            IsUpdatingReplicas = false;
        }
    }

    private async Task UpdateRoutingAsync()
    {
        if (IsUpdatingRouting)
        {
            return;
        }

        if (IsReadOnly)
        {
            RoutingUpdateSeverity = ResourceSignalSeverity.Warning;
            RoutingUpdateMessage = "Resource Manager is in read-only mode.";
            return;
        }

        if (Resource is null || !BuiltInProviderResourceUiTypes.IsContainerApplication(Resource.EffectiveTypeId))
        {
            RoutingUpdateSeverity = ResourceSignalSeverity.Warning;
            RoutingUpdateMessage = "Routing settings are not supported for this resource.";
            return;
        }

        if (IsCookieSessionAffinity && string.IsNullOrWhiteSpace(SessionAffinityCookieName))
        {
            RoutingUpdateSeverity = ResourceSignalSeverity.Warning;
            RoutingUpdateMessage = "Cookie session affinity requires a cookie name.";
            return;
        }

        IsUpdatingRouting = true;
        RoutingUpdateMessage = null;
        RoutingUpdateSeverity = null;
        try
        {
            var attributes = new Dictionary<CloudShell.ResourceModel.ResourceAttributeId, CloudShell.ResourceModel.ResourceAttributeValue>
            {
                [ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityMode] =
                    NormalizeSessionAffinityMode(SessionAffinityMode)
            };
            if (IsCookieSessionAffinity)
            {
                attributes[ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityCookieName] =
                    SessionAffinityCookieName!.Trim();
                attributes[ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityDurationSeconds] =
                    Math.Max(1, SessionAffinityDurationSeconds);
            }

            var result = await Templates.ApplyResourceTemplateAsync(
                new CloudShell.ResourceModel.ResourceTemplate(
                    "Update container app routing",
                    [
                        new CloudShell.ResourceModel.ResourceDefinition(
                            Resource.Name,
                            ContainerApplicationResourceTypeProvider.ResourceTypeId,
                            ResourceId: Resource.Id,
                            ProviderId: ContainerApplicationResourceTypeProvider.ProviderId,
                            Attributes: new CloudShell.ResourceModel.ResourceAttributeValueMap(attributes))
                    ]));

            RoutingUpdateSeverity = result.IsCommitted && !result.HasErrors
                ? ResourceSignalSeverity.Success
                : ResourceSignalSeverity.Error;
            RoutingUpdateMessage = result.IsCommitted && !result.HasErrors
                ? "Routing settings were updated."
                : FormatDiagnostics(result.Diagnostics);
            await RefreshAsync();
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            RoutingUpdateSeverity = ResourceSignalSeverity.Error;
            RoutingUpdateMessage = $"Routing update failed: {exception.Message}";
        }
        finally
        {
            IsUpdatingRouting = false;
        }
    }

    private string GetModeLabel() =>
        RequestedReplicaSlots > 1 ? "Replicated" : "Single instance";

    private int OccupiedReplicaSlots =>
        ReplicaSlots.Count(slot => slot.Occupant is not null);

    private string GetMaterializedSlotsLabel() =>
        MaterializedReplicas.Count > 0
            ? MaterializedReplicas.Count.ToString(CultureInfo.InvariantCulture)
            : GetMaterializedSlotsFallback();

    private string GetMaterializedSlotsFallback()
    {
        var projectedCount = GetAttribute(ResourceAttributeNames.DeploymentMaterializedReplicas, string.Empty);
        if (!string.IsNullOrWhiteSpace(projectedCount))
        {
            return projectedCount;
        }

        return Resource?.State switch
        {
            ResourceState.Starting or ResourceState.Stopped or ResourceState.Stopping => "0",
            _ => "not observed"
        };
    }

    private string GetReplicaSlotStateSummary()
    {
        if (ReplicaSlotStates.Count == 0)
        {
            return "not observed";
        }

        var openCount = ReplicaSlotStates.Count(state =>
            state.Status is ResourceReplicaSlotReconciliationStatus.Unhealthy
                or ResourceReplicaSlotReconciliationStatus.Repairing
                or ResourceReplicaSlotReconciliationStatus.RepairFailed);
        return openCount == 0
            ? $"{ReplicaSlotStates.Count.ToString(CultureInfo.InvariantCulture)} observed"
            : $"{openCount.ToString(CultureInfo.InvariantCulture)} needing attention";
    }

    private string GetAttribute(string attributeName, string fallback) =>
        Resource is not null &&
        Resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static string GetAttribute(Resource resource, string attributeName, string fallback) =>
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private void InitializeRoutingFields()
    {
        SessionAffinityMode = NormalizeSessionAffinityMode(GetAttribute(
            ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityMode,
            ResourceOrchestratorSessionAffinityMode.None.ToString()));
        SessionAffinityCookieName = GetAttribute(
            ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityCookieName,
            "CloudShellReplica");
        SessionAffinityDurationSeconds =
            TryGetPositiveInt(
                Resource,
                ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityDurationSeconds) ??
            3600;
    }

    private static string GetSessionAffinityLabel(Resource resource)
    {
        var mode = NormalizeSessionAffinityMode(GetAttribute(
            resource,
            ContainerApplicationResourceTypeProvider.Attributes.RoutingSessionAffinityMode,
            ResourceOrchestratorSessionAffinityMode.None.ToString()));
        if (string.Equals(mode, ResourceOrchestratorSessionAffinityMode.Cookie.ToString(), StringComparison.OrdinalIgnoreCase))
        {
            return "Cookie";
        }

        if (string.Equals(mode, ResourceOrchestratorSessionAffinityMode.ClientIp.ToString(), StringComparison.OrdinalIgnoreCase))
        {
            return "Client IP";
        }

        return "None";
    }

    private static string NormalizeSessionAffinityMode(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        Enum.TryParse<ResourceOrchestratorSessionAffinityMode>(
            value,
            ignoreCase: true,
            out var mode)
            ? mode.ToString()
            : ResourceOrchestratorSessionAffinityMode.None.ToString();

    private static int? TryGetPositiveInt(Resource? resource, string attributeName)
    {
        if (resource is null ||
            !resource.ResourceAttributes.TryGetValue(attributeName, out var value) ||
            !int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var count) ||
            count < 1)
        {
            return null;
        }

        return count;
    }

    private static string FormatDiagnostics(IEnumerable<CloudShell.ResourceModel.ResourceDefinitionDiagnostic> diagnostics)
    {
        var messages = diagnostics
            .Where(diagnostic => diagnostic.Severity == CloudShell.ResourceModel.ResourceDefinitionDiagnosticSeverity.Error)
            .Select(diagnostic => diagnostic.Message)
            .ToArray();
        return messages.Length == 0
            ? "Routing settings could not be updated."
            : string.Join(" ", messages);
    }

    private static bool IsReplicaResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, "runtime.container", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(
            GetAttribute(resource, ResourceAttributeNames.RuntimeKind, string.Empty),
            "containerReplica",
            StringComparison.OrdinalIgnoreCase);

    private static int GetReplicaOrdinal(Resource resource) =>
        int.TryParse(
            GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, string.Empty),
            out var ordinal)
            ? ordinal
            : int.MaxValue;

    private static IReadOnlyList<ReplicaSlotView> CreateReplicaSlots(
        int requestedSlots,
        IReadOnlyList<Resource> replicas)
    {
        var maxReplicaOrdinal = replicas
            .Select(GetReplicaOrdinal)
            .Where(ordinal => ordinal != int.MaxValue)
            .DefaultIfEmpty(0)
            .Max();
        var slotCount = Math.Max(requestedSlots, maxReplicaOrdinal);

        if (slotCount <= 1)
        {
            return [];
        }

        var replicasByOrdinal = replicas
            .Where(replica => GetReplicaOrdinal(replica) != int.MaxValue)
            .GroupBy(GetReplicaOrdinal)
            .ToDictionary(group => group.Key, group => group.First());

        return Enumerable
            .Range(1, slotCount)
            .Select(ordinal =>
            {
                replicasByOrdinal.TryGetValue(ordinal, out var occupant);
                return new ReplicaSlotView(ordinal, slotCount, occupant);
            })
            .ToArray();
    }

    private static string FormatReplicaOrdinal(Resource resource)
    {
        var ordinal = GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, "?");
        var count = GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaCount, "?");
        return $"{ordinal} of {count}";
    }

    private static string GetSlotSummary(ReplicaSlotView slot) =>
        slot.Occupant is null
            ? "No active replica"
            : $"Replica {slot.Ordinal.ToString(CultureInfo.InvariantCulture)} of {slot.SlotCount.ToString(CultureInfo.InvariantCulture)}";

    private static string GetMaterializationLabel(Resource resource) =>
        GetAttribute(resource, ResourceAttributeNames.RuntimeMaterialization, "unknown") switch
        {
            "orchestratorMaterialized" => "Materialized",
            "orchestratorPending" => "Pending",
            "orchestratorFailed" => "Failed",
            var materialization when !string.IsNullOrWhiteSpace(materialization) => materialization,
            _ => "unknown"
        };

    private ResourceReplicaSlotState? GetSlotState(ReplicaSlotView slot) =>
        ReplicaSlotStates
            .Where(state => state.SlotOrdinal == slot.Ordinal)
            .OrderByDescending(state => state.LastCompletedAt ?? state.LastAttemptedAt ?? state.ObservedAt)
            .FirstOrDefault();

    private static string GetReplicaSlotStatusLabel(ResourceReplicaSlotState? state) =>
        state?.Status switch
        {
            ResourceReplicaSlotReconciliationStatus.Unhealthy => "Unhealthy",
            ResourceReplicaSlotReconciliationStatus.Repairing => "Repairing",
            ResourceReplicaSlotReconciliationStatus.Repaired => "Repaired",
            ResourceReplicaSlotReconciliationStatus.RepairFailed => "Repair failed",
            ResourceReplicaSlotReconciliationStatus.Materialized => "Materialized",
            null => "not observed",
            _ => state.Status.ToString()
        };

    private static string GetReplicaSlotStateDetail(ResourceReplicaSlotState? state)
    {
        if (state is null)
        {
            return "No slot reconciliation state recorded";
        }

        if (!string.IsNullOrWhiteSpace(state.LastResult))
        {
            return state.LastResult;
        }

        if (!string.IsNullOrWhiteSpace(state.Detail))
        {
            return state.Detail;
        }

        return state.ObservedAt.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);
    }

    private static int GetReplicaCount(Resource? resource)
    {
        if (resource is null)
        {
            return 1;
        }

        return TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentRequestedReplicaSlots) ??
            TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentRequestedReplicas) ??
            TryGetReplicaCount(resource, ResourceAttributeNames.ContainerReplicas) ??
            1;
    }

    private static int? TryGetReplicaCount(Resource resource, string attributeName) =>
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var count)
            ? Math.Max(1, count)
            : null;

    public void Dispose()
    {
        IsDisposed = true;
    }

    private sealed record ReplicaSlotView(
        int Ordinal,
        int SlotCount,
        Resource? Occupant)
    {
        public string Label => $"Slot {Ordinal.ToString(CultureInfo.InvariantCulture)}";
    }
}
