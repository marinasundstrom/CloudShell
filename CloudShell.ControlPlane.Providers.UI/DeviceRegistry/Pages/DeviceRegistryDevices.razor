@using System.Text.Json
@inject IResourceManager ResourceManager
@inject IServiceProvider Services

@if (DeviceManager is null)
{
    <EmptyState Title="Device inventory unavailable"
                Message="This UI host does not have access to the Device Registry runtime manager." />
}
else if (Resource is null)
{
    <EmptyState Title="Device Registry is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Devices</h3>
                <p>@GetDeviceSummary()</p>
            </div>
        </div>

        @if (Devices.Count == 0)
        {
            <EmptyState Title="No enrolled devices"
                        Message="Enrolled devices will appear here after a device provisions an identity." />
        }
        else
        {
            <ResourceTable AriaLabel="Enrolled devices">
                <thead>
                    <tr>
                        <th>Subject</th>
                        <th>Platform</th>
                        <th>Operating system</th>
                        <th>Architecture</th>
                        <th>Presence</th>
                        <th>Status</th>
                        <th>Last seen</th>
                        <th>Enrolled</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var device in Devices)
                    {
                        <tr>
                            <td>
                                <strong>@device.Subject</strong>
                                <div class="table-subtext">@device.Id</div>
                            </td>
                            <td>@GetProperty(device, "platform")</td>
                            <td>
                                @GetOperatingSystem(device)
                                <div class="table-subtext">@GetProperty(device, "osDescription")</div>
                            </td>
                            <td>@GetArchitecture(device)</td>
                            <td>@FormatPresence(device)</td>
                            <td>@FormatStatus(device)</td>
                            <td>@FormatOptionalTimestamp(device.LastSeenAt)</td>
                            <td>@FormatTimestamp(device.EnrolledAt)</td>
                            <td>
                                <FluentButton Appearance="Appearance.Neutral"
                                              IconStart="@(new Icons.Regular.Size20.Info())"
                                              OnClick="() => SelectDevice(device)">
                                    Details
                                </FluentButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </ResourceTable>
        }
    </section>

    @if (SelectedDevice is not null)
    {
        <section class="blade-section">
            <div class="blade-section-header">
                <div>
                    <h3>@SelectedDevice.Subject</h3>
                    <p>@SelectedDevice.ClientId</p>
                </div>
                <div class="heading-actions">
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(!CanRevokeSelectedDevice || IsMutatingDevice)"
                                  IconStart="@(new Icons.Regular.Size20.ErrorCircle())"
                                  OnClick="RevokeSelectedDevice">
                        Revoke access
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@IsMutatingDevice"
                                  IconStart="@(new Icons.Regular.Size20.Delete())"
                                  OnClick="RemoveSelectedDevice">
                        Remove
                    </FluentButton>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(DeviceOperationMessage))
            {
                <p>@DeviceOperationMessage</p>
            }

            <ResourceTable AriaLabel="Device identity details">
                <tbody>
                    <tr>
                        <th scope="row">Identity category</th>
                        <td>@SelectedDevice.IdentityCategory</td>
                    </tr>
                    <tr>
                        <th scope="row">Identity provider</th>
                        <td>@SelectedDevice.IdentityProviderId</td>
                    </tr>
                    <tr>
                        <th scope="row">Identity resource</th>
                        <td>@SelectedDevice.IdentityResourceId</td>
                    </tr>
                    <tr>
                        <th scope="row">Identity name</th>
                        <td>@SelectedDevice.IdentityName</td>
                    </tr>
                    <tr>
                        <th scope="row">Status</th>
                        <td>@FormatStatus(SelectedDevice)</td>
                    </tr>
                    <tr>
                        <th scope="row">Presence</th>
                        <td>@FormatPresence(SelectedDevice)</td>
                    </tr>
                    <tr>
                        <th scope="row">Last seen</th>
                        <td>@FormatOptionalTimestamp(SelectedDevice.LastSeenAt)</td>
                    </tr>
                    <tr>
                        <th scope="row">Last seen source</th>
                        <td>@FormatOptionalValue(SelectedDevice.LastSeenSource)</td>
                    </tr>
                    <tr>
                        <th scope="row">Revoked</th>
                        <td>@FormatOptionalTimestamp(SelectedDevice.RevokedAt)</td>
                    </tr>
                    <tr>
                        <th scope="row">Revocation reason</th>
                        <td>@FormatOptionalValue(SelectedDevice.RevokedReason)</td>
                    </tr>
                </tbody>
            </ResourceTable>
        </section>

        <section class="blade-section">
            <div class="blade-section-header">
                <div>
                    <h3>Twin</h3>
                    <p>@GetTwinSummary(SelectedDevice)</p>
                </div>
                <div class="heading-actions">
                    <FluentButton Appearance="Appearance.Accent"
                                  Disabled="@IsUpdatingTwin"
                                  IconStart="@(new Icons.Regular.Size20.Save())"
                                  OnClick="UpdateDesiredStateAsync">
                        Save desired state
                    </FluentButton>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(TwinOperationMessage))
            {
                <p>@TwinOperationMessage</p>
            }

            <ResourceTable AriaLabel="Device twin metadata">
                <tbody>
                    <tr>
                        <th scope="row">Desired version</th>
                        <td>@SelectedDevice.Twin.Desired.Version</td>
                    </tr>
                    <tr>
                        <th scope="row">Desired updated</th>
                        <td>@FormatOptionalTimestamp(SelectedDevice.Twin.Desired.UpdatedAt)</td>
                    </tr>
                    <tr>
                        <th scope="row">Reported version</th>
                        <td>@SelectedDevice.Twin.Reported.Version</td>
                    </tr>
                    <tr>
                        <th scope="row">Reported updated</th>
                        <td>@FormatOptionalTimestamp(SelectedDevice.Twin.Reported.UpdatedAt)</td>
                    </tr>
                    <tr>
                        <th scope="row">Last sync</th>
                        <td>@FormatOptionalTimestamp(SelectedDevice.Twin.LastSyncedAt)</td>
                    </tr>
                </tbody>
            </ResourceTable>

            <div class="form-grid">
                <label for="device-twin-desired">Desired state</label>
                <FluentTextArea Id="device-twin-desired"
                                AriaLabel="Desired twin state JSON"
                                @bind-Value="DesiredStateJson"
                                Rows="8"
                                Style="width: 100%;" />
            </div>

            <ResourceTable AriaLabel="Reported twin state">
                <thead>
                    <tr>
                        <th>Reported state</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <pre>@FormatTwinStateJson(SelectedDevice.Twin.Reported.State)</pre>
                        </td>
                    </tr>
                </tbody>
            </ResourceTable>
        </section>

        <section class="blade-section">
            <div class="blade-section-header">
                <div>
                    <h3>Properties</h3>
                    <p>@GetPairSummary(SelectedDevice.Properties, "property", "properties")</p>
                </div>
            </div>

            <ResourceTable AriaLabel="Device properties">
                <tbody>
                    @foreach (var property in GetPairs(SelectedDevice.Properties))
                    {
                        <tr>
                            <th scope="row">@property.Key</th>
                            <td>@property.Value</td>
                        </tr>
                    }
                </tbody>
            </ResourceTable>
        </section>

        <section class="blade-section">
            <div class="blade-section-header">
                <div>
                    <h3>Claims</h3>
                    <p>@GetPairSummary(SelectedDevice.Claims, "claim", "claims")</p>
                </div>
            </div>

            <ResourceTable AriaLabel="Device claims">
                <tbody>
                    @foreach (var claim in GetPairs(SelectedDevice.Claims))
                    {
                        <tr>
                            <th scope="row">@claim.Key</th>
                            <td>@claim.Value</td>
                        </tr>
                    }
                </tbody>
            </ResourceTable>
        </section>
    }
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private CloudShell.Abstractions.ResourceManager.Resource? Resource { get; set; }
    private IDeviceRegistryRuntimeDeviceManager? DeviceManager { get; set; }
    private List<DeviceRegistryRuntimeDevice> Devices { get; } = [];
    private string? SelectedDeviceId { get; set; }
    private bool IsMutatingDevice { get; set; }
    private bool IsUpdatingTwin { get; set; }
    private string? DeviceOperationMessage { get; set; }
    private string DesiredStateJson { get; set; } = "{}";
    private string? TwinEditorDeviceId { get; set; }
    private string? TwinOperationMessage { get; set; }
    private DeviceRegistryRuntimeDevice? SelectedDevice =>
        Devices.FirstOrDefault(device => string.Equals(
            device.Id,
            SelectedDeviceId,
            StringComparison.OrdinalIgnoreCase));
    private bool CanRevokeSelectedDevice =>
        SelectedDevice is { } device && !IsRevoked(device);

    protected override async Task OnParametersSetAsync()
    {
        DeviceManager = Services.GetService(typeof(IDeviceRegistryRuntimeDeviceManager))
            as IDeviceRegistryRuntimeDeviceManager;
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);

        Devices.Clear();
        if (DeviceManager is not null && Resource is not null)
        {
            var devices = await DeviceManager.ListDevicesAsync(Resource);
            Devices.AddRange(devices);
        }

        if (Devices.Count == 0)
        {
            SelectedDeviceId = null;
        }
        else if (SelectedDevice is null)
        {
            SelectedDeviceId = Devices[0].Id;
        }

        SyncTwinEditor();
    }

    private string GetDeviceSummary() =>
        Devices.Count == 1
            ? "1 device is enrolled in this registry."
            : $"{Devices.Count} devices are enrolled in this registry.";

    private void SelectDevice(DeviceRegistryRuntimeDevice device)
    {
        SelectedDeviceId = device.Id;
        SyncTwinEditor(force: true);
    }

    private async Task RevokeSelectedDevice()
    {
        if (DeviceManager is null ||
            Resource is null ||
            SelectedDevice is null ||
            !CanRevokeSelectedDevice)
        {
            return;
        }

        await MutateSelectedDeviceAsync(async device =>
        {
            var updated = await DeviceManager.RevokeDeviceAsync(
                Resource,
                device.Id,
                "Revoked from Resource Manager");
            var index = Devices.FindIndex(current => string.Equals(
                current.Id,
                device.Id,
                StringComparison.OrdinalIgnoreCase));
            if (index >= 0)
            {
                Devices[index] = updated;
            }

            DeviceOperationMessage = "Device access was revoked.";
        });
    }

    private async Task RemoveSelectedDevice()
    {
        if (DeviceManager is null ||
            Resource is null ||
            SelectedDevice is null)
        {
            return;
        }

        await MutateSelectedDeviceAsync(async device =>
        {
            await DeviceManager.RemoveDeviceAsync(
                Resource,
                device.Id);
            Devices.RemoveAll(current => string.Equals(
                current.Id,
                device.Id,
                StringComparison.OrdinalIgnoreCase));
            SelectedDeviceId = Devices.FirstOrDefault()?.Id;
            SyncTwinEditor(force: true);
            DeviceOperationMessage = "Device record was removed.";
        });
    }

    private async Task UpdateDesiredStateAsync()
    {
        if (DeviceManager is null ||
            Resource is null ||
            SelectedDevice is null ||
            IsUpdatingTwin)
        {
            return;
        }

        IsUpdatingTwin = true;
        TwinOperationMessage = null;
        try
        {
            var desiredState = ParseTwinStateJson(DesiredStateJson);
            var twin = await DeviceManager.SetDesiredStateAsync(
                Resource,
                SelectedDevice.Id,
                desiredState);
            var index = Devices.FindIndex(current => string.Equals(
                current.Id,
                SelectedDevice.Id,
                StringComparison.OrdinalIgnoreCase));
            if (index >= 0)
            {
                Devices[index] = Devices[index] with
                {
                    Twin = twin
                };
            }

            TwinOperationMessage = "Desired state was updated.";
            SyncTwinEditor(force: true);
        }
        catch (Exception exception) when (exception is InvalidOperationException or HttpRequestException or JsonException)
        {
            TwinOperationMessage = exception.Message;
        }
        finally
        {
            IsUpdatingTwin = false;
        }
    }

    private void SyncTwinEditor(bool force = false)
    {
        if (SelectedDevice is null)
        {
            DesiredStateJson = "{}";
            TwinEditorDeviceId = null;
            TwinOperationMessage = null;
            return;
        }

        if (!force &&
            string.Equals(TwinEditorDeviceId, SelectedDevice.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        DesiredStateJson = FormatTwinStateJson(SelectedDevice.Twin.Desired.State);
        TwinEditorDeviceId = SelectedDevice.Id;
        TwinOperationMessage = null;
    }

    private async Task MutateSelectedDeviceAsync(
        Func<DeviceRegistryRuntimeDevice, Task> operation)
    {
        var device = SelectedDevice;
        if (device is null || IsMutatingDevice)
        {
            return;
        }

        IsMutatingDevice = true;
        DeviceOperationMessage = null;
        try
        {
            await operation(device);
        }
        catch (Exception exception) when (exception is InvalidOperationException or HttpRequestException or JsonException)
        {
            DeviceOperationMessage = exception.Message;
        }
        finally
        {
            IsMutatingDevice = false;
        }
    }

    private static string GetOperatingSystem(DeviceRegistryRuntimeDevice device)
    {
        var operatingSystem = GetProperty(device, "operatingSystem");
        return operatingSystem == "-"
            ? GetProperty(device, "osDescription")
            : operatingSystem;
    }

    private static string GetArchitecture(DeviceRegistryRuntimeDevice device)
    {
        var osArchitecture = GetProperty(device, "osArchitecture");
        var processArchitecture = GetProperty(device, "processArchitecture");
        if (osArchitecture == "-")
        {
            return processArchitecture;
        }

        return processArchitecture == "-"
            ? osArchitecture
            : $"{osArchitecture} / {processArchitecture}";
    }

    private static string GetProperty(
        DeviceRegistryRuntimeDevice device,
        string name) =>
        device.Properties.TryGetValue(name, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : "-";

    private static IEnumerable<KeyValuePair<string, string>> GetPairs(
        IReadOnlyDictionary<string, string> values) =>
        values.OrderBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase);

    private static string GetPairSummary(
        IReadOnlyDictionary<string, string> values,
        string singular,
        string plural) =>
        values.Count == 1
            ? $"1 {singular}"
            : $"{values.Count} {plural}";

    private static string GetTwinSummary(DeviceRegistryRuntimeDevice device) =>
        device.Twin.LastSyncedAt is null
            ? "Desired and reported state for this device."
            : $"Last synced {FormatTimestamp(device.Twin.LastSyncedAt.Value)}.";

    private static IReadOnlyDictionary<string, JsonElement> ParseTwinStateJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return new Dictionary<string, JsonElement>(StringComparer.OrdinalIgnoreCase);
        }

        using var document = JsonDocument.Parse(json);
        if (document.RootElement.ValueKind != JsonValueKind.Object)
        {
            throw new JsonException("Desired state must be a JSON object.");
        }

        var state = new Dictionary<string, JsonElement>(StringComparer.OrdinalIgnoreCase);
        foreach (var property in document.RootElement.EnumerateObject())
        {
            state[property.Name] = property.Value.Clone();
        }

        return state;
    }

    private static string FormatTwinStateJson(
        IReadOnlyDictionary<string, JsonElement> state) =>
        JsonSerializer.Serialize(
            state,
            new JsonSerializerOptions
            {
                WriteIndented = true
            });

    private static string FormatTimestamp(DateTimeOffset timestamp) =>
        timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static string FormatOptionalTimestamp(DateTimeOffset? timestamp) =>
        timestamp is null
            ? "-"
            : FormatTimestamp(timestamp.Value);

    private static string FormatOptionalValue(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? "-"
            : value;

    private static string FormatStatus(DeviceRegistryRuntimeDevice device) =>
        string.IsNullOrWhiteSpace(device.Status)
            ? "active"
            : device.Status;

    private static string FormatPresence(DeviceRegistryRuntimeDevice device) =>
        string.IsNullOrWhiteSpace(device.Presence)
            ? "unknown"
            : device.Presence;

    private static bool IsRevoked(DeviceRegistryRuntimeDevice device) =>
        string.Equals(device.Status, "revoked", StringComparison.OrdinalIgnoreCase) ||
        device.RevokedAt is not null;
}
