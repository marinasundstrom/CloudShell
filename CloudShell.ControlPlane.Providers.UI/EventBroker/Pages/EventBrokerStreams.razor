@using System.Net.Http.Headers
@using System.Security.Claims
@using CloudShell.Abstractions.Authorization
@using CloudShell.ControlPlane.Authentication
@using CloudShell.EventBroker.Client
@using CloudShell.ResourceModel
@using Microsoft.Extensions.Options
@inject ICloudShellAuthorizationService Authorization
@inject IResourceManager ResourceManager
@inject BuiltInAuthorityTokenService TokenService
@inject IOptions<CloudShellAuthenticationOptions> AuthenticationOptions

@if (Resource is null)
{
    <EmptyState Title="Event Broker is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Protocols</h3>
                <p>@GetProtocolSummary()</p>
            </div>
        </div>

        @if (ProtocolRows.Count == 0)
        {
            <EmptyState Title="No protocols"
                        Message="This broker does not declare protocol endpoints." />
        }
        else
        {
            <ResourceTable AriaLabel="Event Broker protocols">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Protocol</th>
                        <th>Endpoint</th>
                        <th>Event format</th>
                        <th>Capabilities</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var protocol in ProtocolRows)
                    {
                        <tr>
                            <td><strong>@protocol.Name</strong></td>
                            <td>@FormatProtocol(protocol.Protocol)</td>
                            <td>@FormatEndpoint(protocol.Address)</td>
                            <td>@FormatEventFormat(protocol.EventFormat)</td>
                            <td>@FormatCapabilities(protocol.Capabilities)</td>
                        </tr>
                    }
                </tbody>
            </ResourceTable>
        }
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Streams</h3>
                <p>@GetStreamSummary()</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <EmptyState Title="Streams unavailable"
                        Message="@Error" />
        }
        else if (Streams.Count == 0)
        {
            <EmptyState Title="No retained events"
                        Message="Streams appear after publishers append events to this broker." />
        }
        else
        {
            <ResourceTable AriaLabel="Event Broker streams">
                <thead>
                    <tr>
                        <th>Stream</th>
                        <th>Events</th>
                        <th>Last sequence</th>
                        <th>Last event</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stream in Streams)
                    {
                        <tr>
                            <td><strong>@stream.Name</strong></td>
                            <td>@stream.EventCount</td>
                            <td>@stream.LastSequence</td>
                            <td>@FormatLastEvent(stream.LastEventAt)</td>
                        </tr>
                    }
                </tbody>
            </ResourceTable>
        }
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private CloudShell.Abstractions.ResourceManager.Resource? Resource { get; set; }
    private IReadOnlyList<EventBrokerProtocolRow> ProtocolRows { get; set; } = [];
    private List<EventBrokerStreamSummary> Streams { get; } = [];
    private string? Error { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Resource = null;
        ProtocolRows = [];
        Streams.Clear();
        Error = null;

        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            return;
        }

        Resource = await ResourceManager.GetResourceAsync(ResourceId);
        if (Resource is null)
        {
            return;
        }

        ProtocolRows = CreateProtocolRows(Resource);
        var endpoint = GetHttpEndpoint();
        if (string.IsNullOrWhiteSpace(endpoint))
        {
            Error = "This broker does not declare an HTTP event endpoint.";
            return;
        }

        try
        {
            if (!Authorization.CanAccessResource(
                    Resource.Id,
                    resourceGroupId: null,
                    EventBrokerResourceOperationPermissions.ReadEvents))
            {
                Error = "You do not have Event Broker read access for this resource.";
                return;
            }

            using var httpClient = new HttpClient();
            httpClient.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue(
                    "Bearer",
                    CreateReadAccessToken(Resource.Id));
            var client = new EventBrokerClient(new Uri(endpoint), httpClient);
            Streams.AddRange(await client.ListStreamsAsync(Resource.Id));
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            Error = $"CloudShell could not read streams from this broker. {FormatStreamReadFailure(exception)}";
        }
    }

    private string GetProtocolSummary() =>
        ProtocolRows.Count == 1
            ? "1 protocol endpoint is declared for this broker."
            : $"{ProtocolRows.Count} protocol endpoints are declared for this broker.";

    private string GetStreamSummary() =>
        Streams.Count == 1
            ? "1 retained stream is available on this broker."
            : $"{Streams.Count} retained streams are available on this broker.";

    private string? GetHttpEndpoint() =>
        ProtocolRows.FirstOrDefault(protocol =>
            string.Equals(protocol.Protocol, EventBrokerProtocols.Http, StringComparison.OrdinalIgnoreCase))
            ?.Address;

    private string CreateReadAccessToken(string resourceId)
    {
        var authentication = AuthenticationOptions.Value;
        var resourcePermission = ResourcePermissionClaimAuthorization.CreateResourcePermissionClaimValue(
            resourceId,
            EventBrokerResourceOperationPermissions.ReadEvents);
        var token = TokenService.IssueToken(
            [
                new Claim(
                    CloudShellAuthenticationOptions.ResourcePermissionClaimType,
                    resourcePermission)
            ],
            authentication.BuiltInAuthority.Audience,
            [EventBrokerClient.DefaultScope]);
        return token.AccessToken;
    }

    private static IReadOnlyList<EventBrokerProtocolRow> CreateProtocolRows(
        CloudShell.Abstractions.ResourceManager.Resource resource)
    {
        var mappings = resource.EndpointNetworkMappings ?? [];
        return resource.Endpoints
            .Select(endpoint =>
            {
                var mapping = mappings.FirstOrDefault(candidate =>
                    candidate.MatchesEndpoint(endpoint.Name));
                return new EventBrokerProtocolRow(
                    endpoint.Name,
                    endpoint.Protocol,
                    mapping?.Address,
                    string.Equals(endpoint.Protocol, EventBrokerProtocols.Http, StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(endpoint.Protocol, EventBrokerProtocols.Mqtt, StringComparison.OrdinalIgnoreCase)
                        ? "json"
                        : null,
                    []);
            })
            .ToArray();
    }

    private static string FormatProtocol(string protocol) =>
        protocol.Trim().ToLowerInvariant() switch
        {
            EventBrokerProtocols.Http => "HTTP",
            EventBrokerProtocols.Mqtt => "MQTT",
            EventBrokerProtocols.Amqp => "AMQP",
            EventBrokerProtocols.Kafka => "Kafka",
            EventBrokerProtocols.EventHubs => "Event Hubs",
            EventBrokerProtocols.Nats => "NATS",
            { Length: > 0 } => "Custom",
            _ => "Not configured"
        };

    private static string FormatCapabilities(IReadOnlyList<string> values) =>
        values.Count == 0
            ? "None"
            : string.Join(", ", values.Select(FormatCapability).Order(StringComparer.OrdinalIgnoreCase));

    private static string FormatCapability(string capability) =>
        capability.Trim().ToLowerInvariant() switch
        {
            EventBrokerProtocolCapabilities.PublishEvents => "Publish",
            EventBrokerProtocolCapabilities.SubscribeEvents => "Subscribe",
            EventBrokerProtocolCapabilities.RetainedEvents => "Retained events",
            EventBrokerProtocolCapabilities.TelemetryIngestion => "Telemetry ingestion",
            { Length: > 0 } => "Custom",
            _ => "Not configured"
        };

    private static string FormatEndpoint(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Not mapped" : value;

    private static string FormatEventFormat(string? value) =>
        value?.Trim().ToLowerInvariant() switch
        {
            "json" => "JSON",
            { Length: > 0 } => "Custom",
            _ => "Not declared"
        };

    private static string FormatLastEvent(DateTimeOffset? timestamp) =>
        timestamp is null
            ? "No events"
            : timestamp.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private static string FormatStreamReadFailure(Exception exception) =>
        exception switch
        {
            HttpRequestException => "Check that the HTTP event endpoint is reachable.",
            TaskCanceledException => "The stream request timed out.",
            UnauthorizedAccessException => "Check Event Broker read permissions for this resource.",
            _ => "Check the broker endpoint and try again."
        };

    private sealed record EventBrokerProtocolRow(
        string Name,
        string Protocol,
        string? Address,
        string? EventFormat,
        IReadOnlyList<string> Capabilities);
}
