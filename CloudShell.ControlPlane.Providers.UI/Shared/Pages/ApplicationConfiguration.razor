@using System.Text.Json
@inject IResourceManager ResourceManager

@if (Resource is null)
{
    <EmptyState Title="Configuration is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Configuration</h3>
                <p>Resource configuration and management details available to CloudShell.</p>
            </div>
        </div>
        <dl class="detail-list">
            <dt>Name</dt>
            <dd>@Resource.Name</dd>
            <dt>Display name</dt>
            <dd>@Resource.EffectiveDisplayName</dd>
            <dt>Type</dt>
            <dd>@FormatResourceType(Resource)</dd>
            <dt>Provider</dt>
            <dd>@Resource.Provider</dd>
            <dt>State</dt>
            <dd>@FormatResourceState(Resource.State)</dd>
            <dt>Source</dt>
            <dd>@FormatResourceSource(Resource.Source)</dd>
            <dt>Management mode</dt>
            <dd>@FormatManagementMode(Resource.ManagementMode)</dd>
            <dt>Service discovery</dt>
            <dd>@GetServiceDiscoveryName()</dd>
            <dt>Environment variables</dt>
            <dd>@GetEnvironmentSummary()</dd>
            <dt>Startup dependencies</dt>
            <dd>@GetDependencySummary()</dd>
            <dt>Last updated</dt>
            <dd>@FormatResourceTimestamp(Resource.LastUpdated)</dd>
        </dl>

        @if (Resource.DependsOn.Count > 0)
        {
            <div class="generated-list configuration-dependency-list">
                <div>
                    <strong>Startup dependencies</strong>
                    @foreach (var dependency in DependencyRows)
                    {
                        @if (dependency.Resource is null)
                        {
                            <span>@dependency.Label</span>
                        }
                        else
                        {
                            <FluentAnchor Href="@ResourceManagerRoutes.ResourceDetails(dependency.ResourceId)">
                                @dependency.Label
                            </FluentAnchor>
                        }
                    }
                </div>
            </div>
        }
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Troubleshooting</h3>
                <p>Stable identifiers and provider behavior for diagnosing this resource.</p>
            </div>
        </div>

        <div class="resource-troubleshooting-list">
            <details class="resource-troubleshooting-details">
                <summary>Resource identifiers</summary>
                <dl class="detail-list">
                    <dt>Resource ID</dt>
                    <dd>@Resource.Id</dd>
                    <dt>Class</dt>
                    <dd>@FormatResourceClass(Resource.ResourceClass)</dd>
                    <dt>Visibility</dt>
                    <dd>@FormatResourceVisibility(Resource.Visibility)</dd>
                    <dt>Resource membership</dt>
                    <dd>@FormatResourceGraphMembership(Resource.ResourceGraphMembership)</dd>
                    <dt>Resource version</dt>
                    <dd>@Resource.Version</dd>
                </dl>
            </details>

            <details class="resource-troubleshooting-details">
                <summary>Capabilities and operations</summary>
                <p>@GetCapabilityOperationSummary()</p>
                <div class="generated-list">
                    <div>
                        <strong>Capabilities</strong>
                        <span>@FormatList(Resource.ResourceCapabilities.Select(capability => FormatCapabilityLabel(capability.Id)))</span>
                    </div>
                    <div>
                        <strong>Operations</strong>
                        <span>@FormatList(Resource.ResourceActions.Select(FormatActionLabel))</span>
                    </div>
                </div>
            </details>
        </div>
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<ResourceDependencyRow> DependencyRows { get; set; } = [];
    private static readonly string[] EnvironmentAttributeRoots =
    [
        EnvironmentVariablesCapabilityProvider.AttributeId.ToString()
    ];

    private static readonly string[] ServiceDiscoveryAttributeNames =
    [
        AspNetCoreProjectResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        JavaScriptAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        JavaAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        GoAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        PythonAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString()
    ];

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        DependencyRows = Resource is null
            ? []
            : await CreateDependencyRowsAsync(Resource);
    }

    private string GetEnvironmentSummary()
    {
        if (Resource is null)
        {
            return "No environment variables are configured.";
        }

        var count = CountEnvironmentVariables(Resource);
        return count switch
        {
            0 => "No environment variables are configured for this resource.",
            1 => "1 environment variable is configured for this resource.",
            _ => $"{count} environment variables are configured for this resource."
        };
    }

    private string GetDependencySummary() =>
        DependencyRows.Count switch
        {
            0 => "No startup dependencies are configured for this resource.",
            1 => "1 startup dependency is configured for this resource.",
            _ => $"{DependencyRows.Count} startup dependencies are configured for this resource."
        };

    private string GetCapabilityOperationSummary() =>
        $"{Resource?.ResourceCapabilities.Count ?? 0} capabilities and {Resource?.ResourceActions.Count ?? 0} operations are available.";

    private string GetServiceDiscoveryName()
    {
        if (Resource is null)
        {
            return "Not configured";
        }

        foreach (var attributeName in ServiceDiscoveryAttributeNames)
        {
            if (Resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
                !string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "Not configured";
    }

    private static string FormatResourceTimestamp(DateTimeOffset timestamp) =>
        timestamp != default &&
        timestamp != DateTimeOffset.MinValue &&
        timestamp != DateTimeOffset.UnixEpoch
            ? timestamp.ToLocalTime().ToString("g")
            : "Not reported";

    private static string FormatResourceState(ResourceState? state) =>
        state switch
        {
            ResourceState.Running => "Running",
            ResourceState.Stopped => "Stopped",
            ResourceState.Starting => "Starting",
            ResourceState.Stopping => "Stopping",
            ResourceState.Paused => "Paused",
            ResourceState.Degraded => "Needs attention",
            ResourceState.Unknown => "Unknown",
            null => "Not reported",
            _ => "Unknown"
        };

    private static string FormatResourceType(Resource resource) =>
        resource.EffectiveTypeId switch
        {
            var type when BuiltInProviderResourceUiTypes.IsExecutableApplication(type) => "Executable application",
            var type when BuiltInProviderResourceUiTypes.IsAspNetCoreProject(type) => "ASP.NET Core project",
            var type when BuiltInProviderResourceUiTypes.IsJavaScriptApp(type) => "JavaScript application",
            var type when BuiltInProviderResourceUiTypes.IsJavaApp(type) => "Java application",
            var type when BuiltInProviderResourceUiTypes.IsGoApp(type) => "Go application",
            var type when BuiltInProviderResourceUiTypes.IsPythonApp(type) => "Python application",
            var type when BuiltInProviderResourceUiTypes.IsContainerApplication(type) => "Container app",
            var type when BuiltInProviderResourceUiTypes.IsSqlServer(type) => "SQL Server",
            var type when BuiltInProviderResourceUiTypes.IsRabbitMQ(type) => "RabbitMQ broker",
            _ => resource.EffectiveTypeId
        };

    private static string FormatResourceSource(ResourceSource source) =>
        source switch
        {
            ResourceSource.User => "User-created",
            ResourceSource.Provider => "Provider-created",
            ResourceSource.Orchestrator => "Orchestrator-created",
            ResourceSource.RuntimeController => "Runtime-created",
            _ => "Unknown"
        };

    private static string FormatManagementMode(ResourceManagementMode mode) =>
        mode switch
        {
            ResourceManagementMode.UserManaged => "User-managed",
            ResourceManagementMode.ProviderManaged => "Provider-managed",
            ResourceManagementMode.OrchestratorManaged => "Orchestrator-managed",
            ResourceManagementMode.RuntimeManaged => "Runtime-managed",
            _ => "Unknown"
        };

    private static string FormatResourceClass(ResourceClass resourceClass) =>
        resourceClass switch
        {
            ResourceClass.Generic => "Generic",
            ResourceClass.Executable => "Executable",
            ResourceClass.Project => "Project",
            ResourceClass.Container => "Container",
            ResourceClass.Service => "Service",
            ResourceClass.Network => "Network",
            ResourceClass.Storage => "Storage",
            ResourceClass.Configuration => "Configuration",
            ResourceClass.Infrastructure => "Infrastructure",
            ResourceClass.SecretsVault => "Secrets vault",
            _ => "Unknown"
        };

    private static string FormatResourceVisibility(ResourceVisibility visibility) =>
        visibility switch
        {
            ResourceVisibility.Normal => "Visible",
            ResourceVisibility.Hidden => "Hidden",
            ResourceVisibility.Diagnostic => "Diagnostic",
            _ => "Unknown"
        };

    private static string FormatResourceGraphMembership(string membership) =>
        membership switch
        {
            ResourceGraphMembershipKinds.Declared => "Declared resource",
            ResourceGraphMembershipKinds.Projected => "Generated resource",
            _ => "Other"
        };

    private static string FormatCapabilityLabel(string capabilityId) =>
        capabilityId switch
        {
            HealthChecksCapabilityId => "Health checks",
            ResourceCapabilityIds.Liveness => "Liveness checks",
            ResourceCapabilityIds.Recovery => "Recovery policy",
            ResourceCapabilityIds.EndpointSource => "Endpoint source",
            ResourceCapabilityIds.ContainerHost => "Container host",
            ResourceCapabilityIds.EnvironmentVariables => "Environment variables",
            ResourceCapabilityIds.LogSources => "Log sources",
            ResourceCapabilityIds.Monitoring => "Monitoring",
            ResourceCapabilityIds.NetworkingProvider => "Networking provider",
            ResourceCapabilityIds.NetworkingEndpointProvider => "Endpoint provider",
            ResourceCapabilityIds.NetworkingEndpointMapper => "Endpoint mapping",
            ResourceCapabilityIds.NetworkingHostNetwork => "Host network",
            ResourceCapabilityIds.NetworkingVirtualNetwork => "Virtual network",
            ResourceCapabilityIds.NetworkingIngress => "Ingress",
            ResourceCapabilityIds.NetworkingGateway => "Gateway",
            ResourceCapabilityIds.NetworkingLoadBalancer => "Load balancer",
            ResourceCapabilityIds.NetworkingBackendPool => "Backend pool",
            ResourceCapabilityIds.NetworkingCluster => "Network cluster",
            ResourceCapabilityIds.NetworkingClusterNode => "Network node",
            ResourceCapabilityIds.NetworkingHealthProbe => "Health probe",
            ResourceCapabilityIds.NetworkingTrafficSplit => "Traffic split",
            ResourceCapabilityIds.NetworkingServiceDiscovery => "Service discovery",
            ResourceCapabilityIds.NetworkingDnsZone => "DNS zone",
            ResourceCapabilityIds.NetworkingNameMapping => "Name mapping",
            ResourceCapabilityIds.NetworkingNamePublisher => "Name publisher",
            ResourceCapabilityIds.NetworkingNameResolver => "Name resolver",
            ResourceCapabilityIds.NetworkingPolicy => "Network policy",
            ResourceCapabilityIds.NetworkingEgress => "Egress",
            ResourceCapabilityIds.NetworkingTls => "TLS",
            ResourceCapabilityIds.StorageVolume => "Storage volume",
            ResourceCapabilityIds.StorageProvider => "Storage provider",
            ResourceCapabilityIds.StorageVolumeConsumer => "Storage volume consumer",
            ResourceCapabilityIds.StorageMountProvider => "Storage mount provider",
            _ => capabilityId
        };

    private const string HealthChecksCapabilityId = "health.checks";

    private static string FormatActionLabel(ResourceAction action) =>
        action.Id switch
        {
            "application.sql-server.reconcile-access" => "Reconcile access",
            "application.rabbitmq.reconcile-access" => "Reconcile access",
            "applyLoadBalancerConfiguration" => "Apply configuration",
            _ when !string.IsNullOrWhiteSpace(action.DisplayName) => action.DisplayName,
            _ => action.Id
        };

    private static string FormatList(IEnumerable<string> values)
    {
        var items = values
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return items.Length == 0
            ? "None"
            : string.Join(", ", items);
    }

    private static int CountEnvironmentVariables(Resource resource)
    {
        var names = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var root in EnvironmentAttributeRoots)
        {
            AddObjectEnvironmentVariableNames(resource, root, names);
            AddFlattenedEnvironmentVariableNames(resource, root, names);
        }

        return names.Count;
    }

    private static void AddObjectEnvironmentVariableNames(
        Resource resource,
        string attributeRoot,
        HashSet<string> names)
    {
        if (!resource.ResourceAttributes.TryGetValue(attributeRoot, out var serialized) ||
            string.IsNullOrWhiteSpace(serialized))
        {
            return;
        }

        try
        {
            using var document = JsonDocument.Parse(serialized);
            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return;
            }

            foreach (var property in document.RootElement.EnumerateObject())
            {
                names.Add(property.Name);
            }
        }
        catch (JsonException)
        {
            names.Add(attributeRoot);
        }
    }

    private static void AddFlattenedEnvironmentVariableNames(
        Resource resource,
        string attributeRoot,
        HashSet<string> names)
    {
        var prefix = attributeRoot + ".";
        foreach (var attribute in resource.ResourceAttributes)
        {
            if (!attribute.Key.StartsWith(prefix, StringComparison.Ordinal))
            {
                continue;
            }

            var path = attribute.Key[prefix.Length..];
            foreach (var suffix in new[] { ".value", ".configurationSettingRef.", ".secretRef." })
            {
                var index = path.IndexOf(suffix, StringComparison.Ordinal);
                if (index > 0)
                {
                    names.Add(path[..index]);
                    break;
                }
            }
        }
    }

    private async Task<IReadOnlyList<ResourceDependencyRow>> CreateDependencyRowsAsync(Resource resource)
    {
        var dependencyIds = resource.DependsOn
            .Where(dependency => !string.IsNullOrWhiteSpace(dependency))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (dependencyIds.Length == 0)
        {
            return [];
        }

        var resourcesById = (await ResourceManager.ListResourcesAsync())
            .ToDictionary(candidate => candidate.Id, StringComparer.OrdinalIgnoreCase);
        return dependencyIds
            .Select(dependencyId =>
            {
                resourcesById.TryGetValue(dependencyId, out var dependency);
                var label = dependency is null
                    ? $"{ResourceDisplayLabels.GetName(dependencyId)} (unavailable)"
                    : ResourceDisplayLabels.GetQualifiedLabel(dependency);
                return new ResourceDependencyRow(dependencyId, label, dependency);
            })
            .OrderBy(row => row.Label, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.ResourceId, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private sealed record ResourceDependencyRow(string ResourceId, string Label, Resource? Resource);
}
