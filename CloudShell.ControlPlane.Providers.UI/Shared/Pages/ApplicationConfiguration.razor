@using System.Text.Json
@inject IResourceManager ResourceManager

@if (Resource is null)
{
    <EmptyState Title="Configuration is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Configuration</h3>
                <p>Resource configuration and management details available to CloudShell.</p>
            </div>
        </div>
        <dl class="detail-list">
            <dt>Name</dt>
            <dd>@Resource.Name</dd>
            <dt>Display name</dt>
            <dd>@Resource.EffectiveDisplayName</dd>
            <dt>Type</dt>
            <dd>@Resource.EffectiveTypeId</dd>
            <dt>Provider</dt>
            <dd>@Resource.Provider</dd>
            <dt>State</dt>
            <dd>@(Resource.State?.ToString() ?? "n/a")</dd>
            <dt>Source</dt>
            <dd>@Resource.Source</dd>
            <dt>Management mode</dt>
            <dd>@Resource.ManagementMode</dd>
            <dt>Service discovery</dt>
            <dd>@GetServiceDiscoveryName()</dd>
            <dt>Environment variables</dt>
            <dd>@GetEnvironmentSummary()</dd>
            <dt>Startup dependencies</dt>
            <dd>@GetDependencySummary()</dd>
            <dt>Last updated</dt>
            <dd>@FormatResourceTimestamp(Resource.LastUpdated)</dd>
        </dl>
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Resource diagnostics</h3>
                <p>Stable identifiers and graph metadata for troubleshooting.</p>
            </div>
        </div>
        <dl class="detail-list">
            <dt>Resource ID</dt>
            <dd>@Resource.Id</dd>
            <dt>Class</dt>
            <dd>@Resource.ResourceClass</dd>
            <dt>Visibility</dt>
            <dd>@Resource.Visibility</dd>
            <dt>Resource membership</dt>
            <dd>@Resource.ResourceGraphMembership</dd>
            <dt>Resource version</dt>
            <dd>@Resource.Version</dd>
        </dl>
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Capabilities and operations</h3>
                <p>@GetCapabilityOperationSummary()</p>
            </div>
        </div>
        <div class="generated-list">
            <div>
                <strong>Capabilities</strong>
                <span>@FormatList(Resource.ResourceCapabilities.Select(capability => capability.Id))</span>
            </div>
            <div>
                <strong>Operations</strong>
                <span>@FormatList(Resource.ResourceActions.Select(action => action.Id))</span>
            </div>
            @if (Resource.DependsOn.Count > 0)
            {
                <div>
                    <strong>Startup dependencies</strong>
                    @foreach (var dependency in DependencyRows)
                    {
                        @if (dependency.Resource is null)
                        {
                            <span>@dependency.Label</span>
                        }
                        else
                        {
                            <FluentAnchor Href="@ResourceManagerRoutes.ResourceDetails(dependency.ResourceId)">
                                @dependency.Label
                            </FluentAnchor>
                        }
                    }
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<ResourceDependencyRow> DependencyRows { get; set; } = [];
    private static readonly string[] EnvironmentAttributeRoots =
    [
        AspNetCoreProjectResourceTypeProvider.Attributes.EnvironmentVariables.ToString(),
        JavaScriptAppResourceTypeProvider.Attributes.EnvironmentVariables.ToString(),
        JavaAppResourceTypeProvider.Attributes.EnvironmentVariables.ToString(),
        GoAppResourceTypeProvider.Attributes.EnvironmentVariables.ToString(),
        PythonAppResourceTypeProvider.Attributes.EnvironmentVariables.ToString()
    ];

    private static readonly string[] ServiceDiscoveryAttributeNames =
    [
        AspNetCoreProjectResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        JavaScriptAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        JavaAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        GoAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString(),
        PythonAppResourceTypeProvider.Attributes.ServiceDiscoveryName.ToString()
    ];

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        DependencyRows = Resource is null
            ? []
            : await CreateDependencyRowsAsync(Resource);
    }

    private string GetEnvironmentSummary()
    {
        if (Resource is null)
        {
            return "No environment variables are declared.";
        }

        var count = CountEnvironmentVariables(Resource);
        return count == 1
            ? "1 environment variable is declared for this resource."
            : $"{count} environment variables are declared for this resource.";
    }

    private string GetDependencySummary() =>
        DependencyRows.Count == 1
            ? "1 startup dependency is declared for this resource."
            : $"{DependencyRows.Count} startup dependencies are declared for this resource.";

    private string GetCapabilityOperationSummary() =>
        $"{Resource?.ResourceCapabilities.Count ?? 0} capabilities and {Resource?.ResourceActions.Count ?? 0} operations are available.";

    private string GetServiceDiscoveryName()
    {
        if (Resource is null)
        {
            return "not declared";
        }

        foreach (var attributeName in ServiceDiscoveryAttributeNames)
        {
            if (Resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
                !string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "not declared";
    }

    private static string FormatResourceTimestamp(DateTimeOffset timestamp) =>
        timestamp != default &&
        timestamp != DateTimeOffset.MinValue &&
        timestamp != DateTimeOffset.UnixEpoch
            ? timestamp.ToLocalTime().ToString("g")
            : "not observed";

    private static string FormatList(IEnumerable<string> values)
    {
        var items = values
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return items.Length == 0
            ? "none"
            : string.Join(", ", items);
    }

    private static int CountEnvironmentVariables(Resource resource)
    {
        var names = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var root in EnvironmentAttributeRoots)
        {
            AddObjectEnvironmentVariableNames(resource, root, names);
            AddFlattenedEnvironmentVariableNames(resource, root, names);
        }

        return names.Count;
    }

    private static void AddObjectEnvironmentVariableNames(
        Resource resource,
        string attributeRoot,
        HashSet<string> names)
    {
        if (!resource.ResourceAttributes.TryGetValue(attributeRoot, out var serialized) ||
            string.IsNullOrWhiteSpace(serialized))
        {
            return;
        }

        try
        {
            using var document = JsonDocument.Parse(serialized);
            if (document.RootElement.ValueKind != JsonValueKind.Object)
            {
                return;
            }

            foreach (var property in document.RootElement.EnumerateObject())
            {
                names.Add(property.Name);
            }
        }
        catch (JsonException)
        {
            names.Add(attributeRoot);
        }
    }

    private static void AddFlattenedEnvironmentVariableNames(
        Resource resource,
        string attributeRoot,
        HashSet<string> names)
    {
        var prefix = attributeRoot + ".";
        foreach (var attribute in resource.ResourceAttributes)
        {
            if (!attribute.Key.StartsWith(prefix, StringComparison.Ordinal))
            {
                continue;
            }

            var path = attribute.Key[prefix.Length..];
            foreach (var suffix in new[] { ".value", ".configurationSettingRef.", ".secretRef." })
            {
                var index = path.IndexOf(suffix, StringComparison.Ordinal);
                if (index > 0)
                {
                    names.Add(path[..index]);
                    break;
                }
            }
        }
    }

    private async Task<IReadOnlyList<ResourceDependencyRow>> CreateDependencyRowsAsync(Resource resource)
    {
        var dependencyIds = resource.DependsOn
            .Where(dependency => !string.IsNullOrWhiteSpace(dependency))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (dependencyIds.Length == 0)
        {
            return [];
        }

        var resourcesById = (await ResourceManager.ListResourcesAsync())
            .ToDictionary(candidate => candidate.Id, StringComparer.OrdinalIgnoreCase);
        return dependencyIds
            .Select(dependencyId =>
            {
                resourcesById.TryGetValue(dependencyId, out var dependency);
                var label = dependency is null
                    ? $"{ResourceDisplayLabels.GetName(dependencyId)} (unavailable)"
                    : ResourceDisplayLabels.GetQualifiedLabel(dependency);
                return new ResourceDependencyRow(dependencyId, label, dependency);
            })
            .OrderBy(row => row.Label, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.ResourceId, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private sealed record ResourceDependencyRow(string ResourceId, string Label, Resource? Resource);
}
