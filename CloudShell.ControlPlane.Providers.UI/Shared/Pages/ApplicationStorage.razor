@inject IResourceManager ResourceManager
@inject IResourceOrchestrationCatalog OrchestrationCatalog

@if (Application is null)
{
    <EmptyState Title="Storage is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (!BuiltInProviderResourceUiTypes.IsApplicationResource(Application.EffectiveTypeId))
{
    <EmptyState Title="Storage is not supported"
                Message="This resource type does not expose application storage." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Storage</h3>
                <p>@GetSummaryMessage()</p>
            </div>
            <FluentButton Appearance="Appearance.Neutral"
                          IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          Disabled="@IsLoading"
                          OnClick="RefreshAsync">
                @(IsLoading ? "Refreshing" : "Refresh")
            </FluentButton>
        </div>

        @if (StorageMounts.Count > 0)
        {
            @if (StorageMounts.Any(mount => !mount.HasProjectedMount))
            {
                <ProcedureMessage Compact="true">
                    One or more attached volumes do not expose mount target details yet. Materialization status is shown from the application resource when available.
                </ProcedureMessage>
            }
            <ResourceTable AriaLabel="Application volume mounts">
                <thead>
                    <tr>
                        <th>Volume</th>
                        <th>Mount</th>
                        <th>Access</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mount in StorageMounts)
                    {
                        <tr>
                            <td>@VolumeReference(mount)</td>
                            <td>@mount.Mount</td>
                            <td>@mount.Access</td>
                            <td>@mount.Status</td>
                        </tr>
                    }
                </tbody>
            </ResourceTable>
        }
        else
        {
            <EmptyState Title="No mounted storage"
                        Message="No volume mounts or volume dependencies are projected for this resource." />
        }
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Application { get; set; }
    private IReadOnlyDictionary<string, Resource> ResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<ApplicationStorageMountView> StorageMounts { get; set; } = [];
    private IReadOnlyList<Resource> VolumeDependencies { get; set; } = [];
    private bool IsLoading { get; set; }

    protected override Task OnParametersSetAsync() => RefreshAsync();

    private async Task RefreshAsync()
    {
        if (IsLoading)
        {
            return;
        }

        IsLoading = true;
        try
        {
            Application = string.IsNullOrWhiteSpace(ResourceId)
                ? null
                : await ResourceManager.GetResourceAsync(ResourceId);
            if (Application is null ||
                !BuiltInProviderResourceUiTypes.IsApplicationResource(Application.EffectiveTypeId))
            {
                StorageMounts = [];
                VolumeDependencies = [];
                ResourcesById = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
                return;
            }

            var resources = await ResourceManager.ListResourcesAsync();
            ResourcesById = resources.ToDictionary(
                resource => resource.Id,
                StringComparer.OrdinalIgnoreCase);

            var orchestration = await OrchestrationCatalog.GetSnapshotAsync();
            var volumeMounts = orchestration.Workloads.TryGetValue(Application.Id, out var workload)
                ? workload.WorkloadVolumeMounts
                    .OrderBy(mount => mount.NormalizedTargetPath, StringComparer.OrdinalIgnoreCase)
                    .ToArray()
                : [];

            VolumeDependencies = Application.DependsOn
                .Select(dependency => ResourcesById.GetValueOrDefault(dependency))
                .Where(resource => resource is not null)
                .Cast<Resource>()
                .Where(BuiltInProviderResourceUiTypes.IsVolumeResource)
                .OrderBy(resource => ResourceDisplayLabels.GetLabel(resource), StringComparer.OrdinalIgnoreCase)
                .ToArray();

            StorageMounts = CreateStorageMountRows(volumeMounts, VolumeDependencies);
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetSummaryMessage()
    {
        if (StorageMounts.Count > 0)
        {
            var projectedCount = StorageMounts.Count(mount => mount.HasProjectedMount);
            if (projectedCount == StorageMounts.Count)
            {
                return StorageMounts.Count == 1
                    ? "1 volume mount is projected from the runtime workload descriptor."
                    : $"{StorageMounts.Count} volume mounts are projected from the runtime workload descriptor.";
            }

            return StorageMounts.Count == 1
                ? "1 attached volume is declared for this resource; mount target details are not available yet."
                : $"{StorageMounts.Count} attached volumes are declared for this resource; {StorageMounts.Count - projectedCount} do not expose mount target details yet.";
        }

        if (VolumeDependencies.Count > 0)
        {
            return VolumeDependencies.Count == 1
                ? "1 volume dependency is declared for this resource."
                : $"{VolumeDependencies.Count} volume dependencies are declared for this resource.";
        }

        return "No mounted storage is projected for this application resource.";
    }

    private IReadOnlyList<ApplicationStorageMountView> CreateStorageMountRows(
        IReadOnlyList<ResourceVolumeMount> projectedMounts,
        IReadOnlyList<Resource> declaredVolumes)
    {
        var rows = new List<ApplicationStorageMountView>();
        var projectedVolumeReferences = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var materialization = GetMountMaterializationLabel();

        foreach (var mount in projectedMounts)
        {
            projectedVolumeReferences.Add(mount.NormalizedVolumeReference);
            rows.Add(new(
                mount.NormalizedVolumeReference,
                ResourcesById.GetValueOrDefault(mount.NormalizedVolumeReference),
                mount.NormalizedTargetPath,
                mount.ReadOnly ? "Read-only" : "Read/write",
                materialization,
                HasProjectedMount: true));
        }

        foreach (var volume in declaredVolumes)
        {
            if (projectedVolumeReferences.Contains(volume.Id))
            {
                continue;
            }

            rows.Add(new(
                volume.Id,
                volume,
                "mount target unavailable",
                "declared dependency",
                materialization,
                HasProjectedMount: false));
        }

        return rows
            .OrderBy(row => ResourceDisplayLabels.GetLabel(row.Volume, row.VolumeReference), StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.Mount, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private RenderFragment VolumeReference(ApplicationStorageMountView mount) => builder =>
    {
        if (mount.Volume is { } volume)
        {
            builder.OpenElement(0, "a");
            builder.AddAttribute(1, "class", "resource-link");
            builder.AddAttribute(2, "href", ResourceManagerRoutes.ResourceDetails(volume.Id));
            builder.AddContent(3, ResourceDisplayLabels.GetLabel(volume));
            builder.CloseElement();
            return;
        }

        builder.AddContent(4, mount.VolumeReference);
    };

    private string GetMountMaterializationLabel() =>
        Application is not null &&
        ResourceVolumeMountDisplay.GetMaterializationSummary(Application) is { } materialization
            ? materialization
            : "declared";

    private sealed record ApplicationStorageMountView(
        string VolumeReference,
        Resource? Volume,
        string Mount,
        string Access,
        string Status,
        bool HasProjectedMount);
}
