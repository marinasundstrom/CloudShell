@using System.Globalization
@inject IResourceManager ResourceManager

@if (Server is null)
{
    <EmptyState Title="SQL Server is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (!BuiltInProviderResourceUiTypes.IsSqlServer(Server.EffectiveTypeId))
{
    <EmptyState Title="Databases are not supported"
                Message="This resource type does not expose SQL Server databases." />
}
else
{
    <div class="blade-section-header">
        <div>
            <h3>Databases</h3>
            <p>@GetSummaryMessage()</p>
        </div>
        <FluentButton Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      Disabled="@IsLoading"
                      OnClick="RefreshDatabasesAsync">
            @(IsLoading ? "Refreshing" : "Refresh")
        </FluentButton>
    </div>

    @if (IsLoading)
    {
        <EmptyState Title="Loading databases"
                    Message="CloudShell is loading databases attached to this SQL Server resource." />
    }
    else if (DatabaseRows.Count == 0)
    {
        <EmptyState Title="No databases"
                    Message="No databases are attached to this SQL Server resource." />
    }
    else
    {
        <ResourceTable AriaLabel="SQL Server databases">
            <thead>
                <tr>
                    <th>Database</th>
                    <th>Provisioning</th>
                    <th>State</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var database in DatabaseRows)
                {
                    <tr>
                        <td>
                            <ResourceTableIdentity IconName="database-item"
                                                   IconTitle="Database"
                                                   Summary="@database.ResourceId">
                                <TitleContent>
                                    <FluentAnchor Href="@ResourceManagerRoutes.ResourceDetails(database.ResourceId)">
                                        @database.Label
                                    </FluentAnchor>
                                </TitleContent>
                            </ResourceTableIdentity>
                        </td>
                        <td>@FormatProvisioning(database.Source, database.EnsureCreated)</td>
                        <td>@FormatState(database.Resource.State)</td>
                    </tr>
                }
            </tbody>
        </ResourceTable>
    }
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Server { get; set; }
    private IReadOnlyList<SqlDatabaseRow> DatabaseRows { get; set; } = [];
    private bool IsLoading { get; set; }

    protected override Task OnParametersSetAsync() => RefreshDatabasesAsync();

    private async Task RefreshDatabasesAsync()
    {
        if (IsLoading)
        {
            return;
        }

        IsLoading = true;
        try
        {
            Server = string.IsNullOrWhiteSpace(ResourceId)
                ? null
                : await ResourceManager.GetResourceAsync(ResourceId);

            if (Server is null ||
                !BuiltInProviderResourceUiTypes.IsSqlServer(Server.EffectiveTypeId))
            {
                DatabaseRows = [];
                return;
            }

            var childDatabases = await ResourceManager.ListResourceChildrenAsync(Server.Id);
            var visibleDatabases = await ResourceManager.ListResourcesAsync(
                new ResourceQuery(ResourceType: SqlDatabaseResourceTypeProvider.ResourceTypeId.ToString()));

            DatabaseRows = childDatabases
                .Concat(visibleDatabases)
            .Where(resource => BuiltInProviderResourceUiTypes.IsSqlDatabase(resource.EffectiveTypeId))
            .Where(resource => IsDatabaseForServer(resource, Server.Id))
            .GroupBy(resource => resource.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => CreateRow(group.First()))
            .OrderBy(row => row.Label, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.QualifiedLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string GetSummaryMessage()
    {
        var count = DatabaseRows.Count.ToString(CultureInfo.InvariantCulture);
        return DatabaseRows.Count switch
        {
            0 => "No databases are attached to this SQL Server resource.",
            1 => "1 database is attached to this SQL Server resource.",
            _ => $"{count} databases are attached to this SQL Server resource."
        };
    }

    private static bool IsDatabaseForServer(Resource database, string serverResourceId) =>
        string.Equals(database.ParentResourceId, serverResourceId, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(database.OwnerResourceId, serverResourceId, StringComparison.OrdinalIgnoreCase) ||
        database.DependsOn.Any(dependency =>
            string.Equals(dependency, serverResourceId, StringComparison.OrdinalIgnoreCase));

    private static SqlDatabaseRow CreateRow(Resource resource)
    {
        var databaseName = GetAttribute(
            resource,
            SqlDatabaseResourceTypeProvider.Attributes.DatabaseName.ToString(),
            resource.Name);
        var source = GetAttribute(
            resource,
            SqlDatabaseResourceTypeProvider.Attributes.Source.ToString(),
            "configured");
        var ensureCreated = TryGetBoolean(
            resource,
            SqlDatabaseResourceTypeProvider.Attributes.EnsureCreated.ToString());

        return new SqlDatabaseRow(
            resource,
            databaseName,
            ensureCreated,
            source);
    }

    private static string GetAttribute(
        Resource resource,
        string attributeName,
        string fallback) =>
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static bool? TryGetBoolean(Resource resource, string attributeName) =>
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        bool.TryParse(value, out var parsed)
            ? parsed
            : null;

    private static string FormatProvisioning(string source, bool? ensureCreated)
    {
        var normalizedSource = source.Trim().ToLowerInvariant();
        if (normalizedSource == "imported")
        {
            return "Imported; creation not managed";
        }

        if (normalizedSource == "provider")
        {
            return "Provider-created";
        }

        return ensureCreated switch
        {
            true => "Ensured by CloudShell",
            false => "Declared; creation not managed",
            _ => "Creation policy not configured"
        };
    }

    private static string FormatState(Abstractions.ResourceManager.ResourceState? state) =>
        state switch
        {
            Abstractions.ResourceManager.ResourceState.Running => "Running",
            Abstractions.ResourceManager.ResourceState.Starting => "Starting",
            Abstractions.ResourceManager.ResourceState.Stopping => "Stopping",
            Abstractions.ResourceManager.ResourceState.Paused => "Paused",
            Abstractions.ResourceManager.ResourceState.Degraded => "Needs attention",
            Abstractions.ResourceManager.ResourceState.Stopped => "Stopped",
            Abstractions.ResourceManager.ResourceState.Unknown => "Unknown",
            null => "Not reported",
            _ => "Unknown"
        };

    private sealed record SqlDatabaseRow(
        Resource Resource,
        string Label,
        bool? EnsureCreated,
        string Source)
    {
        public string ResourceId => Resource.Id;
        public string QualifiedLabel => ResourceDisplayLabels.GetQualifiedLabel(Resource);
    }
}
