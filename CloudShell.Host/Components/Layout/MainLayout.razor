@inherits LayoutComponentBase
@inject ShellCatalog ShellCatalog
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L

<div class="shell">
    <aside class="shell-sidebar">
        <div class="brand">
            <div class="brand-mark">CS</div>
            <div class="brand-text">
                <div class="brand-name">CloudShell</div>
                <div class="brand-subtitle">@L["Platform control plane"]</div>
            </div>
            <button type="button"
                    class="nav-toggle"
                    title="@L["Toggle navigation"]"
                    aria-label="@L["Toggle navigation"]"
                    aria-expanded="true"
                    data-nav-toggle>
                <span class="nav-toggle-icon" aria-hidden="true"></span>
            </button>
        </div>

        <NavMenu />

        <div class="sidebar-footer">
            <span class="status-dot"></span>
            <span class="sidebar-footer-text">@L["Local workspace"]</span>
        </div>
    </aside>

    <main class="shell-main">
        <header class="shell-topbar">
            <div class="environment-picker">
                <span class="eyebrow">@L["Environment"]</span>
                <strong>@L["Development"]</strong>
            </div>
            <div class="command-surface">
                <LanguageSelector />
                <FluentButton Appearance="Appearance.Neutral">@L["Refresh"]</FluentButton>
                @if (Authorization.HasPermission(CloudShellPermissions.Resources.Create))
                {
                    <FluentButton Appearance="Appearance.Accent" Href="/resources/add">
                        @L["New resource"]
                    </FluentButton>
                }
                <AuthorizeView>
                    <Authorized Context="authentication">
                        <span class="signed-in-user">
                            @(authentication.User.Identity?.Name ?? L["Authenticated user"])
                        </span>
                        <a href="/account/logout">@L["Sign out"]</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <article class="shell-content">
            @Body
        </article>
    </main>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

<div id="blazor-error-ui" data-nosnippet>
    @L["An unhandled error has occurred."]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">x</span>
</div>
