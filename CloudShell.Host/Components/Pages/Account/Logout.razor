@page "/account/logout"
@layout AccountLayout
@inject CloudShellAccountService Accounts
@inject NavigationManager Navigation

<PageTitle>Sign out</PageTitle>

<div class="account-heading">
    <span class="eyebrow">Authentication</span>
    <h1>Sign out</h1>
    <p>End the current CloudShell session.</p>
</div>

<EditForm Model="@Input"
          method="post"
          OnValidSubmit="SignOut"
          FormName="logout"
          Enhance="false">
    <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit">
        Sign out
    </FluentButton>
    <FluentButton Appearance="Appearance.Neutral" Href="/">
        Cancel
    </FluentButton>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private LogoutInput? Input { get; set; }

    protected override void OnInitialized()
    {
        Input ??= new LogoutInput();
    }

    private async Task SignOut()
    {
        await Accounts.SignOutAsync();
        Navigation.NavigateTo("/account/login", forceLoad: true);
    }

    private sealed class LogoutInput;
}
