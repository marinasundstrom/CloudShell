@inject IStringLocalizer<SharedResource> L

<div class="click-me-counter">
    <div>
        <span class="eyebrow">@L["Shell view component"]</span>
        <h2>@L["Click counter"]</h2>
        <p>@L["This component is hosted by a CloudShell view contribution."]</p>
    </div>

    <div class="click-me-value" aria-live="polite">
        <span>@L["Current count"]</span>
        <strong>@CurrentCount</strong>
    </div>

    <FluentButton Appearance="Appearance.Accent" OnClick="IncrementCount">
        @L["Click me"]
    </FluentButton>
</div>

@code {
    private int CurrentCount { get; set; }

    private void IncrementCount() => CurrentCount++;
}
