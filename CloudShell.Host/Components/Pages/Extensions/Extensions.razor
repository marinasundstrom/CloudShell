@page "/extensions"
@inject ShellCatalog ShellCatalog
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Extensions"]</PageTitle>

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Platform"]</span>
        <h1>@L["Extensions"]</h1>
        <p>@L["Shell extensions registered through the service container. Extensions can add views, services, and resource types."]</p>
    </div>
    <div class="heading-actions">
        <FluentButton Appearance="Appearance.Neutral">@L["Reload"]</FluentButton>
        <FluentButton Appearance="Appearance.Accent">@L["Install"]</FluentButton>
    </div>
</section>

<section class="dashboard-grid">
    <article class="panel panel-wide">
        <div class="panel-header">
            <div>
                <h2>@L["Shell extensions"]</h2>
                <p>@L["{0} registered extensions", ShellCatalog.Extensions.Count]</p>
            </div>
        </div>

        <div class="extension-grid">
            @foreach (var extension in ShellCatalog.Extensions)
            {
                <div class="extension-card">
                    <div>
                        <strong>@extension.DisplayName</strong>
                        <span>@extension.Id · v@(extension.Version)</span>
                    </div>
                    <p>@extension.Description</p>
                    <div class="tag-row">
                        @foreach (var capability in extension.Provides)
                        {
                            <span>@capability</span>
                        }
                    </div>
                    @if (extension.Views.Any(view => view.ShowInNavigation) ||
                        extension.CustomViews.Any(view => view.ShowInNavigation))
                    {
                        <div class="extension-views">
                            @foreach (var view in extension.Views.Where(view => view.ShowInNavigation))
                            {
                                <a href="@view.Route">@L[view.Title]</a>
                            }
                            @foreach (var view in extension.CustomViews.Where(view => view.ShowInNavigation))
                            {
                                <a href="@view.Route">@L[view.Title]</a>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>@L["Resource types"]</h2>
                <p>@L["{0} available", ShellCatalog.ResourceTypes.Count]</p>
            </div>
        </div>

        <div class="provider-list">
            @foreach (var resourceType in ShellCatalog.ResourceTypes)
            {
                <div class="provider-row">
                    <div>
                        <strong>@resourceType.DisplayName</strong>
                        <span>@resourceType.Id</span>
                    </div>
                    <div>
                        <strong>@resourceType.Icon</strong>
                        <span>@L["type"]</span>
                    </div>
                </div>
            }
        </div>
    </article>
</section>
