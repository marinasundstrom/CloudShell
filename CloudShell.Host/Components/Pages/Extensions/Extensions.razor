@page "/extensions"
@rendermode InteractiveServer
@inject ShellCatalog ShellCatalog
@inject ICloudShellExtensionActivationStore ActivationStore
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Extensions"]</PageTitle>

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Platform"]</span>
        <h1>@L["Extensions"]</h1>
        <p>@L["Extensions registered through the service container. Host configuration or this UI can activate their contributions."]</p>
    </div>
    <div class="heading-actions">
        <FluentButton Appearance="Appearance.Neutral">@L["Reload"]</FluentButton>
    </div>
</section>

<section class="dashboard-grid">
    <article class="panel panel-wide">
        <div class="panel-header">
            <div>
                <h2>@L["Shell extensions"]</h2>
                <p>@L["{0} supported extensions", ShellCatalog.SupportedExtensions.Count]</p>
            </div>
        </div>

        <div class="extension-grid">
            @foreach (var status in ShellCatalog.ExtensionStatuses)
            {
                var extension = status.Extension;
                <div class="extension-card">
                    <div>
                        <strong>@extension.DisplayName</strong>
                        <span>@extension.Id · v@(extension.Version)</span>
                    </div>
                    <p>@extension.Description</p>
                    <div class="tag-row">
                        <span>@GetStatusText(status)</span>
                    </div>
                    <div class="tag-row">
                        @foreach (var capability in extension.Provides)
                        {
                            <span>@capability</span>
                        }
                    </div>
                    @if (status.IsActive &&
                        (extension.Views.Any(view => view.ShowInNavigation) ||
                        extension.CustomViews.Any(view => view.ShowInNavigation)))
                    {
                        <div class="extension-views">
                            @foreach (var view in extension.Views.Where(view => view.ShowInNavigation))
                            {
                                <a href="@view.Route">@L[view.Title]</a>
                            }
                            @foreach (var view in extension.CustomViews.Where(view => view.ShowInNavigation))
                            {
                                <a href="@view.Route">@L[view.Title]</a>
                            }
                        </div>
                    }
                    <div class="heading-actions">
                        @if (status.IsUserManaged)
                        {
                            <FluentButton Appearance="@(status.IsActive ? Appearance.Neutral : Appearance.Accent)"
                                          OnClick="() => ToggleExtensionAsync(status)">
                                @(status.IsActive ? L["Disable"] : L["Enable"])
                            </FluentButton>
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Neutral" Disabled="true">
                                @L["Managed by host"]
                            </FluentButton>
                        }
                    </div>
                </div>
            }
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>@L["Resource types"]</h2>
                <p>@L["{0} available", ShellCatalog.ResourceTypes.Count]</p>
            </div>
        </div>

        <div class="provider-list">
            @foreach (var resourceType in ShellCatalog.ResourceTypes)
            {
                <div class="provider-row">
                    <div>
                        <strong>@resourceType.DisplayName</strong>
                        <span>@resourceType.Id</span>
                    </div>
                    <div>
                        <strong>@resourceType.Icon</strong>
                        <span>@L["type"]</span>
                    </div>
                </div>
            }
        </div>
    </article>
</section>

@code {
    private async Task ToggleExtensionAsync(CloudShellExtensionStatus status)
    {
        if (!status.IsUserManaged)
        {
            return;
        }

        var state = status.IsActive
            ? CloudShellExtensionActivationState.Disabled
            : CloudShellExtensionActivationState.Enabled;

        await ActivationStore.SetActivationStateAsync(status.Extension.Id, state);
    }

    private string GetStatusText(CloudShellExtensionStatus status) =>
        status.Kind switch
        {
            CloudShellExtensionStatusKind.Enabled => L["Enabled"],
            CloudShellExtensionStatusKind.Disabled => L["Disabled"],
            CloudShellExtensionStatusKind.EnabledByHost => L["Enabled by host configuration"],
            CloudShellExtensionStatusKind.DisabledByHost => L["Disabled by host configuration"],
            CloudShellExtensionStatusKind.Blocked => L[status.Reason ?? "Blocked"],
            _ => status.Kind.ToString()
        };
}
