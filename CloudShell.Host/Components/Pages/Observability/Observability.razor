@page "/observability"
@inject IResourceManagerStore ResourceManager
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Observability"]</PageTitle>

@{
    var resources = ResourceManager.GetResources();
}

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Observability"]</span>
        <h1>@L["Telemetry workspace"]</h1>
        <p>@L["Placeholder surface for logs, traces, metrics, and resource-aware diagnostics."]</p>
    </div>
    <div class="heading-actions">
        <FluentButton Appearance="Appearance.Neutral">@L["Import OTLP"]</FluentButton>
        <FluentButton Appearance="Appearance.Accent">@L["Connect collector"]</FluentButton>
    </div>
</section>

<section class="dashboard-grid">
    <article class="panel panel-wide">
        <div class="panel-header">
            <div>
                <h2>@L["Signal coverage"]</h2>
                <p>@L["Telemetry tabs will bind to resources through Resource Manager."]</p>
            </div>
        </div>

        <div class="signal-grid">
            <div>
                <span>@L["Logs"]</span>
                <strong>@resources.Count(resource => resource.State != ResourceState.Stopped)</strong>
            </div>
            <div>
                <span>@L["Traces"]</span>
                <strong>@resources.Count(resource => resource.Kind.Contains("Service", StringComparison.OrdinalIgnoreCase) || resource.Kind.Contains("App", StringComparison.OrdinalIgnoreCase))</strong>
            </div>
            <div>
                <span>@L["Metrics"]</span>
                <strong>@resources.Count</strong>
            </div>
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>@L["Resource focus"]</h2>
                <p>@L["Current inventory states."]</p>
            </div>
        </div>

        <div class="activity-list">
            @foreach (var resource in resources.Take(8))
            {
                <div class="activity-row">
                    <span class="state-dot @GetStateClass(resource.State)"></span>
                    <div>
                        <strong>@resource.Name</strong>
                        <span>@resource.Kind</span>
                    </div>
                </div>
            }
        </div>
    </article>
</section>

@code {
    private static string GetStateClass(ResourceState state) => state switch
    {
        ResourceState.Running => "state-running",
        ResourceState.Starting => "state-starting",
        ResourceState.Degraded => "state-degraded",
        ResourceState.Stopped => "state-stopped",
        _ => "state-unknown"
    };
}
