@page "/resources"
@rendermode InteractiveServer
@inject IResourceManagerStore ResourceManager
@inject IResourceRegistrationStore Registrations
@inject ILogStore LogStore
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Resources"]</PageTitle>

@{
    var allResources = ResourceManager.GetResources();
    var groups = ResourceManager.GetResourceGroups();
    var rows = BuildRows(allResources);
    var selected = SelectedResource ?? rows.FirstOrDefault()?.Resource;
}

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Resource Manager"]</span>
        <h1>@L["Resources"]</h1>
        <p>@L["Explore registered resources, project groups, endpoints, dependencies, and nested sub-resources."]</p>
    </div>
    <div class="heading-actions">
        <FluentButton Appearance="Appearance.Neutral">@L["Refresh"]</FluentButton>
        @if (Authorization.CanAccessResourceGroup(
            "__new_resource_group",
            CloudShellPermissions.ResourceGroups.Create))
        {
            <FluentButton Appearance="Appearance.Neutral" OnClick="CreateGroup">
                @L["Create group"]
            </FluentButton>
        }
        @if (Authorization.HasPermission(CloudShellPermissions.Resources.Create))
        {
            <FluentButton Appearance="Appearance.Accent" OnClick="AddResource">
                @L["Add resource"]
            </FluentButton>
        }
    </div>
</section>

@if (ProcedureMessage is not null)
{
    <div class="procedure-message">@ProcedureMessage</div>
}

@if (PendingAction is not null)
{
    <div class="procedure-confirmation">
        <strong>@PendingAction.Action.DisplayName @PendingAction.Resource.Name?</strong>
        <span>@GetConfirmationMessage(PendingAction.Resource, PendingAction.Action)</span>
        <div class="form-actions">
            <FluentButton Appearance="Appearance.Neutral" OnClick="CancelResourceAction">
                @L["Cancel"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmResourceAction">
                @PendingAction.Action.DisplayName
            </FluentButton>
        </div>
    </div>
}

<section class="resource-explorer">
    <aside class="resource-scopes">
        <div class="scope-heading">
            <h2>@L["Scope"]</h2>
            <span>@L["{0} resources", allResources.Count]</span>
        </div>

        <button class="scope-item @(SelectedScope is null ? "active" : null)" @onclick="() => SelectScope(null)">
            <span>@L["All resources"]</span>
            <strong>@allResources.Count</strong>
        </button>

        <div class="scope-label">@L["Resource groups"]</div>
        @foreach (var group in groups)
        {
            var count = allResources.Count(resource => GetGroup(resource)?.Id == group.Id);
            <button class="scope-item @(SelectedScope == group.Id ? "active" : null)" @onclick="() => SelectScope(group.Id)">
                <span>@group.Name</span>
                <small>@group.Description</small>
                <strong>@count</strong>
            </button>
        }

        @{
            var ungroupedCount = allResources.Count(resource => GetGroup(resource) is null);
        }
        <button class="scope-item @(SelectedScope == UngroupedScope ? "active" : null)" @onclick="() => SelectScope(UngroupedScope)">
            <span>@L["Ungrouped"]</span>
            <small>@L["Outside a project group"]</small>
            <strong>@ungroupedCount</strong>
        </button>
    </aside>

    <div class="resource-list panel">
        <div class="inventory-toolbar">
            <FluentSearch @bind-Value="Filter" Placeholder="@L["Filter by name or type"]" />
            <div class="toolbar-meta">@L["{0} shown", rows.Count]</div>
        </div>

        <div class="resource-list-header">
            <span>@L["Name"]</span>
            <span>@L["Type"]</span>
            <span>@L["Group"]</span>
            <span>@L["State"]</span>
            <span>@L["Endpoint"]</span>
            <span>@L["Actions"]</span>
        </div>

        <div class="resource-tree" role="treegrid" aria-label="@L["Resources"]">
            @foreach (var row in rows)
            {
                var resource = row.Resource;
                var group = GetGroup(resource);
                <div class="resource-tree-row @(selected?.Id == resource.Id ? "selected" : null)"
                     role="row"
                     @onclick="() => OpenResource(resource)">
                    <div class="resource-name-cell" style="--resource-depth: @row.Depth">
                        @if (row.ChildCount > 0)
                        {
                            <button class="tree-toggle"
                                    title="@L["Toggle sub-resources"]"
                                    @onclick="() => ToggleResource(resource.Id)"
                                    @onclick:stopPropagation="true">
                                @(CollapsedResourceIds.Contains(resource.Id) ? "+" : "-")
                            </button>
                        }
                        else
                        {
                            <span class="tree-spacer"></span>
                        }

                        <span class="resource-kind-icon">@GetResourceGlyph(resource.Kind)</span>
                        <div>
                            @if (resource.DetailRoute is not null)
                            {
                                <a class="resource-link"
                                   href="@resource.DetailRoute"
                                   @onclick:stopPropagation="true">@resource.Name</a>
                            }
                            else
                            {
                                <strong>@resource.Name</strong>
                            }
                            @if (row.ChildCount > 0)
                            {
                                <small>@L["{0} sub-resources", row.ChildCount]</small>
                            }
                        </div>
                    </div>
                    <span>@resource.Kind</span>
                    <span>@(group?.Name ?? L["Ungrouped"])</span>
                    <span><span class="state-pill @GetStateClass(resource.State)">@resource.State</span></span>
                    <span class="endpoint">@resource.PrimaryEndpoint</span>
                    <span class="resource-row-actions" @onclick:stopPropagation="true">
                        @ResourceActionControls(resource)
                    </span>
                </div>
            }

            @if (rows.Count == 0)
            {
                <div class="empty-state">
                    <strong>@L["No resources in this scope"]</strong>
                    <span>@L["Change the scope or filter to view other resources."]</span>
                </div>
            }
        </div>
    </div>

    <aside class="resource-blade panel">
        @if (selected is not null)
        {
            var group = GetGroup(selected);
            var parent = selected.ParentResourceId is null ? null : ResourceManager.GetResource(selected.ParentResourceId);
            var children = ResourceManager.GetChildren(selected.Id);

            @if (parent is not null)
            {
                <button class="parent-link" @onclick="() => SelectResource(parent)">
                    @L["Back to {0}", parent.Name]
                </button>
            }

            <div class="detail-heading">
                <span class="resource-kind-icon large">@GetResourceGlyph(selected.Kind)</span>
                <div>
                    <h2>@selected.Name</h2>
                    <p>@selected.Kind</p>
                </div>
            </div>

            <div class="blade-status">
                <span class="state-dot @GetStateClass(selected.State)"></span>
                <strong>@selected.State</strong>
                <span>@L["Updated {0}", selected.LastUpdated.ToLocalTime().ToString("HH:mm:ss")]</span>
            </div>

            @if (selected.DetailRoute is not null)
            {
                <div class="blade-actions">
                    <FluentButton Appearance="Appearance.Accent" OnClick="() => Navigation.NavigateTo(selected.DetailRoute)">
                        @L["Open resource"]
                    </FluentButton>
                    @ResourceActionControls(selected)
                    @if (CanManage(selected) && HasUpdateProcedure(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => UpdateResource(selected)">
                            @L["Update"]
                        </FluentButton>
                    }
                    @if (CanDelete(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => PromptDelete(selected)">
                            @L["Delete"]
                        </FluentButton>
                    }
                </div>
            }
            else
            {
                <div class="blade-actions">
                    @ResourceActionControls(selected)
                    @if (CanManage(selected) && HasUpdateProcedure(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => UpdateResource(selected)">
                            @L["Update"]
                        </FluentButton>
                    }
                    @if (CanDelete(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => PromptDelete(selected)">
                            @L["Delete"]
                        </FluentButton>
                    }
                </div>
            }

            @if (DeleteConfirmationResourceId == selected.Id)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Delete registration?"]</strong>
                    <span>@L["The provider will commit the delete procedure for this resource."]</span>
                    <div class="form-actions">
                        <FluentButton Appearance="Appearance.Neutral" OnClick="CancelDelete">
                            @L["Cancel"]
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="() => DeleteResource(selected)">
                            @L["Delete"]
                        </FluentButton>
                    </div>
                </div>
            }

            <section class="blade-section">
                <h3>@L["Essentials"]</h3>
                <dl class="detail-list">
                    <dt>@L["Type"]</dt>
                    <dd>@selected.EffectiveTypeId</dd>
                    <dt>@L["Resource group"]</dt>
                    <dd>@(group?.Name ?? L["Ungrouped"])</dd>
                    <dt>@L["Region"]</dt>
                    <dd>@selected.Region</dd>
                    <dt>@L["Version"]</dt>
                    <dd>@selected.Version</dd>
                    <dt>@L["Resource ID"]</dt>
                    <dd>@selected.Id</dd>
                </dl>
            </section>

            @if (children.Count > 0)
            {
                <section class="blade-section">
                    <h3>@L["Sub-resources"]</h3>
                    <div class="subresource-list">
                        @foreach (var child in children)
                        {
                            <button @onclick="() => SelectResource(child)">
                                <span class="resource-kind-icon">@GetResourceGlyph(child.Kind)</span>
                                <span>
                                    <strong>@child.Name</strong>
                                    <small>@child.Kind</small>
                                </span>
                                <span class="state-dot @GetStateClass(child.State)"></span>
                            </button>
                        }
                    </div>
                </section>
            }

            <section class="blade-section">
                <h3>@L["Endpoints"]</h3>
                <div class="endpoint-list">
                    @foreach (var endpoint in selected.Endpoints)
                    {
                        <div>
                            <strong>@endpoint.Name</strong>
                            <span>@endpoint.Address</span>
                            <small>@endpoint.Protocol @(endpoint.IsExternal ? L["external"] : L["internal"])</small>
                        </div>
                    }
                </div>
            </section>

            @if (selected.DependsOn.Count > 0)
            {
                <section class="blade-section">
                    <h3>@L["Dependencies"]</h3>
                    <div class="dependency-list">
                        @foreach (var dependency in selected.DependsOn)
                        {
                            <span>@dependency</span>
                        }
                    </div>
                </section>
            }
        }
    </aside>
</section>

@code {
    private const string UngroupedScope = "__ungrouped";
    private readonly HashSet<string> CollapsedResourceIds = new(StringComparer.OrdinalIgnoreCase);
    private string? Filter { get; set; }
    private string? SelectedScope { get; set; }
    private CloudResource? SelectedResource { get; set; }
    private string? DeleteConfirmationResourceId { get; set; }
    private string? ProcedureMessage { get; set; }
    private string? ExecutingActionKey { get; set; }
    private PendingResourceAction? PendingAction { get; set; }

    private IReadOnlyList<ResourceRow> BuildRows(IReadOnlyList<CloudResource> allResources)
    {
        var scoped = allResources
            .Where(IsInSelectedScope)
            .ToArray();
        var scopedIds = scoped.Select(resource => resource.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var childrenByParent = scoped
            .Where(resource => resource.ParentResourceId is not null)
            .GroupBy(resource => resource.ParentResourceId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.OrderBy(resource => resource.Name).ToArray(), StringComparer.OrdinalIgnoreCase);

        HashSet<string>? visibleIds = null;
        if (!string.IsNullOrWhiteSpace(Filter))
        {
            visibleIds = scoped
                .Where(MatchesFilter)
                .Select(resource => resource.Id)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            foreach (var resource in scoped.Where(resource => visibleIds.Contains(resource.Id)))
            {
                var parentId = resource.ParentResourceId;
                while (parentId is not null && scopedIds.Contains(parentId) && visibleIds.Add(parentId))
                {
                    parentId = scoped.First(item => item.Id == parentId).ParentResourceId;
                }
            }
        }

        var rows = new List<ResourceRow>();
        var roots = scoped
            .Where(resource => resource.ParentResourceId is null || !scopedIds.Contains(resource.ParentResourceId))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase);

        foreach (var root in roots)
        {
            AddResourceRow(root, 0, childrenByParent, visibleIds, rows);
        }

        return rows;
    }

    private void AddResourceRow(
        CloudResource resource,
        int depth,
        IReadOnlyDictionary<string, CloudResource[]> childrenByParent,
        HashSet<string>? visibleIds,
        List<ResourceRow> rows)
    {
        if (visibleIds is not null && !visibleIds.Contains(resource.Id))
        {
            return;
        }

        var children = childrenByParent.GetValueOrDefault(resource.Id) ?? [];
        rows.Add(new ResourceRow(resource, depth, children.Length));

        if (CollapsedResourceIds.Contains(resource.Id) && visibleIds is null)
        {
            return;
        }

        foreach (var child in children)
        {
            AddResourceRow(child, depth + 1, childrenByParent, visibleIds, rows);
        }
    }

    private bool IsInSelectedScope(CloudResource resource)
    {
        var group = GetGroup(resource);
        return SelectedScope switch
        {
            null => true,
            UngroupedScope => group is null,
            _ => group?.Id == SelectedScope
        };
    }

    private bool MatchesFilter(CloudResource resource) =>
        resource.Name.Contains(Filter!, StringComparison.OrdinalIgnoreCase) ||
        resource.Kind.Contains(Filter!, StringComparison.OrdinalIgnoreCase) ||
        resource.EffectiveTypeId.Contains(Filter!, StringComparison.OrdinalIgnoreCase);

    private ResourceGroup? GetGroup(CloudResource resource) =>
        ResourceManager.GetGroupForResource(resource.Id);

    private void SelectScope(string? scope)
    {
        SelectedScope = scope;
        SelectedResource = null;
    }

    private void ToggleResource(string resourceId)
    {
        if (!CollapsedResourceIds.Add(resourceId))
        {
            CollapsedResourceIds.Remove(resourceId);
        }
    }

    private void OpenResource(CloudResource resource)
    {
        if (resource.DetailRoute is not null)
        {
            Navigation.NavigateTo(resource.DetailRoute);
            return;
        }

        SelectResource(resource);
    }

    private void SelectResource(CloudResource resource) => SelectedResource = resource;

    private void CreateGroup() => Navigation.NavigateTo("/resources/groups/new");

    private void AddResource() => Navigation.NavigateTo("/resources/add");

    private void UpdateResource(CloudResource resource) =>
        Navigation.NavigateTo($"/resources/{Uri.EscapeDataString(resource.Id)}/edit");

    private void OpenLogs(CloudResource resource)
    {
        var logs = LogStore.GetLogsForResource(resource.Id);
        var query = new Dictionary<string, string?>
        {
            ["resourceId"] = resource.Id
        };

        if (logs.Count == 1)
        {
            query["logId"] = logs[0].Id;
        }

        Navigation.NavigateTo(Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query));
    }

    private void PromptDelete(CloudResource resource)
    {
        DeleteConfirmationResourceId = resource.Id;
        ProcedureMessage = null;
    }

    private void CancelDelete() => DeleteConfirmationResourceId = null;

    private async Task DeleteResource(CloudResource resource)
    {
        var registration = Registrations.GetRegistration(resource.Id);
        var provider = registration is null
            ? null
            : ResourceManager.Providers.FirstOrDefault(item =>
                string.Equals(item.Id, registration.ProviderId, StringComparison.OrdinalIgnoreCase));

        if (provider is not IResourceProcedureProvider procedureProvider)
        {
            ProcedureMessage = L["This provider does not support deleting the selected resource."].Value;
            return;
        }

        var group = GetGroup(resource);
        var result = await procedureProvider.DeleteAsync(
            new ResourceProcedureContext(resource, registration, group?.Id, Registrations));

        ProcedureMessage = result.Message;
        DeleteConfirmationResourceId = null;
        SelectedResource = null;
    }

    private async Task RequestResourceAction(CloudResource resource, ResourceAction action)
    {
        if (action.RequiresConfirmation)
        {
            PendingAction = new PendingResourceAction(resource, action);
            ProcedureMessage = null;
            return;
        }

        await ExecuteResourceAction(resource, action);
    }

    private async Task ConfirmResourceAction()
    {
        if (PendingAction is null)
        {
            return;
        }

        var pending = PendingAction;
        PendingAction = null;
        await ExecuteResourceAction(pending.Resource, pending.Action);
    }

    private void CancelResourceAction() => PendingAction = null;

    private async Task ExecuteResourceAction(CloudResource resource, ResourceAction action)
    {
        var provider = GetProcedureProvider(resource);
        if (provider is null)
        {
            ProcedureMessage = L["This provider does not support actions for the selected resource."].Value;
            return;
        }

        ExecutingActionKey = GetActionKey(resource, action);
        ProcedureMessage = null;
        try
        {
            var registration = GetRegistrationForResourceOrAncestor(resource);
            var group = GetGroup(resource);
            var result = await provider.ExecuteActionAsync(
                new ResourceProcedureContext(resource, registration, group?.Id, Registrations),
                action);

            ProcedureMessage = result.Message;
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            ExecutingActionKey = null;
        }
    }

    private bool CanManage(CloudResource resource)
    {
        var group = GetGroup(resource);
        return Authorization.CanAccessResource(
            resource.Id,
            group?.Id,
            CloudShellPermissions.Resources.Manage);
    }

    private bool HasUpdateProcedure(CloudResource resource) =>
        ShellCatalog.ResourceTypes.Any(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase) &&
            (type.UpdateComponentType is not null || type.ResourceTabs.Count > 0));

    private bool CanDelete(CloudResource resource)
    {
        var registration = Registrations.GetRegistration(resource.Id);
        if (registration is null || !CanManage(resource))
        {
            return false;
        }

        return ResourceManager.Providers.Any(provider =>
            string.Equals(provider.Id, registration.ProviderId, StringComparison.OrdinalIgnoreCase) &&
            provider is IResourceProcedureProvider);
    }

    private bool CanExecuteAction(CloudResource resource) =>
        resource.ResourceActions.Count > 0 &&
        CanManage(resource) &&
        GetProcedureProvider(resource) is not null;

    private bool IsExecutingAction(CloudResource resource, ResourceAction action) =>
        string.Equals(ExecutingActionKey, GetActionKey(resource, action), StringComparison.Ordinal);

    private IResourceProcedureProvider? GetProcedureProvider(CloudResource resource)
    {
        var registration = GetRegistrationForResourceOrAncestor(resource);
        if (registration is not null)
        {
            return ResourceManager.Providers.FirstOrDefault(provider =>
                string.Equals(provider.Id, registration.ProviderId, StringComparison.OrdinalIgnoreCase))
                as IResourceProcedureProvider;
        }

        return ResourceManager.Providers.FirstOrDefault(provider =>
            string.Equals(provider.DisplayName, resource.Provider, StringComparison.OrdinalIgnoreCase))
            as IResourceProcedureProvider;
    }

    private ResourceRegistration? GetRegistrationForResourceOrAncestor(CloudResource resource)
    {
        var current = resource;
        var visited = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        while (visited.Add(current.Id))
        {
            var registration = Registrations.GetRegistration(current.Id);
            if (registration is not null)
            {
                return registration;
            }

            if (current.ParentResourceId is null)
            {
                return null;
            }

            var parent = ResourceManager.GetResource(current.ParentResourceId);
            if (parent is null)
            {
                return null;
            }

            current = parent;
        }

        return null;
    }

    private static string GetActionKey(CloudResource resource, ResourceAction action) =>
        $"{resource.Id}:{action.Id}";

    private RenderFragment ResourceActionControls(CloudResource resource) => builder =>
    {
        var logs = LogStore.GetLogsForResource(resource.Id);
        if (resource.ResourceActions.Count == 0 && logs.Count == 0)
        {
            return;
        }

        var sequence = 0;
        foreach (var action in resource.ResourceActions.Where(IsInlineAction))
        {
            builder.OpenComponent<FluentButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-icon-button");
            builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "Style", "width: 2rem; min-width: 2rem;");
            builder.AddAttribute(sequence++, "Title", action.DisplayName);
            builder.AddAttribute(sequence++, "Disabled",
                !CanExecuteAction(resource) || IsExecutingAction(resource, action));
            builder.AddAttribute(sequence++, "OnClick",
                EventCallback.Factory.Create<MouseEventArgs>(
                    this,
                    () => RequestResourceAction(resource, action)));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
            {
                buttonBuilder.OpenElement(0, "span");
                buttonBuilder.AddAttribute(1, "class", $"action-icon {GetActionIconClass(action)}");
                buttonBuilder.AddAttribute(2, "aria-hidden", "true");
                buttonBuilder.CloseElement();
            }));
            builder.CloseComponent();
        }

        var overflowActions = resource.ResourceActions
            .Where(action => !IsInlineAction(action))
            .ToArray();

        if (overflowActions.Length == 0)
        {
            if (logs.Count > 0)
            {
                builder.OpenComponent<FluentButton>(sequence++);
                builder.AddAttribute(sequence++, "Class", "action-icon-button");
                builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
                builder.AddAttribute(sequence++, "Style", "width: 2rem; min-width: 2rem;");
                builder.AddAttribute(sequence++, "Title", GetLogsActionLabel(logs.Count));
                builder.AddAttribute(sequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => OpenLogs(resource)));
                builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
                {
                    buttonBuilder.OpenElement(0, "span");
                    buttonBuilder.AddAttribute(1, "class", "action-icon action-icon-logs");
                    buttonBuilder.AddAttribute(2, "aria-hidden", "true");
                    buttonBuilder.CloseElement();
                }));
                builder.CloseComponent();
            }

            return;
        }

        builder.OpenComponent<FluentMenuButton>(sequence++);
        builder.AddAttribute(sequence++, "Class", "action-overflow-button");
        builder.AddAttribute(sequence++, "UseMenuService", false);
        builder.AddAttribute(sequence++, "ButtonAppearance", Appearance.Neutral);
        builder.AddAttribute(sequence++, "ButtonStyle", "width: 2rem; min-width: 2rem;");
        builder.AddAttribute(sequence++, "ButtonContent", (RenderFragment)(buttonBuilder =>
        {
            buttonBuilder.OpenElement(0, "span");
            buttonBuilder.AddAttribute(1, "class", "action-overflow-label");
            buttonBuilder.AddAttribute(2, "aria-label", L["More actions"]);
            buttonBuilder.AddContent(3, "⋮");
            buttonBuilder.CloseElement();
        }));
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(menuBuilder =>
        {
            var menuSequence = 0;
            foreach (var action in overflowActions)
            {
                menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                menuBuilder.AddAttribute(menuSequence++, "Disabled",
                    !CanExecuteAction(resource) || IsExecutingAction(resource, action));
                menuBuilder.AddAttribute(menuSequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => RequestResourceAction(resource, action)));
                menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                {
                    itemBuilder.OpenElement(0, "span");
                    itemBuilder.AddAttribute(1, "class", "menu-action-content");
                    itemBuilder.OpenElement(2, "span");
                    itemBuilder.AddAttribute(3, "class", $"action-icon {GetActionIconClass(action)}");
                    itemBuilder.AddAttribute(4, "aria-hidden", "true");
                    itemBuilder.CloseElement();
                    itemBuilder.OpenElement(5, "span");
                    itemBuilder.AddContent(6, IsExecutingAction(resource, action)
                        ? L["Working"]
                        : action.DisplayName);
                    itemBuilder.CloseElement();
                    itemBuilder.CloseElement();
                }));
                menuBuilder.CloseComponent();
            }

            if (logs.Count > 0)
            {
                menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                menuBuilder.AddAttribute(menuSequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => OpenLogs(resource)));
                menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                {
                    itemBuilder.OpenElement(0, "span");
                    itemBuilder.AddAttribute(1, "class", "menu-action-content");
                    itemBuilder.OpenElement(2, "span");
                    itemBuilder.AddAttribute(3, "class", "action-icon action-icon-logs");
                    itemBuilder.AddAttribute(4, "aria-hidden", "true");
                    itemBuilder.CloseElement();
                    itemBuilder.OpenElement(5, "span");
                    itemBuilder.AddContent(6, GetLogsActionLabel(logs.Count));
                    itemBuilder.CloseElement();
                    itemBuilder.CloseElement();
                }));
                menuBuilder.CloseComponent();
            }
        }));
        builder.CloseComponent();
    };

    private static bool IsInlineAction(ResourceAction action) =>
        action.EffectivePresentation.DisplayStyle == ResourceActionDisplayStyle.Inline;

    private static string GetActionIconClass(ResourceAction action) => action.EffectivePresentation.Icon switch
    {
        ResourceActionIcon.Run => "action-icon-run",
        ResourceActionIcon.Stop => "action-icon-stop",
        ResourceActionIcon.Pause => "action-icon-pause",
        ResourceActionIcon.Restart => "action-icon-restart",
        _ => "action-icon-custom"
    };

    private string GetConfirmationMessage(CloudResource resource, ResourceAction action) =>
        action.Description ??
        L["This will run the {0} action for {1}.", action.DisplayName, resource.Name].Value;

    private string GetLogsActionLabel(int logCount) =>
        logCount == 1 ? L["Logs"].Value : L["Logs ({0})", logCount].Value;

    private static string GetResourceGlyph(string kind) =>
        kind.Contains("Docker Engine", StringComparison.OrdinalIgnoreCase) ? "D" :
        kind.Contains("Container", StringComparison.OrdinalIgnoreCase) ? "C" :
        kind.Contains("Database", StringComparison.OrdinalIgnoreCase) || kind.Contains("SQL", StringComparison.OrdinalIgnoreCase) ? "DB" :
        kind.Contains("Redis", StringComparison.OrdinalIgnoreCase) ? "R" :
        kind.Contains("Collector", StringComparison.OrdinalIgnoreCase) ? "T" :
        kind.Contains("Worker", StringComparison.OrdinalIgnoreCase) ? "W" :
        kind.Contains("Broker", StringComparison.OrdinalIgnoreCase) ? "Q" :
        "S";

    private static string GetStateClass(ResourceState state) => state switch
    {
        ResourceState.Running => "state-running",
        ResourceState.Starting => "state-starting",
        ResourceState.Paused => "state-paused",
        ResourceState.Degraded => "state-degraded",
        ResourceState.Stopped => "state-stopped",
        _ => "state-unknown"
    };

    private sealed record ResourceRow(CloudResource Resource, int Depth, int ChildCount);

    private sealed record PendingResourceAction(CloudResource Resource, ResourceAction Action);
}
