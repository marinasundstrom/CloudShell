{
  "Authentication": {
    "Enabled": true,
    "Mode": "Identity",
    "AllowLocalSetup": false,
    "DefaultScheme": "CloudShell.Cookie",
    "ChallengeScheme": "CloudShell.OpenIdConnect",
    "RoleClaimType": "http://schemas.microsoft.com/ws/2008/06/identity/claims/role",
    "AdministratorRole": "CloudShell.Administrator",
    "RolePermissions": {
      "CloudShell.Administrator": [ "*" ],
      "CloudShell.Contributor": [
        "resource-groups.read",
        "resource-groups.create",
        "resource-groups.manage",
        "resources.read",
        "resources.create",
        "resources.manage"
      ],
      "CloudShell.Reader": [
        "resource-groups.read",
        "resources.read"
      ]
    },
    "RoleResourceGroups": {
      "CloudShell.Administrator": [ "*" ]
    },
    "OpenIdConnect": {
      "CallbackPath": "/signin-oidc",
      "RequireHttpsMetadata": true,
      "GetClaimsFromUserInfoEndpoint": true,
      "Scopes": [ "openid", "profile", "email" ]
    }
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell.db",
    "IdentityConnectionString": "Data Source=Data/identity.db"
  },
  "Localization": {
    "DefaultCulture": "en",
    "SupportedCultures": [ "en" ]
  },
  "Shell": {
    "ApplicationName": "CloudShell"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
