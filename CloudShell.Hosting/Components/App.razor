@using System.Globalization
@using Microsoft.AspNetCore.Components.Endpoints

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name" dir="@GetTextDirection()">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["_content/Microsoft.FluentUI.AspNetCore.Components/css/reboot.css"]" />
    <link rel="stylesheet" href="@Assets["_content/CloudShell.Hosting/app.css"]" />
    <link rel="stylesheet" href="@Assets["CloudShell.Components.styles.css"]" />
    <link rel="stylesheet" href="@Assets["_content/CloudShell.Hosting/CloudShell.Hosting.bundle.scp.css"]" />
    <script src="@Assets["_content/Microsoft.FluentUI.AspNetCore.Components/js/loading-theme.js"]" type="text/javascript"></script>
    <loading-theme storage-name="cloudshell.theme"></loading-theme>
    <ImportMap />
    <link rel="icon" type="image/png" href="@Assets["_content/CloudShell.Hosting/favicon.png"]" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <ReconnectModal />
    <script src="@Assets["_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.lib.module.js"]" type="module" async></script>
    <script src="@Assets["_content/CloudShell.Hosting/shell.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private Microsoft.AspNetCore.Http.HttpContext HttpContext { get; set; } = default!;

    private IComponentRenderMode? PageRenderMode =>
        HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;

    private static string GetTextDirection() =>
        CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft ? "rtl" : "ltr";
}
