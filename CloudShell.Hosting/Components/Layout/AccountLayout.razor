@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<main class="account-shell">
    <section class="account-brand">
        <div class="brand-mark">CS</div>
        <div>
            <div class="brand-name">CloudShell</div>
            <div class="brand-subtitle">@L["Platform control plane"]</div>
        </div>
        <div class="command-surface">
            <LanguageSelector />
            <ThemeSelector />
        </div>
    </section>

    <section class="account-panel panel">
        @Body
    </section>
</main>
