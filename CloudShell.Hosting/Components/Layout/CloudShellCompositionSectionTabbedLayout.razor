@inject CompositionRegistry Composition
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using CloudShell.UI.Composition

@{
    var sections = GetSections();
    var selectedSection = GetSelectedSection(sections);
}

<CloudShellTabbedLayout Items="@BuildItems(sections)"
                        SelectedItemId="@selectedSection?.Section.Id.Value"
                        SelectedItemChanged="SelectSection"
                        AriaLabel="@AriaLabel"
                        PanelDescription="@PanelDescription"
                        Class="@Class"
                        @attributes="AdditionalAttributes">
    <SummaryContent>
        @if (SummaryContent is not null)
        {
            @SummaryContent(sections)
        }
    </SummaryContent>
    <EmptyContent>
        @if (EmptyContent is not null)
        {
            @EmptyContent
        }
    </EmptyContent>
    <HeaderContent Context="item">
        @{
            var section = FindSection(sections, item.Id);
        }
        @if (section is not null && HeaderContent is not null)
        {
            @HeaderContent(section)
        }
        else
        {
            <div class="panel-header">
                <div>
                    <h2>@item.Title</h2>
                    @if (PanelDescription is not null)
                    {
                        <p>@PanelDescription</p>
                    }
                </div>
            </div>
        }
    </HeaderContent>
    <ChildContent Context="item">
        @{
            var section = FindSection(sections, item.Id);
        }
        @if (section is not null && ChildContent is not null)
        {
            @ChildContent(section)
        }
        else if (section is not null)
        {
            <DynamicComponent Type="section.Section.ComponentType" />
        }
    </ChildContent>
</CloudShellTabbedLayout>

@code {
    [Parameter, EditorRequired]
    public PageId Page { get; set; }

    [Parameter, EditorRequired]
    public SectionOutletId Outlet { get; set; }

    [Parameter]
    public string QueryParameter { get; set; } = "section";

    [Parameter]
    public string AriaLabel { get; set; } = "Sections";

    [Parameter]
    public string Group { get; set; } = "Sections";

    [Parameter]
    public string? GroupTitle { get; set; }

    [Parameter]
    public string? PanelDescription { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public Func<CompositionSectionProjection, string?>? IconSelector { get; set; }

    [Parameter]
    public Func<CompositionSectionProjection, string?>? DescriptionSelector { get; set; }

    [Parameter]
    public RenderFragment<IReadOnlyList<CompositionSectionProjection>>? SummaryContent { get; set; }

    [Parameter]
    public RenderFragment? EmptyContent { get; set; }

    [Parameter]
    public RenderFragment<CompositionSectionProjection>? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment<CompositionSectionProjection>? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private IReadOnlyList<CompositionSectionProjection> GetSections() =>
        Composition
            .GetSectionProjections(Page, Outlet)
            .ToArray();

    private CompositionSectionProjection? GetSelectedSection(IReadOnlyList<CompositionSectionProjection> sections)
    {
        var selectedSectionId = GetSelectedSectionId();
        if (!string.IsNullOrWhiteSpace(selectedSectionId))
        {
            var requested = selectedSectionId.Trim();
            var requestedSection = sections.FirstOrDefault(section =>
                string.Equals(section.Section.Id.Value, requested, StringComparison.OrdinalIgnoreCase));
            if (requestedSection is not null)
            {
                return requestedSection;
            }
        }

        return sections.FirstOrDefault();
    }

    private IReadOnlyList<CloudShellTabbedLayoutItem> BuildItems(
        IReadOnlyList<CompositionSectionProjection> sections) =>
        sections
            .Select(section => new CloudShellTabbedLayoutItem(
                section.Section.Id.Value,
                L[section.Section.Title].Value,
                section.Section.Order,
                Group: L[Group].Value,
                GroupTitle: GroupTitle is null ? null : L[GroupTitle].Value,
                Icon: IconSelector?.Invoke(section),
                Description: DescriptionSelector?.Invoke(section),
                ModuleId: section.ModuleId.Value))
            .ToArray();

    private void SelectSection(CloudShellTabbedLayoutItem item)
    {
        Navigation.NavigateTo(
            Composition.ResolveHref(
                CompositionTarget.ForPage(Page),
                new Dictionary<string, object?>
                {
                    [QueryParameter] = item.Id
                }),
            replace: true);
    }

    private string? GetSelectedSectionId()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(QueryParameter, out var value)
            ? value.ToString()
            : null;
    }

    private static CompositionSectionProjection? FindSection(
        IReadOnlyList<CompositionSectionProjection> sections,
        string sectionId) =>
        sections.FirstOrDefault(section =>
            string.Equals(section.Section.Id.Value, sectionId, StringComparison.OrdinalIgnoreCase));
}
