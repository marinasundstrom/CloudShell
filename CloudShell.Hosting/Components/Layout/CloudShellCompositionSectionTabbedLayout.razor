@inject CompositionRegistry Composition
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using CloudShell.UI.Composition
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable

@{
    var sections = GetSections();
    var selectedSection = GetSelectedSection(sections);
    var selectedSectionIssue = GetSelectedSectionIssue(sections);
}

<CloudShellTabbedLayout Items="@BuildItems(sections)"
                        SelectedItemId="@selectedSection?.Section.Id.Value"
                        SelectedItemChanged="SelectSection"
                        SelectFirstItemWhenSelectedMissing="@(selectedSectionIssue is null)"
                        AriaLabel="@AriaLabel"
                        PanelDescription="@PanelDescription"
                        Class="@Class"
                        @attributes="AdditionalAttributes">
    <SummaryContent>
        @if (SummaryContent is not null)
        {
            @SummaryContent(sections)
        }
    </SummaryContent>
    <EmptyContent>
        @if (selectedSectionIssue is not null)
        {
            <EmptyState Title="@selectedSectionIssue.Title"
                        Message="@selectedSectionIssue.Message">
                <FluentAnchor Appearance="Appearance.Neutral" Href="@selectedSectionIssue.RecoveryHref">
                    @selectedSectionIssue.RecoveryLabel
                </FluentAnchor>
            </EmptyState>
        }
        else if (EmptyContent is not null)
        {
            @EmptyContent
        }
    </EmptyContent>
    <HeaderContent Context="item">
        @{
            var section = FindSection(sections, item.Id);
        }
        @if (section is not null && HeaderContent is not null)
        {
            @HeaderContent(section)
        }
        else
        {
            <div class="panel-header">
                <div>
                    <h2>@item.Title</h2>
                    @if (PanelDescription is not null)
                    {
                        <p>@PanelDescription</p>
                    }
                </div>
            </div>
        }
    </HeaderContent>
    <ChildContent Context="item">
        @{
            var section = FindSection(sections, item.Id);
        }
        @if (section is not null && ChildContent is not null)
        {
            @ChildContent(section)
        }
        else if (section is not null)
        {
            <DynamicComponent Type="section.Section.ComponentType" />
        }
    </ChildContent>
</CloudShellTabbedLayout>

@code {
    [Parameter, EditorRequired]
    public PageId Page { get; set; }

    [Parameter, EditorRequired]
    public SectionOutletId Outlet { get; set; }

    [Parameter]
    public string QueryParameter { get; set; } = "section";

    [Parameter]
    public string? RouteSegment { get; set; }

    [Parameter]
    public string RouteParameter { get; set; } = "section";

    [Parameter]
    public string AriaLabel { get; set; } = "Sections";

    [Parameter]
    public string Group { get; set; } = "Sections";

    [Parameter]
    public string? GroupTitle { get; set; }

    [Parameter]
    public string? PanelDescription { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public Func<CompositionSectionProjection, string?>? IconSelector { get; set; }

    [Parameter]
    public Func<CompositionSectionProjection, string?>? DescriptionSelector { get; set; }

    [Parameter]
    public RenderFragment<IReadOnlyList<CompositionSectionProjection>>? SummaryContent { get; set; }

    [Parameter]
    public RenderFragment? EmptyContent { get; set; }

    [Parameter]
    public RenderFragment<CompositionSectionProjection>? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment<CompositionSectionProjection>? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string? SelectedSectionId { get; set; }

    protected override void OnInitialized()
    {
        SelectedSectionId = ReadSelectedSectionId(GetSections());
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override void OnParametersSet()
    {
        SelectedSectionId = ReadSelectedSectionId(GetSections());
    }

    private IReadOnlyList<CompositionSectionProjection> GetSections() =>
        Composition
            .GetSectionProjections(Page, Outlet)
            .ToArray();

    private CompositionSectionProjection? GetSelectedSection(IReadOnlyList<CompositionSectionProjection> sections)
    {
        if (GetSelectedSectionIssue(sections) is not null)
        {
            return null;
        }

        if (!string.IsNullOrWhiteSpace(SelectedSectionId))
        {
            var requested = SelectedSectionId.Trim();
            var requestedSection = sections.FirstOrDefault(section =>
                string.Equals(section.Section.Id.Value, requested, StringComparison.OrdinalIgnoreCase));
            if (requestedSection is not null)
            {
                return requestedSection;
            }
        }

        return sections.FirstOrDefault();
    }

    private CompositionSectionSelectionIssue? GetSelectedSectionIssue(IReadOnlyList<CompositionSectionProjection> sections)
    {
        if (!TryReadRequestedSection(out var requested, out var isRouteSegment))
        {
            return null;
        }

        if (TryResolveSectionRequest(sections, requested, out _))
        {
            return null;
        }

        var message = isRouteSegment
            ? L["Section '{0}' is not available.", requested].Value
            : L["Section '{0}' is not a valid section ID or route segment.", requested].Value;
        return new(
            L["Section not found"].Value,
            message,
            L["Open overview"].Value,
            Composition.ResolveHref(CompositionTarget.ForPage(Page)));
    }

    private IReadOnlyList<CloudShellTabbedLayoutItem> BuildItems(
        IReadOnlyList<CompositionSectionProjection> sections) =>
        sections
            .Select(section => new CloudShellTabbedLayoutItem(
                section.Section.Id.Value,
                L[section.Section.Title].Value,
                section.Section.Order,
                Group: L[Group].Value,
                GroupTitle: GroupTitle is null ? null : L[GroupTitle].Value,
                Icon: IconSelector?.Invoke(section),
                Description: DescriptionSelector?.Invoke(section),
                ModuleId: section.ModuleId.Value))
            .ToArray();

    private void SelectSection(CloudShellTabbedLayoutItem item)
    {
        SelectedSectionId = item.Id;

        Navigation.NavigateTo(
            BuildSectionHref(item.Id),
            replace: true);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        var selectedSectionId = ReadSelectedSectionId(GetSections(), args.Location);
        if (string.Equals(SelectedSectionId, selectedSectionId, StringComparison.Ordinal))
        {
            return;
        }

        SelectedSectionId = selectedSectionId;
        _ = InvokeAsync(StateHasChanged);
    }

    private string? ReadSelectedSectionId(
        IReadOnlyList<CompositionSectionProjection> sections,
        string? location = null)
    {
        return TryReadRequestedSection(location, out var requested, out _) &&
            TryResolveSectionRequest(sections, requested, out var section)
                ? section.Section.Id.Value
                : null;
    }

    private bool TryReadRequestedSection(out string requested, out bool isRouteSegment) =>
        TryReadRequestedSection(location: null, out requested, out isRouteSegment);

    private bool TryReadRequestedSection(
        string? location,
        out string requested,
        out bool isRouteSegment)
    {
        requested = string.Empty;
        isRouteSegment = false;

        var uri = Navigation.ToAbsoluteUri(location ?? Navigation.Uri);
        if (TryReadRouteSectionSegment(uri, location is null, out var routeSegment))
        {
            requested = routeSegment;
            isRouteSegment = true;
            return true;
        }

        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue(QueryParameter, out var value))
        {
            return false;
        }

        requested = Uri.UnescapeDataString(value.ToString().Trim());
        return !string.IsNullOrWhiteSpace(requested);
    }

    private static bool TryResolveSectionRequest(
        IReadOnlyList<CompositionSectionProjection> sections,
        string requested,
        out CompositionSectionProjection section)
    {
        section = null!;
        var requestedSection = sections.FirstOrDefault(section =>
            string.Equals(section.Section.Id.Value, requested, StringComparison.OrdinalIgnoreCase));
        if (requestedSection is not null)
        {
            section = requestedSection;
            return true;
        }

        return TryResolveSectionRouteSegment(sections, requested, out section);
    }

    private static CompositionSectionProjection? FindSection(
        IReadOnlyList<CompositionSectionProjection> sections,
        string sectionId) =>
        sections.FirstOrDefault(section =>
            string.Equals(section.Section.Id.Value, sectionId, StringComparison.OrdinalIgnoreCase));

    private string BuildSectionHref(string sectionId)
    {
        var sections = GetSections();
        var section = FindSection(sections, sectionId);
        var pageHref = Composition.ResolveHref(CompositionTarget.ForPage(Page));
        if (section is null || section.Section.Id == sections.FirstOrDefault()?.Section.Id)
        {
            return pageHref;
        }

        return Composition.ResolveHref(
            CompositionTarget.ForPage(Page),
            new Dictionary<string, object?>
            {
                [RouteParameter] = GetSectionRouteSegment(section.Section.Id)
            });
    }

    private bool TryReadRouteSectionSegment(
        Uri uri,
        bool allowRouteParameter,
        out string segment)
    {
        segment = string.Empty;
        if (allowRouteParameter && !string.IsNullOrWhiteSpace(RouteSegment))
        {
            segment = Uri.UnescapeDataString(RouteSegment.Trim());
            return true;
        }

        var pageHref = Composition.ResolveHref(CompositionTarget.ForPage(Page));
        var pagePath = Navigation.ToAbsoluteUri(pageHref).AbsolutePath.TrimEnd('/');
        var currentPath = uri.AbsolutePath.TrimEnd('/');
        if (!currentPath.StartsWith(pagePath + "/", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var remaining = currentPath[(pagePath.Length + 1)..];
        if (remaining.Length == 0 || remaining.Contains('/', StringComparison.Ordinal))
        {
            return false;
        }

        segment = Uri.UnescapeDataString(remaining);
        return true;
    }

    private static bool TryResolveSectionRouteSegment(
        IReadOnlyList<CompositionSectionProjection> sections,
        string segment,
        out CompositionSectionProjection section)
    {
        section = null!;
        var matchingSections = sections
            .Where(item => string.Equals(
                GetSectionRouteSegment(item.Section.Id),
                segment,
                StringComparison.OrdinalIgnoreCase))
            .ToArray();
        if (matchingSections.Length != 1)
        {
            return false;
        }

        section = matchingSections[0];
        return true;
    }

    private static string GetSectionRouteSegment(SectionId id)
    {
        var value = id.Value;
        var separatorIndex = value.LastIndexOf('.', StringComparison.Ordinal);
        return separatorIndex < 0 ? value : value[(separatorIndex + 1)..];
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private sealed record CompositionSectionSelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);
}
