@inject ICoreShellBlazorSectionOutletProjectionService SectionOutlets
@inject ICoreShellRouteService Routes
@inject ICoreShellSectionAddressService SectionAddresses
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using CoreShell.Blazor
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable

<CloudShellTabbedLayout Items="@BuildItems()"
                        SelectedItemId="@SelectedSectionId"
                        SelectedItemChanged="SelectSection"
                        SelectFirstItemWhenSelectedMissing="@(SelectedSectionIssue is null)"
                        AriaLabel="@AriaLabel"
                        PanelDescription="@PanelDescription"
                        Class="@Class"
                        @attributes="AdditionalAttributes">
    <SummaryContent>
        @if (SummaryContent is not null)
        {
            @SummaryContent(Sections.Select(section => section.BlazorSection.Section).ToArray())
        }
    </SummaryContent>
    <EmptyContent>
        @if (SelectedSectionIssue is not null)
        {
            <EmptyState Title="@SelectedSectionIssue.Title"
                        Message="@SelectedSectionIssue.Message">
                <CloudShellCoreShellAnchor Appearance="Appearance.Neutral"
                                           Page="@Page">
                    @SelectedSectionIssue.RecoveryLabel
                </CloudShellCoreShellAnchor>
            </EmptyState>
        }
        else if (EmptyContent is not null)
        {
            @EmptyContent
        }
    </EmptyContent>
    <HeaderContent Context="item">
        @{
            var section = FindSection(item.Id);
        }
        @if (section is not null && HeaderContent is not null)
        {
            @HeaderContent(section.Section)
        }
        else
        {
            <ShellPanelHeader Title="@item.Title"
                              Description="@PanelDescription" />
        }
    </HeaderContent>
    <ChildContent Context="item">
        @{
            var section = FindSection(item.Id);
        }
        @if (section is not null && ChildContent is not null)
        {
            @ChildContent(section)
        }
        else if (section is not null)
        {
            <DynamicComponent Type="section.ContentType" />
        }
    </ChildContent>
</CloudShellTabbedLayout>

@code {
    [Parameter, EditorRequired]
    public CoreShellPageId Page { get; set; }

    [Parameter, EditorRequired]
    public CoreShellSectionOutletId Outlet { get; set; }

    [Parameter]
    public string? RouteSegment { get; set; }

    [Parameter]
    public string AriaLabel { get; set; } = "Sections";

    [Parameter]
    public string Group { get; set; } = "Sections";

    [Parameter]
    public string? GroupTitle { get; set; }

    [Parameter]
    public string? PanelDescription { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public Func<CoreShellBlazorSection, string?>? IconSelector { get; set; }

    [Parameter]
    public Func<CoreShellBlazorSection, string?>? DescriptionSelector { get; set; }

    [Parameter]
    public RenderFragment<IReadOnlyList<CoreShellSectionContribution>>? SummaryContent { get; set; }

    [Parameter]
    public RenderFragment? EmptyContent { get; set; }

    [Parameter]
    public RenderFragment<CoreShellSectionContribution>? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment<CoreShellBlazorSection>? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private CoreShellSectionOutletContribution? OutletContribution { get; set; }

    private IReadOnlyList<RenderedSection> Sections { get; set; } = [];

    private string? PageHref { get; set; }

    private string? SelectedSectionId { get; set; }

    private CoreShellSectionSelectionIssue? SelectedSectionIssue => GetSelectedSectionIssue();

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadSectionsAsync();
        SelectedSectionId = ReadSelectedSectionId();
    }

    private async Task LoadSectionsAsync()
    {
        var resolved = await SectionOutlets.ResolveSectionOutletAsync(Page, Outlet);
        OutletContribution = resolved?.Outlet.Outlet;
        PageHref = (await Routes.ResolveTargetAsync(CoreShellTarget.ForPage(Page))).Href;

        if (resolved is null)
        {
            Sections = [];
            return;
        }

        var firstSection = resolved.Sections.FirstOrDefault()?.Section.Id;
        var sections = new List<RenderedSection>();
        foreach (var section in resolved.Sections)
        {
            var href = firstSection == section.Section.Id
                ? PageHref
                : (await Routes.ResolveTargetAsync(CoreShellTarget.ForSection(section.Section.Id))).Href;

            sections.Add(new RenderedSection(section, href));
        }

        Sections = sections;
    }

    private CoreShellBlazorSection? FindSection(string sectionId) =>
        Sections
            .Select(section => section.BlazorSection)
            .FirstOrDefault(section =>
                string.Equals(section.Section.Id.Value, sectionId, StringComparison.OrdinalIgnoreCase));

    private IReadOnlyList<CloudShellTabbedLayoutItem> BuildItems() =>
        Sections
            .Select(section => new CloudShellTabbedLayoutItem(
                section.BlazorSection.Section.Id.Value,
                L[section.BlazorSection.Section.Title].Value,
                section.BlazorSection.Section.Order,
                Group: GetGroup(section.BlazorSection),
                GroupTitle: GetGroupTitle(section.BlazorSection),
                Icon: IconSelector?.Invoke(section.BlazorSection),
                Description: DescriptionSelector?.Invoke(section.BlazorSection),
                Href: section.Href))
            .ToArray();

    private string GetGroup(CoreShellBlazorSection section)
    {
        var group = GetAttribute(section.Section, CoreShellAttributeNames.Group) ?? Group;
        return L[group].Value;
    }

    private string? GetGroupTitle(CoreShellBlazorSection section)
    {
        var groupTitle = GetAttribute(section.Section, CoreShellAttributeNames.GroupTitle) ?? GroupTitle;
        return groupTitle is null ? null : L[groupTitle].Value;
    }

    private static string? GetAttribute(
        CoreShellSectionContribution section,
        string name) =>
        section.Attributes.TryGetValue(name, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : null;

    private void SelectSection(CloudShellTabbedLayoutItem item)
    {
        SelectedSectionId = item.Id;

        var href = Sections
            .FirstOrDefault(section =>
                string.Equals(section.BlazorSection.Section.Id.Value, item.Id, StringComparison.OrdinalIgnoreCase))
            ?.Href;

        if (!string.IsNullOrWhiteSpace(href))
        {
            Navigation.NavigateTo(href, replace: true);
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        var selectedSectionId = ReadSelectedSectionId(args.Location);
        if (string.Equals(SelectedSectionId, selectedSectionId, StringComparison.Ordinal))
        {
            return;
        }

        SelectedSectionId = selectedSectionId;
        _ = InvokeAsync(StateHasChanged);
    }

    private string? ReadSelectedSectionId(string? location = null) =>
        TryReadRequestedSection(location, out var requested, out _) &&
        TryResolveSectionRequest(requested, out var section)
            ? section.Id.Value
            : null;

    private CoreShellSectionSelectionIssue? GetSelectedSectionIssue()
    {
        if (!TryReadRequestedSection(location: null, out var requested, out var isRouteSegment))
        {
            return null;
        }

        if (TryResolveSectionRequest(requested, out _))
        {
            return null;
        }

        var message = isRouteSegment
            ? L["Section '{0}' is not available.", requested].Value
            : L["Section '{0}' is not a valid section ID or route segment.", requested].Value;
        return new(
            L["Section not found"].Value,
            message,
            L["Open overview"].Value);
    }

    private bool TryReadRequestedSection(
        string? location,
        out string requested,
        out bool isRouteSegment)
    {
        requested = string.Empty;
        isRouteSegment = false;

        var uri = Navigation.ToAbsoluteUri(location ?? Navigation.Uri);
        if (TryReadRouteSectionSegment(uri, location is null, out var routeSegment))
        {
            requested = routeSegment;
            isRouteSegment = true;
            return true;
        }

        if (string.IsNullOrWhiteSpace(uri.Fragment))
        {
            return false;
        }

        requested = Uri.UnescapeDataString(uri.Fragment.TrimStart('#'));
        return !string.IsNullOrWhiteSpace(requested);
    }

    private bool TryReadRouteSectionSegment(
        Uri uri,
        bool allowRouteSegmentParameter,
        out string segment)
    {
        segment = string.Empty;
        if (allowRouteSegmentParameter && !string.IsNullOrWhiteSpace(RouteSegment))
        {
            segment = Uri.UnescapeDataString(RouteSegment.Trim());
            return true;
        }

        if (string.IsNullOrWhiteSpace(PageHref))
        {
            return false;
        }

        var pagePath = Navigation.ToAbsoluteUri(PageHref).AbsolutePath.TrimEnd('/');
        var currentPath = uri.AbsolutePath.TrimEnd('/');
        if (!currentPath.StartsWith(pagePath + "/", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var remaining = currentPath[(pagePath.Length + 1)..];
        if (remaining.Length == 0 || remaining.Contains('/', StringComparison.Ordinal))
        {
            return false;
        }

        segment = Uri.UnescapeDataString(remaining);
        return true;
    }

    private bool TryResolveSectionRequest(
        string requested,
        out CoreShellSectionContribution section)
    {
        section = null!;
        if (OutletContribution is null)
        {
            return false;
        }

        return SectionAddresses.TryResolveSectionRequest(
            OutletContribution,
            Sections.Select(rendered => rendered.BlazorSection.Section).ToArray(),
            requested,
            out section);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private sealed record RenderedSection(
        CoreShellBlazorSection BlazorSection,
        string Href);

    private sealed record CoreShellSectionSelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel);
}
