@inherits LayoutComponentBase
@inject ICloudShellUserSettingsProvider Settings
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@using CoreShell.Blazor
@implements IDisposable

<div class="shell @CollapsedClass">
    <aside class="shell-sidebar">
        <NavMenu IsCollapsed="IsNavCollapsed"
                 IsCollapsedChanged="SetCollapsedStateAsync"
                 NavigationRequested="CollapseNavigationForCompactViewportAsync" />
    </aside>

    <main class="shell-main">
        <ShellTopbar />

        <article class="shell-content">
            <CoreShellBlazorHost RequireRegisteredPage="false">
                @Body
            </CoreShellBlazorHost>
        </article>
    </main>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

<div id="blazor-error-ui" data-nosnippet>
    @L["An unhandled error has occurred."]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool IsNavCollapsed { get; set; }
    private string? CurrentLocation { get; set; }
    private bool ShouldScrollToTop { get; set; }

    private string? CollapsedClass => IsNavCollapsed ? "nav-collapsed" : null;

    protected override void OnInitialized()
    {
        CurrentLocation = Navigation.Uri;
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var storedCollapsed = await LoadCollapsedStateAsync();
            var compactViewport = await JSRuntime.InvokeAsync<bool>("cloudShellNav.isCompactViewport");
            IsNavCollapsed = compactViewport || storedCollapsed;
            if (compactViewport && !storedCollapsed)
            {
                await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", true, false);
            }
            else
            {
                await StoreCollapsedStateAsync(persistBrowser: true);
            }

            StateHasChanged();
        }

        if (ShouldScrollToTop)
        {
            ShouldScrollToTop = false;
            await JSRuntime.InvokeVoidAsync("cloudShellLayout.scrollToTop");
        }
    }

    private async Task SetCollapsedStateAsync(bool collapsed)
    {
        IsNavCollapsed = collapsed;
        var compactViewport = await JSRuntime.InvokeAsync<bool>("cloudShellNav.isCompactViewport");
        if (compactViewport)
        {
            await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", collapsed, false);
        }
        else
        {
            await StoreCollapsedStateAsync(persistBrowser: true);
        }

        StateHasChanged();
    }

    private async Task CollapseNavigationForCompactViewportAsync()
    {
        if (!IsNavCollapsed && await JSRuntime.InvokeAsync<bool>("cloudShellNav.isCompactViewport"))
        {
            await SetCollapsedStateAsync(true);
        }
    }

    private async Task<bool> LoadCollapsedStateAsync()
    {
        var browserValue = await JSRuntime.InvokeAsync<bool?>("cloudShellNav.getStoredCollapsed");
        if (browserValue.HasValue)
        {
            return browserValue.Value;
        }

        var storedValue = await Settings.GetSettingAsync(CloudShellUserSettingKeys.NavigationCollapsed);
        return string.Equals(storedValue?.Value, "true", StringComparison.OrdinalIgnoreCase);
    }

    private async Task StoreCollapsedStateAsync(bool persistBrowser)
    {
        await Settings.SetSettingAsync(
            CloudShellUserSettingKeys.NavigationCollapsed,
            IsNavCollapsed ? "true" : "false");
        await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", IsNavCollapsed, persistBrowser);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        if (IsSamePathAndQuery(CurrentLocation, args.Location))
        {
            CurrentLocation = args.Location;
            return;
        }

        CurrentLocation = args.Location;
        ShouldScrollToTop = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private static bool IsSamePathAndQuery(string? first, string? second)
    {
        if (string.IsNullOrWhiteSpace(first) || string.IsNullOrWhiteSpace(second))
        {
            return string.Equals(first, second, StringComparison.Ordinal);
        }

        return Uri.TryCreate(first, UriKind.Absolute, out var firstUri) &&
            Uri.TryCreate(second, UriKind.Absolute, out var secondUri) &&
            string.Equals(firstUri.GetLeftPart(UriPartial.Query), secondUri.GetLeftPart(UriPartial.Query), StringComparison.Ordinal);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
