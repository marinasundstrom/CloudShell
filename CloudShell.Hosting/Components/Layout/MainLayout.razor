@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<div class="shell">
    <aside class="shell-sidebar">
        <div class="brand">
            <div class="brand-mark">CS</div>
            <div class="brand-text">
                <div class="brand-name">CloudShell</div>
                <div class="brand-subtitle">@L["Platform control plane"]</div>
            </div>
            <NavToggle />
        </div>

        <NavMenu />

        <div class="sidebar-footer">
            <span class="status-dot"></span>
            <span class="sidebar-footer-text">@L["Local workspace"]</span>
        </div>
    </aside>

    <main class="shell-main">
        <header class="shell-topbar">
            <div class="environment-picker">
                <span class="eyebrow">@L["Environment"]</span>
                <strong>@L["Development"]</strong>
            </div>
            <div class="command-surface">
                <LanguageSelector />
                <AuthorizeView>
                    <Authorized Context="authentication">
                        <span class="signed-in-user">
                            @(authentication.User.Identity?.Name ?? L["Authenticated user"])
                        </span>
                        <a href="/account/logout">@L["Sign out"]</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <article class="shell-content">
            @Body
        </article>
    </main>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

<div id="blazor-error-ui" data-nosnippet>
    @L["An unhandled error has occurred."]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">x</span>
</div>
