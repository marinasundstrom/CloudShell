@inherits LayoutComponentBase
@inject Microsoft.Extensions.Options.IOptionsMonitor<CloudShellDisplayOptions> DisplayOptions
@inject Microsoft.Extensions.Hosting.IHostEnvironment HostEnvironment
@inject ICloudShellUserSettingsProvider Settings
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<div class="shell @CollapsedClass">
    <aside class="shell-sidebar">
        <NavMenu IsCollapsed="IsNavCollapsed" IsCollapsedChanged="SetCollapsedStateAsync" />
    </aside>

    <main class="shell-main">
        <header class="shell-topbar">
            <div class="environment-picker">
                <span class="eyebrow">@L["Environment"]</span>
                <strong>@GetEnvironmentName()</strong>
            </div>
            <div class="command-surface">
                <LanguageSelector />
                <ThemeSelector />
                <AuthorizeView>
                    <Authorized Context="authentication">
                        <span class="signed-in-user">
                            @(authentication.User.Identity?.Name ?? L["Authenticated user"])
                        </span>
                        <a href="/account/logout">@L["Sign out"]</a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <article class="shell-content">
            @Body
        </article>
    </main>
</div>

<FluentToastProvider />
<FluentDialogProvider />
<FluentTooltipProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />

<div id="blazor-error-ui" data-nosnippet>
    @L["An unhandled error has occurred."]
    <a href="." class="reload">@L["Reload"]</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool IsNavCollapsed { get; set; }

    private string? CollapsedClass => IsNavCollapsed ? "nav-collapsed" : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        IsNavCollapsed = await LoadCollapsedStateAsync();
        await StoreCollapsedStateAsync(persistBrowser: true);
        StateHasChanged();
    }

    private string GetEnvironmentName() =>
        string.IsNullOrWhiteSpace(DisplayOptions.CurrentValue.EnvironmentName)
            ? HostEnvironment.EnvironmentName
            : DisplayOptions.CurrentValue.EnvironmentName.Trim();

    private async Task SetCollapsedStateAsync(bool collapsed)
    {
        IsNavCollapsed = collapsed;
        await StoreCollapsedStateAsync(persistBrowser: true);

        StateHasChanged();
    }

    private async Task<bool> LoadCollapsedStateAsync()
    {
        var browserValue = await JSRuntime.InvokeAsync<bool?>("cloudShellNav.getStoredCollapsed");
        if (browserValue.HasValue)
        {
            return browserValue.Value;
        }

        var storedValue = await Settings.GetSettingAsync(CloudShellUserSettingKeys.NavigationCollapsed);
        return string.Equals(storedValue?.Value, "true", StringComparison.OrdinalIgnoreCase);
    }

    private async Task StoreCollapsedStateAsync(bool persistBrowser)
    {
        await Settings.SetSettingAsync(
            CloudShellUserSettingKeys.NavigationCollapsed,
            IsNavCollapsed ? "true" : "false");
        await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", IsNavCollapsed, persistBrowser);
    }
}
