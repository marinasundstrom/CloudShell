@rendermode InteractiveServer
@inject ShellCatalog ShellCatalog
@inject Microsoft.Extensions.Options.IOptionsMonitor<CloudShellDisplayOptions> DisplayOptions
@inject ICloudShellUserSettingsProvider Settings
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<div class="brand">
    <div class="brand-mark">CS</div>
    <div class="brand-text">
        <div class="brand-name">@GetApplicationName()</div>
        <div class="brand-subtitle">@L["Platform control plane"]</div>
    </div>
    <button type="button"
            class="nav-toggle @CollapsedClass"
            title="@L["Toggle navigation"]"
            aria-label="@L["Toggle navigation"]"
            aria-expanded="@AriaExpanded"
            @onclick="ToggleNavigation">
        <span class="nav-toggle-icon" aria-hidden="true"></span>
    </button>
</div>

<nav class="nav-shell" aria-label="@L["Primary"]">
    @foreach (var group in ShellCatalog.NavigationItems.GroupBy(item => item.Group))
    {
        <section class="nav-group">
            <div class="nav-group-title">@L[group.Key]</div>

            @foreach (var item in group)
            {
                <NavLink class="nav-link" href="@item.Href" Match="@GetMatch(item.Href)">
                    <ShellNavigationIcon Icon="@item.Icon" />
                    <span class="nav-label">@L[item.Text]</span>
                </NavLink>
            }
        </section>
    }
</nav>

<div class="sidebar-footer">
    <span class="status-dot"></span>
    <span class="sidebar-footer-text">@L["Local workspace"]</span>
</div>

@code {
    private bool IsNavCollapsed { get; set; }

    private string AriaExpanded => IsNavCollapsed ? "false" : "true";
    private string? CollapsedClass => IsNavCollapsed ? "collapsed" : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        IsNavCollapsed = await LoadCollapsedStateAsync();
        await StoreCollapsedStateAsync();
        StateHasChanged();
    }

    private static NavLinkMatch GetMatch(string href) =>
        href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix;

    private string GetApplicationName() =>
        string.IsNullOrWhiteSpace(DisplayOptions.CurrentValue.ApplicationName)
            ? "CloudShell"
            : DisplayOptions.CurrentValue.ApplicationName.Trim();

    private async Task ToggleNavigation()
    {
        IsNavCollapsed = !IsNavCollapsed;
        await StoreCollapsedStateAsync();
    }

    private async Task<bool> LoadCollapsedStateAsync()
    {
        var browserValue = await JSRuntime.InvokeAsync<bool?>("cloudShellNav.getStoredCollapsed");
        if (browserValue.HasValue)
        {
            return browserValue.Value;
        }

        var storedValue = await Settings.GetSettingAsync(CloudShellUserSettingKeys.NavigationCollapsed);
        return string.Equals(storedValue?.Value, "true", StringComparison.OrdinalIgnoreCase);
    }

    private async Task StoreCollapsedStateAsync()
    {
        await Settings.SetSettingAsync(
            CloudShellUserSettingKeys.NavigationCollapsed,
            IsNavCollapsed ? "true" : "false");
        await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", IsNavCollapsed, true);
    }
}
