@inject ShellCatalog ShellCatalog
@inject ICloudShellUserSettingsProvider Settings
@inject Microsoft.Extensions.Options.IOptionsMonitor<CloudShellDisplayOptions> DisplayOptions
@inject IStringLocalizer<SharedResource> L
@using System.Text.Json

<div class="brand">
    <div class="brand-mark">CS</div>
    <div class="brand-text">
        <div class="brand-name">@GetApplicationName()</div>
        <div class="brand-subtitle">@L["Platform control plane"]</div>
    </div>
    <button type="button" id="navmenu-toggle" class="nav-toggle @CollapsedClass" title="@L["Toggle navigation"]"
            aria-label="@L["Toggle navigation"]" aria-expanded="@AriaExpanded" @onclick="ToggleNavigation">
        <span class="nav-toggle-icon" aria-hidden="true"></span>
    </button>
</div>

<nav class="nav-shell" aria-label="@L["Primary"]">
    <FluentNavMenu Class="cloudshell-nav-menu"
                   Title="@L["Primary"]"
                   Margin="0">
    @{
        var navigationItems = ShellCatalog.NavigationItems;
        var childItemsByParent = navigationItems
            .Where(item => !string.IsNullOrWhiteSpace(item.ParentId))
            .GroupBy(item => item.ParentId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.ToArray(), StringComparer.OrdinalIgnoreCase);
        var rootItems = navigationItems
            .Where(item => string.IsNullOrWhiteSpace(item.ParentId))
            .ToArray();
    }
    @foreach (var group in rootItems.GroupBy(item => item.Group))
    {
        <section class="nav-group">
            <div class="nav-group-title">@L[group.Key]</div>

            @foreach (var item in group)
            {
                var hasChildren = childItemsByParent.TryGetValue(item.Id, out var childItems);
                var childrenCollapsed = IsGroupCollapsed(item.Id);

                <div class="nav-parent-row @(hasChildren ? "has-children" : null)">
                    <FluentNavLink Class="cloudshell-nav-link"
                                   Href="@item.Href"
                                   Match="@GetMatch(item.Href)"
                                   Icon="@ShellNavigationIcons.FromName(item.Icon)"
                                   IconColor="Color.Neutral"
                                   Tooltip="@L[item.Text]"
                                   ActiveClass="active">
                        <span class="nav-label">@L[item.Text]</span>
                    </FluentNavLink>

                    @if (hasChildren)
                    {
                        <button type="button"
                                class="nav-group-toggle @(childrenCollapsed ? "collapsed" : null)"
                                title="@GetGroupToggleTitle(item, childrenCollapsed)"
                                aria-label="@GetGroupToggleTitle(item, childrenCollapsed)"
                                aria-expanded="@(!childrenCollapsed)"
                                @onclick="() => ToggleGroupAsync(item.Id)">
                            <span class="nav-chevron" aria-hidden="true"></span>
                        </button>
                    }
                </div>

                @if (hasChildren && !childrenCollapsed)
                {
                    <div class="nav-subitems">
                        @foreach (var child in childItems!)
                        {
                            <FluentNavLink Class="cloudshell-nav-link cloudshell-nav-sub-link"
                                           Href="@child.Href"
                                           Match="@GetMatch(child.Href)"
                                           Icon="@ShellNavigationIcons.FromName(child.Icon)"
                                           IconColor="Color.Neutral"
                                           Tooltip="@L[child.Text]"
                                           ActiveClass="active">
                                <span class="nav-label">@L[child.Text]</span>
                            </FluentNavLink>
                        }
                    </div>
                }
            }
        </section>
    }
    </FluentNavMenu>
</nav>

<div class="sidebar-footer">
    <span class="status-dot"></span>
    <span class="sidebar-footer-text">@L["Local workspace"]</span>
</div>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public EventCallback<bool> IsCollapsedChanged { get; set; }

    private string AriaExpanded => IsCollapsed ? "false" : "true";
    private string? CollapsedClass => IsCollapsed ? "collapsed" : null;
    private HashSet<string> CollapsedGroups { get; } = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var setting = await Settings.GetSettingAsync(CloudShellUserSettingKeys.NavigationCollapsedGroups);
        foreach (var groupId in ParseCollapsedGroups(setting?.Value))
        {
            CollapsedGroups.Add(groupId);
        }
    }

    private static NavLinkMatch GetMatch(string href) =>
        href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix;

    private string GetApplicationName() =>
        string.IsNullOrWhiteSpace(DisplayOptions.CurrentValue.ApplicationName)
            ? "CloudShell"
            : DisplayOptions.CurrentValue.ApplicationName.Trim();

    private Task ToggleNavigation() =>
        IsCollapsedChanged.InvokeAsync(!IsCollapsed);

    private bool IsGroupCollapsed(string itemId) =>
        CollapsedGroups.Contains(itemId);

    private async Task ToggleGroupAsync(string itemId)
    {
        if (!CollapsedGroups.Add(itemId))
        {
            CollapsedGroups.Remove(itemId);
        }

        await Settings.SetSettingAsync(
            CloudShellUserSettingKeys.NavigationCollapsedGroups,
            JsonSerializer.Serialize(CollapsedGroups.Order(StringComparer.OrdinalIgnoreCase)));
    }

    private string GetGroupToggleTitle(NavItemContribution item, bool collapsed) =>
        collapsed
            ? L["Expand {0}", L[item.Text]].Value
            : L["Collapse {0}", L[item.Text]].Value;

    private static IReadOnlyList<string> ParseCollapsedGroups(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return [];
        }

        try
        {
            return JsonSerializer.Deserialize<string[]>(value) ?? [];
        }
        catch (JsonException)
        {
            return value
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToArray();
        }
    }
}
