@rendermode InteractiveServer
@inject IJSRuntime JSRuntime
@inject ICloudShellUserSettingsProvider Settings
@inject IStringLocalizer<SharedResource> L

<button type="button"
        class="nav-toggle @CollapsedClass"
        title="@L["Toggle navigation"]"
        aria-label="@L["Toggle navigation"]"
        aria-expanded="@AriaExpanded"
        @onclick="ToggleNavigation">
    <span class="nav-toggle-icon" aria-hidden="true"></span>
</button>

@code {
    private bool IsNavCollapsed { get; set; }

    private string AriaExpanded => IsNavCollapsed ? "false" : "true";
    private string? CollapsedClass => IsNavCollapsed ? "collapsed" : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var storedValue = await Settings.GetSettingAsync(CloudShellUserSettingKeys.NavigationCollapsed);

        IsNavCollapsed = string.Equals(storedValue?.Value, "true", StringComparison.OrdinalIgnoreCase);
        await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", IsNavCollapsed, true);
        StateHasChanged();
    }

    private async Task ToggleNavigation()
    {
        IsNavCollapsed = !IsNavCollapsed;
        await Settings.SetSettingAsync(
            CloudShellUserSettingKeys.NavigationCollapsed,
            IsNavCollapsed ? "true" : "false");
        await JSRuntime.InvokeVoidAsync("cloudShellNav.setCollapsed", IsNavCollapsed, true);
    }
}
