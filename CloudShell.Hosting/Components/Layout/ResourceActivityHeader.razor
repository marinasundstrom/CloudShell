<div class="@CssClass" @attributes="AdditionalAttributes">
    <div>
        <h3>@Title</h3>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <span>@Subtitle</span>
        }
    </div>
    @if (Actions is not null)
    {
        @if (string.IsNullOrWhiteSpace(ActionsClass))
        {
            @Actions
        }
        else
        {
            <div class="@ActionsClass">
                @Actions
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public string? ActionsClass { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(Class)
        ? "resource-activity-header"
        : $"resource-activity-header {Class}";
}
