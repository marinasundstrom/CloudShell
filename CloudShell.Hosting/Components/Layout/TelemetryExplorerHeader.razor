<div class="@CssClass" @attributes="AdditionalAttributes">
    @if (ShowSummary)
    {
        @if (SummaryContent is not null)
        {
            @SummaryContent
        }
        else
        {
            <div>
                <h2>@Title</h2>
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <p>@Description</p>
                }
            </div>
        }
    }
    @if (ShowActions && Actions is not null)
    {
        <div class="log-viewer-actions">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter]
    public bool ShowSummary { get; set; } = true;

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? SummaryContent { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public bool ShowActions { get; set; } = true;

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass
    {
        get
        {
            var cssClass = "panel-header log-viewer-header";
            if (!ShowSummary)
            {
                cssClass += " controls-only";
            }

            return string.IsNullOrWhiteSpace(Class)
                ? cssClass
                : $"{cssClass} {Class}";
        }
    }
}
