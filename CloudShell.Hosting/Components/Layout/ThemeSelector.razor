@rendermode InteractiveServer
@inject ICloudShellUserSettingsProvider Settings
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<FluentDesignTheme @bind-Mode="Mode" StorageName="@StorageName" />

<div class="theme-selector">
    <FluentMenuButton Class="theme-menu-button" UseMenuService="false" ButtonAppearance="Appearance.Stealth"
                      ButtonStyle="width: 2.1rem; min-width: 2.1rem; height: 2.1rem; padding: 0;" title="@GetThemeDisplayName(Mode)"
                      aria-label="@L["Theme"]">
        <ButtonContent>
            <FluentIcon Value="@GetThemeIcon(Mode)" Color="Color.Neutral" />
        </ButtonContent>
        <ChildContent>
            @foreach (var mode in ThemeModes)
            {
                <FluentMenuItem @key="mode" OnClick="@(async () => await ChangeMode(mode))">
                    <span class="theme-menu-item">
                        <FluentIcon Value="@GetThemeIcon(mode)" Color="Color.Neutral" />
                        <span>@GetThemeDisplayName(mode)</span>
                    </span>
                </FluentMenuItem>
            }
        </ChildContent>
    </FluentMenuButton>
</div>

@code {
    private const string StorageName = "cloudshell.theme";

    private static readonly IReadOnlyList<DesignThemeModes> ThemeModes =
    [
        DesignThemeModes.System,
        DesignThemeModes.Light,
        DesignThemeModes.Dark
    ];

    private DesignThemeModes Mode { get; set; } = DesignThemeModes.System;

    protected override async Task OnInitializedAsync()
    {
        var setting = await Settings.GetSettingAsync(CloudShellUserSettingKeys.ThemeMode);
        if (Enum.TryParse<DesignThemeModes>(setting?.Value, ignoreCase: true, out var mode))
        {
            Mode = mode;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CacheThemeModeAsync();
        }
    }

    private string GetThemeDisplayName(DesignThemeModes mode) =>
        mode switch
        {
            DesignThemeModes.Light => L["Light"],
            DesignThemeModes.Dark => L["Dark"],
            _ => L["System"]
        };

    private static Icon GetThemeIcon(DesignThemeModes mode) =>
        mode switch
        {
            DesignThemeModes.Light => new Icons.Regular.Size20.WeatherSunny(),
            DesignThemeModes.Dark => new Icons.Regular.Size20.WeatherMoon(),
            _ => new Icons.Regular.Size20.System()
        };

    private async Task ChangeMode(DesignThemeModes mode)
    {
        Mode = mode;
        await Settings.SetSettingAsync(CloudShellUserSettingKeys.ThemeMode, mode.ToString());
        await CacheThemeModeAsync();

        StateHasChanged();
    }

    private ValueTask CacheThemeModeAsync() =>
        JSRuntime.InvokeVoidAsync(
            "cloudShellTheme.setMode",
            StorageName,
            GetFluentStorageMode());

    private string? GetFluentStorageMode() =>
        Mode switch
        {
            DesignThemeModes.Dark => "dark",
            DesignThemeModes.Light => "light",
            _ => null
        };
}
