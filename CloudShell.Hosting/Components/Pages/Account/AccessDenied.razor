@page "/account/access-denied"
@attribute [AllowAnonymous]
@layout AccountLayout
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Access denied"]</PageTitle>

<div class="account-heading">
    <span class="eyebrow">@L["Authorization"]</span>
    <h1>@L["Access denied"]</h1>
    <p>@L["Your identity does not have permission to access this CloudShell operation."]</p>
</div>

<FluentAnchor Appearance="Appearance.Accent" Href="/">
    @L["Return to CloudShell"]
</FluentAnchor>
