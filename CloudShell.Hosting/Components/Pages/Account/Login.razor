@page "/account/login"
@attribute [AllowAnonymous]
@attribute [ExcludeFromInteractiveRouting]
@layout AccountLayout
@inject IAccountService Accounts
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Sign in"]</PageTitle>

<div class="account-heading">
    <span class="eyebrow">@L["Authentication"]</span>
    <h1>@L["Sign in to CloudShell"]</h1>
</div>

@if (RequiresSetup)
{
    <FluentMessageBar Intent="MessageIntent.Info">
        @L["No local administrator exists yet."]
        <a href="/account/setup">@L["Set up CloudShell"]</a>
    </FluentMessageBar>
}
else if (UsesExternalProvider)
{
    <p>@L["Continue with the authentication provider configured for this dashboard."]</p>
    <FluentAnchor Appearance="Appearance.Accent" Href="@ChallengeUrl">
        @L["Continue"]
    </FluentAnchor>
}
else
{
    <EditForm Model="@Input"
              method="post"
              OnValidSubmit="SignIn"
              FormName="login"
              Enhance="false">
        <DataAnnotationsValidator />

        @if (Accounts.Mode.Equals("Identity", StringComparison.OrdinalIgnoreCase))
        {
            <label for="login-identifier">@GetIdentifierLabel()</label>
            <FluentTextField Id="login-identifier"
                             Name="Input.Identifier"
                             @bind-Value="Input!.Identifier"
                             AutoComplete="@GetIdentifierAutoComplete()" />
        }

        <label for="login-credential">
            @(Accounts.Mode.Equals("Secret", StringComparison.OrdinalIgnoreCase)
                ? L["Dashboard secret"]
                : L["Password"])
        </label>
        <FluentTextField Id="login-credential"
                         Name="Input.Credential"
                         TextFieldType="TextFieldType.Password"
                         @bind-Value="Input!.Credential"
                         AutoComplete="current-password" />

        <ValidationSummary />

        @if (Errors.Count > 0)
        {
            <FluentMessageBar Intent="MessageIntent.Error">
                @foreach (var error in Errors)
                {
                    <div>@error</div>
                }
            </FluentMessageBar>
        }

        <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit">
            @L["Sign in"]
        </FluentButton>
    </EditForm>
}

@code {
    [SupplyParameterFromForm]
    private LoginInput? Input { get; set; }

    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    private string? ReturnUrl { get; set; }

    private bool RequiresSetup { get; set; }
    private List<string> Errors { get; } = [];

    private bool UsesExternalProvider =>
        Accounts.Mode.Equals("OpenIdConnect", StringComparison.OrdinalIgnoreCase) ||
        Accounts.Mode.Equals("External", StringComparison.OrdinalIgnoreCase);

    private string ChallengeUrl =>
        $"/account/challenge?returnUrl={Uri.EscapeDataString(GetReturnUrl())}";

    protected override async Task OnInitializedAsync()
    {
        Input ??= new LoginInput();
        RequiresSetup =
            Accounts.Mode.Equals("Identity", StringComparison.OrdinalIgnoreCase) &&
            Accounts.AllowLocalSetup &&
            !await Accounts.HasLocalUsersAsync();
    }

    private async Task SignIn()
    {
        Errors.Clear();
        if (Accounts.Mode.Equals("Identity", StringComparison.OrdinalIgnoreCase) &&
            string.IsNullOrWhiteSpace(Input!.Identifier))
        {
            Errors.Add(Accounts.AllowUserNameSignIn
                ? L["Email or username is required."].Value
                : L["Email is required."].Value);
            return;
        }

        var result = await Accounts.SignInAsync(Input!.Identifier, Input.Credential);
        if (!result.Succeeded)
        {
            Errors.AddRange(result.Errors);
            return;
        }

        Navigation.NavigateTo(GetReturnUrl(), forceLoad: true);
    }

    private string GetReturnUrl() =>
        !string.IsNullOrWhiteSpace(ReturnUrl) &&
        ReturnUrl.StartsWith('/') &&
        !ReturnUrl.StartsWith("//", StringComparison.Ordinal)
            ? ReturnUrl
            : "/";

    private string GetIdentifierLabel() =>
        Accounts.AllowUserNameSignIn
            ? L["Email or username"].Value
            : L["Email"].Value;

    private string GetIdentifierAutoComplete() =>
        Accounts.AllowUserNameSignIn ? "username" : "email";

    private sealed class LoginInput
    {
        public string Identifier { get; set; } = string.Empty;

        [Required]
        public string Credential { get; set; } = string.Empty;
    }
}
