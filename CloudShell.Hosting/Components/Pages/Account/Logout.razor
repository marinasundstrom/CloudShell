@page "/account/logout"
@layout AccountLayout
@inject IAccountService Accounts
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Sign out"]</PageTitle>

<div class="account-heading">
    <span class="eyebrow">@L["Authentication"]</span>
    <h1>@L["Sign out"]</h1>
    <p>@L["End the current CloudShell session."]</p>
</div>

<EditForm Model="@Input"
          method="post"
          OnValidSubmit="SignOut"
          FormName="logout"
          Enhance="false">
    <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit">
        @L["Sign out"]
    </FluentButton>
    <FluentButton Appearance="Appearance.Neutral" Href="/">
        @L["Cancel"]
    </FluentButton>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private LogoutInput? Input { get; set; }

    protected override void OnInitialized()
    {
        Input ??= new LogoutInput();
    }

    private async Task SignOut()
    {
        await Accounts.SignOutAsync();
        Navigation.NavigateTo("/account/login", forceLoad: true);
    }

    private sealed class LogoutInput;
}
