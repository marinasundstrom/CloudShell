@page "/account/setup"
@attribute [AllowAnonymous]
@layout AccountLayout
@inject IAccountService Accounts
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Set up CloudShell"]</PageTitle>

<div class="account-heading">
    <span class="eyebrow">@L["First run"]</span>
    <h1>@L["Create the administrator"]</h1>
    <p>@L["This local account receives full access to all resource groups and resources."]</p>
</div>

@if (!CanSetUp)
{
    <FluentMessageBar Intent="MessageIntent.Warning">
        @L["Local account setup is unavailable or has already been completed."]
    </FluentMessageBar>
    <FluentButton Appearance="Appearance.Accent" Href="/account/login">
        @L["Return to sign in"]
    </FluentButton>
}
else
{
    <EditForm Model="@Input"
              method="post"
              OnValidSubmit="CreateAdministrator"
              FormName="setup"
              Enhance="false">
        <DataAnnotationsValidator />

        <label for="setup-email">@L["Email"]</label>
        <FluentTextField Id="setup-email"
                         @bind-Value="Input!.Email"
                         AutoComplete="email" />

        <label for="setup-password">@L["Password"]</label>
        <FluentTextField Id="setup-password"
                         TextFieldType="TextFieldType.Password"
                         @bind-Value="Input!.Password"
                         AutoComplete="new-password" />
        <small>@L["Use at least 12 characters with upper and lowercase letters, a number, and a symbol."]</small>

        <label for="setup-confirm">@L["Confirm password"]</label>
        <FluentTextField Id="setup-confirm"
                         TextFieldType="TextFieldType.Password"
                         @bind-Value="Input!.ConfirmPassword"
                         AutoComplete="new-password" />

        <ValidationSummary />

        @if (Errors.Count > 0)
        {
            <FluentMessageBar Intent="MessageIntent.Error">
                @foreach (var error in Errors)
                {
                    <div>@error</div>
                }
            </FluentMessageBar>
        }

        <FluentButton Appearance="Appearance.Accent" Type="ButtonType.Submit">
            @L["Create administrator"]
        </FluentButton>
    </EditForm>
}

@code {
    [SupplyParameterFromForm]
    private SetupInput? Input { get; set; }

    private bool CanSetUp { get; set; }
    private List<string> Errors { get; } = [];

    protected override async Task OnInitializedAsync()
    {
        Input ??= new SetupInput();
        CanSetUp =
            Accounts.Mode.Equals("Identity", StringComparison.OrdinalIgnoreCase) &&
            Accounts.AllowLocalSetup &&
            !await Accounts.HasLocalUsersAsync();
    }

    private async Task CreateAdministrator()
    {
        Errors.Clear();
        var result = await Accounts.CreateAdministratorAsync(Input!.Email, Input.Password);
        if (!result.Succeeded)
        {
            Errors.AddRange(result.Errors);
            return;
        }

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private sealed class SetupInput
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        [MinLength(12)]
        public string Password { get; set; } = string.Empty;

        [Compare(nameof(Password))]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
