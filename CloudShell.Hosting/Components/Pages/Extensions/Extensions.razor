@page "/extensions"
@rendermode InteractiveServer
@inject ShellCatalog ShellCatalog
@inject ICloudShellExtensionActivationStore ActivationStore
@inject ICloudShellAuthorizationService Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Extensions"]</PageTitle>

@if (!CanReadShell)
{
    <EmptyState Title="@L["Access denied"].Value"
                Message="@L["Your identity does not have permission to view shell configuration."].Value" />
}
else
{
    <section class="page-heading compact">
        <div>
            <span class="eyebrow">@L["Platform"]</span>
            <h1>@L["Extensions"]</h1>
            <p>@L["Extensions registered through the service container. Host configuration or this UI can activate their contributions."]</p>
        </div>
        <div class="heading-actions">
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSyncCircle())">
                @L["Reload"]
            </FluentButton>
        </div>
    </section>

    <section class="dashboard-grid">
        <article class="panel panel-wide">
            <ShellPanelHeader Title="@L["Shell extensions"].Value"
                              Description="@L["{0} supported extensions", ShellCatalog.SupportedExtensions.Count].Value" />

            <div class="extension-grid">
                @foreach (var status in ShellCatalog.ExtensionStatuses)
                {
                    var extension = status.Extension;
                    <div class="extension-card">
                        <div>
                            <strong>@extension.DisplayName</strong>
                            <span>@extension.Id · v@(extension.Version)</span>
                        </div>
                        <p>@extension.Description</p>
                        <div class="tag-row">
                            <span>@GetStatusText(status)</span>
                        </div>
                        <div class="tag-row">
                            @foreach (var capability in extension.Provides)
                            {
                                <span>@capability</span>
                            }
                        </div>
                        @if (status.IsActive &&
                            (extension.NavigationItems.Any(item => item.ShowInNavigation) ||
                            extension.CustomViews.Any(view => view.ShowInNavigation)))
                        {
                            <div class="extension-views">
                                @foreach (var item in extension.NavigationItems.Where(item => item.ShowInNavigation))
                                {
                                    <a href="@item.Href">@L[item.Text]</a>
                                }
                                @foreach (var view in extension.CustomViews.Where(view => view.ShowInNavigation))
                                {
                                    <a href="@view.Route">@L[view.Title]</a>
                                }
                            </div>
                        }
                        <div class="heading-actions">
                            @if (status.IsUserManaged && CanConfigureShell)
                            {
                                <FluentButton Appearance="@(status.IsActive ? Appearance.Neutral : Appearance.Accent)"
                                              OnClick="() => ToggleExtensionAsync(status)">
                                    @(status.IsActive ? L["Disable"] : L["Enable"])
                                </FluentButton>
                            }
                            else if (status.IsUserManaged)
                            {
                                <FluentButton Appearance="Appearance.Neutral" Disabled="true">
                                    @L["Read only"]
                                </FluentButton>
                            }
                            else
                            {
                                <FluentButton Appearance="Appearance.Neutral" Disabled="true">
                                    @L["Managed by host"]
                                </FluentButton>
                            }
                        </div>
                    </div>
                }
            </div>
        </article>

        <article class="panel">
            <ShellPanelHeader Title="@L["Resource types"].Value"
                              Description="@L["{0} available", ShellCatalog.ResourceTypes.Count].Value" />

            <div class="provider-list">
                @foreach (var resourceType in ShellCatalog.ResourceTypes)
                {
                    <div class="provider-row">
                        <div>
                            <span class="resource-kind-icon" aria-hidden="true">
                                <FluentIcon Value="@ResourceTypeIcons.FromName(resourceType.Icon)" />
                            </span>
                            <span>@L["type"]</span>
                        </div>
                        <div>
                            <strong>@resourceType.DisplayName</strong>
                            <span>@resourceType.Id</span>
                        </div>
                    </div>
                }
            </div>
        </article>
    </section>
}

@code {
    private bool CanReadShell =>
        Authorization.HasPermission(CloudShellPermissions.Shell.Read) || CanConfigureShell;

    private bool CanConfigureShell =>
        Authorization.HasPermission(CloudShellPermissions.Shell.Configure);

    private async Task ToggleExtensionAsync(CloudShellExtensionStatus status)
    {
        if (!status.IsUserManaged || !CanConfigureShell)
        {
            return;
        }

        var state = status.IsActive
            ? CloudShellExtensionActivationState.Disabled
            : CloudShellExtensionActivationState.Enabled;

        await ActivationStore.SetActivationStateAsync(
            status.Extension.Id,
            state,
            await GetUpdatedByAsync());
    }

    private async Task<string?> GetUpdatedByAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authenticationState.User;

        return user.Identity?.Name ??
            user.Claims.FirstOrDefault(claim => claim.Type.EndsWith("/name", StringComparison.OrdinalIgnoreCase))?.Value;
    }

    private string GetStatusText(CloudShellExtensionStatus status) =>
        status.Kind switch
        {
            CloudShellExtensionStatusKind.Enabled => L["Enabled"],
            CloudShellExtensionStatusKind.Disabled => L["Disabled"],
            CloudShellExtensionStatusKind.EnabledByHost => L["Enabled by host configuration"],
            CloudShellExtensionStatusKind.DisabledByHost => L["Disabled by host configuration"],
            CloudShellExtensionStatusKind.Blocked => L[status.Reason ?? "Blocked"],
            _ => status.Kind.ToString()
        };
}
