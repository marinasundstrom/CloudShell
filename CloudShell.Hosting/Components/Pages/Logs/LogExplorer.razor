@implements IAsyncDisposable
@inject ILogManager LogManager
@inject IResourceManager ResourceManager
@inject ResourceManagerDisplaySettings DisplaySettings
@inject NavigationManager Navigation
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L

@{
    var logs = GetSelectableLogs();
    var selectedLogView = ResolveLogView();
    var selectionIssue = selectedLogView == LogSourcesView ? null : GetSelectionIssue(logs);
    var selected = selectionIssue is null ? GetSelectedLog(logs, selectedLogView == LogSourcesView) : null;
    var selectedResourceFilterId = GetSelectedResourceFilterId();
}

@if (ShowHeading && Inline)
{
    <ResourceActivityHeader Title="@L["Logs"].Value"
                            Subtitle="@L["Resource telemetry"].Value"
                            ActionsClass="heading-actions">
        <Actions>
            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                    @L["Clear trace filter"]
                </FluentButton>
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshSelectedLog">
                @L["Refresh"]
            </FluentButton>
        </Actions>
    </ResourceActivityHeader>
}
else if (ShowHeading)
{
    <section class="page-heading compact">
        <div>
            <span class="eyebrow">@L["Logs"]</span>
            <h1>@L["Logs"]</h1>
            <p>@L["Browse logs registered by resources, providers, and extension-owned artifacts."]</p>
        </div>
        <div class="heading-actions">
            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                    @L["Clear trace filter"]
                </FluentButton>
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshSelectedLog">
                @L["Refresh"]
            </FluentButton>
        </div>
    </section>
}

<section class="trace-workspace">
    <div class="log-viewer @(UsePanel ? "panel" : null)">
        @if (selectionIssue is not null)
        {
            <EmptyState Title="@selectionIssue.Title" Message="@selectionIssue.Message">
                <FluentAnchor Appearance="Appearance.Neutral" Href="@selectionIssue.RecoveryHref">
                    @selectionIssue.RecoveryLabel
                </FluentAnchor>
            </EmptyState>
        }
        else if (selected is null)
        {
            <EmptyState Title="@L["No log selected"].Value"
                        Message="@L["Select a log source to inspect recent entries."].Value" />
        }
        else
        {
            <nav class="metric-view-tabs" role="tablist" aria-label="@L["Log views"]">
                <a class="@GetLogViewTabClass(LogStreamView, selectedLogView)"
                   role="tab"
                   aria-selected="@(selectedLogView == LogStreamView)"
                   href="@BuildLogViewRoute(LogStreamView, selected)">
                    @L["Stream"]
                </a>
                <a class="@GetLogViewTabClass(LogSourcesView, selectedLogView)"
                   role="tab"
                   aria-selected="@(selectedLogView == LogSourcesView)"
                   href="@BuildLogViewRoute(LogSourcesView, selected)">
                    @L["Sources"]
                </a>
            </nav>

            @if (selectedLogView == LogSourcesView)
            {
                <TelemetryExplorerHeader ShowSummary="@ShowSourceSummary"
                                         Title="@L["Log sources"].Value"
                                         Description="@L["{0} source(s) available", GetInventoryLogSources().Count].Value">
                    <Actions>
                        @if (!Inline)
                        {
                            <ResourceSourceSelect Id="log-resource-filter"
                                                  Label="@L["Resource"]"
                                                  Options="LogResourceFilters"
                                                  SelectedResourceId="selectedResourceFilterId"
                                                  SelectedResourceIdChanged="SelectResourceFilter"
                                                  AllOptionLabel="@L["All resources"].Value" />
                        }
                    </Actions>
                </TelemetryExplorerHeader>

                var inventorySources = GetInventoryLogSources();
                @if (ShowSourceInventory && inventorySources.Count > 0)
                {
                    <div class="log-source-inventory-shell">
                        <table class="log-source-inventory" aria-label="@L["Log sources"]">
                            <thead>
                                <tr>
                                    <th class="log-source-inventory-source" scope="col">@L["Source"]</th>
                                    <th class="log-source-inventory-log" scope="col">@L["Log"]</th>
                                    <th scope="col">@L["Kind"]</th>
                                    <th scope="col">@L["Format"]</th>
                                    <th scope="col">@L["Availability"]</th>
                                    <th scope="col">@L["Capabilities"]</th>
                                    <th class="log-source-inventory-action" scope="col">@L["Action"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var source in inventorySources)
                                {
                                    var isSelected = string.Equals(source.Id, selected.Id, StringComparison.OrdinalIgnoreCase);
                                    var isSelectable = IsSelectableLogSource(source, logs);
                                    var activityRoute = BuildActivityRoute(source);
                                    <tr class="@(isSelected ? "selected" : null)">
                                        <td class="log-source-inventory-source">
                                            <span title="@GetLogSourceLabel(source)">@GetLogSourceLabel(source)</span>
                                        </td>
                                        <td class="log-source-inventory-log">
                                            <span title="@source.Name">@source.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(source.Description))
                                            {
                                                <small>@source.Description</small>
                                            }
                                        </td>
                                        <td>@FormatLogSourceKind(source.Kind)</td>
                                        <td>@FormatLogFormat(source.Format)</td>
                                        <td>@FormatAvailability(source.Availability)</td>
                                        <td>@FormatCapabilities(source.Capabilities)</td>
                                        <td class="log-source-inventory-action">
                                            @if (isSelected)
                                            {
                                                <span>@L["Selected"]</span>
                                            }
                                            else if (isSelectable)
                                            {
                                                <FluentAnchor Appearance="Appearance.Neutral"
                                                              Href="@BuildLogSourceRoute(source, TraceId)">
                                                    @L["Open"]
                                                </FluentAnchor>
                                            }
                                            else if (activityRoute is not null)
                                            {
                                                <FluentAnchor Appearance="Appearance.Neutral"
                                                              Href="@activityRoute">
                                                    @L["Activity"]
                                                </FluentAnchor>
                                            }
                                            else
                                            {
                                                <span>@L["Listed"]</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <EmptyState Title="@L["No log sources"].Value"
                                Message="@L["No log sources are registered for this view."].Value"
                                Compact="true" />
                }
            }
            else
            {
                <TelemetryExplorerHeader ShowSummary="@ShowSourceSummary"
                                         Title="@GetLogSourceLabel(selected)"
                                         Description="@GetLogMetadataLabel(selected)">
                    <Actions>
                        @if (!ShowHeading && !string.IsNullOrWhiteSpace(TraceId))
                        {
                            <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                                @L["Clear trace filter"]
                            </FluentButton>
                        }
                        @if (!Inline)
                        {
                            <ResourceSourceSelect Id="log-resource-filter"
                                                  Label="@L["Resource"]"
                                                  Options="LogResourceFilters"
                                                  SelectedResourceId="selectedResourceFilterId"
                                                  SelectedResourceIdChanged="SelectResourceFilter"
                                                  AllOptionLabel="@L["All resources"].Value" />
                        }
                        <label class="trace-source-filter" for="log-source-filter">
                            <span>@L["Log source"]</span>
                            <select id="log-source-filter" class="trace-source-select" value="@selected.Id"
                                    @onchange="SelectLog">
                                @foreach (var log in logs)
                                {
                                    <option value="@log.Id">@GetLogOptionLabel(log)</option>
                                }
                            </select>
                        </label>
                        @if (IsCombinedLog(selected) && GetMergedSourceFilterOptions().Count > 1)
                        {
                            <details class="log-source-filter-menu">
                                <summary>
                                    <span>@L["Sources"]</span>
                                    <strong>@GetMergedSourceFilterSummary()</strong>
                                </summary>
                                <div class="log-source-filter-options" role="group" aria-label="@L["Merged log sources"]">
                                    <div class="log-source-filter-commands">
                                        <FluentButton Appearance="Appearance.Neutral"
                                                      Disabled="@AreAllMergedSourcesSelected()"
                                                      OnClick="SelectAllMergedSources">
                                            @L["All"]
                                        </FluentButton>
                                    </div>
                                    @foreach (var source in GetMergedSourceFilterOptions())
                                    {
                                        <FluentCheckbox Class="log-source-filter-checkbox"
                                                        Value="@IsMergedSourceSelected(source)"
                                                        ValueChanged="enabled => SetMergedSourceSelected(source.Id, enabled)">
                                            <span title="@GetMergedSourceFilterLabel(source)">@GetMergedSourceFilterLabel(source)</span>
                                        </FluentCheckbox>
                                    }
                                </div>
                            </details>
                        }
                        <FluentCheckbox Class="log-wrap-toggle" @bind-Value="WrapLogMessages">
                            @L["Wrap"]
                        </FluentCheckbox>
                        <FluentCheckbox Class="log-wrap-toggle" @bind-Value="ShowStructuredOnly"
                                        Disabled="@(GetStructuredEntryCount() == 0)">
                            @L["Structured only"]
                        </FluentCheckbox>
                        @if (selected.SupportsStreaming)
                        {
                            <FluentCheckbox Class="log-stream-toggle" Value="@IsSelectedLogStreaming(selected)"
                                            ValueChanged="enabled => SetStreamingEnabled(selected, enabled)" Disabled="@IsLoading">
                                @(IsSelectedLogStreaming(selected) ? L["Streaming"] : L["Stream"])
                            </FluentCheckbox>
                        }
                    </Actions>
                </TelemetryExplorerHeader>

                @if (ShowSourceDescription && !string.IsNullOrWhiteSpace(selected.Description))
                {
                    <p class="log-description">@selected.Description</p>
                }

                @if (!string.IsNullOrWhiteSpace(TraceId))
                {
                    <p class="log-description">@L["Showing entries correlated with trace {0}.", FormatTraceId(TraceId)]</p>
                }

                @if (IsLoading)
                {
                    <EmptyState Title="@L["Loading log entries"].Value"
                                Message="@L["Reading recent output from {0}.", selected.Provider].Value"
                                Compact="true" />
                }
                else if (ReadError is not null)
                {
                    <ProcedureMessage Message="@ReadError" />
                }
                else if (Entries.Count == 0)
                {
                    <EmptyState Title="@(IsSelectedLogStreaming(selected) ? L["Waiting for entries"].Value : L["No entries"].Value)"
                                Message="@(IsSelectedLogStreaming(selected)
                                    ? L["Streaming is active for this log source."].Value
                                    : GetNoEntriesMessage(selected))"
                                Compact="true" />
                }
                else
                    {
                        var visibleEntries = GetVisibleEntries();

                        <div class="log-history-bar">
                            <FluentButton Appearance="Appearance.Neutral" Disabled="@(!CanLoadOlderEntries || IsLoadingOlder)"
                                          OnClick="LoadOlderEntriesAsync">
                                @(IsLoadingOlder ? L["Loading older"] : L["Load older"])
                            </FluentButton>
                            <span>@GetEntryCountLabel(visibleEntries.Count)</span>
                        </div>

                        @if (visibleEntries.Count == 0)
                        {
                            <EmptyState Title="@GetEmptyFilteredTitle()"
                                        Message="@GetEmptyFilteredMessage()"
                                        Compact="true" />
                        }
                        else
                        {
                            <LogViewer @ref="LogViewerComponent"
                                       Entries="visibleEntries"
                                       WrapMessages="WrapLogMessages"
                                       AriaLabel="@selected.Name"
                                       TraceRouteFactory="entry => BuildTraceRoute(selected.ResourceId, entry.TraceId!)" />
                        }
                    }
                }
            }
        </div>
    </section>

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public string? LogId { get; set; }

    [Parameter]
    public string? TraceId { get; set; }

    [Parameter]
    public string? View { get; set; }

    [Parameter]
    public string? SourceIds { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public bool ShowHeading { get; set; } = true;

    [Parameter]
    public bool ShowSourceSummary { get; set; } = true;

    [Parameter]
    public bool ShowSourceDescription { get; set; } = true;

    [Parameter]
    public bool UsePanel { get; set; } = true;

    [Parameter]
    public bool ShowSourceInventory { get; set; } = true;

    private IReadOnlyList<LogEntry> Entries { get; set; } = [];
    private string? LoadedLogId { get; set; }
    private string? LoadedMergedSourceFilterKey { get; set; }
    private string? StreamingLogId { get; set; }
    private string? ReadError { get; set; }
    private CancellationTokenSource? StreamingCancellation { get; set; }
    private Task? StreamingTask { get; set; }
    private HashSet<string> DisabledStreamingLogIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private bool IsLoading { get; set; }
    private bool IsLoadingOlder { get; set; }
    private bool CanLoadOlderEntries { get; set; }
    private bool IsStreaming { get; set; }
    private bool WrapLogMessages { get; set; }
    private bool ShowStructuredOnly { get; set; }
    private bool ShouldScrollToLatest { get; set; }
    private int ScrollToLatestAttemptCount { get; set; }
    private double? PreservePrependedScrollHeight { get; set; }
    private bool IsDisposed { get; set; }
    private IReadOnlyList<LogSource> VisibleLogSources { get; set; } = [];
    private IReadOnlyList<ResourceSourceSelectOption> LogResourceFilters { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> LogResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private Resource? SelectedResource { get; set; }
    private LogViewer? LogViewerComponent { get; set; }

    private const string AllLogsId = "__all";
    private const string SourceIdsQueryName = "sourceIds";
    private const string LogStreamView = "stream";
    private const string LogSourcesView = "sources";
    private const int InitialWindowEntries = 100;
    private const int HistoryPageEntries = 100;
    private const int MaxWindowEntries = 500;
    private const int MaxScrollToLatestAttempts = 8;

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        await LoadVisibleLogsAsync();

        if (ResolveLogView() == LogSourcesView)
        {
            await StopStreamingAsync();
            return;
        }

        var selected = GetSelectedLog(GetSelectableLogs());
        if (selected is null)
        {
            await StopStreamingAsync();
            Entries = [];
            LoadedLogId = null;
            LoadedMergedSourceFilterKey = null;
            CanLoadOlderEntries = false;
            CancelScrollToLatest();
            return;
        }

        if (!string.Equals(LoadedLogId, selected.Id, StringComparison.OrdinalIgnoreCase) ||
            IsLoadedMergedSourceFilterStale(selected))
        {
            await StopStreamingAsync();
            await LoadLogAsync(selected);
            await StartStreamingByDefaultAsync(selected);
        }
        else
        {
            await StartStreamingByDefaultAsync(selected);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldScrollToLatest)
        {
            if (PreservePrependedScrollHeight is { } previousScrollHeight)
            {
                PreservePrependedScrollHeight = null;
                await PreservePrependedScrollAsync(previousScrollHeight);
            }

            return;
        }

        if (await ScrollLogToLatestAsync())
        {
            ShouldScrollToLatest = false;
            ScrollToLatestAttemptCount = 0;
            return;
        }

        if (ScrollToLatestAttemptCount < MaxScrollToLatestAttempts)
        {
            ScrollToLatestAttemptCount++;
            await Task.Delay(25);
            if (!IsDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            ShouldScrollToLatest = false;
            ScrollToLatestAttemptCount = 0;
        }
    }

    private IReadOnlyList<LogSource> GetVisibleLogs() =>
        VisibleLogSources;

    private IReadOnlyList<LogSource> GetSelectableLogs()
    {
        var logs = GetVisibleLogs();
        var operationalLogs = GetOperationalLogSources(logs);
        if (operationalLogs.Count == 0)
        {
            return logs;
        }

        return operationalLogs.Count == 1
            ? operationalLogs
            : [CreateCombinedLogSource(operationalLogs), .. operationalLogs];
    }

    private IReadOnlyList<LogSource> GetOperationalLogSources(IReadOnlyList<LogSource> logs) =>
        logs
            .Where(log => !IsCombinedLog(log) && !IsActivityLog(log))
            .ToArray();

    private IReadOnlyList<LogSource> GetMergedLogSources()
    {
        var sources = GetOperationalLogSources(VisibleLogSources);
        var requestedSourceIds = GetRequestedMergedSourceIds();
        if (requestedSourceIds is null)
        {
            return sources;
        }

        return sources
            .Where(source => requestedSourceIds.Contains(source.Id))
            .ToArray();
    }

    private IReadOnlyList<LogSource> GetMergedSourceFilterOptions() =>
        GetOperationalLogSources(VisibleLogSources)
            .OrderBy(source => GetLogSourceLabel(source), StringComparer.OrdinalIgnoreCase)
            .ThenBy(source => source.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<LogSource> GetInventoryLogSources() =>
        VisibleLogSources
            .Where(log => !IsCombinedLog(log))
            .OrderBy(log => GetLogSourceLabel(log), StringComparer.OrdinalIgnoreCase)
            .ThenBy(log => log.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private LogSource CreateCombinedLogSource(IReadOnlyList<LogSource> logs)
    {
        var selectedResourceFilterId = GetSelectedResourceFilterId();
        var resourceId = Inline
            ? (string.IsNullOrWhiteSpace(ResourceId) ? null : ResourceId)
            : selectedResourceFilterId;
        var sourceName = SelectedResource is null
            ? null
            : GetResourceLabel(SelectedResource);
        sourceName ??=
            selectedResourceFilterId is null
                ? L["All resources"].Value
                : LogResourceFilters.FirstOrDefault(option =>
                    string.Equals(option.ResourceId, selectedResourceFilterId, StringComparison.OrdinalIgnoreCase))?.Name
                    ?? selectedResourceFilterId;
        return new LogSource(
            AllLogsId,
            L["All logs"].Value,
            L["Telemetry"].Value,
            sourceName,
            LogSourceKind.Resource,
            ResourceId: resourceId,
            Description: logs.Count == 1
                ? L["Recent entries from the available operational log source."].Value
                : L["Merged recent entries from all operational log sources."].Value);
    }

    private IReadOnlySet<string>? GetRequestedMergedSourceIds()
    {
        if (SourceIds is null)
        {
            return null;
        }

        return SourceIds
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private bool IsMergedSourceSelected(LogSource source) =>
        GetRequestedMergedSourceIds() is not { } selectedIds ||
        selectedIds.Contains(source.Id);

    private bool AreAllMergedSourcesSelected()
    {
        var sources = GetMergedSourceFilterOptions();
        return sources.Count == 0 || GetMergedLogSources().Count == sources.Count;
    }

    private string GetMergedSourceFilterSummary()
    {
        var sources = GetMergedSourceFilterOptions();
        var selectedCount = GetMergedLogSources().Count;
        return selectedCount == sources.Count
            ? L["All sources"].Value
            : L["{0} of {1}", selectedCount, sources.Count].Value;
    }

    private string GetMergedSourceFilterLabel(LogSource source) =>
        $"{GetLogSourceLabel(source)} / {source.Name}";

    private string GetMergedSourceFilterKey() =>
        string.Join(
            "|",
            GetMergedLogSources()
                .Select(source => source.Id)
                .OrderBy(id => id, StringComparer.OrdinalIgnoreCase));

    private bool IsLoadedMergedSourceFilterStale(LogSource selected) =>
        IsCombinedLog(selected) &&
        !string.Equals(LoadedMergedSourceFilterKey, GetMergedSourceFilterKey(), StringComparison.Ordinal);

    private void SelectAllMergedSources() =>
        NavigateToMergedSourceFilter(null);

    private void SetMergedSourceSelected(string sourceId, bool selected)
    {
        var selectedIds = GetRequestedMergedSourceIds() is { } requestedSourceIds
            ? new HashSet<string>(requestedSourceIds, StringComparer.OrdinalIgnoreCase)
            : GetMergedSourceFilterOptions()
                .Select(source => source.Id)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (selected)
        {
            selectedIds.Add(sourceId);
        }
        else
        {
            selectedIds.Remove(sourceId);
        }

        NavigateToMergedSourceFilter(selectedIds);
    }

    private void NavigateToMergedSourceFilter(IReadOnlySet<string>? selectedSourceIds)
    {
        var selected = GetSelectedLog(GetSelectableLogs());
        if (selected is null)
        {
            return;
        }

        Navigation.NavigateTo(BuildLogRoute(selected, TraceId, selectedSourceIds));
    }

    private IReadOnlyList<LogEntry> GetVisibleEntries()
    {
        var entries = Entries.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(TraceId))
        {
            entries = entries.Where(entry =>
                string.Equals(entry.TraceId, TraceId, StringComparison.OrdinalIgnoreCase));
        }

        if (ShowStructuredOnly)
        {
            entries = entries.Where(LogView.HasStructuredMetadata);
        }

        return entries.ToArray();
    }

    private int GetStructuredEntryCount() =>
        Entries.Count(LogView.HasStructuredMetadata);

    private string GetEntryCountLabel(int visibleEntryCount)
    {
        var structuredCount = GetStructuredEntryCount();
        return ShowStructuredOnly
            ? L["{0} structured entries in view", visibleEntryCount].Value
            : L["{0} entries in view / {1} structured", visibleEntryCount, structuredCount].Value;
    }

    private async Task LoadVisibleLogsAsync()
    {
        if (Inline)
        {
            var query = string.IsNullOrWhiteSpace(ResourceId)
                ? null
                : new LogQuery(ResourceId: ResourceId);
            var inlineLogSources = await LogManager.ListLogSourcesAsync(query);
            VisibleLogSources = inlineLogSources;
            LogResourceFilters = [];
            LogResourcesById = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
            SelectedResource = string.IsNullOrWhiteSpace(ResourceId)
                ? null
                : await ResourceManager.GetResourceAsync(ResourceId);
            if (SelectedResource is not null)
            {
                LogResourcesById = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase)
                {
                    [SelectedResource.Id] = SelectedResource
                };
            }
            return;
        }

        var allLogSources = await LogManager.ListLogSourcesAsync();
        var resourceIds = allLogSources
            .Select(log => log.ResourceId)
            .Where(resourceId => !string.IsNullOrWhiteSpace(resourceId))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        IReadOnlyList<Resource> resources = resourceIds.Length == 0 &&
            string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : await ResourceManager.ListResourcesAsync();
        var resourcesById = resources.ToDictionary(resource => resource.Id, StringComparer.OrdinalIgnoreCase);
        LogResourcesById = resourcesById;

        LogResourceFilters = resourceIds
            .Select(resourceId => new ResourceSourceSelectOption(
                resourceId!,
                resourcesById.TryGetValue(resourceId!, out var resource)
                    ? GetResourceLabel(resource)
                    : allLogSources.First(log => string.Equals(log.ResourceId, resourceId, StringComparison.OrdinalIgnoreCase)).SourceName))
            .OrderBy(option => option.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        var selectedResourceFilterId = GetSelectedResourceFilterId();
        SelectedResource = selectedResourceFilterId is not null &&
            resourcesById.TryGetValue(selectedResourceFilterId, out var selectedResource)
                ? selectedResource
                : null;
        VisibleLogSources = selectedResourceFilterId is null
            ? allLogSources
            : allLogSources
                .Where(log => string.Equals(log.ResourceId, selectedResourceFilterId, StringComparison.OrdinalIgnoreCase))
                .ToArray();
    }

    private LogSource? GetSelectedLog(
        IReadOnlyList<LogSource> logs,
        bool ignoreSelectionIssue = false)
    {
        if (!ignoreSelectionIssue && GetSelectionIssue(logs) is not null)
        {
            return null;
        }

        if (!string.IsNullOrWhiteSpace(LogId))
        {
            var requested = logs.FirstOrDefault(log =>
                string.Equals(log.Id, LogId, StringComparison.OrdinalIgnoreCase));
            if (requested is not null)
            {
                return requested;
            }
        }

        return GetDefaultLog(logs);
    }

    private LogSelectionIssue? GetSelectionIssue(IReadOnlyList<LogSource> logs)
    {
        if (IsRequestedResourceFilterUnavailable())
        {
            var resourceId = ResourceId?.Trim() ?? string.Empty;
            return new LogSelectionIssue(
                L["Resource log filter not found"].Value,
                L["No log sources are registered for resource '{0}'.", GetResourceLabel(resourceId)].Value,
                L["Show all logs"].Value,
                "/logs");
        }

        if (!string.IsNullOrWhiteSpace(LogId) &&
            !logs.Any(log => string.Equals(log.Id, LogId, StringComparison.OrdinalIgnoreCase)))
        {
            var recoveryHref = Inline && !string.IsNullOrWhiteSpace(ResourceId)
                ? ResourceManagerCompositionLinks.ResourceDetails(Composition, ResourceId, ResourcePredefinedViewIds.Logs)
                : BuildAllLogsRoute();
            return new LogSelectionIssue(
                L["Log source not found"].Value,
                L["Log source '{0}' is not available in the current log view.", LogId.Trim()].Value,
                L["Show available logs"].Value,
                recoveryHref);
        }

        return null;
    }

    private static LogSource? GetDefaultLog(IReadOnlyList<LogSource> logs) =>
        logs.FirstOrDefault(IsCombinedLog)
        ?? logs.FirstOrDefault(log => log.SupportsStreaming)
        ?? logs.FirstOrDefault(log => !IsActivityLog(log))
        ?? logs.FirstOrDefault();

    private static bool IsCombinedLog(LogSource log) =>
        string.Equals(log.Id, AllLogsId, StringComparison.OrdinalIgnoreCase);

    private static bool IsSelectableLogSource(LogSource source, IReadOnlyList<LogSource> logs) =>
        logs.Any(log => string.Equals(log.Id, source.Id, StringComparison.OrdinalIgnoreCase));

    private string ResolveLogView() =>
        string.Equals(View, LogSourcesView, StringComparison.OrdinalIgnoreCase)
            ? LogSourcesView
            : LogStreamView;

    private string GetLogViewTabClass(string view, string selectedView) =>
        string.Equals(view, selectedView, StringComparison.OrdinalIgnoreCase)
            ? "metric-view-tab active"
            : "metric-view-tab";

    private static bool IsActivityLog(LogSource log) =>
        log.Kind == ResourceLogSourceKind.Activity ||
        (string.Equals(log.Provider, "Activity", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(log.Name, "Activity", StringComparison.OrdinalIgnoreCase));

    private void SelectLog(ChangeEventArgs args) =>
        SelectLog(args.Value?.ToString());

    private void SelectResourceFilter(string? resourceId)
    {
        var query = new Dictionary<string, string?>();
        if (!string.IsNullOrWhiteSpace(resourceId))
        {
            query["resourceId"] = resourceId;
        }
        AddLogViewQuery(query, ResolveLogView());

        if (!string.IsNullOrWhiteSpace(TraceId))
        {
            query["traceId"] = TraceId.Trim();
        }

        Navigation.NavigateTo(Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query));
    }

    private void SelectLog(string? logId)
    {
        if (string.IsNullOrWhiteSpace(logId) ||
            string.Equals(logId, LogId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var log = GetSelectableLogs().FirstOrDefault(candidate =>
            string.Equals(candidate.Id, logId, StringComparison.OrdinalIgnoreCase));
        if (log is not null)
        {
            Navigation.NavigateTo(BuildLogSourceRoute(log, TraceId));
        }
    }

    private string GetLogOptionLabel(LogSource log) =>
        IsCombinedLog(log)
            ? log.Name
            : $"{GetLogSourceLabel(log)} / {log.Name}";

    private string GetLogMetadataLabel(LogSource log)
    {
        if (IsCombinedLog(log))
        {
            return $"{log.Name} / {log.Provider} / {log.SourceKind}";
        }

        return $"{log.Name} / {log.Provider} / {FormatLogSourceKind(log.Kind)} / {FormatLogFormat(log.Format)} / {FormatAvailability(log.Availability)}";
    }

    private string GetLogSourceLabel(LogSource log) =>
        !string.IsNullOrWhiteSpace(log.ResourceId) &&
        LogResourcesById.TryGetValue(log.ResourceId, out var resource)
            ? GetResourceLabel(resource)
            : log.SourceName;

    private string FormatLogSourceKind(ResourceLogSourceKind kind) =>
        kind switch
        {
            ResourceLogSourceKind.ProcessOutput => L["Process output"].Value,
            ResourceLogSourceKind.ProcessStdout => L["Process stdout"].Value,
            ResourceLogSourceKind.ProcessStderr => L["Process stderr"].Value,
            ResourceLogSourceKind.File => L["File"].Value,
            ResourceLogSourceKind.FilePattern => L["File pattern"].Value,
            ResourceLogSourceKind.Container => L["Container"].Value,
            ResourceLogSourceKind.External => L["External"].Value,
            ResourceLogSourceKind.Activity => L["Activity"].Value,
            ResourceLogSourceKind.ProviderDefined => L["Provider defined"].Value,
            _ => L["Other"].Value
        };

    private string FormatLogFormat(LogFormat format) =>
        format switch
        {
            LogFormat.PlainText => L["Plain text"].Value,
            LogFormat.JsonConsole => L["JSON console"].Value,
            LogFormat.SerilogCompactJson => L["Serilog compact JSON"].Value,
            LogFormat.OpenTelemetry => L["OpenTelemetry"].Value,
            LogFormat.Structured => L["Structured"].Value,
            LogFormat.ResourceEvent => L["Resource event"].Value,
            LogFormat.ProviderDefined => L["Provider defined"].Value,
            _ => format.ToString()
        };

    private string FormatAvailability(LogSourceAvailability availability) =>
        availability switch
        {
            LogSourceAvailability.ResourceRunning => L["Resource running"].Value,
            LogSourceAvailability.ProducerRunning => L["Producer running"].Value,
            LogSourceAvailability.Persisted => L["Persisted"].Value,
            LogSourceAvailability.Always => L["Always available"].Value,
            LogSourceAvailability.ProviderDefined => L["Provider defined"].Value,
            _ => L["Availability unknown"].Value
        };

    private string FormatCapabilities(LogSourceCapabilities capabilities)
    {
        if (capabilities == LogSourceCapabilities.None)
        {
            return L["None"].Value;
        }

        var labels = new List<string>();
        AddCapabilityLabel(labels, capabilities, LogSourceCapabilities.Read, L["Read"].Value);
        AddCapabilityLabel(labels, capabilities, LogSourceCapabilities.Stream, L["Stream"].Value);
        AddCapabilityLabel(labels, capabilities, LogSourceCapabilities.Query, L["Query"].Value);
        AddCapabilityLabel(labels, capabilities, LogSourceCapabilities.Search, L["Search"].Value);
        AddCapabilityLabel(labels, capabilities, LogSourceCapabilities.StructuredFields, L["Structured"].Value);

        return string.Join(", ", labels);
    }

    private static void AddCapabilityLabel(
        List<string> labels,
        LogSourceCapabilities capabilities,
        LogSourceCapabilities capability,
        string label)
    {
        if (capabilities.HasFlag(capability))
        {
            labels.Add(label);
        }
    }

    private string GetResourceLabel(Resource resource) =>
        DisplaySelection.GetResourceLabel(resource);

    private string GetResourceLabel(string resourceId) =>
        LogResourcesById.TryGetValue(resourceId, out var resource)
            ? GetResourceLabel(resource)
            : ResourceDisplayLabels.GetName(resourceId);

    private void ClearTraceFilter()
    {
        var selected = GetSelectedLog(GetSelectableLogs());
        if (selected is null)
        {
            if (Inline && !string.IsNullOrWhiteSpace(ResourceId))
            {
                Navigation.NavigateTo(ResourceManagerCompositionLinks.ResourceDetails(Composition, ResourceId, ResourcePredefinedViewIds.Logs));
            }
            else
            {
                var query = new Dictionary<string, string?>();
                if (GetSelectedResourceFilterId() is { Length: > 0 } resourceId)
                {
                    query["resourceId"] = resourceId;
                }

                Navigation.NavigateTo(Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query));
            }

            return;
        }

        Navigation.NavigateTo(BuildLogRoute(selected));
    }

    private async Task RefreshSelectedLog()
    {
        await LoadVisibleLogsAsync();
        var selected = GetSelectedLog(GetSelectableLogs());
        if (selected is not null)
        {
            await StopStreamingAsync();
            await LoadLogAsync(selected);
            await StartStreamingByDefaultAsync(selected);
        }
    }

    private async Task LoadLogAsync(LogSource log)
    {
        IsLoading = true;
        ReadError = null;
        try
        {
            Entries = IsCombinedLog(log)
                ? await ReadCombinedLogAsync(InitialWindowEntries)
                : await LogManager.ReadLogSourceAsync(
                    log.Id,
                    new ReadLogOptions(MaxEntries: InitialWindowEntries));
            CanLoadOlderEntries = Entries.Count >= InitialWindowEntries;
            if (Entries.Count > 0)
            {
                RequestScrollToLatest();
            }
            LoadedLogId = log.Id;
            LoadedMergedSourceFilterKey = IsCombinedLog(log) ? GetMergedSourceFilterKey() : null;
        }
        catch (Exception exception)
        {
            Entries = [];
            CanLoadOlderEntries = false;
            ReadError = exception.Message;
            LoadedLogId = log.Id;
            LoadedMergedSourceFilterKey = IsCombinedLog(log) ? GetMergedSourceFilterKey() : null;
            CancelScrollToLatest();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task<IReadOnlyList<LogEntry>> ReadCombinedLogAsync(
        int maxEntries,
        DateTimeOffset? before = null)
    {
        var sources = GetMergedLogSources();
        if (sources.Count == 0)
        {
            return [];
        }

        var reads = await Task.WhenAll(
            sources.Select(async log => new
            {
                Source = log,
                Entries = await LogManager.ReadLogSourceAsync(
                    log.Id,
                    new ReadLogOptions(
                        MaxEntries: maxEntries,
                        Before: before))
            }));

        return reads
            .SelectMany(read => read.Entries.Select(entry => WithMergedEntrySource(read.Source, entry)))
            .DistinctBy(GetEntryKey)
            .OrderBy(entry => entry.Timestamp)
            .TakeLast(maxEntries)
            .ToArray();
    }

    private LogEntry WithMergedEntrySource(LogSource source, LogEntry entry)
    {
        var sourceLabel = GetLogSourceLabel(source);
        var entrySource = string.IsNullOrWhiteSpace(entry.Source)
            ? source.Name
            : entry.Source;
        return entry with
        {
            Source = $"{sourceLabel} / {entrySource}"
        };
    }

    private async Task LoadOlderEntriesAsync()
    {
        var selected = GetSelectedLog(GetSelectableLogs());
        if (selected is null ||
            Entries.Count == 0 ||
            IsLoadingOlder)
        {
            return;
        }

        IsLoadingOlder = true;
        ReadError = null;
        var previousScrollHeight = await GetLogScrollHeightAsync();

        try
        {
            var before = Entries.Min(entry => entry.Timestamp);
            var olderEntries = IsCombinedLog(selected)
                ? await ReadCombinedLogAsync(HistoryPageEntries, before)
                : await LogManager.ReadLogSourceAsync(
                    selected.Id,
                    new ReadLogOptions(
                        MaxEntries: HistoryPageEntries,
                        Before: before));

            CanLoadOlderEntries = olderEntries.Count >= HistoryPageEntries;
            Entries = olderEntries
                .Concat(Entries)
                .DistinctBy(GetEntryKey)
                .OrderBy(entry => entry.Timestamp)
                .Take(MaxWindowEntries)
                .ToArray();
            CancelScrollToLatest();
            PreservePrependedScrollHeight = previousScrollHeight;
        }
        catch (Exception exception)
        {
            ReadError = exception.Message;
        }
        finally
        {
            IsLoadingOlder = false;
        }
    }

    private async Task SetStreamingEnabled(LogSource log, bool enabled)
    {
        if (enabled)
        {
            DisabledStreamingLogIds.Remove(log.Id);
            await StartStreamingAsync(log);
            return;
        }

        DisabledStreamingLogIds.Add(log.Id);
        await StopStreamingAsync();
    }

    private async Task StartStreamingByDefaultAsync(LogSource log)
    {
        if (log.SupportsStreaming && !DisabledStreamingLogIds.Contains(log.Id))
        {
            await StartStreamingAsync(log);
        }
    }

    private async Task StartStreamingAsync(LogSource log)
    {
        if (!log.SupportsStreaming ||
            IsSelectedLogStreaming(log))
        {
            return;
        }

        await StopStreamingAsync();

        ReadError = null;
        var cancellation = new CancellationTokenSource();
        StreamingCancellation = cancellation;
        StreamingLogId = log.Id;
        IsStreaming = true;
        RequestScrollToLatest();
        StreamingTask = StreamEntriesAsync(log, cancellation);
    }

    private async Task StopStreamingAsync()
    {
        var cancellation = StreamingCancellation;
        if (cancellation is null)
        {
            IsStreaming = false;
            StreamingLogId = null;
            StreamingTask = null;
            return;
        }

        cancellation.Cancel();
        StreamingCancellation = null;
        StreamingTask = null;
        StreamingLogId = null;
        IsStreaming = false;
        await Task.CompletedTask;
    }

    private async Task StreamEntriesAsync(LogSource log, CancellationTokenSource cancellation)
    {
        try
        {
            await foreach (var entry in LogManager.StreamLogSourceAsync(
                log.Id,
                new StreamLogOptions(InitialEntries: 0),
                cancellation.Token))
            {
                var shouldFollowLatest = true;
                await InvokeAsync(async () =>
                {
                    shouldFollowLatest = await IsLogAtLatestAsync();
                });
                await InvokeAsync(() =>
                {
                    if (!string.Equals(LoadedLogId, log.Id, StringComparison.OrdinalIgnoreCase))
                    {
                        return;
                    }

                    Entries = Entries
                        .Concat([entry])
                        .TakeLast(MaxWindowEntries)
                        .ToArray();
                    if (shouldFollowLatest)
                    {
                        RequestScrollToLatest();
                    }
                    else
                    {
                        CancelScrollToLatest();
                    }
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception exception)
        {
            if (!cancellation.IsCancellationRequested)
            {
                await InvokeAsync(() => ReadError = exception.Message);
            }
        }
        finally
        {
            if (ReferenceEquals(StreamingCancellation, cancellation))
            {
                StreamingCancellation = null;
                StreamingTask = null;
                StreamingLogId = null;
                IsStreaming = false;
                cancellation.Dispose();

                if (!IsDisposed)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
            else
            {
                cancellation.Dispose();
            }
        }
    }

    private bool IsSelectedLogStreaming(LogSource log) =>
        IsStreaming &&
        string.Equals(StreamingLogId, log.Id, StringComparison.OrdinalIgnoreCase);

    private async Task<bool> IsLogAtLatestAsync()
    {
        return LogViewerComponent is null || await LogViewerComponent.IsAtLatestAsync();
    }

    private async Task<bool> ScrollLogToLatestAsync()
    {
        return LogViewerComponent is not null && await LogViewerComponent.ScrollToLatestAsync();
    }

    private void RequestScrollToLatest()
    {
        ShouldScrollToLatest = true;
        ScrollToLatestAttemptCount = 0;
    }

    private void CancelScrollToLatest()
    {
        ShouldScrollToLatest = false;
        ScrollToLatestAttemptCount = 0;
    }

    private async Task<double> GetLogScrollHeightAsync() =>
        LogViewerComponent is null ? 0 : await LogViewerComponent.GetScrollHeightAsync();

    private async Task PreservePrependedScrollAsync(double previousScrollHeight)
    {
        if (LogViewerComponent is not null)
        {
            await LogViewerComponent.PreservePrependedScrollAsync(previousScrollHeight);
        }
    }

    private static (
        DateTimeOffset Timestamp,
        string Message,
        string? Severity,
        string? Source,
        string? EventId,
        string? Category,
        string? TraceId,
        string? SpanId) GetEntryKey(LogEntry entry) =>
        (
            entry.Timestamp,
            entry.Message,
            entry.Severity,
            entry.Source,
            entry.EventId,
            entry.Category,
            entry.TraceId,
            entry.SpanId);

    private string BuildLogRoute(
        LogSource log,
        string? traceId = null,
        IReadOnlySet<string>? mergedSourceIds = null)
    {
        var query = new Dictionary<string, string?>();
        if (!IsCombinedLog(log))
        {
            query["logId"] = log.Id;
        }
        else
        {
            AddMergedSourceFilterQuery(query, mergedSourceIds);
        }

        AddLogViewQuery(query, ResolveLogView());

        if (Inline && !string.IsNullOrWhiteSpace(log.ResourceId))
        {
            if (!string.IsNullOrWhiteSpace(traceId))
            {
                query["traceId"] = traceId.Trim();
            }

            return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                ResourceManagerCompositionLinks.ResourceDetails(Composition, log.ResourceId, ResourcePredefinedViewIds.Logs),
                query);
        }

        if (GetSelectedResourceFilterId() is { Length: > 0 } resourceId)
        {
            query["resourceId"] = resourceId;
        }

        if (!string.IsNullOrWhiteSpace(traceId))
        {
            query["traceId"] = traceId.Trim();
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query);
    }

    private string BuildLogSourceRoute(LogSource log, string? traceId = null)
    {
        if (Inline || IsCombinedLog(log))
        {
            return BuildLogRoute(log, traceId);
        }

        var query = new Dictionary<string, string?>
        {
            ["logId"] = log.Id
        };
        AddLogViewQuery(query, LogStreamView);

        if (!string.IsNullOrWhiteSpace(traceId))
        {
            query["traceId"] = traceId.Trim();
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query);
    }

    private string BuildLogViewRoute(string view, LogSource? selected)
    {
        var query = new Dictionary<string, string?>();
        if (selected is not null && !IsCombinedLog(selected))
        {
            query["logId"] = selected.Id;
        }
        else if (selected is not null)
        {
            AddMergedSourceFilterQuery(query);
        }

        AddLogViewQuery(query, view);

        if (!string.IsNullOrWhiteSpace(TraceId))
        {
            query["traceId"] = TraceId.Trim();
        }

        if (Inline && !string.IsNullOrWhiteSpace(ResourceId))
        {
            return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                ResourceManagerCompositionLinks.ResourceDetails(Composition, ResourceId, ResourcePredefinedViewIds.Logs),
                query);
        }

        if (GetSelectedResourceFilterId() is { Length: > 0 } resourceId)
        {
            query["resourceId"] = resourceId;
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query);
    }

    private void AddLogViewQuery(Dictionary<string, string?> query, string view)
    {
        if (!string.Equals(view, LogStreamView, StringComparison.OrdinalIgnoreCase))
        {
            query[Inline ? "logView" : "view"] = view;
        }
    }

    private void AddMergedSourceFilterQuery(
        Dictionary<string, string?> query,
        IReadOnlySet<string>? selectedSourceIds = null)
    {
        var sources = GetMergedSourceFilterOptions();
        if (sources.Count <= 1)
        {
            return;
        }

        var sourceIds = selectedSourceIds ?? GetRequestedMergedSourceIds();
        if (sourceIds is null)
        {
            return;
        }

        var knownSourceIds = sources
            .Where(source => sourceIds.Contains(source.Id))
            .Select(source => source.Id)
            .OrderBy(id => id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (knownSourceIds.Length == sources.Count)
        {
            return;
        }

        query[SourceIdsQueryName] = string.Join(",", knownSourceIds);
    }

    private string? BuildActivityRoute(LogSource log) =>
        IsActivityLog(log) && !string.IsNullOrWhiteSpace(log.ResourceId)
            ? ResourceManagerCompositionLinks.ResourceDetails(
                Composition,
                log.ResourceId,
                ResourcePredefinedViewIds.Activity)
            : null;

    private string GetEmptyFilteredTitle() =>
        !string.IsNullOrWhiteSpace(TraceId)
            ? L["No related log entries"].Value
            : L["No structured entries"].Value;

    private string GetEmptyFilteredMessage() =>
        !string.IsNullOrWhiteSpace(TraceId)
            ? L["This log source has entries, but none are correlated with the selected trace."].Value
            : L["This log source has entries, but none contain structured metadata."].Value;

    private string GetNoEntriesMessage(LogSource selected) =>
        IsCombinedLog(selected) && GetMergedLogSources().Count == 0
            ? L["Select at least one source to read merged log entries."].Value
            : L["This log source did not return recent entries."].Value;

    private string BuildTraceRoute(string? resourceId, string traceId)
    {
        var query = new Dictionary<string, string?>
        {
            ["traceId"] = traceId
        };

        if (Inline && !string.IsNullOrWhiteSpace(resourceId))
        {
            return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Traces),
                query);
        }

        if (!string.IsNullOrWhiteSpace(resourceId))
        {
            query["resourceId"] = resourceId;
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            "/observability/traces",
            query);
    }

    private static string FormatTraceId(string traceId) =>
        traceId.Length <= 12
            ? traceId
            : traceId[^12..];

    public async ValueTask DisposeAsync()
    {
        IsDisposed = true;
        await StopStreamingAsync();
    }

    private string? GetSelectedResourceFilterId()
    {
        if (Inline || string.IsNullOrWhiteSpace(ResourceId))
        {
            return null;
        }

        return LogResourceFilters.Any(option =>
            string.Equals(option.ResourceId, ResourceId, StringComparison.OrdinalIgnoreCase))
                ? ResourceId
                : null;
    }

    private bool IsRequestedResourceFilterUnavailable() =>
        !Inline &&
        !string.IsNullOrWhiteSpace(ResourceId) &&
        !LogResourceFilters.Any(option =>
            string.Equals(option.ResourceId, ResourceId, StringComparison.OrdinalIgnoreCase));

    private static string BuildAllLogsRoute() => "/logs";

    private sealed record LogSelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);

}
