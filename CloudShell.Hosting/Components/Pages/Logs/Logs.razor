@page "/logs"
@rendermode InteractiveServer
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L
@using CloudShell.Abstractions.Authorization

<PageTitle>@L["Logs"]</PageTitle>

@if (!Authorization.CanReadLogs())
{
    <section class="empty-state">
        <strong>@L["Access denied"]</strong>
        <span>@L["Your identity does not have permission to view observability logs."]</span>
    </section>
}
else
{
    <LogExplorer ResourceId="@ResourceId"
                 LogId="@LogId"
                 TraceId="@TraceId"
                 View="@View" />
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? LogId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? TraceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? View { get; set; }
}
