@page "/logs"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@inject ILogManager LogManager
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Logs"]</PageTitle>

@{
    var logs = GetVisibleLogs();
    var selected = GetSelectedLog(logs);
    var selectedResource = SelectedResource;
}

@if (Inline)
{
    <div class="resource-activity-header">
        <div>
            <h3>@L["Logs"]</h3>
            <span>@L["Resource telemetry"]</span>
        </div>
        <div class="heading-actions">
            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                    @L["Clear trace filter"]
                </FluentButton>
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshSelectedLog">
                @L["Refresh"]
            </FluentButton>
        </div>
    </div>
}
else
{
    <section class="page-heading compact">
        <div>
            <span class="eyebrow">@L["Logs"]</span>
            <h1>@L["Logs"]</h1>
            <p>@L["Browse logs registered by resources, providers, and extension-owned artifacts."]</p>
        </div>
        <div class="heading-actions">
            @if (!string.IsNullOrWhiteSpace(ResourceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ShowAllLogs">
                    @L["All logs"]
                </FluentButton>
            }
            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                    @L["Clear trace filter"]
                </FluentButton>
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshSelectedLog">
                @L["Refresh"]
            </FluentButton>
        </div>
    </section>
}

<section class="trace-workspace">
    <div class="log-viewer panel">
        @if (selected is null)
        {
            <div class="empty-state">
                <strong>@L["No log selected"]</strong>
                <span>@L["Select a log source to inspect recent entries."]</span>
            </div>
        }
        else
        {
            <div class="panel-header log-viewer-header">
                <div>
                    <h2>@selected.SourceName</h2>
                    <p>@selected.Name / @selected.Provider / @selected.SourceKind</p>
                </div>
                <div class="log-viewer-actions">
                    <label class="trace-source-filter" for="log-source-filter">
                        <span>@L["Log source"]</span>
                        <select id="log-source-filter" class="trace-source-select" value="@selected.Id"
                                @onchange="SelectLog">
                            @foreach (var log in logs)
                            {
                                <option value="@log.Id">@($"{log.SourceName} / {log.Name}")</option>
                            }
                        </select>
                    </label>
                    <FluentCheckbox Class="log-wrap-toggle" @bind-Value="WrapLogMessages">
                        @L["Wrap"]
                    </FluentCheckbox>
                    <FluentCheckbox Class="log-wrap-toggle" @bind-Value="ShowStructuredOnly"
                                    Disabled="@(GetStructuredEntryCount() == 0)">
                        @L["Structured only"]
                    </FluentCheckbox>
                    @if (selected.SupportsStreaming)
                    {
                        <FluentCheckbox Class="log-stream-toggle" Value="@IsSelectedLogStreaming(selected)"
                                        ValueChanged="enabled => SetStreamingEnabled(selected, enabled)" Disabled="@IsLoading">
                            @(IsSelectedLogStreaming(selected) ? L["Streaming"] : L["Stream"])
                        </FluentCheckbox>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(selected.Description))
            {
                <p class="log-description">@selected.Description</p>
            }

            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <p class="log-description">@L["Showing entries correlated with trace {0}.", FormatTraceId(TraceId)]</p>
            }

            @if (IsLoading)
            {
                <div class="empty-state compact">
                    <strong>@L["Loading log entries"]</strong>
                    <span>@L["Reading recent output from {0}.", selected.Provider]</span>
                </div>
            }
            else if (ReadError is not null)
            {
                <div class="procedure-message">@ReadError</div>
            }
            else if (Entries.Count == 0)
            {
                <div class="empty-state compact">
                    <strong>@(IsSelectedLogStreaming(selected) ? L["Waiting for entries"] : L["No entries"])</strong>
                    <span>@(IsSelectedLogStreaming(selected)
                                                ? L["Streaming is active for this log source."]
                                                : L["This log source did not return recent entries."])</span>
                    </div>
                }
            else
                {
                    var visibleEntryItems = GetVisibleEntryItems();
                    var selectedStructuredEntryItem = GetSelectedStructuredEntryItem(visibleEntryItems);
                    var selectedStructuredEntry = selectedStructuredEntryItem?.Entry;

                    <div class="log-history-bar">
                        <FluentButton Appearance="Appearance.Neutral" Disabled="@(!CanLoadOlderEntries || IsLoadingOlder)"
                                      OnClick="LoadOlderEntriesAsync">
                            @(IsLoadingOlder ? L["Loading older"] : L["Load older"])
                        </FluentButton>
                        <span>@GetEntryCountLabel(visibleEntryItems.Count)</span>
                    </div>

                    @if (visibleEntryItems.Count == 0)
                    {
                        <div class="empty-state compact">
                            <strong>@GetEmptyFilteredTitle()</strong>
                            <span>@GetEmptyFilteredMessage()</span>
                        </div>
                    }
                    else
                    {
                        <div class="structured-log-view">
                            <div @ref="LogEntryList" class="log-entry-list @(WrapLogMessages ? "wrap" : null)" role="log"
                                 aria-label="@selected.Name">
                                @foreach (var item in visibleEntryItems)
                                {
                                    var entry = item.Entry;
                                    var isStructured = HasStructuredMetadata(entry);
                                    var isSelectedStructured =
                                        isStructured &&
                                        string.Equals(item.SelectionKey, selectedStructuredEntryItem?.SelectionKey, StringComparison.Ordinal);
                                    <button
                                        class="log-entry @(isStructured ? "structured" : null) @(isSelectedStructured ? "selected" : null)"
                                        type="button" aria-pressed="@isSelectedStructured" @onclick="() => SelectStructuredEntry(item)">
                                        <time>@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</time>
                                        <span class="log-entry-source">@entry.Source</span>
                                        <span class="log-entry-severity">@entry.Severity</span>
                                        <div class="log-entry-body">
                                            <pre>@entry.Message</pre>
                                            @if (isStructured)
                                            {
                                                <span class="structured-log-summary">
                                                    @GetStructuredSummary(entry)
                                                </span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>

                            @if (selectedStructuredEntry is null)
                            {
                                <aside class="structured-log-details empty">
                                    <div class="empty-state compact">
                                        <strong>@L["No structured entry selected"]</strong>
                                        <span>@L["Select a structured log entry to inspect its fields."]</span>
                                    </div>
                                </aside>
                            }
                            else
                            {
                                <aside class="structured-log-details">
                                    <div class="structured-log-detail-header">
                                        <span>@selectedStructuredEntry.Severity</span>
                                        <h3>@selectedStructuredEntry.Message</h3>
                                        <p>@selectedStructuredEntry.Timestamp.ToLocalTime().ToString("g")</p>
                                    </div>

                                    <dl class="detail-list compact structured-log-core">
                                        <dt>@L["Category"]</dt>
                                        <dd>@(selectedStructuredEntry.Category ?? L["none"].Value)</dd>
                                        <dt>@L["Event ID"]</dt>
                                        <dd>@(selectedStructuredEntry.EventId ?? L["none"].Value)</dd>
                                        <dt>@L["Source"]</dt>
                                        <dd>@(selectedStructuredEntry.Source ?? L["none"].Value)</dd>
                                        <dt>@L["Trace ID"]</dt>
                                        <dd>
                                            @if (!string.IsNullOrWhiteSpace(selectedStructuredEntry.TraceId))
                                            {
                                                <a class="resource-link"
                                                   href="@BuildTraceRoute(selected.ResourceId, selectedStructuredEntry.TraceId)">
                                                    @selectedStructuredEntry.TraceId
                                                </a>
                                            }
                                            else
                                            {
                                                @L["none"]
                                            }
                                        </dd>
                                        <dt>@L["Span ID"]</dt>
                                        <dd>@(selectedStructuredEntry.SpanId ?? L["none"].Value)</dd>
                                        @if (!string.IsNullOrWhiteSpace(selectedStructuredEntry.ExceptionSummary))
                                        {
                                            <dt>@L["Exception"]</dt>
                                            <dd>@selectedStructuredEntry.ExceptionSummary</dd>
                                        }
                                    </dl>

                                    <div class="structured-log-detail-actions">
                                        @if (!string.IsNullOrWhiteSpace(selectedStructuredEntry.TraceId))
                                        {
                                            <FluentAnchor Appearance="Appearance.Neutral"
                                                          Href="@BuildTraceRoute(selected.ResourceId, selectedStructuredEntry.TraceId)">
                                                @L["Open trace"]
                                            </FluentAnchor>
                                        }
                                    </div>

                                    <div class="structured-log-attributes">
                                        <h3>@L["Attributes"]</h3>
                                        @if (selectedStructuredEntry.Attributes is null ||
                                            selectedStructuredEntry.Attributes.Count == 0)
                                        {
                                            <p>@L["No attributes were captured for this entry."]</p>
                                        }
                                        else
                                        {
                                            <dl class="log-entry-metadata">
                                                @foreach (var item in selectedStructuredEntry.Attributes
                                                    .Where(item => !string.IsNullOrWhiteSpace(item.Value))
                                                    .OrderBy(item => item.Key, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <dt>@item.Key</dt>
                                                    <dd>@item.Value</dd>
                                                }
                                            </dl>
                                        }
                                    </div>
                                </aside>
                            }
                        </div>
                    }
                }
            }
        </div>
    </section>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? LogId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? TraceId { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    private IReadOnlyList<LogEntry> Entries { get; set; } = [];
    private string? LoadedLogId { get; set; }
    private string? StreamingLogId { get; set; }
    private string? SelectedStructuredEntryKey { get; set; }
    private string? ReadError { get; set; }
    private CancellationTokenSource? StreamingCancellation { get; set; }
    private Task? StreamingTask { get; set; }
    private ElementReference LogEntryList { get; set; }
    private IJSObjectReference? LogModule { get; set; }
    private HashSet<string> DisabledStreamingLogIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private bool IsLoading { get; set; }
    private bool IsLoadingOlder { get; set; }
    private bool CanLoadOlderEntries { get; set; }
    private bool IsStreaming { get; set; }
    private bool WrapLogMessages { get; set; }
    private bool ShowStructuredOnly { get; set; }
    private bool ShouldScrollToLatest { get; set; }
    private double? PreservePrependedScrollHeight { get; set; }
    private bool IsDisposed { get; set; }
    private IReadOnlyList<LogDescriptor> VisibleLogs { get; set; } = [];
    private Resource? SelectedResource { get; set; }

    private const int InitialWindowEntries = 100;
    private const int HistoryPageEntries = 100;
    private const int MaxWindowEntries = 500;

    protected override async Task OnParametersSetAsync()
    {
        await LoadVisibleLogsAsync();

        var selected = GetSelectedLog(VisibleLogs);
        if (selected is null)
        {
            await StopStreamingAsync();
            Entries = [];
            LoadedLogId = null;
            SelectedStructuredEntryKey = null;
            CanLoadOlderEntries = false;
            return;
        }

        if (!string.Equals(LoadedLogId, selected.Id, StringComparison.OrdinalIgnoreCase))
        {
            await StopStreamingAsync();
            await LoadLogAsync(selected);
            await StartStreamingByDefaultAsync(selected);
        }
        else
        {
            await StartStreamingByDefaultAsync(selected);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldScrollToLatest)
        {
            if (PreservePrependedScrollHeight is { } previousScrollHeight)
            {
                PreservePrependedScrollHeight = null;
                await PreservePrependedScrollAsync(previousScrollHeight);
            }

            return;
        }

        if (await ScrollLogToLatestAsync())
        {
            ShouldScrollToLatest = false;
        }
    }

    private IReadOnlyList<LogDescriptor> GetVisibleLogs() =>
        VisibleLogs;

    private IReadOnlyList<LogEntry> GetVisibleEntries()
    {
        var entries = Entries.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(TraceId))
        {
            entries = entries.Where(entry =>
                string.Equals(entry.TraceId, TraceId, StringComparison.OrdinalIgnoreCase));
        }

        if (ShowStructuredOnly)
        {
            entries = entries.Where(HasStructuredMetadata);
        }

        return entries.ToArray();
    }

    private IReadOnlyList<LogEntryDisplayItem> GetVisibleEntryItems()
    {
        var occurrenceCounts = new Dictionary<string, int>(StringComparer.Ordinal);
        return GetVisibleEntries()
            .Select(entry =>
            {
                var baseKey = GetEntrySelectionBaseKey(entry);
                occurrenceCounts.TryGetValue(baseKey, out var occurrence);
                occurrenceCounts[baseKey] = occurrence + 1;
                return new LogEntryDisplayItem(entry, $"{baseKey}|{occurrence}");
            })
            .ToArray();
    }

    private int GetStructuredEntryCount() =>
        Entries.Count(HasStructuredMetadata);

    private string GetEntryCountLabel(int visibleEntryCount)
    {
        var structuredCount = GetStructuredEntryCount();
        return ShowStructuredOnly
            ? L["{0} structured entries in view", visibleEntryCount].Value
            : L["{0} entries in view / {1} structured", visibleEntryCount, structuredCount].Value;
    }

    private LogEntryDisplayItem? GetSelectedStructuredEntryItem(IReadOnlyList<LogEntryDisplayItem> visibleEntryItems)
    {
        if (!string.IsNullOrWhiteSpace(SelectedStructuredEntryKey))
        {
            var selected = visibleEntryItems.FirstOrDefault(item =>
                HasStructuredMetadata(item.Entry) &&
                string.Equals(item.SelectionKey, SelectedStructuredEntryKey, StringComparison.Ordinal));
            if (selected is not null)
            {
                return selected;
            }
        }

        return visibleEntryItems.LastOrDefault(item => HasStructuredMetadata(item.Entry));
    }

    private void SelectStructuredEntry(LogEntryDisplayItem item)
    {
        if (HasStructuredMetadata(item.Entry))
        {
            SelectedStructuredEntryKey = item.SelectionKey;
        }
    }

    private static string GetEntrySelectionBaseKey(LogEntry entry) =>
        string.Join(
            "|",
            entry.Timestamp.ToUnixTimeMilliseconds().ToString(CultureInfo.InvariantCulture),
            entry.Source,
            entry.Severity,
            entry.EventId,
            entry.Category,
            entry.TraceId,
            entry.SpanId,
            entry.Message);

    private string GetStructuredSummary(LogEntry entry)
    {
        var fields = GetStructuredMetadata(entry).Count;
        return L["{0} structured fields", fields].Value;
    }

    private async Task LoadVisibleLogsAsync()
    {
        VisibleLogs = await LogManager.ListLogsAsync(
            string.IsNullOrWhiteSpace(ResourceId)
                ? null
                : new LogQuery(ResourceId: ResourceId));
        SelectedResource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
    }

    private LogDescriptor? GetSelectedLog(IReadOnlyList<LogDescriptor> logs)
    {
        if (!string.IsNullOrWhiteSpace(LogId))
        {
            var requested = logs.FirstOrDefault(log =>
                string.Equals(log.Id, LogId, StringComparison.OrdinalIgnoreCase));
            if (requested is not null)
            {
                return requested;
            }
        }

        if (!string.IsNullOrWhiteSpace(TraceId))
        {
            var traceSource = logs.FirstOrDefault(log => log.SupportsStreaming);
            if (traceSource is not null)
            {
                return traceSource;
            }
        }

        return logs.FirstOrDefault();
    }

    private void SelectLog(ChangeEventArgs args) =>
        SelectLog(args.Value?.ToString());

    private void SelectLog(string? logId)
    {
        if (string.IsNullOrWhiteSpace(logId) ||
            string.Equals(logId, LogId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var log = VisibleLogs.FirstOrDefault(candidate =>
            string.Equals(candidate.Id, logId, StringComparison.OrdinalIgnoreCase));
        if (log is not null)
        {
            Navigation.NavigateTo(BuildLogRoute(log, TraceId));
        }
    }

    private void ShowAllLogs() => Navigation.NavigateTo("/logs");

    private void ClearTraceFilter()
    {
        var selected = GetSelectedLog(VisibleLogs);
        if (selected is null)
        {
            if (Inline && !string.IsNullOrWhiteSpace(ResourceId))
            {
                Navigation.NavigateTo(ResourceManagerRoutes.ResourceDetails(ResourceId, ResourcePredefinedViewIds.Logs));
            }
            else
            {
                Navigation.NavigateTo(string.IsNullOrWhiteSpace(ResourceId)
                    ? "/logs"
                    : Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                        "/logs",
                        "resourceId",
                        ResourceId));
            }

            return;
        }

        Navigation.NavigateTo(BuildLogRoute(selected));
    }

    private async Task RefreshSelectedLog()
    {
        await LoadVisibleLogsAsync();
        var selected = GetSelectedLog(VisibleLogs);
        if (selected is not null)
        {
            await StopStreamingAsync();
            await LoadLogAsync(selected);
            await StartStreamingByDefaultAsync(selected);
        }
    }

    private async Task LoadLogAsync(LogDescriptor log)
    {
        IsLoading = true;
        ReadError = null;
        try
        {
            Entries = await LogManager.ReadLogAsync(
                log.Id,
                new ReadLogOptions(MaxEntries: InitialWindowEntries));
            CanLoadOlderEntries = Entries.Count >= InitialWindowEntries;
            ShouldScrollToLatest = Entries.Count > 0;
            LoadedLogId = log.Id;
            SelectedStructuredEntryKey = null;
        }
        catch (Exception exception)
        {
            Entries = [];
            CanLoadOlderEntries = false;
            ReadError = exception.Message;
            LoadedLogId = log.Id;
            SelectedStructuredEntryKey = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadOlderEntriesAsync()
    {
        var selected = GetSelectedLog(GetVisibleLogs());
        if (selected is null ||
            Entries.Count == 0 ||
            IsLoadingOlder)
        {
            return;
        }

        IsLoadingOlder = true;
        ReadError = null;
        var previousScrollHeight = await GetLogScrollHeightAsync();

        try
        {
            var before = Entries.Min(entry => entry.Timestamp);
            var olderEntries = await LogManager.ReadLogAsync(
                selected.Id,
                new ReadLogOptions(
                    MaxEntries: HistoryPageEntries,
                    Before: before));

            CanLoadOlderEntries = olderEntries.Count >= HistoryPageEntries;
            Entries = olderEntries
                .Concat(Entries)
                .DistinctBy(GetEntryKey)
                .OrderBy(entry => entry.Timestamp)
                .Take(MaxWindowEntries)
                .ToArray();
            ShouldScrollToLatest = false;
            PreservePrependedScrollHeight = previousScrollHeight;
        }
        catch (Exception exception)
        {
            ReadError = exception.Message;
        }
        finally
        {
            IsLoadingOlder = false;
        }
    }

    private async Task SetStreamingEnabled(LogDescriptor log, bool enabled)
    {
        if (enabled)
        {
            DisabledStreamingLogIds.Remove(log.Id);
            await StartStreamingAsync(log);
            return;
        }

        DisabledStreamingLogIds.Add(log.Id);
        await StopStreamingAsync();
    }

    private async Task StartStreamingByDefaultAsync(LogDescriptor log)
    {
        if (log.SupportsStreaming && !DisabledStreamingLogIds.Contains(log.Id))
        {
            await StartStreamingAsync(log);
        }
    }

    private async Task StartStreamingAsync(LogDescriptor log)
    {
        if (!log.SupportsStreaming ||
            IsSelectedLogStreaming(log))
        {
            return;
        }

        await StopStreamingAsync();

        ReadError = null;
        var cancellation = new CancellationTokenSource();
        StreamingCancellation = cancellation;
        StreamingLogId = log.Id;
        IsStreaming = true;
        ShouldScrollToLatest = true;
        StreamingTask = StreamEntriesAsync(log, cancellation);
    }

    private async Task StopStreamingAsync()
    {
        var cancellation = StreamingCancellation;
        if (cancellation is null)
        {
            IsStreaming = false;
            StreamingLogId = null;
            StreamingTask = null;
            return;
        }

        cancellation.Cancel();
        StreamingCancellation = null;
        StreamingTask = null;
        StreamingLogId = null;
        IsStreaming = false;
        await Task.CompletedTask;
    }

    private async Task StreamEntriesAsync(LogDescriptor log, CancellationTokenSource cancellation)
    {
        try
        {
            await foreach (var entry in LogManager.StreamLogAsync(
                log.Id,
                new StreamLogOptions(InitialEntries: 0),
                cancellation.Token))
            {
                var shouldFollowLatest = true;
                await InvokeAsync(async () =>
                {
                    shouldFollowLatest = await IsLogAtLatestAsync();
                });
                await InvokeAsync(() =>
                {
                    if (!string.Equals(LoadedLogId, log.Id, StringComparison.OrdinalIgnoreCase))
                    {
                        return;
                    }

                    Entries = Entries
                        .Concat([entry])
                        .TakeLast(MaxWindowEntries)
                        .ToArray();
                    ShouldScrollToLatest = shouldFollowLatest;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        catch (Exception exception)
        {
            if (!cancellation.IsCancellationRequested)
            {
                await InvokeAsync(() => ReadError = exception.Message);
            }
        }
        finally
        {
            if (ReferenceEquals(StreamingCancellation, cancellation))
            {
                StreamingCancellation = null;
                StreamingTask = null;
                StreamingLogId = null;
                IsStreaming = false;
                cancellation.Dispose();

                if (!IsDisposed)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
            else
            {
                cancellation.Dispose();
            }
        }
    }

    private bool IsSelectedLogStreaming(LogDescriptor log) =>
        IsStreaming &&
        string.Equals(StreamingLogId, log.Id, StringComparison.OrdinalIgnoreCase);

    private async Task<bool> IsLogAtLatestAsync()
    {
        if (Entries.Count == 0)
        {
            return true;
        }

        try
        {
            var module = await GetLogModuleAsync();
            return await module.InvokeAsync<bool>("isAtLatest", LogEntryList);
        }
        catch (JSException)
        {
            return true;
        }
    }

    private async Task<bool> ScrollLogToLatestAsync()
    {
        try
        {
            var module = await GetLogModuleAsync();
            return await module.InvokeAsync<bool>("scrollToLatest", LogEntryList);
        }
        catch (JSException)
        {
            return false;
        }
    }

    private async Task<double> GetLogScrollHeightAsync()
    {
        try
        {
            var module = await GetLogModuleAsync();
            return await module.InvokeAsync<double>("getScrollHeight", LogEntryList);
        }
        catch (JSException)
        {
            return 0;
        }
    }

    private async Task PreservePrependedScrollAsync(double previousScrollHeight)
    {
        try
        {
            var module = await GetLogModuleAsync();
            await module.InvokeVoidAsync("preservePrependedScroll", LogEntryList, previousScrollHeight);
        }
        catch (JSException)
        {
        }
    }

    private async Task<IJSObjectReference> GetLogModuleAsync()
    {
        if (LogModule is null)
        {
            LogModule = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./Components/Pages/Logs/Logs.razor.js");
        }

        return LogModule;
    }

    private static bool HasStructuredMetadata(LogEntry entry) =>
        !string.IsNullOrWhiteSpace(entry.EventId) ||
        !string.IsNullOrWhiteSpace(entry.Category) ||
        !string.IsNullOrWhiteSpace(entry.TraceId) ||
        !string.IsNullOrWhiteSpace(entry.SpanId) ||
        !string.IsNullOrWhiteSpace(entry.ExceptionSummary) ||
        entry.Attributes?.Count > 0;

    private static IReadOnlyList<KeyValuePair<string, string>> GetStructuredMetadata(LogEntry entry)
    {
        var metadata = new List<KeyValuePair<string, string>>();
        AddIfPresent(metadata, "category", entry.Category);
        AddIfPresent(metadata, "eventId", entry.EventId);
        AddIfPresent(metadata, "traceId", entry.TraceId);
        AddIfPresent(metadata, "spanId", entry.SpanId);
        AddIfPresent(metadata, "exception", entry.ExceptionSummary);
        if (entry.Attributes is not null)
        {
            metadata.AddRange(
                entry.Attributes
                    .Where(attribute => !string.IsNullOrWhiteSpace(attribute.Value))
                    .OrderBy(attribute => attribute.Key, StringComparer.OrdinalIgnoreCase));
        }

        return metadata;
    }

    private static void AddIfPresent(
        List<KeyValuePair<string, string>> metadata,
        string key,
        string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            metadata.Add(new KeyValuePair<string, string>(key, value));
        }
    }

    private sealed record LogEntryDisplayItem(LogEntry Entry, string SelectionKey);

    private static (
        DateTimeOffset Timestamp,
        string Message,
        string? Severity,
        string? Source,
        string? EventId,
        string? Category,
        string? TraceId,
        string? SpanId) GetEntryKey(LogEntry entry) =>
        (
            entry.Timestamp,
            entry.Message,
            entry.Severity,
            entry.Source,
            entry.EventId,
            entry.Category,
            entry.TraceId,
            entry.SpanId);

    private string BuildLogRoute(LogDescriptor log, string? traceId = null)
    {
        var query = new Dictionary<string, string?>
        {
            ["logId"] = log.Id
        };

        if (Inline && !string.IsNullOrWhiteSpace(log.ResourceId))
        {
            query["tab"] = ResourcePredefinedViewIds.Logs.Value;
            if (!string.IsNullOrWhiteSpace(traceId))
            {
                query["traceId"] = traceId.Trim();
            }

            return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                ResourceManagerRoutes.ResourceDetails(log.ResourceId),
                query);
        }

        if (!string.IsNullOrWhiteSpace(log.ResourceId))
        {
            query["resourceId"] = log.ResourceId;
        }

        if (!string.IsNullOrWhiteSpace(traceId))
        {
            query["traceId"] = traceId.Trim();
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query);
    }

    private string GetEmptyFilteredTitle() =>
        !string.IsNullOrWhiteSpace(TraceId)
            ? L["No related log entries"].Value
            : L["No structured entries"].Value;

    private string GetEmptyFilteredMessage() =>
        !string.IsNullOrWhiteSpace(TraceId)
            ? L["This log source has entries, but none are correlated with the selected trace."].Value
            : L["This log source has entries, but none contain structured metadata."].Value;

    private static bool IsTraceMetadata(KeyValuePair<string, string> item) =>
        string.Equals(item.Key, "traceId", StringComparison.OrdinalIgnoreCase);

    private static string BuildTraceRoute(string? resourceId, string traceId)
    {
        var query = new Dictionary<string, string?>
        {
            ["traceId"] = traceId
        };

        if (!string.IsNullOrWhiteSpace(resourceId))
        {
            query["resourceId"] = resourceId;
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            "/observability/traces",
            query);
    }

    private static string FormatTraceId(string traceId) =>
        traceId.Length <= 12
            ? traceId
            : traceId[^12..];

    public async ValueTask DisposeAsync()
    {
        IsDisposed = true;
        await StopStreamingAsync();
        if (LogModule is not null)
        {
            await LogModule.DisposeAsync();
        }
    }
}
