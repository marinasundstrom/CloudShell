@page "/logs"
@rendermode InteractiveServer
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L
@using CloudShell.Abstractions.Authorization

<PageTitle>@L["Logs"]</PageTitle>

@if (!Authorization.CanReadLogs())
{
    <EmptyState Title="@L["Access denied"].Value"
                Message="@L["Your identity does not have permission to view observability logs."].Value" />
}
else
{
    <LogExplorer ResourceId="@ResourceId"
                 LogSourceId="@LogSourceId"
                 TraceId="@TraceId"
                 View="@View"
                 SourceIds="@SourceIds" />
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? LogSourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? TraceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? View { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? SourceIds { get; set; }
}
