<LogExplorer ResourceId="@ResourceId"
             LogId="@LogId"
             TraceId="@TraceId"
             Inline="true" />

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public string? LogId { get; set; }

    [Parameter]
    public string? TraceId { get; set; }
}
