@page "/observability/dependencies"
@rendermode InteractiveServer
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L
@using CloudShell.Abstractions.Authorization

<PageTitle>@L["Dependencies"]</PageTitle>

@if (!Authorization.CanReadTraces())
{
    <EmptyState Title="@L["Access denied"].Value"
                Message="@L["Your identity does not have permission to view observability traces."].Value" />
}
else
{
    <ServiceDependencyGraph HeadingTitle="@L["Dependencies"].Value"
                            HeadingDescription="@L["Inspect OpenTelemetry service request relationships as edge data."].Value"
                            PanelTitle="@L["Request paths"].Value"
                            GraphModeSelectId="dependencies-mode"
                            ShowMap="false" />
}
