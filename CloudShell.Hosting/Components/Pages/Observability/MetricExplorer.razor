@implements IDisposable
@using System.Globalization
@inject IMetricManager MetricManager
@inject IResourceManager ResourceManager
@inject ResourceManagerDisplaySettings DisplaySettings
@inject NavigationManager Navigation
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L
@inject IOptionsMonitor<MetricVisualizationOptions> MetricVisualizations

@{
    var resources = MetricResources;
    var selectionIssue = GetSelectionIssue(resources);
    var selected = selectionIssue is null ? GetSelectedResource(resources) : null;
    var points = RecentPoints;
    var scopes = selected?.EffectiveObservability.TelemetryScopes ?? [];
    var selectedScope = GetSelectedScope(selected);
    var metricPanels = selected is null
        ? Array.Empty<MetricPanelViewModel>()
        : BuildMetricPanels(selected, points);
    var selectedMetricView = ResolveMetricView(metricPanels);
}

@if (ShowHeading && Inline)
{
    <ResourceActivityHeader Title="@L["Metrics"].Value"
                            Subtitle="@L["Resource telemetry"].Value"
                            ActionsClass="heading-actions">
        <Actions>
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshPointsAsync">
                @L["Refresh"]
            </FluentButton>
        </Actions>
    </ResourceActivityHeader>
}
else if (ShowHeading)
{
    <section class="page-heading compact">
        <div>
            <span class="eyebrow">@L["Observability"]</span>
            <h1>@L["Metrics"]</h1>
            <p>@L["Inspect application/runtime metric points retained by CloudShell."]</p>
        </div>
        <div class="heading-actions">
            <FluentButton Appearance="Appearance.Neutral" OnClick="ShowAllResources">
                @L["All metric resources"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshPointsAsync">
                @L["Refresh"]
            </FluentButton>
        </div>
    </section>
}

<section class="trace-workspace">
    <div class="log-viewer @(UsePanel ? "panel" : null)">
        @if (selectionIssue is not null)
        {
            <EmptyState Title="@selectionIssue.Title" Message="@selectionIssue.Message">
                <FluentAnchor Appearance="Appearance.Neutral" Href="@selectionIssue.RecoveryHref">
                    @selectionIssue.RecoveryLabel
                </FluentAnchor>
            </EmptyState>
        }
        else if (selected is null)
        {
            <EmptyState Title="@L["No resource selected"].Value"
                        Message="@L["No visible resources currently declare metric support."].Value" />
        }
        else
        {
            var metricSummaries = BuildMetricSummaries(points);

            @if (ShouldShowSourceHeader(scopes))
            {
                <TelemetryExplorerHeader ShowSummary="@ShowSourceSummary"
                                         Title="@GetResourceLabel(selected)"
                                         Description="@($"{selected.Kind} / {selected.Provider}{GetStateSuffix(selected)}")">
                    <Actions>
                        @if (ShowResourceSelector)
                        {
                            <ResourceSourceSelect Id="metric-source-filter"
                                                  Label="@L["Metric source"]"
                                                  Resources="resources"
                                                  SelectedResourceId="selected.Id"
                                                  SelectedResourceIdChanged="SelectResource"
                                                  ResourceLabel="GetResourceLabel" />
                        }
                        @if (scopes.Count > 1)
                        {
                            <label class="trace-source-filter" for="metric-scope-filter">
                                <span>@L["Scope"]</span>
                                <select id="metric-scope-filter" class="trace-source-select"
                                        value="@(selectedScope?.ScopeResourceId ?? string.Empty)"
                                        @onchange="SelectScope">
                                    <option value="">@L["All scopes"]</option>
                                    @foreach (var scope in scopes)
                                    {
                                        <option value="@scope.ScopeResourceId">@scope.Name</option>
                                    }
                                </select>
                            </label>
                        }
                        @if (ShowResourceLink)
                        {
                            <FluentAnchor Appearance="Appearance.Neutral" Href="@BuildResourceRoute(selected.Id)">
                                @L["Open resource"]
                            </FluentAnchor>
                        }
                    </Actions>
                </TelemetryExplorerHeader>
            }

            @if (ShowResourceDetails)
            {
                <dl class="detail-list">
                    <dt>@L["Resource ID"]</dt>
                    <dd>@selected.Id</dd>
                    <dt>@L["Service name"]</dt>
                    <dd>@(selected.EffectiveObservability.ServiceName ?? NormalizeServiceName(selected.Name, selected.Id))</dd>
                    <dt>@L["Metric points"]</dt>
                    <dd>@GetPointSummary(points.Count)</dd>
                    @if (selectedScope is not null)
                    {
                        <dt>@L["Scope"]</dt>
                        <dd>@selectedScope.Name</dd>
                    }
                </dl>
            }

            @if (points.Count == 0 && metricPanels.Count == 0)
            {
                <EmptyState Title="@L["No metrics received"].Value"
                            Message="@L["Start this resource and send traffic through it. Metrics are retained only while CloudShell is running."].Value"
                            Compact="true" />
            }
            else
            {
                @if (points.Count > 0)
                {
                    <SummaryMetricGrid AriaLabel="@L["Metric summaries"].Value">
                        @foreach (var summary in metricSummaries)
                        {
                            <SummaryMetricCard Title="@summary.Name"
                                               Value="@FormatMetricValue(summary.LatestValue, summary.Unit)"
                                               Summary="@L["{0} point(s) / latest {1}", summary.PointCount, summary.LatestTimestamp.ToLocalTime().ToString("HH:mm:ss")].Value"
                                               Compact="true" />
                        }
                    </SummaryMetricGrid>
                }

                @if (metricPanels.Count > 0)
                {
                    <nav class="metric-view-tabs" role="tablist" aria-label="@L["Metric views"]">
                        <a class="@GetMetricViewTabClass(MetricGraphsView, selectedMetricView)"
                           role="tab"
                           aria-selected="@(selectedMetricView == MetricGraphsView)"
                           href="@BuildMetricRoute(selected.Id, selectedScope?.ScopeResourceId, MetricGraphsView)">
                            @L["Graphs"]
                        </a>
                        <a class="@GetMetricViewTabClass(MetricStreamView, selectedMetricView)"
                           role="tab"
                           aria-selected="@(selectedMetricView == MetricStreamView)"
                           href="@BuildMetricRoute(selected.Id, selectedScope?.ScopeResourceId, MetricStreamView)">
                            @L["Stream"]
                        </a>
                    </nav>
                }

                @if (selectedMetricView == MetricGraphsView)
                {
                    <div class="metric-panel-grid" aria-label="@L["Configured metric visualizations"]">
                        @foreach (var panel in metricPanels)
                        {
                            <section class="metric-panel @(panel.Kind == MetricPanelKind.Indicator ? "indicator" : "line")">
                                <header>
                                    <div>
                                        <h3>@panel.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(panel.Description))
                                        {
                                            <p>@panel.Description</p>
                                        }
                                    </div>
                                    <span>@panel.MetricName</span>
                                </header>

                                @if (!panel.HasData)
                                {
                                    <div class="metric-panel-empty">
                                        <strong>@L["No matching points"]</strong>
                                        <span>@L["CloudShell has not retained points for this metric yet."]</span>
                                    </div>
                                }
                                else if (panel.Kind == MetricPanelKind.Indicator)
                                {
                                    <div class="metric-indicator">
                                        <strong>@FormatMetricValue(panel.DisplayValue, panel.Unit)</strong>
                                        <span>@panel.AggregationLabel / @L["latest {0}", FormatTimestamp(panel.LatestTimestamp)]</span>
                                    </div>
                                }
                                else
                                {
                                    <CloudShellLineChart Values="@panel.Values"
                                                         AriaLabel="@L["{0} line chart", panel.Title].Value" />
                                    <div class="metric-panel-stats">
                                        <span>@L["latest {0}", FormatMetricValue(panel.DisplayValue, panel.Unit)]</span>
                                        <span>@L["min {0}", FormatMetricValue(panel.MinValue, panel.Unit)]</span>
                                        <span>@L["max {0}", FormatMetricValue(panel.MaxValue, panel.Unit)]</span>
                                        <span>@L["{0} point(s)", panel.PointCount]</span>
                                    </div>
                                }
                            </section>
                        }
                    </div>
                }
                else
                {
                    @if (points.Count == 0)
                    {
                        <EmptyState Title="@L["No metrics received"].Value"
                                    Message="@L["Start this resource and send traffic through it. Metrics are retained only while CloudShell is running."].Value"
                                    Compact="true" />
                    }
                    else
                    {
                        <div class="metric-point-table-shell">
                        <table class="metric-point-table" aria-label="@L["Recent metric points"]">
                            <thead>
                                <tr>
                                    <th class="metric-point-time" scope="col">@L["Time"]</th>
                                    <th class="metric-point-source" scope="col">@L["Source"]</th>
                                    <th class="metric-point-name" scope="col">@L["Metric"]</th>
                                    <th class="metric-point-value" scope="col">@L["Value"]</th>
                                    <th scope="col">@L["Attributes"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var point in points)
                                {
                                    <tr>
                                        <td class="metric-point-time">
                                            <time>@point.Timestamp.ToLocalTime().ToString("HH:mm:ss")</time>
                                        </td>
                                        <td class="metric-point-source">
                                            <span title="@point.ServiceName">@point.ServiceName</span>
                                        </td>
                                        <td class="metric-point-name">
                                            <span title="@point.Name">@point.Name</span>
                                        </td>
                                        <td class="metric-point-value">@FormatMetricValue(point.Value, point.Unit)</td>
                                        <td>
                                            @if (point.MetricAttributes.Count == 0)
                                            {
                                                <span class="metric-point-empty">@L["None"]</span>
                                            }
                                            else
                                            {
                                                <div class="metric-point-attributes">
                                                    @foreach (var metricAttribute in point.MetricAttributes)
                                                    {
                                                        <span class="metric-point-attribute">
                                                            <strong>@metricAttribute.Key</strong>=@metricAttribute.Value
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    }
                }
            }
        }
    </div>
</section>

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public string? ScopeResourceId { get; set; }

    [Parameter]
    public string? View { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public bool ShowHeading { get; set; } = true;

    [Parameter]
    public bool UsePanel { get; set; } = true;

    [Parameter]
    public bool ShowSourceSummary { get; set; } = true;

    [Parameter]
    public bool ShowResourceSelector { get; set; } = true;

    [Parameter]
    public bool ShowResourceLink { get; set; } = true;

    [Parameter]
    public bool ShowResourceDetails { get; set; } = true;

    private System.Threading.Timer? refreshTimer;
    private const string MetricGraphsView = "graphs";
    private const string MetricStreamView = "stream";
    private IReadOnlyList<Resource> MetricResources { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> ResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<MetricPoint> RecentPoints { get; set; } = [];
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private bool IsDisposed { get; set; }
    private bool IsRefreshingPoints { get; set; }

    protected override void OnInitialized()
    {
        refreshTimer = new System.Threading.Timer(
            _ =>
            {
                if (!IsDisposed)
                {
                    _ = InvokeAsync(RefreshPointsAsync);
                }
            },
            null,
            TimeSpan.FromSeconds(5),
            TimeSpan.FromSeconds(5));
    }

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        var resources = await ResourceManager.ListResourcesAsync();
        ResourcesById = resources.ToDictionary(resource => resource.Id, StringComparer.OrdinalIgnoreCase);
        MetricResources = resources
            .Where(resource => resource.EffectiveObservability.Metrics)
            .OrderBy(DisplaySelection.GetResourceSortLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        await RefreshPointsAsync();
    }

    public void Dispose()
    {
        IsDisposed = true;
        refreshTimer?.Dispose();
    }

    private Resource? GetSelectedResource(IReadOnlyList<Resource> resources)
    {
        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            var requested = resources.FirstOrDefault(resource =>
                string.Equals(resource.Id, ResourceId, StringComparison.OrdinalIgnoreCase));
            if (requested is not null)
            {
                return requested;
            }
        }

        return resources.FirstOrDefault();
    }

    private TelemetrySelectionIssue? GetSelectionIssue(IReadOnlyList<Resource> resources)
    {
        if (!string.IsNullOrWhiteSpace(ResourceId) &&
            !resources.Any(resource => string.Equals(resource.Id, ResourceId, StringComparison.OrdinalIgnoreCase)))
        {
            var resourceId = ResourceId.Trim();
            return new TelemetrySelectionIssue(
                L["Metric resource not found"].Value,
                L["Resource '{0}' does not expose metrics or is not available.", GetResourceLabel(resourceId)].Value,
                Inline ? L["Open Resources"].Value : L["All metric resources"].Value,
                Inline ? GetResourcesRoute() : "/observability/metrics");
        }

        var selected = GetSelectedResource(resources);
        if (selected is not null &&
            !string.IsNullOrWhiteSpace(ScopeResourceId) &&
            GetSelectedScope(selected) is null)
        {
            var scopeResourceId = ScopeResourceId.Trim();
            return new TelemetrySelectionIssue(
                L["Metric scope not found"].Value,
                L["Telemetry scope '{0}' is not available for {1}.", GetResourceLabel(scopeResourceId), GetResourceLabel(selected)].Value,
                L["Show all scopes"].Value,
                BuildMetricRoute(selected.Id));
        }

        return null;
    }

    private async Task RefreshPointsAsync()
    {
        if (IsRefreshingPoints || IsDisposed)
        {
            return;
        }

        IsRefreshingPoints = true;
        var selectionIssue = GetSelectionIssue(MetricResources);
        var selected = selectionIssue is null ? GetSelectedResource(MetricResources) : null;
        try
        {
            RecentPoints = selected is null
                ? []
                : await MetricManager.ListMetricPointsAsync(new MetricQuery(
                    ResourceId: selected.Id,
                    MaxPoints: GetMetricPointWindow(selected),
                    Scope: GetSelectedScope(selected)?.ToQueryScope()));

            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            IsRefreshingPoints = false;
        }
    }

    private void SelectResource(ChangeEventArgs args) =>
        SelectResource(args.Value?.ToString());

    private void SelectResource(string? resourceId)
    {
        if (string.IsNullOrWhiteSpace(resourceId) ||
            string.Equals(resourceId, ResourceId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Navigation.NavigateTo(BuildMetricRoute(resourceId, view: GetRequestedMetricView()));
    }

    private void SelectScope(ChangeEventArgs args)
    {
        var selected = GetSelectedResource(MetricResources);
        if (selected is null)
        {
            return;
        }

        Navigation.NavigateTo(BuildMetricRoute(selected.Id, args.Value?.ToString(), GetRequestedMetricView()));
    }

    private void ShowAllResources() => Navigation.NavigateTo("/observability/metrics");

    private string GetResourcesRoute() =>
        ResourceManagerCompositionLinks.ResourceManagerPage(
            Composition,
            ResourceManagerCompositionIds.ResourcesPage,
            ResourceManagerRoutes.Resources);

    private string BuildMetricRoute(
        string resourceId,
        string? scopeResourceId = null,
        string? view = null)
    {
        var query = new Dictionary<string, string?>();
        if (!string.IsNullOrWhiteSpace(scopeResourceId))
        {
            query["scopeResourceId"] = scopeResourceId.Trim();
        }

        var normalizedView = NormalizeMetricView(view);
        if (normalizedView is not null)
        {
            query[Inline ? "metricView" : "view"] = normalizedView;
        }

        if (Inline)
        {
            return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Metrics),
                query);
        }

        query["resourceId"] = resourceId;
        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            "/observability/metrics",
            query);
    }

    private string ResolveMetricView(IReadOnlyList<MetricPanelViewModel> panels)
    {
        var requested = GetRequestedMetricView();
        if (requested == MetricStreamView)
        {
            return MetricStreamView;
        }

        return panels.Count > 0
            ? MetricGraphsView
            : MetricStreamView;
    }

    private string? GetRequestedMetricView() =>
        NormalizeMetricView(View) ??
        NormalizeMetricView(GetQueryValue(Inline ? "metricView" : "view")) ??
        NormalizeMetricView(GetQueryValue("metricView"));

    private string? GetQueryValue(string name)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(name, out var value)
            ? value.FirstOrDefault()
            : null;
    }

    private static string? NormalizeMetricView(string? view)
    {
        if (string.Equals(view, MetricGraphsView, StringComparison.OrdinalIgnoreCase))
        {
            return MetricGraphsView;
        }

        if (string.Equals(view, MetricStreamView, StringComparison.OrdinalIgnoreCase))
        {
            return MetricStreamView;
        }

        return null;
    }

    private static string GetMetricViewTabClass(string view, string selectedView) =>
        string.Equals(view, selectedView, StringComparison.Ordinal)
            ? "metric-view-tab active"
            : "metric-view-tab";

    private TelemetryScopeDescriptor? GetSelectedScope(Resource? resource)
    {
        if (resource is null || string.IsNullOrWhiteSpace(ScopeResourceId))
        {
            return null;
        }

        return resource.EffectiveObservability.TelemetryScopes.FirstOrDefault(scope =>
            string.Equals(scope.ScopeResourceId, ScopeResourceId, StringComparison.OrdinalIgnoreCase));
    }

    private string BuildResourceRoute(string resourceId) =>
        ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId);

    private static string GetStateSuffix(Resource resource) =>
        resource.State is { } state ? $" / {state}" : string.Empty;

    private string GetResourceLabel(Resource resource) =>
        DisplaySelection.GetResourceLabel(resource);

    private string GetResourceLabel(string resourceId) =>
        ResourcesById.TryGetValue(resourceId, out var resource)
            ? GetResourceLabel(resource)
            : ResourceDisplayLabels.GetName(resourceId);

    private string GetPointSummary(int pointCount) =>
        L["{0} points retained in memory", pointCount].Value;

    private bool ShouldShowSourceHeader(IReadOnlyList<TelemetryScopeDescriptor> scopes) =>
        ShowSourceSummary ||
        ShowResourceSelector ||
        scopes.Count > 1 ||
        ShowResourceLink;

    private static string NormalizeServiceName(string name, string resourceId)
    {
        var candidate = string.IsNullOrWhiteSpace(name) ? resourceId : name;
        var normalized = string.Join(
                "-",
                candidate.Trim().ToLowerInvariant().Split(
                    [' ', '.', '_', ':', '/', '\\'],
                    StringSplitOptions.RemoveEmptyEntries))
            .Trim('-');

        return string.IsNullOrWhiteSpace(normalized) ? resourceId : normalized;
    }

    private static string FormatMetricValue(double value, string? unit) =>
        string.IsNullOrWhiteSpace(unit)
            ? value.ToString("0.###", CultureInfo.InvariantCulture)
            : $"{value.ToString("0.###", CultureInfo.InvariantCulture)} {unit}";

    private static string FormatTimestamp(DateTimeOffset? timestamp) =>
        timestamp?.ToLocalTime().ToString("HH:mm:ss", CultureInfo.CurrentCulture) ?? "--";

    private IReadOnlyList<MetricPanelViewModel> BuildMetricPanels(
        Resource resource,
        IReadOnlyList<MetricPoint> points)
    {
        var resourceOptions = GetMetricVisualizationOptions(resource);
        if (resourceOptions is null)
        {
            return [];
        }

        return resourceOptions.Panels
            .Select(panel => BuildMetricPanel(panel, points))
            .OfType<MetricPanelViewModel>()
            .ToArray();
    }

    private static bool MatchesResourceMetricVisualization(
        ResourceMetricVisualizationOptions options,
        Resource resource)
    {
        if (!string.IsNullOrWhiteSpace(options.ResourceId) &&
            string.Equals(options.ResourceId.Trim(), resource.Id, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return !string.IsNullOrWhiteSpace(options.ResourceName) &&
            string.Equals(options.ResourceName.Trim(), resource.Name, StringComparison.OrdinalIgnoreCase);
    }

    private MetricPanelViewModel? BuildMetricPanel(
        MetricPanelOptions panel,
        IReadOnlyList<MetricPoint> points)
    {
        if (string.IsNullOrWhiteSpace(panel.MetricName))
        {
            return null;
        }

        var metricName = panel.MetricName.Trim();
        var maxPoints = Math.Clamp(panel.MaxPoints, 1, 1_000);
        var metricPoints = points
            .Where(point => string.Equals(point.Name, metricName, StringComparison.OrdinalIgnoreCase))
            .Where(point => MatchesAttributeFilters(point, panel.AttributeFilters))
            .OrderByDescending(point => point.Timestamp)
            .Take(maxPoints)
            .Reverse()
            .ToArray();
        var values = metricPoints.Select(point => point.Value).ToArray();
        var title = string.IsNullOrWhiteSpace(panel.Title)
            ? metricName
            : panel.Title.Trim();
        var unit = string.IsNullOrWhiteSpace(panel.Unit)
            ? metricPoints.LastOrDefault()?.Unit
            : panel.Unit.Trim();

        if (values.Length == 0)
        {
            return new MetricPanelViewModel(
                title,
                panel.Description,
                metricName,
                panel.Kind,
                panel.Aggregation,
                GetAggregationLabel(panel.Aggregation),
                unit,
                HasData: false,
                DisplayValue: 0,
                MinValue: 0,
                MaxValue: 0,
                PointCount: 0,
                LatestTimestamp: null,
                Values: []);
        }

        var displayValue = AggregateMetricValues(values, panel.Aggregation);
        return new MetricPanelViewModel(
            title,
            panel.Description,
            metricName,
            panel.Kind,
            panel.Aggregation,
            GetAggregationLabel(panel.Aggregation),
            unit,
            HasData: true,
            displayValue,
            values.Min(),
            values.Max(),
            values.Length,
            metricPoints[^1].Timestamp,
            values);
    }

    private static bool MatchesAttributeFilters(
        MetricPoint point,
        IReadOnlyDictionary<string, string> filters)
    {
        if (filters.Count == 0)
        {
            return true;
        }

        foreach (var filter in filters)
        {
            if (!point.MetricAttributes.TryGetValue(filter.Key, out var value) ||
                !string.Equals(value, filter.Value, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return true;
    }

    private ResourceMetricVisualizationOptions? GetMetricVisualizationOptions(Resource resource) =>
        MetricVisualizations.CurrentValue.Resources.FirstOrDefault(options =>
            MatchesResourceMetricVisualization(options, resource));

    private int GetMetricPointWindow(Resource resource)
    {
        var panelWindow = GetMetricVisualizationOptions(resource)?.Panels
            .Select(panel => panel.MaxPoints)
            .DefaultIfEmpty(0)
            .Max() ?? 0;

        return Math.Clamp(Math.Max(200, panelWindow), 1, 1_000);
    }

    private LocalizedString GetAggregationLabel(MetricPanelAggregation aggregation) =>
        aggregation switch
        {
            MetricPanelAggregation.Average => L["average"],
            MetricPanelAggregation.Sum => L["sum"],
            MetricPanelAggregation.Min => L["min"],
            MetricPanelAggregation.Max => L["max"],
            MetricPanelAggregation.Count => L["count"],
            _ => L["latest"]
        };

    private static double AggregateMetricValues(
        IReadOnlyList<double> values,
        MetricPanelAggregation aggregation) =>
        aggregation switch
        {
            MetricPanelAggregation.Average => values.Average(),
            MetricPanelAggregation.Sum => values.Sum(),
            MetricPanelAggregation.Min => values.Min(),
            MetricPanelAggregation.Max => values.Max(),
            MetricPanelAggregation.Count => values.Count,
            _ => values[^1]
        };

    private static IReadOnlyList<MetricSummary> BuildMetricSummaries(IReadOnlyList<MetricPoint> points) =>
        points
            .GroupBy(point => point.Name, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var latest = group.OrderByDescending(point => point.Timestamp).First();
                return new MetricSummary(
                    group.Key,
                    latest.Value,
                    latest.Unit,
                    latest.Timestamp,
                    group.Count());
            })
            .OrderBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private sealed record MetricSummary(
        string Name,
        double LatestValue,
        string? Unit,
        DateTimeOffset LatestTimestamp,
        int PointCount);

    private sealed record MetricPanelViewModel(
        string Title,
        string? Description,
        string MetricName,
        MetricPanelKind Kind,
        MetricPanelAggregation Aggregation,
        LocalizedString AggregationLabel,
        string? Unit,
        bool HasData,
        double DisplayValue,
        double MinValue,
        double MaxValue,
        int PointCount,
        DateTimeOffset? LatestTimestamp,
        IReadOnlyList<double> Values);

    private sealed record TelemetrySelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);
}
