@page "/telemetry/metrics"
@page "/observability/metrics"
@rendermode InteractiveServer
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L
@using CloudShell.Abstractions.Authorization

<PageTitle>@L["Metrics"]</PageTitle>

@if (!Authorization.CanReadMetrics())
{
    <EmptyState Title="@L["Access denied"].Value"
                Message="@L["Your identity does not have permission to view telemetry metrics."].Value" />
}
else
{
    <MetricExplorer ResourceId="@ResourceId"
                    ScopeResourceId="@ScopeResourceId"
                    View="@View" />
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ScopeResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? View { get; set; }
}
