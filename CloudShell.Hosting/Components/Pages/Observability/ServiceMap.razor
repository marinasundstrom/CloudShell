@page "/observability/service-map"
@rendermode InteractiveServer
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L
@using CloudShell.Abstractions.Authorization

<PageTitle>@L["Service map"]</PageTitle>

@if (!Authorization.CanReadTraces())
{
    <section class="empty-state">
        <strong>@L["Access denied"]</strong>
        <span>@L["Your identity does not have permission to view observability traces."]</span>
    </section>
}
else
{
    <ServiceDependencyGraph HeadingTitle="@L["Service map"].Value"
                            HeadingDescription="@L["Visualize service-to-service request flow from OpenTelemetry traces."].Value"
                            PanelTitle="@L["Live request flow"].Value"
                            GraphModeSelectId="service-map-mode"
                            ShowMap="true" />
}
