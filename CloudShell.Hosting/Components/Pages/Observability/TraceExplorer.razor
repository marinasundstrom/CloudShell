@implements IDisposable
@using System.Globalization
@inject ITraceManager TraceManager
@inject IResourceManager ResourceManager
@inject ResourceManagerDisplaySettings DisplaySettings
@inject NavigationManager Navigation
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L

@{
    var resources = TraceResources;
    var selectionIssue = GetSelectionIssue(resources);
    var allSourcesSelected = IsAllSourcesSelected();
    var selected = selectionIssue is null && !allSourcesSelected ? GetSelectedResource(resources) : null;
    var scopes = selected?.EffectiveObservability.TelemetryScopes ?? [];
    var selectedScope = GetSelectedScope(selected);
}

@if (ShowHeading && Inline)
{
    <div class="resource-activity-header">
        <div>
            <h3>@L["Traces"]</h3>
            <span>@L["Resource telemetry"]</span>
        </div>
        <div class="heading-actions">
            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                    @L["Clear trace filter"]
                </FluentButton>
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshSpansAsync">
                @L["Refresh"]
            </FluentButton>
        </div>
    </div>
}
else if (ShowHeading)
{
    <section class="page-heading compact">
        <div>
            <span class="eyebrow">@L["Observability"]</span>
            <h1>@L["Traces"]</h1>
            <p>@L["Inspect resources that are configured to export distributed traces."]</p>
        </div>
        <div class="heading-actions">
            @if (!string.IsNullOrWhiteSpace(TraceId))
            {
                <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                    @L["Clear trace filter"]
                </FluentButton>
            }
            <FluentButton Appearance="Appearance.Neutral" OnClick="ShowAllResources">
                @L["All trace resources"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                          OnClick="RefreshSpansAsync">
                @L["Refresh"]
            </FluentButton>
        </div>
    </section>
}

<section class="trace-workspace">
    <div class="log-viewer @(UsePanel ? "panel" : null)">
        @if (selectionIssue is not null)
        {
            <EmptyState Title="@selectionIssue.Title" Message="@selectionIssue.Message">
                <FluentAnchor Appearance="Appearance.Neutral" Href="@selectionIssue.RecoveryHref">
                    @selectionIssue.RecoveryLabel
                </FluentAnchor>
            </EmptyState>
        }
        else if (selected is null && !allSourcesSelected)
        {
            <EmptyState Title="@L["No resource selected"].Value"
                        Message="@L["No visible resources currently declare trace support."].Value" />
        }
        else
        {
            var observability = selected?.EffectiveObservability;
            var spans = RecentSpans;

            @if (ShouldShowSourceHeader(scopes))
            {
                <TelemetryExplorerHeader ShowSummary="@ShowSourceSummary">
                    <SummaryContent>
                        <div>
                            @if (selected is null)
                            {
                                <h2>@L["All sources"]</h2>
                                <p>@L["{0} trace resources", resources.Count]</p>
                            }
                            else
                            {
                                <h2>@GetResourceLabel(selected)</h2>
                                <p>@selected.Kind / @selected.Provider@GetStateSuffix(selected)</p>
                            }
                        </div>
                    </SummaryContent>
                    <Actions>
                        @if (!ShowHeading && !string.IsNullOrWhiteSpace(TraceId))
                        {
                            <FluentButton Appearance="Appearance.Neutral" OnClick="ClearTraceFilter">
                                @L["Clear trace filter"]
                            </FluentButton>
                        }
                        @if (ShowResourceSelector)
                        {
                            <ResourceSourceSelect Id="trace-source-filter"
                                                  Label="@L["Trace source"]"
                                                  Resources="resources"
                                                  SelectedResourceId="selected?.Id"
                                                  SelectedResourceIdChanged="SelectResource"
                                                  AllOptionLabel="@(Inline ? null : L["All sources"].Value)"
                                                  ResourceLabel="GetResourceLabel" />
                        }
                        @if (selected is not null && scopes.Count > 1)
                        {
                            <label class="trace-source-filter" for="trace-scope-filter">
                                <span>@L["Scope"]</span>
                                <select id="trace-scope-filter" class="trace-source-select"
                                        value="@(selectedScope?.ScopeResourceId ?? string.Empty)"
                                        @onchange="SelectScope">
                                    <option value="">@L["All scopes"]</option>
                                    @foreach (var scope in scopes)
                                    {
                                        <option value="@scope.ScopeResourceId">@scope.Name</option>
                                    }
                                </select>
                            </label>
                        }
                        @if (ShowResourceLink && selected is not null)
                        {
                            <FluentAnchor Appearance="Appearance.Neutral" Href="@BuildResourceRoute(selected.Id)">
                                @L["Open resource"]
                            </FluentAnchor>
                        }
                    </Actions>
                </TelemetryExplorerHeader>
            }

            @if (ShowResourceDetails && selected is not null && string.IsNullOrWhiteSpace(TraceId))
            {
                <dl class="detail-list">
                    <dt>@L["Resource name"]</dt>
                    <dd>@DisplaySelection.GetResourceName(selected)</dd>
                    <dt>@L["Canonical resource ID"]</dt>
                    <dd>@selected.Id</dd>
                    <dt>@L["Service name"]</dt>
                    <dd>@(observability?.ServiceName ?? NormalizeServiceName(selected.Name, selected.Id))</dd>
                    <dt>@L["OTLP endpoint"]</dt>
                    <dd>@(observability?.OtlpEndpoint ?? L["Provider/default environment"].Value)</dd>
                    <dt>@L["Protocol"]</dt>
                    <dd>@(observability?.OtlpProtocol ?? L["grpc or http/protobuf"].Value)</dd>
                    <dt>@L["Primary endpoint"]</dt>
                    <dd>@selected.PrimaryEndpoint</dd>
                    <dt>@L["Resource attributes"]</dt>
                    <dd>@GetResourceAttributes(selected, observability)</dd>
                    @if (selectedScope is not null)
                    {
                        <dt>@L["Scope"]</dt>
                        <dd>@selectedScope.Name</dd>
                    }
                </dl>
            }

            <TelemetryExplorerHeader Title="@(string.IsNullOrWhiteSpace(TraceId) ? L["Recent spans"].Value : L["Trace chart"].Value)"
                                     Description="@GetSpanSummary(spans.Count)"
                                     ShowActions="@string.IsNullOrWhiteSpace(TraceId)">
                <Actions>
                    <label class="trace-source-filter compact" for="trace-sort-mode">
                        <span>@L["Sort"]</span>
                        <select id="trace-sort-mode"
                                class="trace-source-select compact"
                                value="@TraceSortMode"
                                @onchange="SelectTraceSortMode">
                            <option value="@TraceSortModes.Newest">@L["Newest"]</option>
                            <option value="@TraceSortModes.LongestDuration">@L["Longest duration"]</option>
                            <option value="@TraceSortModes.ErrorsFirst">@L["Errors first"]</option>
                        </select>
                    </label>
                </Actions>
            </TelemetryExplorerHeader>

            @if (spans.Count == 0)
            {
                <EmptyState Title="@L["No spans received"].Value"
                            Message="@L["Start this resource and send traffic through it. Spans are retained only while CloudShell is running."].Value"
                            Compact="true" />
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(TraceId))
                {
                    var trace = BuildTraceView(spans);
                    var selectedSpan = GetSelectedSpan(trace);

                    <section class="trace-detail">
                        <div class="trace-summary-grid">
                            <div>
                                <span>@L["Trace ID"]</span>
                                <strong>@trace.TraceId</strong>
                            </div>
                            <div>
                                <span>@L["Entry operation"]</span>
                                <strong>@trace.EntryOperation</strong>
                            </div>
                            <div>
                                <span>@L["Duration"]</span>
                                <strong>@FormatDuration(trace.Duration)</strong>
                            </div>
                            <div>
                                <span>@L["Total spans"]</span>
                                <strong>@trace.Rows.Count</strong>
                            </div>
                            <div>
                                <span>@L["Error spans"]</span>
                                <strong>@trace.ErrorSpanCount</strong>
                            </div>
                        </div>

                        <div class="trace-detail-grid">
                            <div class="trace-waterfall-panel">
                                <div class="trace-service-legend" aria-label="@L["Services"]">
                                    @foreach (var service in trace.Services)
                                    {
                                        <div class="trace-service-row">
                                            <span class="trace-service-color" style="@GetServiceColorStyle(service.Color)"></span>
                                            <span>@service.Name</span>
                                            <div class="trace-service-meter">
                                                <span style="@GetServiceMeterStyle(service.Percent, service.Color)"></span>
                                            </div>
                                            <strong>@service.Percent.ToString("0.#", CultureInfo.InvariantCulture)%</strong>
                                        </div>
                                    }
                                </div>

                                <div class="trace-waterfall-header">
                                    <span>@L["Operation"]</span>
                                    <span>@L["Service"]</span>
                                    <div class="trace-waterfall-axis">
                                        <span>0ms</span>
                                        <span>@FormatDuration(trace.Duration / 2)</span>
                                        <span>@FormatDuration(trace.Duration)</span>
                                    </div>
                                    <span>@L["Duration"]</span>
                                </div>

                                <div class="trace-waterfall" role="tree" aria-label="@L["Trace spans"]">
                                    <div class="trace-waterfall-ticks" aria-hidden="true">
                                        <span></span>
                                        <span></span>
                                        <span></span>
                                    </div>
                                    <div class="trace-waterfall-rows">
                                        @foreach (var row in trace.Rows)
                                        {
                                            var isSelected = selectedSpan?.SpanId == row.Span.SpanId;
                                            <button class="@GetTraceSpanRowClass(row, isSelected)" role="treeitem"
                                                    @onclick="() => SelectSpan(row.Span)">
                                                <span class="trace-span-label" style="@GetTraceRowIndentStyle(row.Depth)">
                                                    <span class="trace-span-title">
                                                        <strong>@row.Span.Name</strong>
                                                        @if (row.HasError)
                                                        {
                                                            <mark class="trace-error-pill">
                                                                <FluentIcon Value="@(new Icons.Regular.Size16.ErrorCircle())" />
                                                                @L["Error"]
                                                            </mark>
                                                        }
                                                        else if (row.NeedsAttention)
                                                        {
                                                            <mark class="trace-attention-pill">
                                                                @L["Needs attention"]
                                                            </mark>
                                                        }
                                                    </span>
                                                    <small>@row.Span.Kind</small>
                                                </span>
                                                <span class="trace-span-service">
                                                    <span class="trace-service-color" style="@GetServiceColorStyle(row.Color)"></span>
                                                    <span>@row.Span.ServiceName</span>
                                                </span>
                                                <span class="trace-span-track">
                                                    <span class="@GetTraceSpanBarClass(row)" style="@GetTraceSpanBarStyle(row)"></span>
                                                </span>
                                                <span class="trace-span-duration">@FormatDuration(row.Span.Duration)</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>

                            <aside class="trace-span-details">
                                @if (selectedSpan is null)
                                {
                                    <EmptyState Title="@L["No span selected"].Value"
                                                Message="@L["Select a span to inspect its details."].Value"
                                                Compact="true" />
                                }
                                else
                                {
                                    <div class="trace-detail-header">
                                        <span class="trace-service-color"
                                              style="@GetServiceColorStyle(GetServiceColor(selectedSpan.ServiceName))"></span>
                                        <div>
                                            <h3>@selectedSpan.Name</h3>
                                            <p>@selectedSpan.ServiceName</p>
                                            @if (IsErrorSpan(selectedSpan))
                                            {
                                                <mark class="trace-error-pill">
                                                    <FluentIcon Value="@(new Icons.Regular.Size16.ErrorCircle())" />
                                                    @L["Error"]
                                                </mark>
                                            }
                                            else if (trace.Rows.FirstOrDefault(row => row.Span.SpanId == selectedSpan.SpanId)?.NeedsAttention == true)
                                            {
                                                <mark class="trace-attention-pill">
                                                    @L["Needs attention"]
                                                </mark>
                                            }
                                        </div>
                                    </div>

                                    <dl class="detail-list compact trace-span-detail-list">
                                        <dt>@L["Span ID"]</dt>
                                        <dd>@selectedSpan.SpanId</dd>
                                        <dt>@L["Parent span"]</dt>
                                        <dd>@(selectedSpan.ParentSpanId ?? L["none"].Value)</dd>
                                        <dt>@L["Resource"]</dt>
                                        <dd>
                                            <a class="resource-link" href="@BuildResourceRoute(selectedSpan.ResourceId)">
                                                @GetResourceLabel(selectedSpan.ResourceId)
                                            </a>
                                        </dd>
                                        <dt>@L["Kind"]</dt>
                                        <dd>@selectedSpan.Kind</dd>
                                        <dt>@L["Status"]</dt>
                                        <dd>@selectedSpan.Status</dd>
                                        <dt>@L["Started"]</dt>
                                        <dd>@selectedSpan.StartTime.ToLocalTime().ToString("g")</dd>
                                        <dt>@L["Duration"]</dt>
                                        <dd>@FormatDuration(selectedSpan.Duration)</dd>
                                    </dl>

                                    <div class="trace-related-actions">
                                        <FluentAnchor Appearance="Appearance.Neutral"
                                                      Href="@BuildLogsRoute(selectedSpan.ResourceId, selectedSpan.TraceId)">
                                            @L["Related logs"]
                                        </FluentAnchor>
                                        <FluentAnchor Appearance="Appearance.Neutral"
                                                      Href="@BuildActivityRoute(selectedSpan.ResourceId, selectedSpan.TraceId, selectedSpan.SpanId)">
                                            @L["Related activity"]
                                        </FluentAnchor>
                                        <FluentAnchor Appearance="Appearance.Neutral"
                                                      Href="@BuildResourceRoute(selectedSpan.ResourceId)">
                                            @L["Open resource"]
                                        </FluentAnchor>
                                    </div>

                                    <div class="trace-attributes">
                                        <h3>@L["Attributes"]</h3>
                                        @if (selectedSpan.SpanAttributes.Count == 0)
                                        {
                                            <p>@L["No span attributes were captured."]</p>
                                        }
                                        else
                                        {
                                            <dl class="log-entry-metadata">
                                                @foreach (var spanAttribute in selectedSpan.SpanAttributes.OrderBy(attribute =>
                            attribute.Key, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <dt>@spanAttribute.Key</dt>
                                                    <dd>@spanAttribute.Value</dd>
                                                }
                                            </dl>
                                        }
                                    </div>
                                }
                            </aside>
                        </div>
                    </section>
                }
                else
                {
                    var traceSummaries = BuildRecentTraceSummaries(spans);
                    @if (traceSummaries.Count > 0)
                    {
                        <div class="recent-trace-list" aria-label="@L["Recent traces"]">
                            @foreach (var trace in traceSummaries)
                            {
                                <a class="@GetRecentTraceItemClass(trace)" href="@BuildTraceRoute(trace.RouteResourceId, trace.TraceId)">
                                    <span>
                                        <strong>@trace.EntryOperation</strong>
                                        <small>@FormatTraceId(trace.TraceId) / @trace.Services</small>
                                        @if (trace.EntryHasError)
                                        {
                                            <mark class="trace-error-pill">
                                                <FluentIcon Value="@(new Icons.Regular.Size16.ErrorCircle())" />
                                                @L["{0} error span(s)", trace.ErrorSpanCount]
                                            </mark>
                                        }
                                        else if (trace.NeedsAttention)
                                        {
                                            <mark class="trace-attention-pill">
                                                @L["Needs attention: {0} error span(s)", trace.ErrorSpanCount]
                                            </mark>
                                        }
                                    </span>
                                    <em>@L["{0} spans", trace.SpanCount]</em>
                                    <b>@FormatDuration(trace.Duration)</b>
                                </a>
                            }
                        </div>
                    }

                    <div class="log-entry-list wrap" role="log" aria-label="@L["Recent spans"]">
                        @foreach (var span in spans)
                        {
                            <div class="log-entry">
                                <time>@span.StartTime.ToLocalTime().ToString("HH:mm:ss")</time>
                                <span class="log-entry-source">@span.Kind</span>
                                <span class="log-entry-level">@span.Duration.TotalMilliseconds.ToString("0.#")ms</span>
                                <div class="log-entry-body">
                                    <pre>@span.Name
trace <a class="resource-link" href="@BuildTraceRoute(span.ResourceId, span.TraceId)">@FormatTraceId(span.TraceId)</a>
span @span.SpanId@(span.ParentSpanId is null ? string.Empty : $" parent {span.ParentSpanId}")
@GetSpanAttributes(span)</pre>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }
    </div>
</section>

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public string? TraceId { get; set; }

    [Parameter]
    public string? ScopeResourceId { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public bool ShowHeading { get; set; } = true;

    [Parameter]
    public bool UsePanel { get; set; } = true;

    [Parameter]
    public bool ShowSourceSummary { get; set; } = true;

    [Parameter]
    public bool ShowResourceSelector { get; set; } = true;

    [Parameter]
    public bool ShowResourceLink { get; set; } = true;

    [Parameter]
    public bool ShowResourceDetails { get; set; } = true;

    private System.Threading.Timer? refreshTimer;
    private IReadOnlyList<Resource> TraceResources { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> ResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<TraceSpan> RecentSpans { get; set; } = [];
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private string? SelectedSpanId { get; set; }
    private string TraceSortMode { get; set; } = TraceSortModes.Newest;
    private bool IsDisposed { get; set; }
    private bool IsRefreshingSpans { get; set; }

    protected override void OnInitialized()
    {
        refreshTimer = new System.Threading.Timer(
            _ =>
            {
                if (!IsDisposed)
                {
                    _ = InvokeAsync(RefreshSpansAsync);
                }
            },
            null,
            TimeSpan.FromSeconds(2),
            TimeSpan.FromSeconds(2));
    }

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        var resources = await ResourceManager.ListResourcesAsync();
        ResourcesById = resources.ToDictionary(resource => resource.Id, StringComparer.OrdinalIgnoreCase);
        TraceResources = resources
            .Where(resource => resource.EffectiveObservability.Traces)
            .OrderBy(DisplaySelection.GetResourceSortLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        await RefreshSpansAsync();
    }

    public void Dispose()
    {
        IsDisposed = true;
        refreshTimer?.Dispose();
    }

    private Resource? GetSelectedResource(IReadOnlyList<Resource> resources)
    {
        if (IsAllSourcesSelected())
        {
            return null;
        }

        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            var requested = resources.FirstOrDefault(resource =>
                string.Equals(resource.Id, ResourceId, StringComparison.OrdinalIgnoreCase));
            if (requested is not null)
            {
                return requested;
            }
        }

        return resources.FirstOrDefault();
    }

    private TelemetrySelectionIssue? GetSelectionIssue(IReadOnlyList<Resource> resources)
    {
        if (!string.IsNullOrWhiteSpace(ResourceId) &&
            !resources.Any(resource => string.Equals(resource.Id, ResourceId, StringComparison.OrdinalIgnoreCase)))
        {
            var resourceId = ResourceId.Trim();
            return new TelemetrySelectionIssue(
                L["Trace resource not found"].Value,
                L["Resource '{0}' does not expose traces or is not available.", GetResourceLabel(resourceId)].Value,
                Inline ? L["Open Resources"].Value : L["All trace resources"].Value,
                Inline ? GetResourcesRoute() : "/observability/traces");
        }

        if (IsAllSourcesSelected())
        {
            return null;
        }

        var selected = GetSelectedResource(resources);
        if (selected is not null &&
            !string.IsNullOrWhiteSpace(ScopeResourceId) &&
            GetSelectedScope(selected) is null)
        {
            var scopeResourceId = ScopeResourceId.Trim();
            return new TelemetrySelectionIssue(
                L["Trace scope not found"].Value,
                L["Telemetry scope '{0}' is not available for {1}.", GetResourceLabel(scopeResourceId), GetResourceLabel(selected)].Value,
                L["Show all scopes"].Value,
                BuildTraceRoute(selected.Id, TraceId));
        }

        return null;
    }

    private async Task RefreshSpansAsync()
    {
        if (IsRefreshingSpans || IsDisposed)
        {
            return;
        }

        IsRefreshingSpans = true;
        var selectionIssue = GetSelectionIssue(TraceResources);
        var allSourcesSelected = selectionIssue is null && IsAllSourcesSelected();
        var selected = selectionIssue is null && !allSourcesSelected ? GetSelectedResource(TraceResources) : null;
        try
        {
            RecentSpans = selectionIssue is not null || (selected is null && !allSourcesSelected)
                ? []
                : await TraceManager.ListTraceSpansAsync(new TraceQuery(
                    ResourceId: selected is not null && string.IsNullOrWhiteSpace(TraceId) ? selected.Id : null,
                    TraceId: NormalizeFilter(TraceId),
                    MaxSpans: 200,
                    Scope: selected is null ? null : GetSelectedScope(selected)?.ToQueryScope()));

            if (!RecentSpans.Any(span => string.Equals(span.SpanId, SelectedSpanId, StringComparison.OrdinalIgnoreCase)))
            {
                SelectedSpanId = RecentSpans
                    .OrderBy(span => span.StartTime)
                    .FirstOrDefault(span => string.IsNullOrWhiteSpace(span.ParentSpanId))
                    ?.SpanId
                    ?? RecentSpans.OrderBy(span => span.StartTime).FirstOrDefault()?.SpanId;
            }

            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            IsRefreshingSpans = false;
        }
    }

    private void SelectResource(ChangeEventArgs args) =>
        SelectResource(args.Value?.ToString());

    private void SelectResource(string? resourceId)
    {
        if (!Inline && string.IsNullOrWhiteSpace(resourceId))
        {
            if (!IsAllSourcesSelected())
            {
                Navigation.NavigateTo(BuildTraceRoute(null, TraceId));
            }

            return;
        }

        if (string.IsNullOrWhiteSpace(resourceId) ||
            string.Equals(resourceId, ResourceId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Navigation.NavigateTo(BuildTraceRoute(resourceId, TraceId));
    }

    private void SelectScope(ChangeEventArgs args)
    {
        var selected = GetSelectedResource(TraceResources);
        if (selected is null)
        {
            return;
        }

        Navigation.NavigateTo(BuildTraceRoute(selected.Id, TraceId, args.Value?.ToString()));
    }

    private void SelectTraceSortMode(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        TraceSortMode = TraceSortModes.IsSupported(value)
            ? value!
            : TraceSortModes.Newest;
    }

    private void ShowAllResources() => Navigation.NavigateTo("/observability/traces");

    private void ClearTraceFilter()
    {
        var selected = GetSelectedResource(TraceResources);
        if (selected is null)
        {
            Navigation.NavigateTo(Inline && !string.IsNullOrWhiteSpace(ResourceId)
                ? ResourceManagerCompositionLinks.ResourceDetails(Composition, ResourceId, ResourcePredefinedViewIds.Traces)
                : "/observability/traces");
            return;
        }

        Navigation.NavigateTo(BuildTraceRoute(selected.Id, scopeResourceId: ScopeResourceId));
    }

    private bool IsAllSourcesSelected() =>
        !Inline && string.IsNullOrWhiteSpace(ResourceId);

    private void SelectSpan(TraceSpan span)
    {
        SelectedSpanId = span.SpanId;
    }

    private static string GetStateSuffix(Resource resource) =>
        resource.State is { } state ? $" / {state}" : string.Empty;

    private string GetResourceLabel(Resource resource) =>
        DisplaySelection.GetResourceLabel(resource);

    private string GetResourceLabel(string resourceId) =>
        ResourcesById.TryGetValue(resourceId, out var resource)
            ? GetResourceLabel(resource)
            : ResourceDisplayLabels.GetName(resourceId);

    private string GetSpanSummary(int spanCount) =>
        string.IsNullOrWhiteSpace(TraceId)
            ? L["{0} spans retained in memory", spanCount].Value
            : L["{0} spans retained in memory for trace {1}", spanCount, FormatTraceId(TraceId)].Value;

    private bool ShouldShowSourceHeader(IReadOnlyList<TelemetryScopeDescriptor> scopes) =>
        ShowSourceSummary ||
        ShowResourceSelector ||
        scopes.Count > 1 ||
        ShowResourceLink ||
        (!ShowHeading && !string.IsNullOrWhiteSpace(TraceId));

    private static Dictionary<string, string?> BuildTraceQuery(
        string? resourceId,
        string? traceId,
        string? scopeResourceId = null)
    {
        var query = new Dictionary<string, string?>();

        if (!string.IsNullOrWhiteSpace(resourceId))
        {
            query["resourceId"] = resourceId.Trim();
        }

        if (!string.IsNullOrWhiteSpace(traceId))
        {
            query["traceId"] = traceId.Trim();
        }

        if (!string.IsNullOrWhiteSpace(scopeResourceId))
        {
            query["scopeResourceId"] = scopeResourceId.Trim();
        }

        return query;
    }

    private static string? NormalizeFilter(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string FormatTraceId(string traceId) =>
        traceId.Length <= 12
            ? traceId
            : traceId[^12..];

    private static string NormalizeServiceName(string name, string resourceId)
    {
        var candidate = string.IsNullOrWhiteSpace(name) ? resourceId : name;
        var normalized = string.Join(
                "-",
                candidate.Trim().ToLowerInvariant().Split(
                    [' ', '.', '_', ':', '/', '\\'],
                    StringSplitOptions.RemoveEmptyEntries))
            .Trim('-');

        return string.IsNullOrWhiteSpace(normalized) ? resourceId : normalized;
    }

    private static string GetResourceAttributes(
        Resource resource,
        ResourceObservability? observability)
    {
        var attributes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["service.instance.id"] = resource.Id,
            ["cloudshell.resource.id"] = resource.Id,
            ["cloudshell.resource.type"] = resource.EffectiveTypeId
        };

        if (observability is not null)
        {
            foreach (var attribute in observability.Attributes)
            {
                attributes[attribute.Key] = attribute.Value;
            }
        }

        return string.Join(", ", attributes.Select(attribute => $"{attribute.Key}={attribute.Value}"));
    }

    private static string GetSpanAttributes(TraceSpan span) =>
        span.SpanAttributes.Count == 0
            ? string.Empty
            : string.Join(", ", span.SpanAttributes.Select(attribute => $"{attribute.Key}={attribute.Value}"));

    private static TraceViewModel BuildTraceView(IReadOnlyList<TraceSpan> spans)
    {
        var ordered = spans
            .OrderBy(span => span.StartTime)
            .ThenBy(span => span.Duration)
            .ToArray();
        var traceId = ordered.FirstOrDefault()?.TraceId ?? string.Empty;
        var traceStart = ordered.FirstOrDefault()?.StartTime ?? DateTimeOffset.UtcNow;
        var traceEnd = ordered
            .Select(span => span.StartTime.Add(span.Duration))
            .DefaultIfEmpty(traceStart)
            .Max();
        var traceDuration = traceEnd - traceStart;
        if (traceDuration <= TimeSpan.Zero)
        {
            traceDuration = TimeSpan.FromMilliseconds(1);
        }

        var serviceColors = ordered
            .Select(span => span.ServiceName)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select((service, index) => new
            {
                Service = service,
                Color = ServicePalette[index % ServicePalette.Length]
            })
            .ToDictionary(item => item.Service, item => item.Color, StringComparer.OrdinalIgnoreCase);

        var depthBySpan = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var spanById = ordered.ToDictionary(span => span.SpanId, StringComparer.OrdinalIgnoreCase);
        int GetDepth(TraceSpan span)
        {
            if (depthBySpan.TryGetValue(span.SpanId, out var depth))
            {
                return depth;
            }

            if (string.IsNullOrWhiteSpace(span.ParentSpanId) ||
                !spanById.TryGetValue(span.ParentSpanId, out var parent))
            {
                depthBySpan[span.SpanId] = 0;
                return 0;
            }

            depth = Math.Min(GetDepth(parent) + 1, 12);
            depthBySpan[span.SpanId] = depth;
            return depth;
        }

        var traceDurationMilliseconds = Math.Max(traceDuration.TotalMilliseconds, 1);
        var childrenByParentSpanId = ordered
            .Where(span => !string.IsNullOrWhiteSpace(span.ParentSpanId))
            .GroupBy(span => span.ParentSpanId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.ToArray(), StringComparer.OrdinalIgnoreCase);
        var hasErrorDescendantBySpanId = new Dictionary<string, bool>(StringComparer.OrdinalIgnoreCase);
        bool HasErrorDescendant(TraceSpan span)
        {
            if (hasErrorDescendantBySpanId.TryGetValue(span.SpanId, out var hasErrorDescendant))
            {
                return hasErrorDescendant;
            }

            hasErrorDescendant = childrenByParentSpanId.TryGetValue(span.SpanId, out var children) &&
                children.Any(child => IsErrorSpan(child) || HasErrorDescendant(child));
            hasErrorDescendantBySpanId[span.SpanId] = hasErrorDescendant;
            return hasErrorDescendant;
        }

        var rows = ordered
            .Select(span =>
            {
                var offset = Math.Max(0, (span.StartTime - traceStart).TotalMilliseconds / traceDurationMilliseconds * 100);
                var width = Math.Max(.6, span.Duration.TotalMilliseconds / traceDurationMilliseconds * 100);
                return new TraceSpanRow(
                    span,
                    GetDepth(span),
                    Math.Min(offset, 99.4),
                    Math.Min(width, 100 - Math.Min(offset, 99.4)),
                    serviceColors.TryGetValue(span.ServiceName, out var color) ? color : ServicePalette[0],
                    IsErrorSpan(span),
                    HasErrorDescendant(span));
            })
            .ToArray();

        var totalServiceDuration = Math.Max(ordered.Sum(span => span.Duration.TotalMilliseconds), 1);
        var services = ordered
            .GroupBy(span => span.ServiceName, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var duration = group.Sum(span => span.Duration.TotalMilliseconds);
                return new TraceServiceSummary(
                    group.Key,
                    serviceColors.TryGetValue(group.Key, out var color) ? color : ServicePalette[0],
                    duration / totalServiceDuration * 100);
            })
            .OrderByDescending(service => service.Percent)
            .ThenBy(service => service.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        var entry = ordered.FirstOrDefault(span => string.IsNullOrWhiteSpace(span.ParentSpanId)) ?? ordered.FirstOrDefault();
        var errorSpanCount = ordered.Count(IsErrorSpan);
        var entryHasError = entry is not null && IsErrorSpan(entry);

        return new TraceViewModel(
            traceId,
            entry?.Name ?? "trace",
            traceDuration,
            errorSpanCount,
            entryHasError,
            rows,
            services);
    }

    private IReadOnlyList<RecentTraceSummary> BuildRecentTraceSummaries(
        IReadOnlyList<TraceSpan> spans) =>
        ApplyTraceSort(
            spans
                .GroupBy(span => span.TraceId, StringComparer.OrdinalIgnoreCase)
                .Select(group =>
                {
                    var ordered = group.OrderBy(span => span.StartTime).ToArray();
                    var first = ordered.First();
                    var entry = ordered.FirstOrDefault(span => string.IsNullOrWhiteSpace(span.ParentSpanId)) ?? first;
                    var end = ordered
                        .Select(span => span.StartTime.Add(span.Duration))
                        .DefaultIfEmpty(first.StartTime)
                        .Max();
                    var services = ordered
                        .Select(span => span.ServiceName)
                        .Distinct(StringComparer.OrdinalIgnoreCase);

                    return new RecentTraceSummary(
                        first.TraceId,
                        entry.ResourceId,
                        entry.Name,
                        ordered.Length,
                        ordered.Count(IsErrorSpan),
                        IsErrorSpan(entry),
                        first.StartTime,
                        end,
                        end - first.StartTime,
                        string.Join(", ", services));
                }),
            TraceSortMode)
            .Take(8)
            .ToArray();

    private TraceSpan? GetSelectedSpan(TraceViewModel trace) =>
        trace.Rows.FirstOrDefault(row => string.Equals(row.Span.SpanId, SelectedSpanId,
StringComparison.OrdinalIgnoreCase))?.Span
        ?? trace.Rows.FirstOrDefault()?.Span;

    // OpenTelemetry span status uses Unset, Ok, and Error. Treat any status
    // outside Unset/Ok as an error signal without HTTP-specific assumptions.
    private static bool IsErrorSpan(TraceSpan span) =>
        !string.IsNullOrWhiteSpace(span.Status) &&
        !string.Equals(span.Status, "Unset", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(span.Status, "Ok", StringComparison.OrdinalIgnoreCase);

    private static string FormatDuration(TimeSpan duration) =>
        duration.TotalSeconds >= 1
            ? $"{duration.TotalSeconds.ToString("0.##", CultureInfo.InvariantCulture)}s"
            : $"{duration.TotalMilliseconds.ToString("0.#", CultureInfo.InvariantCulture)}ms";

    private static string GetTraceRowIndentStyle(int depth) =>
        $"--trace-depth: {depth.ToString(CultureInfo.InvariantCulture)}";

    private static string GetTraceSpanBarStyle(TraceSpanRow row) =>
        string.Create(
            CultureInfo.InvariantCulture,
            $"left: {row.OffsetPercent:0.###}%; width: {row.WidthPercent:0.###}%; background: {GetTraceSpanBarColor(row)};");

    private static string GetTraceSpanBarColor(TraceSpanRow row) =>
        row.HasError
            ? "var(--cloudshell-danger-text)"
            : row.NeedsAttention
                ? "var(--cloudshell-warning-text)"
                : row.Color;

    private static string GetTraceSpanRowClass(TraceSpanRow row, bool isSelected) =>
        (isSelected, row.HasError, row.NeedsAttention) switch
        {
            (true, true, _) => "trace-span-row selected error",
            (true, false, true) => "trace-span-row selected attention",
            (true, false, false) => "trace-span-row selected",
            (false, true, _) => "trace-span-row error",
            (false, false, true) => "trace-span-row attention",
            _ => "trace-span-row"
        };

    private static string GetTraceSpanBarClass(TraceSpanRow row) =>
        row.HasError
            ? "trace-span-bar error"
            : row.NeedsAttention
                ? "trace-span-bar attention"
                : "trace-span-bar";

    private static string GetRecentTraceItemClass(RecentTraceSummary trace) =>
        trace.EntryHasError
            ? "recent-trace-item error"
            : trace.NeedsAttention
                ? "recent-trace-item attention"
                : "recent-trace-item";

    private static IOrderedEnumerable<RecentTraceSummary> ApplyTraceSort(
        IEnumerable<RecentTraceSummary> traces,
        string sortMode) =>
        sortMode switch
        {
            TraceSortModes.LongestDuration => traces
                .OrderByDescending(trace => trace.Duration)
                .ThenByDescending(trace => trace.EndedAt)
                .ThenBy(trace => trace.EntryOperation, StringComparer.OrdinalIgnoreCase),
            TraceSortModes.ErrorsFirst => traces
                .OrderByDescending(trace => trace.AttentionRank)
                .ThenByDescending(trace => trace.EndedAt)
                .ThenByDescending(trace => trace.Duration)
                .ThenBy(trace => trace.EntryOperation, StringComparer.OrdinalIgnoreCase),
            _ => traces
                .OrderByDescending(trace => trace.EndedAt)
                .ThenByDescending(trace => trace.Duration)
                .ThenBy(trace => trace.EntryOperation, StringComparer.OrdinalIgnoreCase)
        };

    private static class TraceSortModes
    {
        public const string Newest = "newest";
        public const string LongestDuration = "longest-duration";
        public const string ErrorsFirst = "errors-first";

        public static bool IsSupported(string? value) =>
            string.Equals(value, Newest, StringComparison.Ordinal) ||
            string.Equals(value, LongestDuration, StringComparison.Ordinal) ||
            string.Equals(value, ErrorsFirst, StringComparison.Ordinal);
    }

    private static string GetServiceColorStyle(string color) =>
        $"background: {color};";

    private static string GetServiceMeterStyle(double percent, string color) =>
        string.Create(
            CultureInfo.InvariantCulture,
            $"width: {Math.Clamp(percent, 0, 100):0.###}%; background: {color};");

    private static string GetServiceColor(string serviceName)
    {
        var hash = StringComparer.OrdinalIgnoreCase.GetHashCode(serviceName);
        var index = Math.Abs(hash % ServicePalette.Length);
        return ServicePalette[index];
    }

    private string BuildTraceRoute(
        string? resourceId,
        string? traceId = null,
        string? scopeResourceId = null)
    {
        if (Inline)
        {
            resourceId ??= ResourceId;
            if (string.IsNullOrWhiteSpace(resourceId))
            {
                return GetResourcesRoute();
            }

            var query = new Dictionary<string, string?>();

            if (!string.IsNullOrWhiteSpace(traceId))
            {
                query["traceId"] = traceId.Trim();
            }

            if (!string.IsNullOrWhiteSpace(scopeResourceId))
            {
                query["scopeResourceId"] = scopeResourceId.Trim();
            }

            return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
                ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Traces),
                query);
        }

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            "/observability/traces",
            BuildTraceQuery(resourceId, traceId, scopeResourceId));
    }

    private TelemetryScopeDescriptor? GetSelectedScope(Resource? resource)
    {
        if (resource is null || string.IsNullOrWhiteSpace(ScopeResourceId))
        {
            return null;
        }

        return resource.EffectiveObservability.TelemetryScopes.FirstOrDefault(scope =>
            string.Equals(scope.ScopeResourceId, ScopeResourceId, StringComparison.OrdinalIgnoreCase));
    }

    private string BuildLogsRoute(string resourceId, string traceId) =>
        Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Logs),
            new Dictionary<string, string?>
            {
                ["traceId"] = traceId
            });

    private string BuildActivityRoute(string resourceId, string traceId, string spanId) =>
        Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Activity),
            new Dictionary<string, string?>
            {
                ["traceId"] = traceId,
                ["spanId"] = spanId
            });

    private string BuildResourceRoute(string resourceId) =>
        ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId);

    private string GetResourcesRoute() =>
        ResourceManagerCompositionLinks.ResourceManagerPage(
            Composition,
            ResourceManagerCompositionIds.ResourcesPage,
            ResourceManagerRoutes.Resources);

    private static readonly string[] ServicePalette =
    [
        "#38bdf8",
        "#f59e0b",
        "#a78bfa",
        "#34d399",
        "#fb7185",
        "#60a5fa",
        "#f97316",
        "#c084fc"
    ];

    private sealed record TraceViewModel(
        string TraceId,
        string EntryOperation,
        TimeSpan Duration,
        int ErrorSpanCount,
        bool EntryHasError,
        IReadOnlyList<TraceSpanRow> Rows,
        IReadOnlyList<TraceServiceSummary> Services)
    {
        public bool NeedsAttention => !EntryHasError && ErrorSpanCount > 0;
    }

    private sealed record TraceSpanRow(
        TraceSpan Span,
        int Depth,
        double OffsetPercent,
        double WidthPercent,
        string Color,
        bool HasError,
        bool HasErrorDescendant)
    {
        public bool NeedsAttention => !HasError && HasErrorDescendant;
    }

    private sealed record TraceServiceSummary(
        string Name,
        string Color,
        double Percent);

    private sealed record RecentTraceSummary(
        string TraceId,
        string RouteResourceId,
        string EntryOperation,
        int SpanCount,
        int ErrorSpanCount,
        bool EntryHasError,
        DateTimeOffset StartedAt,
        DateTimeOffset EndedAt,
        TimeSpan Duration,
        string Services)
    {
        public bool NeedsAttention => !EntryHasError && ErrorSpanCount > 0;

        public int AttentionRank => EntryHasError ? 2 : NeedsAttention ? 1 : 0;
    }

    private sealed record TelemetrySelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);
}
