@page "/telemetry/traces"
@page "/observability/traces"
@rendermode InteractiveServer
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L
@using CloudShell.Abstractions.Authorization

<PageTitle>@L["Traces"]</PageTitle>

@if (!Authorization.CanReadTraces())
{
    <EmptyState Title="@L["Access denied"].Value"
                Message="@L["Your identity does not have permission to view telemetry traces."].Value" />
}
else
{
    <TraceExplorer ResourceId="@ResourceId"
                   TraceId="@TraceId"
                   ScopeResourceId="@ScopeResourceId" />
}

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ResourceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? TraceId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public string? ScopeResourceId { get; set; }
}
