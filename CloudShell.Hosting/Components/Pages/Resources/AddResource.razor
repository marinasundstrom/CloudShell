@page "/resources/add"
@rendermode InteractiveServer
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject ICoreShellRouteService ShellRoutes
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Add resource"]</PageTitle>

@{
    var resourceTypes = ShellCatalog.ResourceTypes;
    var selectedTypeIssue = GetRequestedResourceTypeIssue(resourceTypes);
    var selectedType = selectedTypeIssue is null
        ? resourceTypes.FirstOrDefault(type => type.Id == SelectedTypeId) ?? resourceTypes.FirstOrDefault()
        : null;
}

<PageHeading Eyebrow="@L["Resource Manager"].Value"
             Title="@L["Add resource"].Value"
             Description="@(IsReadOnly
                 ? L["Resource Manager is in read-only mode. Resource registration is disabled in this UI."].Value
                 : L["Select the type of resource to register. Extensions own the registration experience for their resource types."].Value)"
             Class="add-resource-heading"
             ActionsClass="">
    <Actions>
        <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
            @L["Cancel"]
        </FluentButton>
    </Actions>
</PageHeading>

@if (IsReadOnly)
{
    <ProcedureMessage>
        @L["Resource Manager is in read-only mode. Resource creation, lifecycle actions, updates, and deletes are disabled in this UI."]
    </ProcedureMessage>
}
else
{
    <section class="add-resource-layout">
        <aside class="panel registration-options add-resource-type-panel">
            <h2>@L["Resource type"]</h2>
            <div class="add-resource-type-picker">
                <label for="resource-type">@L["Type"]</label>
                <button id="resource-type"
                        type="button"
                        class="add-resource-type-trigger"
                        aria-haspopup="listbox"
                        aria-expanded="@IsTypePickerOpen"
                        @onclick="ToggleTypePicker">
                    @if (selectedType is null)
                    {
                        <span class="add-resource-type-trigger-text">@L["Select a resource type"]</span>
                    }
                    else
                    {
                        <span class="add-resource-option selected-trigger-option">
                            <span class="add-resource-type-icon" aria-hidden="true">
                                <FluentIcon Value="@ResourceTypeIcons.FromName(selectedType.Icon)" />
                            </span>
                            <span class="add-resource-option-text">
                                <strong>@selectedType.DisplayName</strong>
                                <span>@selectedType.Description</span>
                            </span>
                        </span>
                    }
                    <span class="add-resource-type-trigger-chevron" aria-hidden="true">▾</span>
                </button>

                @if (IsTypePickerOpen)
                {
                    <div class="add-resource-type-list" role="listbox" aria-labelledby="resource-type">
                        @foreach (var resourceType in resourceTypes)
                        {
                            var isSelected = string.Equals(
                                resourceType.Id,
                                selectedType?.Id,
                                StringComparison.OrdinalIgnoreCase);
                            <button type="button"
                                    role="option"
                                    class="add-resource-type-item @(isSelected ? "selected" : null)"
                                    aria-selected="@isSelected"
                                    @onclick="@(() => SelectType(resourceType.Id))">
                                <div class="add-resource-option">
                                    <span class="add-resource-type-icon" aria-hidden="true">
                                        <FluentIcon Value="@ResourceTypeIcons.FromName(resourceType.Icon)" />
                                    </span>
                                    <div class="add-resource-option-text">
                                        <strong>@resourceType.DisplayName</strong>
                                        <span>@resourceType.Description</span>
                                    </div>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="add-resource-type-actions">
                <a href="@GetCreateResourceGroupRoute()">@L["Create a resource group"]</a>
            </div>
        </aside>

        <div class="panel registration-host add-resource-form-panel">
            @if (selectedTypeIssue is not null)
            {
                <EmptyState Title="@selectedTypeIssue.Title"
                            Message="@selectedTypeIssue.Message">
                    <FluentAnchor Appearance="Appearance.Neutral" Href="@selectedTypeIssue.RecoveryHref">
                        @selectedTypeIssue.RecoveryLabel
                    </FluentAnchor>
                </EmptyState>
            }
            else if (selectedType is null)
            {
                <EmptyState Title="@L["No resource types are installed"].Value"
                            Message="@L["Install an extension that contributes at least one resource type."].Value" />
            }
            else
            {
                var probeContext = GetProbeContext(selectedType);
                <CascadingValue Value="probeContext">
                    <CascadingValue Value="selectedType">
                        <CascadingValue Value="RegistrationNavigation">
                            <DynamicComponent Type="selectedType.RegistrationComponentType" />
                        </CascadingValue>
                    </CascadingValue>
                </CascadingValue>
            }
        </div>
    </section>
}

@code {
    private const string ResourceTypeQueryParameter = "type";
    private string? SelectedTypeId { get; set; }
    private bool IsTypePickerOpen { get; set; }
    private string? ReturnUrl { get; set; }
    private Dictionary<string, ResourceRegistrationProbeContext> ProbeContexts { get; } =
        new(StringComparer.OrdinalIgnoreCase);
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private ResourceRegistrationNavigationContext RegistrationNavigation =>
        new(ReturnUrl);

    protected override async Task OnInitializedAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        ReturnUrl = GetRequestedReturnUrl();

        if (IsReadOnly)
        {
            return;
        }

        if (!Authorization.HasPermission(CloudShellPermissions.Resources.Create))
        {
            Navigation.NavigateTo("/account/access-denied");
            return;
        }

        SelectedTypeId ??= GetRequestedResourceTypeId() ??
            ShellCatalog.ResourceTypes.FirstOrDefault()?.Id;
    }

    private void Cancel() => Navigation.NavigateTo(RegistrationNavigation.GetReturnUrlOrDefault());

    private void ChangeSelectedType(string? resourceTypeId)
    {
        IsTypePickerOpen = false;
        SelectedTypeId = resourceTypeId;
        var target = Navigation.GetUriWithQueryParameter(
            ResourceTypeQueryParameter,
            string.IsNullOrWhiteSpace(resourceTypeId) ? null : resourceTypeId);
        Navigation.NavigateTo(target, replace: true);
    }

    private void ToggleTypePicker() =>
        IsTypePickerOpen = !IsTypePickerOpen;

    private void SelectType(string resourceTypeId) =>
        ChangeSelectedType(resourceTypeId);

    private string? GetRequestedResourceTypeId()
    {
        var requested = GetRequestedQueryValue(ResourceTypeQueryParameter);
        if (string.IsNullOrWhiteSpace(requested))
        {
            return null;
        }

        return ShellCatalog.ResourceTypes.Any(type =>
            string.Equals(type.Id, requested, StringComparison.OrdinalIgnoreCase))
            ? requested
            : null;
    }

    private ResourceTypeSelectionIssue? GetRequestedResourceTypeIssue(
        IReadOnlyList<ResourceTypeContribution> resourceTypes)
    {
        var requested = GetRequestedQueryValue(ResourceTypeQueryParameter);
        if (string.IsNullOrWhiteSpace(requested) ||
            resourceTypes.Any(type => string.Equals(type.Id, requested, StringComparison.OrdinalIgnoreCase)))
        {
            return null;
        }

        var resourceTypeId = requested.Trim();
        return new ResourceTypeSelectionIssue(
            L["Resource type not found"].Value,
            L["Resource type '{0}' is not installed or is not available.", resourceTypeId].Value,
            L["Show resource types"].Value,
            BuildAddResourceRoute());
    }

    private string? GetRequestedReturnUrl()
    {
        var returnUrl = GetRequestedQueryValue("returnUrl");
        return ResourceRegistrationNavigationContext.IsLocalReturnUrl(returnUrl)
                ? returnUrl
                : null;
    }

    private string? GetRequestedQueryValue(string name)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(name, out var values)
            ? values.ToString()
            : null;
    }

    private string BuildAddResourceRoute()
    {
        var query = new Dictionary<string, string?>();
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
        {
            query["returnUrl"] = ReturnUrl;
        }

        return ResourceManagerShellLinks.ResourceManagerPage(ShellRoutes,
            ResourceManagerShellIds.AddResourcePage,
            ResourceManagerRoutes.AddResource,
            query);
    }

    private string GetCreateResourceGroupRoute() =>
        ResourceManagerShellLinks.ResourceManagerPage(ShellRoutes,
            ResourceManagerShellIds.CreateResourceGroupPage,
            ResourceManagerRoutes.CreateResourceGroup);

    private ResourceRegistrationProbeContext GetProbeContext(ResourceTypeContribution type)
    {
        if (!ProbeContexts.TryGetValue(type.Id, out var context))
        {
            context = new ResourceRegistrationProbeContext(type);
            ProbeContexts[type.Id] = context;
        }

        return context;
    }

    private sealed record ResourceTypeSelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);
}
