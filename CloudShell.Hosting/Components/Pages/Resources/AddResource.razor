@page "/resources/add"
@rendermode InteractiveServer
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Add resource"]</PageTitle>

@{
    var resourceTypes = ShellCatalog.ResourceTypes;
    var selectedType = resourceTypes.FirstOrDefault(type => type.Id == SelectedTypeId)
        ?? resourceTypes.FirstOrDefault();
}

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Resource Manager"]</span>
        <h1>@L["Add resource"]</h1>
        <p>@L["Select the type of resource to register. Extensions own the registration experience for their resource types."]</p>
    </div>
    <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
        @L["Cancel"]
    </FluentButton>
</section>

<section class="registration-layout">
    <aside class="panel registration-options">
        <h2>@L["Resource type"]</h2>
        <label for="resource-type">@L["Type"]</label>
        <FluentSelect TOption="string"
                      Id="resource-type"
                      @bind-Value="SelectedTypeId"
                      Appearance="Appearance.Outline">
            @foreach (var type in resourceTypes)
            {
                <FluentOption TOption="string" Value="@type.Id">@type.DisplayName</FluentOption>
            }
        </FluentSelect>

        @if (selectedType is not null)
        {
            <div class="selected-type-card">
                <span class="resource-kind-icon">@GetTypeGlyph(selectedType)</span>
                <div>
                    <strong>@selectedType.DisplayName</strong>
                    <p>@selectedType.Description</p>
                </div>
            </div>
        }

        <a href="/resources/groups/new">@L["Create a resource group"]</a>
    </aside>

    <div class="panel registration-host">
        @if (selectedType is null)
        {
            <div class="empty-state">
                <strong>@L["No resource types are installed"]</strong>
                <span>@L["Install an extension that contributes at least one resource type."]</span>
            </div>
        }
        else
        {
            var probeContext = GetProbeContext(selectedType);
            <div class="provider-summary compact">
                <div class="provider-status">
                    <span class="state-dot state-running"></span>
                    <div>
                        <strong>@selectedType.DisplayName</strong>
                        <span>@selectedType.Description</span>
                    </div>
                </div>
            </div>
            <CascadingValue Value="probeContext">
                <CascadingValue Value="selectedType">
                    <DynamicComponent Type="selectedType.RegistrationComponentType" />
                </CascadingValue>
            </CascadingValue>
        }
    </div>
</section>

@code {
    private string? SelectedTypeId { get; set; }
    private Dictionary<string, ResourceRegistrationProbeContext> ProbeContexts { get; } =
        new(StringComparer.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        if (!Authorization.HasPermission(CloudShellPermissions.Resources.Create))
        {
            Navigation.NavigateTo("/account/access-denied");
            return;
        }

        SelectedTypeId ??= ShellCatalog.ResourceTypes.FirstOrDefault()?.Id;
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private ResourceRegistrationProbeContext GetProbeContext(ResourceTypeContribution type)
    {
        if (!ProbeContexts.TryGetValue(type.Id, out var context))
        {
            context = new ResourceRegistrationProbeContext(type);
            ProbeContexts[type.Id] = context;
        }

        return context;
    }

    private static string GetTypeGlyph(ResourceTypeContribution type) =>
        type.Icon switch
        {
            "docker" => "D",
            _ => type.DisplayName[..1].ToUpperInvariant()
        };
}
