@page "/resources/groups/new"
@rendermode InteractiveServer
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Create resource group"]</PageTitle>

<PageHeading Eyebrow="@L["Resource Manager"].Value"
             Title="@L["Create resource group"].Value"
             Description="@(IsReadOnly
                 ? L["Resource Manager is in read-only mode. Resource group creation is disabled in this UI."].Value
                 : L["Create a project boundary for organizing resources across resource types."].Value)" />

@if (IsReadOnly)
{
    <ProcedureMessage>
        @L["Resource Manager is in read-only mode. Resource creation, lifecycle actions, updates, and deletes are disabled in this UI."]
    </ProcedureMessage>
}
else
{
    <FormPanel RenderAsSection="true" Class="panel">
        <label for="group-name">@L["Name"]</label>
        <FluentTextField Id="group-name" @bind-Value="Name" Placeholder="@L["Project development"]" />

        <label for="group-description">@L["Description"]</label>
        <FluentTextArea Id="group-description" @bind-Value="Description" Rows="4" Placeholder="@L["Resources for the project development environment."]" />

        <FormActions>
            <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
                @L["Cancel"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size20.FolderAdd())"
                          Disabled="@string.IsNullOrWhiteSpace(Name)"
                          OnClick="CreateGroup">
                @L["Create"]
            </FluentButton>
        </FormActions>
    </FormPanel>
}

@code {
    private string Name { get; set; } = string.Empty;
    private string Description { get; set; } = string.Empty;
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;

    protected override void OnInitialized()
    {
        if (IsReadOnly)
        {
            return;
        }

        if (!Authorization.CanAccessResourceGroup(
                "__new_resource_group",
                CloudShellPermissions.ResourceGroups.Create))
        {
            Navigation.NavigateTo("/account/access-denied");
        }
    }

    private void Cancel() => Navigation.NavigateTo(GetResourcesRoute());

    private async Task CreateGroup()
    {
        if (IsReadOnly)
        {
            return;
        }

        await ResourceManager.CreateResourceGroupAsync(
            new CreateResourceGroupCommand(Name, Description));
        Navigation.NavigateTo(GetAddResourceRoute());
    }

    private string GetResourcesRoute() =>
        ResourceManagerCompositionLinks.ResourceManagerPage(
            Composition,
            ResourceManagerCompositionIds.ResourcesPage,
            ResourceManagerRoutes.Resources);

    private string GetAddResourceRoute() =>
        ResourceManagerCompositionLinks.ResourceManagerPage(
            Composition,
            ResourceManagerCompositionIds.AddResourcePage,
            ResourceManagerRoutes.AddResource);
}
