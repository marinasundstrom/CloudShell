@inject IResourceManager ResourceManager
@inject ICoreShellRouteService ShellRoutes
@inject IStringLocalizer<SharedResource> L

@if (DnsZone is null)
{
    <EmptyState Title="DNS zone unavailable"
                Message="The DNS zone resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <h3>DNS zone</h3>
        <dl class="detail-list">
            <dt>Zone name</dt>
            <dd>@GetZoneAttribute(ResourceAttributeNames.DnsZoneName, DnsZone.Name)</dd>
            <dt>Provider</dt>
            <dd>@GetZoneAttribute(ResourceAttributeNames.DnsProvider, "logical")</dd>
            <dt>Name mappings</dt>
            <dd>@NameMappings.Count</dd>
            <dt>Conflicts</dt>
            <dd>@GetZoneAttribute(ResourceAttributeNames.DnsConflictCount, "0")</dd>
        </dl>
    </section>

    <section class="blade-section">
        <h3>Name mappings</h3>
        @if (NameMappings.Count == 0)
        {
            <p class="muted">No name mappings are owned by this DNS zone.</p>
        }
        else
        {
            @if (HasMappingAttention)
            {
                <ProcedureMessage Compact="true">
                    One or more name mappings need attention. Open the mapping to inspect diagnostics or update its configuration.
                </ProcedureMessage>
            }

            <div class="generated-list">
                @foreach (var mapping in NameMappings)
                {
                    <ResourceListItem Resource="mapping"
                                      Summary="@GetMappingSummary(mapping)"
                                      Metadata="@GetMappingMetadata(mapping)">
                        <TitleContent>
                            <a class="resource-link" href="@BuildResourceRoute(mapping.Id, ResourcePredefinedViewIds.Overview)">
                                @ResourceNameMappingDisplay.GetHostName(mapping)
                            </a>
                        </TitleContent>
                        <ChildContent>
                            @if (GetNameMappingEndpointAddress(mapping) is { } resolvedEndpoint)
                            {
                                <span class="inline-resource-reference">
                                    <span class="muted">@L["Resolved target endpoint"]</span>
                                    <EndpointLink Address="@resolvedEndpoint" />
                                </span>
                            }
                        </ChildContent>
                    </ResourceListItem>
                }
            </div>
        }
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? DnsZone { get; set; }
    private IReadOnlyList<Resource> NameMappings { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> ResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);

    private bool HasMappingAttention =>
        NameMappings.Any(mapping =>
            string.Equals(
                GetAttribute(mapping, ResourceAttributeNames.NameMappingStatus, "Ready"),
                "Conflict",
                StringComparison.OrdinalIgnoreCase) ||
            string.Equals(
                GetAttribute(mapping, ResourceAttributeNames.NameMappingMaterializationStatus, string.Empty),
                "PublishFailed",
                StringComparison.OrdinalIgnoreCase) ||
            string.Equals(
                GetAttribute(mapping, ResourceAttributeNames.NameMappingMaterializationStatus, string.Empty),
                "LogicalOnly",
                StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        var resources = ResourceCollectionProjection.DistinctById(await ResourceManager.ListResourcesAsync());
        ResourcesById = ResourceCollectionProjection.ToDictionaryById(resources);
        DnsZone = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ResourcesById.GetValueOrDefault(ResourceId);
        NameMappings = DnsZone is null
            ? []
            : resources
                .Where(IsOwnedNameMapping)
                .OrderBy(ResourceNameMappingDisplay.GetHostName, StringComparer.OrdinalIgnoreCase)
                .ToArray();
    }

    private bool IsOwnedNameMapping(Resource resource) =>
        ResourceNameMappingDisplay.IsNameMappingResource(resource) &&
        string.Equals(resource.ParentResourceId, DnsZone?.Id, StringComparison.OrdinalIgnoreCase);

    private string GetMappingSummary(Resource mapping)
    {
        var targetResourceId = GetAttribute(mapping, ResourceAttributeNames.NameMappingTargetResourceId, string.Empty);
        var targetLabel = ResourcesById.TryGetValue(targetResourceId, out var target)
            ? ResourceDisplayLabels.GetLabel(target)
            : ResourceDisplayLabels.GetName(targetResourceId);
        var endpoint = GetAttribute(mapping, ResourceAttributeNames.NameMappingTargetEndpointName, "default");

        return $"{targetLabel}/{endpoint}";
    }

    private string GetMappingMetadata(Resource mapping)
    {
        var parts = new List<string>
        {
            $"Exposure: {GetAttribute(mapping, ResourceAttributeNames.NameMappingExposure, ResourceExposureScope.Public.ToString())}",
            GetProviderLabel(mapping),
            $"Materialization: {ResourceNameMappingDisplay.GetMaterializationLabel(mapping, Localize)}"
        };

        if (!string.Equals(
                GetAttribute(mapping, ResourceAttributeNames.NameMappingStatus, "Ready"),
                "Ready",
                StringComparison.OrdinalIgnoreCase))
        {
            parts.Add($"Status: {GetAttribute(mapping, ResourceAttributeNames.NameMappingStatus, "unknown")}");
        }

        return string.Join(" - ", parts);
    }

    private string? GetNameMappingEndpointAddress(Resource mapping)
    {
        var targetResourceId = ResourceNameMappingDisplay.GetTargetResourceId(mapping);
        var target = string.IsNullOrWhiteSpace(targetResourceId)
            ? null
            : ResourcesById.GetValueOrDefault(targetResourceId);

        return ResourceNameMappingDisplay.GetMappedEndpointAddress(mapping, target);
    }

    private string GetProviderLabel(Resource mapping)
    {
        var providerResourceId = GetAttribute(mapping, ResourceAttributeNames.NameMappingProviderResourceId, string.Empty);
        if (!string.IsNullOrWhiteSpace(providerResourceId))
        {
            return ResourcesById.TryGetValue(providerResourceId, out var provider)
                ? $"Provider: {ResourceDisplayLabels.GetLabel(provider)}"
                : $"Provider: {ResourceDisplayLabels.GetName(providerResourceId)}";
        }

        return $"Provider: {GetAttribute(mapping, ResourceAttributeNames.DnsProvider, "logical")}";
    }

    private string GetZoneAttribute(string name, string fallback) =>
        DnsZone?.ResourceAttributes.TryGetValue(name, out var value) == true &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static string GetAttribute(Resource resource, string name, string fallback) =>
        resource.ResourceAttributes.TryGetValue(name, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private string BuildResourceRoute(string resourceId, ResourceViewId tabId) =>
        ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId, tabId);

    private string Localize(string value) => L[value].Value;
}
