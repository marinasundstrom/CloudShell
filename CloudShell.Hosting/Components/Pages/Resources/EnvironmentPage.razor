@page "/environment"
@rendermode InteractiveServer
@using System.Globalization
@inject IResourceManager ResourceManager
@inject IResourceEventManager ResourceEvents
@inject IResourceDeploymentManager Deployments
@inject IStringLocalizer<SharedResource> L
@inject CloudShell.UI.Composition.CompositionRegistry Composition

<PageTitle>@L["Environment"]</PageTitle>

<PageHeading Eyebrow="@L["Workspace"].Value"
             Title="@L["Current environment"].Value"
             Description="@L["Inspect environment revisions, deployment records, and materialized resource state for the current host."].Value">
    <Actions>
        <span class="toolbar-meta">@L["Current host"]</span>
        <FluentButton Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      OnClick="RefreshAsync">
            @L["Refresh"]
        </FluentButton>
    </Actions>
</PageHeading>

<SummaryMetricGrid AriaLabel="@L["Environment summary"].Value">
    <SummaryMetricCard Title="@L["Resources"].Value"
                       Value="@Resources.Count"
                       Summary="@L["Visible resources in this host environment"].Value"
                       IconName="resources" />
    <SummaryMetricCard Title="@L["Environment revisions"].Value"
                       Value="@EnvironmentRevisionRows.Count"
                       Summary="@L["Projected environment revisions"].Value"
                       IconName="dependencies" />
    <SummaryMetricCard Title="@L["Deployment records"].Value"
                       Value="@DeploymentRecords.Count"
                       Summary="@L["Recorded deployment attempts"].Value"
                       IconName="environment" />
    <SummaryMetricCard Title="@L["Replica groups"].Value"
                       Value="@ReplicaGroupCount"
                       Summary="@L["Projected materialized runtime groups"].Value"
                       IconName="container" />
</SummaryMetricGrid>

<section class="environment-page-grid">
    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Environment revisions"].Value"
                          Description="@L["Projected revisions for deployment-produced environment state, plus the current declared resource graph baseline."].Value">
            <Actions>
                <span class="toolbar-meta">@GetLoadedAtLabel()</span>
            </Actions>
        </ShellPanelHeader>

        @if (EnvironmentRevisionRows.Count == 0)
        {
            <EmptyState Title="@L["No environment resources"].Value"
                        Message="@L["Environment revisions will appear here when resources are declared or materialized through Resource Manager deployment."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-revision-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Environment revision"]</th>
                        <th>@L["Resources"]</th>
                        <th>@L["Deployments"]</th>
                        <th>@L["Services"]</th>
                        <th>@L["Replica groups"]</th>
                        <th>@L["Latest status"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var revision in EnvironmentRevisionRows)
                    {
                        <tr>
                            <td>
                                <strong>@revision.EnvironmentRevisionId</strong>
                                <div class="table-subtext">@revision.Description</div>
                            </td>
                            <td>@revision.ResourceCount</td>
                            <td>@revision.DeploymentCount</td>
                            <td>@revision.ServiceCount</td>
                            <td>@revision.ReplicaGroupCount</td>
                            <td>@revision.LatestStatus</td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Deployment history"].Value"
                          Description="@L["Deployment records produced by Resource Manager deployment apply. Runtime-capacity updates remain environment activity unless they apply a deployment."].Value" />

        @if (DeploymentRecords.Count == 0)
        {
            <EmptyState Title="@L["No deployment records"].Value"
                        Message="@L["Deployment records will appear here after Resource Manager applies deployment definitions."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-history-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Deployment"]</th>
                        <th>@L["Source resource"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Environment revision"]</th>
                        <th>@L["Based on"]</th>
                        <th>@L["Provisioned by"]</th>
                        <th>@L["Completed"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in DeploymentRecords)
                    {
                        var sourceResource = GetResource(record.SourceResourceId);
                        <tr>
                            <td>
                                <strong class="environment-identifier">@record.DeploymentId</strong>
                                <div class="table-subtext">@record.RuntimeRevisionId</div>
                            </td>
                            <td>
                                <ResourceTableIdentity IconName="@GetResourceIconName(sourceResource, record.SourceResourceId)"
                                                       IconTitle="@GetResourceIconTitle(sourceResource)"
                                                       Summary="@record.ServiceId">
                                    <TitleContent>
                                        <FluentAnchor Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, record.SourceResourceId)">
                                            @(sourceResource?.EffectiveDisplayName ?? record.SourceResourceId)
                                        </FluentAnchor>
                                    </TitleContent>
                                </ResourceTableIdentity>
                            </td>
                            <td>
                                @record.Status
                                <div class="table-subtext">@GetDeploymentRecordMessage(record)</div>
                            </td>
                            <td>
                                <span class="environment-identifier">@GetEnvironmentRevisionLabel(record)</span>
                                <div class="table-subtext">@GetEnvironmentRevisionStatus(record)</div>
                            </td>
                            <td><span class="environment-identifier">@GetOptional(record.BasedOnEnvironmentRevisionId)</span></td>
                            <td>@GetOptional(record.ProvisionedBy ?? record.TriggeredBy)</td>
                            <td>@GetCompletionLabel(record)</td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Materialized deployment state"].Value"
                          Description="@L["Resource Manager deployment metadata currently projected by materialized resources."].Value" />

        @if (DeploymentRows.Count == 0)
        {
            <EmptyState Title="@L["No deployment metadata projected"].Value"
                        Message="@L["Deployments will appear here when resources materialize runtime state through Resource Manager orchestration."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-deployment-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Resource"]</th>
                        <th>@L["Deployment"]</th>
                        <th>@L["Runtime revision"]</th>
                        <th>@L["Environment revision"]</th>
                        <th>@L["Service"]</th>
                        <th>@L["Replica group"]</th>
                        <th>@L["Replicas"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in DeploymentRows)
                    {
                        <tr>
                            <td>
                                <ResourceTableIdentity IconName="@GetResourceIconName(row.Resource, row.Resource.Id)"
                                                       IconTitle="@GetResourceIconTitle(row.Resource)"
                                                       Summary="@row.Resource.Id">
                                    <TitleContent>
                                        <FluentAnchor Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, row.Resource.Id)">
                                            @row.Resource.EffectiveDisplayName
                                        </FluentAnchor>
                                    </TitleContent>
                                </ResourceTableIdentity>
                            </td>
                            <td>
                                <strong class="environment-identifier">@row.DeploymentId</strong>
                                <div class="table-subtext">@row.Status</div>
                            </td>
                            <td><span class="environment-identifier">@row.RuntimeRevision</span></td>
                            <td><span class="environment-identifier">@row.EnvironmentRevisionId</span></td>
                            <td><span class="environment-identifier">@row.ServiceId</span></td>
                            <td><span class="environment-identifier">@row.ReplicaGroupId</span></td>
                            <td>@row.ReplicaSummary</td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel>
        <ShellPanelHeader Title="@L["Recent environment activity"].Value"
                          Description="@L["Latest deployment and runtime-capacity events emitted by resources in this environment."].Value" />

        @if (DeploymentEvents.Count == 0)
        {
            <EmptyState Title="@L["No environment activity"].Value"
                        Message="@L["Environment activity will appear after Resource Manager applies deployments, updates runtime capacity, or cleans up runtime state."].Value"
                        Compact="true" />
        }
        else
        {
            <ShellActivityList>
                @foreach (var resourceEvent in DeploymentEvents)
                {
                    <ShellActivityLink Title="@GetEventTitle(resourceEvent.EventType)"
                                       Summary="@resourceEvent.Message"
                                       TrailingText="@resourceEvent.Timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)"
                                       Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceEvent.ResourceId)" />
                }
            </ShellActivityList>
        }
    </ShellPanel>

    <ShellPanel>
        <ShellPanelHeader Title="@L["Model note"].Value"
                          Description="@L["Current scope"].Value" />
        <p class="panel-body-text">
            @L["CloudShell currently treats the local host as one active deployment environment. A future Control Plane Environment concept may contain resources within a host or runtime boundary; this page is currently a diagnostic view over the active host and its projected environment revisions."]
        </p>
    </ShellPanel>
</section>

@code {
    private IReadOnlyList<Resource> Resources { get; set; } = [];
    private IReadOnlyList<EnvironmentRevisionProjectionRow> EnvironmentRevisionRows { get; set; } = [];
    private IReadOnlyList<ResourceDeploymentRecord> DeploymentRecords { get; set; } = [];
    private IReadOnlyList<EnvironmentDeploymentRow> DeploymentRows { get; set; } = [];
    private IReadOnlyList<ResourceEvent> DeploymentEvents { get; set; } = [];
    private DateTimeOffset LoadedAt { get; set; }

    private int ReplicaGroupCount =>
        DeploymentRows
            .Select(row => row.ReplicaGroupId)
            .Where(value => !string.IsNullOrWhiteSpace(value) && value != "not projected")
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

    protected override async Task OnInitializedAsync() =>
        await RefreshAsync();

    private async Task RefreshAsync()
    {
        Resources = await ResourceManager.ListResourcesAsync();
        DeploymentRows = Resources
            .Where(resource => resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.DeploymentId))
            .Select(EnvironmentDeploymentRow.Create)
            .OrderBy(row => row.Resource.Name, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(row => row.Resource.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        EnvironmentRevisionRows = EnvironmentRevisionProjection.CreateRows(Resources);
        DeploymentRecords = await Deployments.ListResourceDeploymentsAsync(new ResourceDeploymentQuery(MaxRecords: 100));
        DeploymentEvents = (await ResourceEvents.ListResourceEventsAsync(new ResourceEventQuery(MaxEvents: 100)))
            .Where(resourceEvent => resourceEvent.EventType.StartsWith(
                ResourceEventTypes.Events.Deployment.Prefix,
                StringComparison.OrdinalIgnoreCase))
            .Take(15)
            .ToArray();
        LoadedAt = DateTimeOffset.UtcNow;
    }

    private string GetLoadedAtLabel() =>
        LoadedAt == default
            ? L["Not loaded"].Value
            : L["Loaded {0:g}", LoadedAt.ToLocalTime()].Value;

    private string GetEventTitle(string eventType) =>
        ResourceEventDisplayNames.GetDisplayName(eventType, L);

    private Resource? GetResource(string resourceId) =>
        Resources.FirstOrDefault(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase));

    private static string GetResourceIconName(Resource? resource, string fallback) =>
        resource is null
            ? fallback
            : FirstNonEmpty(resource.EffectiveTypeId, resource.ResourceClass.ToString(), resource.Kind) ?? fallback;

    private static string GetResourceIconTitle(Resource? resource) =>
        resource?.Kind ?? "Resource";

    private string GetDeploymentRecordMessage(ResourceDeploymentRecord record) =>
        GetOptional(record.Error ?? record.Message ?? record.Cause);

    private string GetEnvironmentRevisionLabel(ResourceDeploymentRecord record) =>
        record.EnvironmentRevisionNumber is { } revisionNumber
            ? L["Revision {0}", revisionNumber].Value
            : GetOptional(record.EnvironmentRevisionId);

    private string GetEnvironmentRevisionStatus(ResourceDeploymentRecord record) =>
        record.EnvironmentRevisionStatus?.ToString() ?? GetOptional(record.EnvironmentRevisionId);

    private string GetCompletionLabel(ResourceDeploymentRecord record)
    {
        var timestamp = record.CompletedAt ?? record.StartedAt;
        return timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);
    }

    private static string GetOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "not projected" : value;

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private sealed record EnvironmentDeploymentRow(
        Resource Resource,
        string DeploymentId,
        string Status,
        string RuntimeRevision,
        string EnvironmentRevisionId,
        string ServiceId,
        string ReplicaGroupId,
        string ReplicaSummary)
    {
        public static EnvironmentDeploymentRow Create(Resource resource)
        {
            var requestedReplicas = GetAttribute(resource, ResourceAttributeNames.DeploymentRequestedReplicas);
            var materializedReplicas = GetAttribute(resource, ResourceAttributeNames.DeploymentMaterializedReplicas);
            var replicaSummary = requestedReplicas == "not projected" && materializedReplicas == "not projected"
                ? "not projected"
                : $"{materializedReplicas} of {requestedReplicas}";

            return new EnvironmentDeploymentRow(
                resource,
                GetAttribute(resource, ResourceAttributeNames.DeploymentId),
                GetAttribute(resource, ResourceAttributeNames.DeploymentStatus),
                GetAttribute(resource, ResourceAttributeNames.DeploymentRevision),
                GetAttribute(resource, ResourceAttributeNames.DeploymentEnvironmentRevisionId),
                GetAttribute(resource, ResourceAttributeNames.DeploymentServiceId),
                GetAttribute(resource, ResourceAttributeNames.DeploymentReplicaGroupId),
                replicaSummary);
        }

        private static string GetAttribute(Resource resource, string name) =>
            resource.ResourceAttributes.GetValueOrDefault(name) ?? "not projected";
    }

    private static bool IsProjected(string value) =>
        !string.IsNullOrWhiteSpace(value) &&
        !string.Equals(value, "not projected", StringComparison.OrdinalIgnoreCase);
}
