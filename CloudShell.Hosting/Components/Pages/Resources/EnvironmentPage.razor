@page "/environment"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@inject IResourceManager ResourceManager
@inject IResourceEventManager ResourceEvents
@inject IResourceDeploymentManager Deployments
@inject IResourceReplicaSlotStateManager ReplicaSlots
@inject IStringLocalizer<SharedResource> L
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject ShellCatalog ShellCatalog

<PageTitle>@L["Environment"]</PageTitle>

<PageHeading Eyebrow="@L["Workspace"].Value"
             Title="@L["Current environment"].Value"
             Description="@L["Inspect environment revisions, deployment records, and materialized resource state for the current host."].Value">
    <Actions>
        <span class="toolbar-meta">@L["Current host"]</span>
        <FluentButton Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      OnClick="RefreshAsync">
            @L["Refresh"]
        </FluentButton>
    </Actions>
</PageHeading>

<SummaryMetricGrid AriaLabel="@L["Environment summary"].Value">
    <SummaryMetricCard Title="@L["Resources"].Value"
                       Value="@Resources.Count"
                       Summary="@L["Visible resources in this host environment"].Value"
                       IconName="resources" />
    <SummaryMetricCard Title="@L["Environment revisions"].Value"
                       Value="@EnvironmentRevisionRows.Count"
                       Summary="@L["Projected environment revisions"].Value"
                       IconName="dependencies" />
    <SummaryMetricCard Title="@L["Deployment records"].Value"
                       Value="@DeploymentRecords.Count"
                       Summary="@L["Recorded deployment attempts"].Value"
                       IconName="environment" />
    <SummaryMetricCard Title="@L["Replica groups"].Value"
                       Value="@ReplicaGroupCount"
                       Summary="@L["Active deployment replica groups"].Value"
                       IconName="container" />
    <SummaryMetricCard Title="@L["Replica slot issues"].Value"
                       Value="@OpenReplicaSlotStateCount"
                       Summary="@L["Open slot reconciliation states"].Value"
                       IconName="health" />
</SummaryMetricGrid>

<section class="environment-page-grid">
    <ShellPanel Wide="true" Class="environment-panel-full environment-map-panel">
        <ShellPanelHeader Title="@L["Environment map"].Value"
                          Description="@L["Significant resource, orchestration, and routing relationships for the active host environment."].Value">
            <Actions>
                <span class="toolbar-meta">@L["{0} relationship(s)", EnvironmentMap.Links.Count]</span>
            </Actions>
        </ShellPanelHeader>

        @if (EnvironmentMap.Nodes.Count == 0)
        {
            <EmptyState Title="@L["No environment state"].Value"
                        Message="@L["Resources, orchestrator services, and routing relationships will appear here when the Resource Manager has environment state to project."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-map-summary" aria-label="@L["Environment map summary"].Value">
                <span><strong>@EnvironmentMap.ResourceCount</strong> @L["resources"]</span>
                <span><strong>@EnvironmentMap.ServiceCount</strong> @L["orchestrator service(s)"]</span>
                <span><strong>@EnvironmentMap.RoutingCount</strong> @L["routing artifact(s)"]</span>
                @if (IncludeNetworkTopologyOverlay)
                {
                    <span><strong>@EnvironmentMap.NetworkTopologyCount</strong> @L["topology artifact(s)"]</span>
                }
                <span class="environment-map-layer-label">@L["Layers"]</span>
                <FluentCheckbox Class="environment-map-layer-toggle"
                                Value="@IncludeNetworkTopologyOverlay"
                                ValueChanged="OnNetworkTopologyOverlayChanged">
                    @L["Network topology"]
                </FluentCheckbox>
                <FluentCheckbox Class="environment-map-layer-toggle"
                                Value="@ShowEnvironmentMapLinkLabels"
                                ValueChanged="OnLinkLabelsChanged">
                    @L["Relationship labels"]
                </FluentCheckbox>
            </div>

            <div class="resource-graph-shell environment-state-map-shell">
                <svg class="environment-state-map-canvas" role="img" aria-label="@L["Environment state map"]"></svg>
                <div class="resource-graph-controls" aria-label="@L["Map controls"]">
                    <FluentButton Appearance="Appearance.Stealth"
                                  Class="environment-map-zoom-in"
                                  Title="@L["Zoom in"]"
                                  aria-label="@L["Zoom in"]">
                        <FluentIcon Value="@(new Icons.Regular.Size20.ZoomIn())" />
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Stealth"
                                  Class="environment-map-zoom-out"
                                  Title="@L["Zoom out"]"
                                  aria-label="@L["Zoom out"]">
                        <FluentIcon Value="@(new Icons.Regular.Size20.ZoomOut())" />
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Stealth"
                                  Class="environment-map-reset"
                                  Title="@L["Reset view"]"
                                  aria-label="@L["Reset view"]">
                        <FluentIcon Value="@(new Icons.Regular.Size20.ArrowReset())" />
                    </FluentButton>
                </div>
            </div>

            @if (SignificantEnvironmentMapLinks.Count > 0)
            {
                <section class="environment-relationship-strip" aria-label="@L["Significant relationships"].Value">
                    <h3>@L["Significant relationships"]</h3>
                    <div class="environment-relationship-list">
                        @foreach (var relationship in SignificantEnvironmentMapLinks)
                        {
                            <div class="environment-relationship-row">
                                <span>@GetEnvironmentMapNodeLabel(relationship.Source)</span>
                                <strong>@relationship.Label</strong>
                                <span>@GetEnvironmentMapNodeLabel(relationship.Target)</span>
                            </div>
                        }
                    </div>
                </section>
            }
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Environment revisions"].Value"
                          Description="@L["Projected revisions for deployment-produced environment state, plus the current declared resource graph baseline."].Value">
            <Actions>
                <span class="toolbar-meta">@GetLoadedAtLabel()</span>
            </Actions>
        </ShellPanelHeader>

        @if (EnvironmentRevisionRows.Count == 0)
        {
            <EmptyState Title="@L["No environment resources"].Value"
                        Message="@L["Environment revisions will appear here when resources are declared or materialized through Resource Manager deployment."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-revision-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Environment revision"]</th>
                        <th>@L["Resources"]</th>
                        <th>@L["Deployments"]</th>
                        <th>@L["Services"]</th>
                        <th>@L["Replica groups"]</th>
                        <th>@L["Latest status"]</th>
                        <th>@L["Based on"]</th>
                        <th>@L["Provisioned by"]</th>
                        <th>@L["Created"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var revision in EnvironmentRevisionRows)
                    {
                        <tr>
                            <td>
                                <strong>@GetEnvironmentRevisionLabel(revision)</strong>
                                <div class="table-subtext">@revision.EnvironmentRevisionId</div>
                            </td>
                            <td>@revision.ResourceCount</td>
                            <td>@revision.DeploymentCount</td>
                            <td>@revision.ServiceCount</td>
                            <td>@revision.ReplicaGroupCount</td>
                            <td>
                                @revision.LatestStatus
                                <div class="table-subtext">@revision.Description</div>
                            </td>
                            <td><span class="environment-identifier">@GetOptional(revision.BasedOnEnvironmentRevisionId)</span></td>
                            <td>@GetOptional(revision.ProvisionedBy)</td>
                            <td>@GetOptionalTimestamp(revision.CreatedAt)</td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Deployment history"].Value"
                          Description="@L["Deployment records produced by Resource Manager deployment apply, including image rollouts and scale reconciliation that changes desired runtime capacity."].Value" />

        @if (DeploymentRecords.Count == 0)
        {
            <EmptyState Title="@L["No deployment records"].Value"
                        Message="@L["Deployment records will appear here after Resource Manager applies deployment definitions."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-history-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Deployment"]</th>
                        <th>@L["Source resource"]</th>
                        <th>@L["Runtime revision"]</th>
                        <th>@L["Replica group"]</th>
                        <th>@L["Replicas"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Environment revision"]</th>
                        <th>@L["Based on"]</th>
                        <th>@L["Provisioned by"]</th>
                        <th>@L["Completed"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in DeploymentRecords)
                    {
                        var sourceResource = GetResource(record.SourceResourceId);
                        <tr>
                            <td>
                                <strong class="environment-identifier">@record.DeploymentId</strong>
                                <div class="table-subtext">@GetOptional(record.Cause)</div>
                            </td>
                            <td>
                                <ResourceTableIdentity IconName="@GetResourceIconName(sourceResource, record.SourceResourceId)"
                                                       IconTitle="@GetResourceIconTitle(sourceResource)"
                                                       Summary="@record.ServiceId">
                                    <TitleContent>
                                        <FluentAnchor Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, record.SourceResourceId)">
                                            @(sourceResource?.EffectiveDisplayName ?? record.SourceResourceId)
                                        </FluentAnchor>
                                    </TitleContent>
                                </ResourceTableIdentity>
                            </td>
                            <td><span class="environment-identifier">@GetRuntimeRevisionLabel(record)</span></td>
                            <td><span class="environment-identifier">@GetReplicaGroupLabel(record)</span></td>
                            <td>@GetDeploymentReplicaSummary(record)</td>
                            <td>
                                @record.Status
                                <div class="table-subtext">@GetDeploymentRecordMessage(record)</div>
                            </td>
                            <td>
                                <span class="environment-identifier">@GetEnvironmentRevisionLabel(record)</span>
                                <div class="table-subtext">@GetEnvironmentRevisionStatus(record)</div>
                            </td>
                            <td><span class="environment-identifier">@GetOptional(record.BasedOnEnvironmentRevisionId)</span></td>
                            <td>@GetOptional(record.ProvisionedBy ?? record.TriggeredBy)</td>
                            <td>@GetCompletionLabel(record)</td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Active replica groups"].Value"
                          Description="@L["Replica group snapshots produced by active deployment records, correlated with current slot reconciliation state."].Value" />

        @if (ReplicaGroupRows.Count == 0)
        {
            <EmptyState Title="@L["No active replica groups"].Value"
                        Message="@L["Active replica groups will appear here after Resource Manager materializes a deployment with requested replica slots."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-replica-group-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Source resource"]</th>
                        <th>@L["Service"]</th>
                        <th>@L["Replica group"]</th>
                        <th>@L["Runtime revision"]</th>
                        <th>@L["Requested slots"]</th>
                        <th>@L["Occupied slots"]</th>
                        <th>@L["Slot reconciliation"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in ReplicaGroupRows)
                    {
                        var sourceResource = GetResource(row.SourceResourceId);
                        <tr>
                            <td>
                                <ResourceTableIdentity IconName="@GetResourceIconName(sourceResource, row.SourceResourceId)"
                                                       IconTitle="@GetResourceIconTitle(sourceResource)"
                                                       Summary="@row.DeploymentId">
                                    <TitleContent>
                                        <FluentAnchor Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, row.SourceResourceId)">
                                            @(sourceResource?.EffectiveDisplayName ?? row.SourceResourceId)
                                        </FluentAnchor>
                                    </TitleContent>
                                </ResourceTableIdentity>
                            </td>
                            <td><span class="environment-identifier">@row.ServiceId</span></td>
                            <td>
                                <span class="environment-identifier">@row.ReplicaGroupId</span>
                                <div class="table-subtext">@GetEnvironmentRevisionLabel(row.Deployment)</div>
                            </td>
                            <td><span class="environment-identifier">@GetOptional(row.RuntimeRevisionId)</span></td>
                            <td>@row.RequestedSlots.ToString(CultureInfo.InvariantCulture)</td>
                            <td>
                                @row.OccupiedSlots.ToString(CultureInfo.InvariantCulture)
                                <div class="table-subtext">@L["{0} materialized", row.MaterializedReplicas]</div>
                            </td>
                            <td>
                                @GetReplicaGroupReconciliationSummary(row)
                                <div class="table-subtext">@GetLatestReplicaGroupReconciliationResult(row)</div>
                            </td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Materialized deployment state"].Value"
                          Description="@L["Resource Manager deployment metadata currently projected by materialized resources."].Value" />

        @if (DeploymentRows.Count == 0)
        {
            <EmptyState Title="@L["No deployment metadata projected"].Value"
                        Message="@L["Deployments will appear here when resources materialize runtime state through Resource Manager orchestration."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-deployment-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Resource"]</th>
                        <th>@L["Deployment"]</th>
                        <th>@L["Runtime revision"]</th>
                        <th>@L["Environment revision"]</th>
                        <th>@L["Service"]</th>
                        <th>@L["Replica group"]</th>
                        <th>@L["Replicas"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in DeploymentRows)
                    {
                        <tr>
                            <td>
                                <ResourceTableIdentity IconName="@GetResourceIconName(row.Resource, row.Resource.Id)"
                                                       IconTitle="@GetResourceIconTitle(row.Resource)"
                                                       Summary="@row.Resource.Id">
                                    <TitleContent>
                                        <FluentAnchor Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, row.Resource.Id)">
                                            @row.Resource.EffectiveDisplayName
                                        </FluentAnchor>
                                    </TitleContent>
                                </ResourceTableIdentity>
                            </td>
                            <td>
                                <strong class="environment-identifier">@row.DeploymentId</strong>
                                <div class="table-subtext">@row.Status</div>
                            </td>
                            <td><span class="environment-identifier">@row.RuntimeRevision</span></td>
                            <td><span class="environment-identifier">@row.EnvironmentRevisionId</span></td>
                            <td><span class="environment-identifier">@row.ServiceId</span></td>
                            <td><span class="environment-identifier">@row.ReplicaGroupId</span></td>
                            <td>@row.ReplicaSummary</td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel Wide="true" Class="environment-panel-full">
        <ShellPanelHeader Title="@L["Replica slot reconciliation"].Value"
                          Description="@L["Current Resource Manager replica slot state and repair outcomes for active replica groups."].Value" />

        @if (ReplicaSlotStates.Count == 0)
        {
            <EmptyState Title="@L["No replica slot state"].Value"
                        Message="@L["Replica slot state will appear here after Resource Manager materializes a deployment with requested replica slots."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="environment-replica-slot-table">
                <ResourceTable>
                <thead>
                    <tr>
                        <th>@L["Resource"]</th>
                        <th>@L["Slot"]</th>
                        <th>@L["Status"]</th>
                        <th>@L["Attempts"]</th>
                        <th>@L["Observed"]</th>
                        <th>@L["Last attempt"]</th>
                        <th>@L["Result"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var state in ReplicaSlotStates)
                    {
                        var resource = GetResource(state.ResourceId);
                        <tr>
                            <td>
                                <ResourceTableIdentity IconName="@GetResourceIconName(resource, state.ResourceId)"
                                                       IconTitle="@GetResourceIconTitle(resource)"
                                                       Summary="@state.ResourceId">
                                    <TitleContent>
                                        <FluentAnchor Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, state.ResourceId)">
                                            @(resource?.EffectiveDisplayName ?? state.ResourceId)
                                        </FluentAnchor>
                                    </TitleContent>
                                </ResourceTableIdentity>
                            </td>
                            <td>@state.SlotOrdinal.ToString(CultureInfo.InvariantCulture)</td>
                            <td>
                                @GetReplicaSlotStatusLabel(state.Status)
                                <div class="table-subtext">@GetOptional(state.Detail)</div>
                            </td>
                            <td>@state.AttemptCount.ToString(CultureInfo.InvariantCulture)</td>
                            <td>@state.ObservedAt.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)</td>
                            <td>@GetOptionalTimestamp(state.LastAttemptedAt)</td>
                            <td>
                                @GetOptional(state.LastResult)
                                <div class="table-subtext">@GetOptional(state.TriggeredBy)</div>
                            </td>
                        </tr>
                    }
                </tbody>
                </ResourceTable>
            </div>
        }
    </ShellPanel>

    <ShellPanel>
        <ShellPanelHeader Title="@L["Recent environment activity"].Value"
                          Description="@L["Latest deployment and runtime-capacity events emitted by resources in this environment."].Value" />

        @if (DeploymentEvents.Count == 0)
        {
            <EmptyState Title="@L["No environment activity"].Value"
                        Message="@L["Environment activity will appear after Resource Manager applies deployments, updates runtime capacity, or cleans up runtime state."].Value"
                        Compact="true" />
        }
        else
        {
            <ShellActivityList>
                @foreach (var resourceEvent in DeploymentEvents)
                {
                    <ShellActivityLink Title="@GetEventTitle(resourceEvent.EventType)"
                                       Summary="@resourceEvent.Message"
                                       TrailingText="@resourceEvent.Timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture)"
                                       Href="@ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceEvent.ResourceId)" />
                }
            </ShellActivityList>
        }
    </ShellPanel>

    <ShellPanel>
        <ShellPanelHeader Title="@L["Model note"].Value"
                          Description="@L["Current scope"].Value" />
        <p class="panel-body-text">
            @L["CloudShell currently treats the local host as one active deployment environment. A future Control Plane Environment concept may contain resources within a host or runtime boundary; this page is currently a diagnostic view over the active host and its projected environment revisions."]
        </p>
    </ShellPanel>
</section>

@code {
    private IReadOnlyList<Resource> Resources { get; set; } = [];
    private IReadOnlyList<EnvironmentRevisionProjectionRow> EnvironmentRevisionRows { get; set; } = [];
    private IReadOnlyList<ResourceDeploymentRecord> DeploymentRecords { get; set; } = [];
    private IReadOnlyList<EnvironmentDeploymentRow> DeploymentRows { get; set; } = [];
    private IReadOnlyList<EnvironmentReplicaGroupRow> ReplicaGroupRows { get; set; } = [];
    private IReadOnlyList<ResourceReplicaSlotState> ReplicaSlotStates { get; set; } = [];
    private IReadOnlyList<ResourceEvent> DeploymentEvents { get; set; } = [];
    private EnvironmentRuntimeMap EnvironmentMap { get; set; } = EnvironmentRuntimeMap.Empty;
    private IJSObjectReference? EnvironmentMapModule { get; set; }
    private DotNetObjectReference<EnvironmentPage>? EnvironmentMapReference { get; set; }
    private DateTimeOffset LoadedAt { get; set; }
    private bool IncludeNetworkTopologyOverlay { get; set; } = true;
    private bool ShowEnvironmentMapLinkLabels { get; set; }

    private int ReplicaGroupCount => ReplicaGroupRows.Count;

    private int OpenReplicaSlotStateCount =>
        ReplicaSlotStates.Count(state =>
            state.Status is ResourceReplicaSlotReconciliationStatus.Unhealthy
                or ResourceReplicaSlotReconciliationStatus.Repairing
                or ResourceReplicaSlotReconciliationStatus.RepairFailed);

    private IReadOnlyList<EnvironmentRuntimeMapLink> SignificantEnvironmentMapLinks =>
        EnvironmentMap.Links
            .Where(link => !string.Equals(
                link.Scope,
                EnvironmentRuntimeMapLinkScopes.Internal,
                StringComparison.OrdinalIgnoreCase))
            .Take(12)
            .ToArray();

    protected override async Task OnInitializedAsync() =>
        await RefreshAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        EnvironmentMapReference = DotNetObjectReference.Create(this);
        EnvironmentMapModule = await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/CloudShell.Hosting/environment-state-map.js");
        await EnvironmentMapModule.InvokeVoidAsync(
            "initializeEnvironmentStateMap",
            ".environment-state-map-canvas",
            EnvironmentMapReference);
        await UpdateEnvironmentMapAsync();
    }

    [JSInvokable]
    public void OpenEnvironmentMapNode(string? detailUrl)
    {
        if (!string.IsNullOrWhiteSpace(detailUrl))
        {
            Navigation.NavigateTo(detailUrl);
        }
    }

    private async Task RefreshAsync()
    {
        Resources = await ResourceManager.ListResourcesAsync();
        DeploymentRows = Resources
            .Where(resource => resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.DeploymentId))
            .Select(EnvironmentDeploymentRow.Create)
            .OrderBy(row => row.Resource.Name, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(row => row.Resource.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        DeploymentRecords = await Deployments.ListResourceDeploymentsAsync(new ResourceDeploymentQuery(MaxRecords: 100));
        EnvironmentRevisionRows = EnvironmentRevisionProjection.CreateRows(Resources, DeploymentRecords);
        ReplicaSlotStates = await ReplicaSlots.ListReplicaSlotStatesAsync(new ResourceReplicaSlotStateQuery(MaxRecords: 100));
        ReplicaGroupRows = CreateReplicaGroupRows(DeploymentRecords, ReplicaSlotStates);
        EnvironmentMap = CreateEnvironmentMap(Resources, DeploymentRecords, ReplicaGroupRows);
        DeploymentEvents = (await ResourceEvents.ListResourceEventsAsync(new ResourceEventQuery(MaxEvents: 100)))
            .Where(IsEnvironmentActivityEvent)
            .Take(15)
            .ToArray();
        LoadedAt = DateTimeOffset.UtcNow;
        await UpdateEnvironmentMapAsync();
    }

    private async Task UpdateEnvironmentMapAsync()
    {
        if (EnvironmentMapModule is not null)
        {
            await EnvironmentMapModule.InvokeVoidAsync(
                "updateEnvironmentStateMap",
                EnvironmentMap,
                new
                {
                    ShowLinkLabels = ShowEnvironmentMapLinkLabels
                });
        }
    }

    private async Task OnNetworkTopologyOverlayChanged(bool enabled)
    {
        IncludeNetworkTopologyOverlay = enabled;
        EnvironmentMap = CreateEnvironmentMap(Resources, DeploymentRecords, ReplicaGroupRows);
        await UpdateEnvironmentMapAsync();
    }

    private async Task OnLinkLabelsChanged(bool enabled)
    {
        ShowEnvironmentMapLinkLabels = enabled;
        await UpdateEnvironmentMapAsync();
    }

    private string GetLoadedAtLabel() =>
        LoadedAt == default
            ? L["Not loaded"].Value
            : L["Loaded {0:g}", LoadedAt.ToLocalTime()].Value;

    private string GetEventTitle(string eventType) =>
        ResourceEventDisplayNames.GetDisplayName(eventType, L);

    private Resource? GetResource(string resourceId) =>
        Resources.FirstOrDefault(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase));

    private static string GetResourceIconName(Resource? resource, string fallback) =>
        resource is null
            ? fallback
            : FirstNonEmpty(resource.EffectiveTypeId, resource.ResourceClass.ToString(), resource.Kind) ?? fallback;

    private static string GetResourceIconTitle(Resource? resource) =>
        resource?.Kind ?? "Resource";

    private string GetDeploymentRecordMessage(ResourceDeploymentRecord record) =>
        GetOptional(record.Error ?? record.Message ?? record.Cause);

    private static string GetRuntimeRevisionLabel(ResourceDeploymentRecord record) =>
        GetOptional(record.ReplicaGroup?.RuntimeRevisionId ?? record.RuntimeRevisionId);

    private static string GetReplicaGroupLabel(ResourceDeploymentRecord record) =>
        GetOptional(record.ReplicaGroup?.Id);

    private static string GetDeploymentReplicaSummary(ResourceDeploymentRecord record) =>
        record.ReplicaGroup is null
            ? "not projected"
            : string.Create(
                CultureInfo.InvariantCulture,
                $"{record.ReplicaGroup.MaterializedReplicas} of {record.ReplicaGroup.RequestedReplicas}");

    private string GetEnvironmentRevisionLabel(ResourceDeploymentRecord record) =>
        record.EnvironmentRevisionNumber is { } revisionNumber
            ? L["Revision {0}", revisionNumber].Value
            : GetOptional(record.EnvironmentRevisionId);

    private string GetEnvironmentRevisionLabel(EnvironmentRevisionProjectionRow row) =>
        row.RevisionNumber is { } revisionNumber
            ? L["Revision {0}", revisionNumber].Value
            : row.EnvironmentRevisionId;

    private string GetEnvironmentRevisionStatus(ResourceDeploymentRecord record) =>
        record.EnvironmentRevisionStatus?.ToString() ?? GetOptional(record.EnvironmentRevisionId);

    private string GetCompletionLabel(ResourceDeploymentRecord record)
    {
        var timestamp = record.CompletedAt ?? record.StartedAt;
        return timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);
    }

    private string GetReplicaGroupReconciliationSummary(EnvironmentReplicaGroupRow row)
    {
        if (row.SlotStateCount == 0)
        {
            return L["No observations"].Value;
        }

        if (row.RepairFailedCount > 0)
        {
            return L["{0} failed", row.RepairFailedCount].Value;
        }

        if (row.RepairingCount > 0)
        {
            return L["{0} repairing", row.RepairingCount].Value;
        }

        if (row.UnhealthyCount > 0)
        {
            return L["{0} unhealthy", row.UnhealthyCount].Value;
        }

        if (row.RepairedCount > 0)
        {
            return L["{0} repaired", row.RepairedCount].Value;
        }

        return L["Observed"].Value;
    }

    private static string GetLatestReplicaGroupReconciliationResult(EnvironmentReplicaGroupRow row) =>
        GetOptional(row.LatestSlotState?.LastResult ?? row.LatestSlotState?.Detail);

    private string GetReplicaSlotStatusLabel(ResourceReplicaSlotReconciliationStatus status) =>
        status switch
        {
            ResourceReplicaSlotReconciliationStatus.Unhealthy => L["Unhealthy"].Value,
            ResourceReplicaSlotReconciliationStatus.Repairing => L["Repairing"].Value,
            ResourceReplicaSlotReconciliationStatus.Repaired => L["Repaired"].Value,
            ResourceReplicaSlotReconciliationStatus.RepairFailed => L["Repair failed"].Value,
            ResourceReplicaSlotReconciliationStatus.Materialized => L["Materialized"].Value,
            _ => status.ToString()
        };

    private string GetOptionalTimestamp(DateTimeOffset? timestamp) =>
        timestamp is null
            ? GetOptional(null)
            : timestamp.Value.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);

    private static string GetOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "not projected" : value;

    private string GetResourceTypeDisplayName(Resource resource) =>
        ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase))
            ?.DisplayName ??
        (string.Equals(resource.Kind, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase)
            ? resource.Kind
            : $"{resource.Kind} ({resource.EffectiveTypeId})");

    private string? GetResourceTypeIconName(Resource resource) =>
        ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase))
            ?.Icon ??
        FirstNonEmpty(resource.EffectiveTypeId, resource.ResourceClass.ToString(), resource.Kind);

    private string GetEnvironmentMapNodeLabel(string nodeId) =>
        EnvironmentMap.Nodes.FirstOrDefault(node =>
            string.Equals(node.Id, nodeId, StringComparison.OrdinalIgnoreCase))?.Label ?? nodeId;

    private static bool IsEnvironmentActivityEvent(ResourceEvent resourceEvent) =>
        resourceEvent.EventType.StartsWith(
            ResourceEventTypes.Events.Deployment.Prefix,
            StringComparison.OrdinalIgnoreCase) ||
        resourceEvent.EventType.StartsWith(
            ResourceEventTypes.Events.ReplicaManagement.Prefix,
            StringComparison.OrdinalIgnoreCase);

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private EnvironmentRuntimeMap CreateEnvironmentMap(
        IReadOnlyList<Resource> resources,
        IReadOnlyList<ResourceDeploymentRecord> deployments,
        IReadOnlyList<EnvironmentReplicaGroupRow> replicaGroups) =>
        EnvironmentRuntimeMapProjection.Create(
            resources,
            deployments,
            replicaGroups.Select(replicaGroup => replicaGroup.ToRuntimeMapReplicaGroup()).ToArray(),
            new EnvironmentRuntimeMapProjectionOptions
            {
                Localize = value => L[value].Value,
                Format = static (format, args) => string.Format(CultureInfo.CurrentCulture, format, args),
                CreateResourceDetailUrl = resource => ResourceManagerCompositionLinks.ResourceDetails(Composition, resource.Id),
                GetStateClass = ResourceStateDisplay.GetStateClass,
                GetResourceTypeLabel = GetResourceTypeDisplayName,
                GetResourceIconName = GetResourceTypeIconName,
                IncludeNetworkTopologyOverlay = IncludeNetworkTopologyOverlay
            });

    private sealed record EnvironmentDeploymentRow(
        Resource Resource,
        string DeploymentId,
        string Status,
        string RuntimeRevision,
        string EnvironmentRevisionId,
        string ServiceId,
        string ReplicaGroupId,
        string ReplicaSummary)
    {
        public static EnvironmentDeploymentRow Create(Resource resource)
        {
            var requestedReplicas = GetAttribute(resource, ResourceAttributeNames.DeploymentRequestedReplicas);
            var materializedReplicas = GetAttribute(resource, ResourceAttributeNames.DeploymentMaterializedReplicas);
            var replicaSummary = requestedReplicas == "not projected" && materializedReplicas == "not projected"
                ? "not projected"
                : $"{materializedReplicas} of {requestedReplicas}";

            return new EnvironmentDeploymentRow(
                resource,
                GetAttribute(resource, ResourceAttributeNames.DeploymentId),
                GetAttribute(resource, ResourceAttributeNames.DeploymentStatus),
                GetAttribute(resource, ResourceAttributeNames.DeploymentRevision),
                GetAttribute(resource, ResourceAttributeNames.DeploymentEnvironmentRevisionId),
                GetAttribute(resource, ResourceAttributeNames.DeploymentServiceId),
                GetAttribute(resource, ResourceAttributeNames.DeploymentReplicaGroupId),
                replicaSummary);
        }

        private static string GetAttribute(Resource resource, string name) =>
            resource.ResourceAttributes.GetValueOrDefault(name) ?? "not projected";
    }

    private static IReadOnlyList<EnvironmentReplicaGroupRow> CreateReplicaGroupRows(
        IReadOnlyList<ResourceDeploymentRecord> deployments,
        IReadOnlyList<ResourceReplicaSlotState> slotStates)
    {
        var slotStatesByGroup = slotStates
            .Where(state => !string.IsNullOrWhiteSpace(state.ReplicaGroupId))
            .GroupBy(
                state => CreateReplicaGroupStateKey(state.ResourceId, state.ReplicaGroupId!),
                StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.ToArray(), StringComparer.OrdinalIgnoreCase);

        return deployments
            .Where(record =>
                record.Status == ResourceOrchestratorDeploymentStatus.Active &&
                record.ReplicaGroup is not null)
            .GroupBy(
                record => string.Join(
                    '\u001f',
                    record.SourceResourceId,
                    record.ServiceId,
                    record.ReplicaGroup?.Id ?? string.Empty),
                StringComparer.OrdinalIgnoreCase)
            .Select(group => group
                .OrderByDescending(record => record.CompletedAt ?? record.StartedAt)
                .First())
            .Select(record =>
            {
                slotStatesByGroup.TryGetValue(
                    CreateReplicaGroupStateKey(record.SourceResourceId, record.ReplicaGroup?.Id),
                    out var groupSlotStates);
                return EnvironmentReplicaGroupRow.Create(record, groupSlotStates ?? []);
            })
            .OrderBy(row => row.SourceResourceId, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.ServiceId, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.ReplicaGroupId, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static string CreateReplicaGroupStateKey(string resourceId, string? replicaGroupId) =>
        $"{resourceId.Trim()}\u001f{replicaGroupId?.Trim()}";

    private sealed record EnvironmentReplicaGroupRow(
        ResourceDeploymentRecord Deployment,
        string SourceResourceId,
        string DeploymentId,
        string ServiceId,
        string ReplicaGroupId,
        string? RuntimeRevisionId,
        int RequestedSlots,
        int OccupiedSlots,
        int MaterializedReplicas,
        int SlotStateCount,
        int UnhealthyCount,
        int RepairingCount,
        int RepairedCount,
        int RepairFailedCount,
        ResourceReplicaSlotState? LatestSlotState)
    {
        public static EnvironmentReplicaGroupRow Create(
            ResourceDeploymentRecord deployment,
            IReadOnlyList<ResourceReplicaSlotState> slotStates)
        {
            var replicaGroup = deployment.ReplicaGroup ??
                throw new InvalidOperationException("Replica group rows require a materialized replica group.");
            var relevantSlotStates = slotStates
                .Where(state =>
                    state.SlotOrdinal >= 1 &&
                    state.SlotOrdinal <= replicaGroup.RequestedReplicaSlots)
                .ToArray();
            return new EnvironmentReplicaGroupRow(
                deployment,
                deployment.SourceResourceId,
                deployment.DeploymentId,
                deployment.ServiceId,
                replicaGroup.Id,
                replicaGroup.RuntimeRevisionId,
                replicaGroup.RequestedReplicaSlots,
                replicaGroup.OccupiedReplicaSlots,
                replicaGroup.MaterializedReplicas,
                relevantSlotStates.Length,
                relevantSlotStates.Count(state => state.Status == ResourceReplicaSlotReconciliationStatus.Unhealthy),
                relevantSlotStates.Count(state => state.Status == ResourceReplicaSlotReconciliationStatus.Repairing),
                relevantSlotStates.Count(state => state.Status == ResourceReplicaSlotReconciliationStatus.Repaired),
                relevantSlotStates.Count(state => state.Status == ResourceReplicaSlotReconciliationStatus.RepairFailed),
                relevantSlotStates
                    .OrderByDescending(state => state.LastCompletedAt ?? state.LastAttemptedAt ?? state.ObservedAt)
                    .FirstOrDefault());
        }

        public EnvironmentRuntimeMapReplicaGroup ToRuntimeMapReplicaGroup() =>
            new(
                SourceResourceId,
                ServiceId,
                ReplicaGroupId,
                RuntimeRevisionId,
                RequestedSlots,
                OccupiedSlots,
                MaterializedReplicas,
                RepairingCount,
                RepairFailedCount);
    }

    public async ValueTask DisposeAsync()
    {
        if (EnvironmentMapModule is not null)
        {
            await EnvironmentMapModule.InvokeVoidAsync("disposeEnvironmentStateMap");
            await EnvironmentMapModule.DisposeAsync();
        }

        EnvironmentMapReference?.Dispose();
    }
}
