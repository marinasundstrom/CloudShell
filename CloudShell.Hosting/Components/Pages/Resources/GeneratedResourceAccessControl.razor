@using CloudShell.Abstractions.Authorization
@using CloudShell.Abstractions.ControlPlane
@using CloudShell.Abstractions.ResourceManager
@using System.Diagnostics.CodeAnalysis
@inject IResourceManager ResourceManager
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L

    <div class="generated-resource-view">
        @if (!string.IsNullOrWhiteSpace(ProcedureMessage))
        {
            <ProcedureMessage Message="@ProcedureMessage" />
        }

    @if (Resource is null)
    {
        <EmptyState Title="@L["Resource not found"].Value"
                    Message="@L["The resource may have been removed or is no longer visible."].Value" />
    }
    else
    {
        <GeneratedResourceViewLayout ResourceType="ResourceType"
                                     ResourceId="@ResourceId"
                                     Resource="Resource"
                                     ViewId="@ResourcePredefinedViewIds.AccessControl"
                                     Sections="@BuildSections()" />
    }
</div>

@code {
    private const string CustomPermissionValue = "__custom";
    private const string ConfigurationStoreResourceType = "configuration.store";
    private const string SecretsVaultResourceType = "secrets.vault";
    private const string VolumeResourceType = "cloudshell.volume";
    private const string NetworkResourceType = "cloudshell.network";
    private const string VirtualNetworkResourceType = "cloudshell.virtualNetwork";
    private const string DnsZoneResourceType = "cloudshell.dnsZone";
    private const string LoadBalancerResourceType = "cloudshell.loadBalancer";
    private const string IdentityProvisioningResourceType = "cloudshell.identity-provisioning";
    private const string SqlServerResourceType = "application.sql-server";

    private static readonly IReadOnlyList<PermissionOption> AllPermissionOptions =
    [
        new("Configuration entries: read", ConfigurationStoreResourceOperationPermissions.ReadEntries, PermissionOptionTarget.ConfigurationStore),
        new("Secrets: read", SecretsVaultResourceOperationPermissions.ReadSecrets, PermissionOptionTarget.SecretsVault),
        new("Volume mount: read", StorageVolumeResourceOperationPermissions.MountRead, PermissionOptionTarget.Volume),
        new("Volume mount: write", StorageVolumeResourceOperationPermissions.MountWrite, PermissionOptionTarget.Volume),
        new("Lifecycle action", CommonResourceOperationPermissions.LifecycleAction, PermissionOptionTarget.LifecycleAction),
        new("Custom resource action", CommonResourceOperationPermissions.ExecuteCustomAction, PermissionOptionTarget.CustomAction),
        new("Network endpoint mapping reconcile", NetworkResourceOperationPermissions.ReconcileEndpointMappings, PermissionOptionTarget.Network),
        new("DNS name mapping reconcile", NetworkResourceOperationPermissions.ReconcileNameMappings, PermissionOptionTarget.DnsZone),
        new("Load balancer configuration apply", LoadBalancerResourceOperationPermissions.ApplyConfiguration, PermissionOptionTarget.LoadBalancer),
        new("Identity provisioning", ResourceIdentityProvisioningOperationPermissions.ProvisionIdentities, PermissionOptionTarget.IdentityProvisioning),
        new("Database: read/write", DatabaseResourceOperationPermissions.ReadWrite, PermissionOptionTarget.Database),
        new("Database access: reconcile", DatabaseResourceOperationPermissions.ReconcileAccess, PermissionOptionTarget.Database),
        new("All permissions", CloudShellPermissions.All, PermissionOptionTarget.Always),
        new("Custom permission", CustomPermissionValue, PermissionOptionTarget.Always)
    ];

    [Parameter, EditorRequired]
    public string ResourceId { get; set; } = string.Empty;

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<PrincipalOption> PrincipalOptions { get; set; } = [];
    private IReadOnlyList<ResourcePermissionGrant> InboundGrants { get; set; } = [];
    private IReadOnlyDictionary<string, ResourcePermissionGrantStatus> GrantStatuses { get; set; } =
        new Dictionary<string, ResourcePermissionGrantStatus>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<GrantGroup> GrantGroups { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> ResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private PrincipalOption? SelectedPrincipal { get; set; }
    private IEnumerable<PrincipalOption> SelectedPrincipals =>
        SelectedPrincipal is null ? [] : [SelectedPrincipal];
    private string SelectedPermission { get; set; } = string.Empty;
    private string CustomPermission { get; set; } = string.Empty;
    private string? ProcedureMessage { get; set; }
    private bool GrantingPermission { get; set; }

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections() =>
    [
        new("assign-access", L["Assign access"], 0, RenderAssignAccess()),
        new("assigned-principals", L["Assigned principals"], 100, RenderAssignedPrincipals())
    ];

    private RenderFragment RenderAssignAccess() => @<text>
        <div class="generated-access-form">
            <label for="access-control-principal-search">@L["Principal"]</label>
            <FluentAutocomplete TOption="PrincipalOption"
                                Id="access-control-principal-search"
                                AutoComplete="off"
                                MaximumSelectedOptions="1"
                                MaximumOptionsSearch="12"
                                OptionClass="access-control-principal-option"
                                Placeholder="@L["Search principals"]"
                                OptionText="FormatPrincipalOption"
                                SelectedOptions="@SelectedPrincipals"
                                SelectedOptionsChanged="SetSelectedPrincipal"
                                OnOptionsSearch="SearchPrincipals">
                <OptionTemplate Context="principal">
                    <div class="access-control-principal-option-row">
                        <strong>@principal.Name</strong>
                        <span>@principal.PrincipalKindLabel</span>
                    </div>
                </OptionTemplate>
            </FluentAutocomplete>
            @if (PrincipalOptions.Count == 0)
            {
                <EmptyState Title="@L["No principals available"].Value"
                            Message="@L["No principals are available to grant access. Resource identities are the only principal source in this MVP slice."].Value"
                            Compact="true" />
            }

            <label for="access-control-permission">@L["Permission"]</label>
            <FluentSelect TOption="string" Id="access-control-permission" @bind-Value="SelectedPermission">
                <FluentOption TOption="string" Value="">@L["Select a permission"]</FluentOption>
                @foreach (var option in AvailablePermissionOptions)
                {
                    <FluentOption TOption="string" Value="@option.Value">@option.Label</FluentOption>
                }
            </FluentSelect>

            @if (IsCustomPermission)
            {
                <label for="access-control-custom-permission">@L["Custom permission"]</label>
                <FluentTextField Id="access-control-custom-permission"
                                 @bind-Value="CustomPermission"
                                 Placeholder="Provider.Namespace/resources/action" />
            }

            <GeneratedRowActions>
                <FluentButton Appearance="Appearance.Accent"
                              Disabled="@(GrantingPermission || IsReadOnly)"
                              OnClick="GrantPermission">
                    @GetGrantButtonLabel()
                </FluentButton>
            </GeneratedRowActions>
        </div>
        @if (IsReadOnly)
        {
            <ProcedureMessage Compact="true">
                @L["Resource Manager is in read-only mode. Access control changes are disabled in this UI."]
            </ProcedureMessage>
        }
        @if (ShouldShowSqlGrantMaterializationNotice())
        {
            <ProcedureMessage Severity="ResourceSignalSeverity.Warning" Role="status">
                @L["Database grants are saved in CloudShell. Reconcile access to create SQL-side users and roles. Workload credential delivery remains provider-owned future work."]
            </ProcedureMessage>
        }
        <p class="muted">@L["CloudShell records that the selected principal can access this resource. Identity and access providers apply or reconcile the grant when provisioning runs."]</p>
    </text>;

    private RenderFragment RenderAssignedPrincipals() => @<text>
        @if (GrantGroups.Count == 0)
        {
            <EmptyState Title="@L["No assigned principals"].Value"
                        Message="@L["No principals have access permissions for this resource."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="generated-list">
                @foreach (var group in GrantGroups)
                {
                    <div>
                        <strong>@PrincipalLink(group.Principal)</strong>
                        @foreach (var permission in group.Permissions)
                        {
                            <span class="access-control-grant-row">
                                <span>
                                    @permission
                                    @if (GetGrantEffectiveness(group.Principal, permission) is { } effectiveness)
                                    {
                                        <small>
                                            @effectiveness.Label
                                            @if (!string.IsNullOrWhiteSpace(effectiveness.Detail))
                                            {
                                                <span> @effectiveness.Detail</span>
                                            }
                                        </small>
                                    }
                                </span>
                                <FluentButton Appearance="Appearance.Neutral"
                                              Disabled="@(IsReadOnly || IsRevokingPermission(group.Principal, permission))"
                                              OnClick="() => RevokePermission(group.Principal, permission)">
                                    @GetRevokeButtonLabel(group.Principal, permission)
                                </FluentButton>
                            </span>
                        }
                    </div>
                }
            </div>
        }
    </text>;
    private string? RevokingPermissionKey { get; set; }
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private bool IsCustomPermission => string.Equals(SelectedPermission, CustomPermissionValue, StringComparison.Ordinal);
    private IReadOnlyList<PermissionOption> AvailablePermissionOptions =>
        Resource is null
            ? []
            : AllPermissionOptions
                .Where(option => option.IsAvailableFor(Resource))
                .ToArray();

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        if (Resource is null)
        {
            PrincipalOptions = [];
            InboundGrants = [];
            GrantStatuses = new Dictionary<string, ResourcePermissionGrantStatus>(StringComparer.OrdinalIgnoreCase);
            GrantGroups = [];
            ResourcesById = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
            SelectedPrincipal = null;
            return;
        }

        var resources = await ResourceManager.ListResourcesAsync();
        ResourcesById = ResourceCollectionProjection.ToDictionaryById(resources.Append(Resource));
        var principals = await ResourceManager.QueryResourcePrincipalsAsync();
        PrincipalOptions = principals
            .Where(principal => !IsCurrentResourceIdentity(principal.Reference))
            .Select(principal =>
            {
                var resource = string.IsNullOrWhiteSpace(principal.Reference.SourceResourceId)
                    ? null
                    : ResourcesById.GetValueOrDefault(principal.Reference.SourceResourceId);
                return new PrincipalOption(
                    principal.Reference,
                    principal,
                    resource,
                    GetPrincipalKey(principal.Reference));
            })
            .OrderBy(principal => principal.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(principal => principal.Principal.Kind)
            .ThenBy(principal => principal.Principal.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (SelectedPrincipal is not null &&
            !PrincipalOptions.Any(principal => string.Equals(principal.Key, SelectedPrincipal.Key, StringComparison.Ordinal)))
        {
            SelectedPrincipal = null;
        }

        InboundGrants = await ResourceManager.ListResourcePermissionGrantsAsync(
            new ResourcePermissionGrantQuery(TargetResourceId: Resource.Id));
        GrantStatuses = (await ResourceManager.ListResourcePermissionGrantStatusesAsync(
                new ResourcePermissionGrantQuery(TargetResourceId: Resource.Id)))
            .ToDictionary(
                status => GetPermissionKey(status.Grant.Principal, status.Grant.Permission),
                StringComparer.OrdinalIgnoreCase);
        GrantGroups = InboundGrants
            .GroupBy(grant => GetPrincipalKey(grant.Principal), StringComparer.OrdinalIgnoreCase)
            .Select(group => new GrantGroup(
                group.First().Principal,
                group
                    .Select(grant => grant.Permission)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Order(StringComparer.OrdinalIgnoreCase)
                    .ToArray()))
            .OrderBy(group => FormatPrincipalName(group.Principal), StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.Principal.Kind)
            .ThenBy(group => group.Principal.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (!string.IsNullOrWhiteSpace(SelectedPermission) &&
            !AvailablePermissionOptions.Any(option =>
                string.Equals(option.Value, SelectedPermission, StringComparison.Ordinal)))
        {
            SelectedPermission = string.Empty;
            CustomPermission = string.Empty;
        }
    }

    private async Task GrantPermission()
    {
        if (GrantingPermission || Resource is null)
        {
            return;
        }

        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            return;
        }

        var permission = ResolvePermission();
        if (!TryGetSelectedPrincipal(out var principal))
        {
            ProcedureMessage = L["Select a principal."].Value;
            return;
        }

        if (string.IsNullOrWhiteSpace(permission))
        {
            ProcedureMessage = L["Select a permission."].Value;
            return;
        }

        GrantingPermission = true;
        ProcedureMessage = null;
        try
        {
            await ResourceManager.GrantResourcePermissionAsync(
                new GrantResourcePermissionCommand(
                    principal.Principal,
                    Resource.Id,
                    permission));
            ProcedureMessage = L["Access permission assigned. Provision or reconcile the principal to apply provider-side changes."].Value;
            SelectedPrincipal = null;
            SelectedPermission = string.Empty;
            CustomPermission = string.Empty;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            GrantingPermission = false;
        }
    }

    private async Task RevokePermission(ResourcePrincipalReference principal, string permission)
    {
        if (Resource is null)
        {
            return;
        }

        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            return;
        }

        RevokingPermissionKey = GetPermissionKey(principal, permission);
        ProcedureMessage = null;
        try
        {
            await ResourceManager.RevokeResourcePermissionAsync(
                new RevokeResourcePermissionCommand(
                    principal,
                    Resource.Id,
                    permission));
            ProcedureMessage = L["Access permission revoked. Provision or reconcile the principal to apply provider-side changes."].Value;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            RevokingPermissionKey = null;
        }
    }

    private string ResolvePermission() =>
        IsCustomPermission ? CustomPermission.Trim() : SelectedPermission.Trim();

    private string GetGrantButtonLabel() =>
        GrantingPermission
            ? L["Assigning access"].Value
            : L["Assign access"].Value;

    private string GetRevokeButtonLabel(ResourcePrincipalReference principal, string permission) =>
        IsRevokingPermission(principal, permission)
            ? L["Revoking"].Value
            : L["Revoke"].Value;

    private bool IsRevokingPermission(ResourcePrincipalReference principal, string permission) =>
        string.Equals(RevokingPermissionKey, GetPermissionKey(principal, permission), StringComparison.Ordinal);

    private static string GetPermissionKey(ResourcePrincipalReference principal, string permission) =>
        $"{GetPrincipalKey(principal)}\u001f{permission}";

    private static string GetPrincipalKey(ResourcePrincipalReference principal) =>
        $"{principal.ProviderId}\u001f{principal.Kind}\u001f{principal.Id}";

    private static string FormatPrincipalOption(PrincipalOption principal) =>
        principal.Name;

    private void SearchPrincipals(OptionsSearchEventArgs<PrincipalOption> args)
    {
        var search = args.Text?.Trim() ?? string.Empty;
        args.Items = string.IsNullOrWhiteSpace(search)
            ? PrincipalOptions
            : PrincipalOptions.Where(principal => MatchesPrincipalSearch(principal, search)).ToArray();
    }

    private static bool MatchesPrincipalSearch(PrincipalOption principal, string search)
    {
        return Contains(principal.Name, search) ||
            Contains(principal.ResourceName, search) ||
            Contains(principal.PrincipalKindLabel, search) ||
            Contains(principal.Principal.Id, search) ||
            Contains(principal.Principal.DisplayName, search) ||
            Contains(principal.Principal.SourceResourceId, search) ||
            Contains(principal.Principal.SourceIdentityName, search) ||
            Contains(principal.ResourcePrincipal.DisplayName, search) ||
            Contains(principal.ResourcePrincipal.Description, search) ||
            principal.ResourcePrincipal.PrincipalAttributes.Any(attribute =>
                Contains(attribute.Key, search) || Contains(attribute.Value, search)) ||
            Contains(principal.Resource?.DisplayName, search) ||
            Contains(principal.Resource?.EffectiveTypeId, search) ||
            Contains(principal.Resource?.ResourceClass.ToString(), search) ||
            Contains(principal.Resource?.IdentityBinding?.ProviderId, search);
    }

    private static bool Contains(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private bool TryGetSelectedPrincipal([NotNullWhen(true)] out PrincipalOption? principal)
    {
        principal = SelectedPrincipal;
        return principal is not null;
    }

    private Task SetSelectedPrincipal(IEnumerable<PrincipalOption> principals)
    {
        SelectedPrincipal = principals.FirstOrDefault();
        return Task.CompletedTask;
    }

    private string FormatPrincipalName(ResourcePrincipalReference principal) =>
        principal.Kind == ResourcePrincipalKind.ResourceIdentity &&
        !string.IsNullOrWhiteSpace(principal.SourceResourceId)
            ? ResourcesById.GetValueOrDefault(principal.SourceResourceId) is { } resource
                ? ResourceDisplayLabels.GetQualifiedLabel(resource)
                : principal.SourceResourceId
            : ResolvePrincipalName(principal);

    private RenderFragment PrincipalLink(ResourcePrincipalReference principal)
    {
        var resource = string.IsNullOrWhiteSpace(principal.SourceResourceId)
            ? null
            : ResourcesById.GetValueOrDefault(principal.SourceResourceId);
        var label = resource is null
            ? ResolvePrincipalName(principal)
            : ResourceDisplayLabels.GetQualifiedLabel(resource);
        var href = resource is null
            ? null
            : ResourceManagerCompositionLinks.ResourceDetails(Composition, resource.Id, ResourcePredefinedViewIds.Identity);
        return @<ResourcePillLink Label="@label"
                                  Href="@href"
                                  Resource="@resource"
                                  Metadata="@FormatPrincipalLabel(principal)"
                                  SecondaryMetadata="@resource?.EffectiveTypeId" />;
    }

    private static string FormatPrincipalLabel(ResourcePrincipalReference principal) =>
        principal.Kind == ResourcePrincipalKind.ResourceIdentity
            ? string.IsNullOrWhiteSpace(principal.SourceIdentityName)
                ? "Default identity"
                : principal.SourceIdentityName
            : principal.Kind.ToString();

    private string ResolvePrincipalName(ResourcePrincipalReference principal) =>
        PrincipalOptions.FirstOrDefault(option =>
            SamePrincipal(option.Principal, principal))?.Name ??
        principal.DisplayName ??
        principal.Id;

    private static bool SamePrincipal(ResourcePrincipalReference left, ResourcePrincipalReference right) =>
        left.Kind == right.Kind &&
        string.Equals(left.ProviderId, right.ProviderId, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(left.Id, right.Id, StringComparison.OrdinalIgnoreCase);

    private bool IsCurrentResourceIdentity(ResourcePrincipalReference principal) =>
        principal.Kind == ResourcePrincipalKind.ResourceIdentity &&
        !string.IsNullOrWhiteSpace(principal.SourceResourceId) &&
        Resource is not null &&
        string.Equals(principal.SourceResourceId, Resource.Id, StringComparison.OrdinalIgnoreCase);

    private bool ShouldShowSqlGrantMaterializationNotice() =>
        Resource is not null &&
        string.Equals(Resource.EffectiveTypeId, SqlServerResourceType, StringComparison.OrdinalIgnoreCase) &&
        (string.Equals(SelectedPermission, DatabaseResourceOperationPermissions.ReadWrite, StringComparison.OrdinalIgnoreCase) ||
         InboundGrants.Any(grant => string.Equals(
             grant.Permission,
             DatabaseResourceOperationPermissions.ReadWrite,
             StringComparison.OrdinalIgnoreCase)));

    private GrantEffectivenessView? GetGrantEffectiveness(ResourcePrincipalReference principal, string permission)
    {
        if (!GrantStatuses.TryGetValue(GetPermissionKey(principal, permission), out var status))
        {
            return null;
        }

        if (status.State == ResourcePermissionGrantEffectivenessState.Unknown &&
            string.IsNullOrWhiteSpace(status.ProviderId))
        {
            return null;
        }

        var label = status.State switch
        {
            ResourcePermissionGrantEffectivenessState.Applied => L["Effective access: applied"].Value,
            ResourcePermissionGrantEffectivenessState.Pending => L["Effective access: pending"].Value,
            ResourcePermissionGrantEffectivenessState.Failed => L["Effective access: failed"].Value,
            ResourcePermissionGrantEffectivenessState.Drifted => L["Effective access: drifted"].Value,
            ResourcePermissionGrantEffectivenessState.NotApplied => L["Effective access: not applied by provider yet"].Value,
            _ => L["Effective access: unknown"].Value
        };

        return new GrantEffectivenessView(label, status.Detail);
    }

    private sealed record PermissionOption(
        string Label,
        string Value,
        PermissionOptionTarget Target)
    {
        public bool IsAvailableFor(Resource resource) => Target switch
        {
            PermissionOptionTarget.ConfigurationStore =>
                IsResourceType(resource, ConfigurationStoreResourceType) ||
                resource.ResourceClass == ResourceClass.Configuration,
            PermissionOptionTarget.SecretsVault =>
                IsResourceType(resource, SecretsVaultResourceType) ||
                resource.ResourceClass == ResourceClass.SecretsVault,
            PermissionOptionTarget.Volume => IsResourceType(resource, VolumeResourceType),
            PermissionOptionTarget.Network =>
                IsResourceType(resource, NetworkResourceType) ||
                IsResourceType(resource, VirtualNetworkResourceType),
            PermissionOptionTarget.DnsZone => IsResourceType(resource, DnsZoneResourceType),
            PermissionOptionTarget.LoadBalancer => IsResourceType(resource, LoadBalancerResourceType),
            PermissionOptionTarget.IdentityProvisioning => IsResourceType(resource, IdentityProvisioningResourceType),
            PermissionOptionTarget.Database => IsResourceType(resource, SqlServerResourceType),
            PermissionOptionTarget.LifecycleAction => resource.ResourceActions.Any(action =>
                action.Kind is ResourceActionKind.Start or
                    ResourceActionKind.Stop or
                    ResourceActionKind.Pause or
                    ResourceActionKind.Restart),
            PermissionOptionTarget.CustomAction => resource.ResourceActions.Any(action =>
                action.Kind == ResourceActionKind.Custom),
            PermissionOptionTarget.Always => true,
            _ => false
        };

        private static bool IsResourceType(Resource resource, string resourceType) =>
            string.Equals(resource.EffectiveTypeId, resourceType, StringComparison.OrdinalIgnoreCase);
    }

    private enum PermissionOptionTarget
    {
        Always,
        ConfigurationStore,
        SecretsVault,
        Volume,
        Network,
        DnsZone,
        LoadBalancer,
        IdentityProvisioning,
        Database,
        LifecycleAction,
        CustomAction
    }

    private sealed record PrincipalOption(
        ResourcePrincipalReference Principal,
        ResourcePrincipal ResourcePrincipal,
        Resource? Resource,
        string Key)
    {
        public string Name => Resource is null
            ? ResourcePrincipal.DisplayName ??
                Principal.DisplayName ??
                Principal.Id
            : ResourceDisplayLabels.GetQualifiedLabel(Resource);

        public string ResourceName => Resource is null
            ? string.Empty
            : ResourceDisplayLabels.GetName(Resource);

        public string PrincipalKindLabel => Principal.Kind switch
        {
            ResourcePrincipalKind.ResourceIdentity => "Resource identity",
            ResourcePrincipalKind.User => "User",
            ResourcePrincipalKind.Group => "Group",
            ResourcePrincipalKind.ServiceAccount => "Service account",
            ResourcePrincipalKind.ServicePrincipal => "Service principal",
            ResourcePrincipalKind.ManagedIdentity => "Managed identity",
            ResourcePrincipalKind.WorkloadIdentity => "Workload identity",
            ResourcePrincipalKind.External => "External principal",
            _ => Principal.Kind.ToString()
        };
    }

    private sealed record GrantGroup(
        ResourcePrincipalReference Principal,
        IReadOnlyList<string> Permissions);

    private sealed record GrantEffectivenessView(
        string Label,
        string? Detail);
}
