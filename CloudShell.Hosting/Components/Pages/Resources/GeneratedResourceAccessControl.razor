@using CloudShell.Abstractions.Authorization
@using CloudShell.Abstractions.ControlPlane
@using CloudShell.Abstractions.ResourceManager
@using System.Diagnostics.CodeAnalysis
@inject IResourceManager ResourceManager
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    @if (!string.IsNullOrWhiteSpace(ProcedureMessage))
    {
        <div class="procedure-message">@ProcedureMessage</div>
    }

    @if (Resource is null)
    {
        <div class="empty-state">
            <strong>@L["Resource not found"]</strong>
            <span>@L["The resource may have been removed or is no longer visible."]</span>
        </div>
    }
    else
    {
        @if (Resource.IdentityBinding is null)
        {
            <section class="generated-section">
                <h3>@L["Assign access"]</h3>
                <div class="empty-state">
                    <strong>@L["Identity required"]</strong>
                    <span>@L["Set up an identity for this resource before assigning access permissions."]</span>
                    <FluentAnchor Href="@ResourceManagerRoutes.ResourceDetails(Resource.Id, ResourcePredefinedViewIds.Identity)">
                        @L["Open Identity"]
                    </FluentAnchor>
                </div>
            </section>
        }
        else
        {
            <section class="generated-section">
                <h3>@L["Assign access"]</h3>
                <div class="generated-access-form">
                    <label for="access-control-identity-search">@L["Resource identity"]</label>
                    <FluentAutocomplete TOption="IdentityOption"
                                        Id="access-control-identity-search"
                                        AutoComplete="off"
                                        MaximumSelectedOptions="1"
                                        MaximumOptionsSearch="12"
                                        Placeholder="@L["Search resource identities"]"
                                        OptionText="FormatIdentityOption"
                                        SelectedOptions="@SelectedIdentities"
                                        SelectedOptionsChanged="SetSelectedIdentity"
                                        OnOptionsSearch="SearchIdentities">
                    </FluentAutocomplete>
                    @if (IdentityOptions.Count == 0)
                    {
                        <p class="muted">@L["No other resource identities are available to grant access."]</p>
                    }

                    <label for="access-control-permission">@L["Permission"]</label>
                    <FluentSelect TOption="string" Id="access-control-permission" @bind-Value="SelectedPermission">
                        <FluentOption TOption="string" Value="">@L["Select a permission"]</FluentOption>
                        @foreach (var option in AvailablePermissionOptions)
                        {
                            <FluentOption TOption="string" Value="@option.Value">@option.Label</FluentOption>
                        }
                    </FluentSelect>

                    @if (IsCustomPermission)
                    {
                        <label for="access-control-custom-permission">@L["Custom permission"]</label>
                        <FluentTextField Id="access-control-custom-permission"
                                         @bind-Value="CustomPermission"
                                         Placeholder="Provider.Namespace/resources/action" />
                    }

                    <div class="generated-row-actions">
                        <FluentButton Appearance="Appearance.Accent"
                                      Disabled="@(GrantingPermission || IsReadOnly)"
                                      OnClick="GrantPermission">
                            @GetGrantButtonLabel()
                        </FluentButton>
                    </div>
                </div>
                @if (IsReadOnly)
                {
                    <div class="procedure-message compact">@L["Resource Manager is in read-only mode. Access control changes are disabled in this UI."]</div>
                }
                <p class="muted">@L["CloudShell records that the selected resource identity can access this resource. The identity provider applies or reconciles the grant when identity provisioning runs."]</p>
            </section>
        }

        <section class="generated-section">
            <h3>@L["Assigned resource identities"]</h3>
            @if (GrantGroups.Count == 0)
            {
                <p class="muted">@L["No resource identities have access permissions for this resource."]</p>
            }
            else
            {
                <div class="generated-list">
                    @foreach (var group in GrantGroups)
                    {
                        <div>
                            <strong>@IdentityLink(group.Identity)</strong>
                            @foreach (var permission in group.Permissions)
                            {
                                <span class="access-control-grant-row">
                                    <span>@permission</span>
                                    <FluentButton Appearance="Appearance.Neutral"
                                                  Disabled="@(IsReadOnly || IsRevokingPermission(group.Identity, permission))"
                                                  OnClick="() => RevokePermission(group.Identity, permission)">
                                        @GetRevokeButtonLabel(group.Identity, permission)
                                    </FluentButton>
                                </span>
                            }
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    private const string CustomPermissionValue = "__custom";
    private const string ConfigurationStoreResourceType = "configuration.store";
    private const string SecretsVaultResourceType = "secrets.vault";
    private const string VolumeResourceType = "cloudshell.volume";
    private const string NetworkResourceType = "cloudshell.network";
    private const string VirtualNetworkResourceType = "cloudshell.virtualNetwork";
    private const string DnsZoneResourceType = "cloudshell.dnsZone";
    private const string LoadBalancerResourceType = "cloudshell.loadBalancer";
    private const string IdentityProvisioningResourceType = "cloudshell.identity-provisioning";

    private static readonly IReadOnlyList<PermissionOption> AllPermissionOptions =
    [
        new("Configuration entries: read", ConfigurationStoreResourceOperationPermissions.ReadEntries, PermissionOptionTarget.ConfigurationStore),
        new("Secrets: read", SecretsVaultResourceOperationPermissions.ReadSecrets, PermissionOptionTarget.SecretsVault),
        new("Volume mount: read", StorageVolumeResourceOperationPermissions.MountRead, PermissionOptionTarget.Volume),
        new("Volume mount: write", StorageVolumeResourceOperationPermissions.MountWrite, PermissionOptionTarget.Volume),
        new("Lifecycle action", CommonResourceOperationPermissions.LifecycleAction, PermissionOptionTarget.LifecycleAction),
        new("Custom resource action", CommonResourceOperationPermissions.ExecuteCustomAction, PermissionOptionTarget.CustomAction),
        new("Network endpoint mapping reconcile", NetworkResourceOperationPermissions.ReconcileEndpointMappings, PermissionOptionTarget.Network),
        new("DNS name mapping reconcile", NetworkResourceOperationPermissions.ReconcileNameMappings, PermissionOptionTarget.DnsZone),
        new("Load balancer configuration apply", LoadBalancerResourceOperationPermissions.ApplyConfiguration, PermissionOptionTarget.LoadBalancer),
        new("Identity provisioning", ResourceIdentityProvisioningOperationPermissions.ProvisionIdentities, PermissionOptionTarget.IdentityProvisioning),
        new("All permissions", CloudShellPermissions.All, PermissionOptionTarget.Always),
        new("Custom permission", CustomPermissionValue, PermissionOptionTarget.Always)
    ];

    [Parameter, EditorRequired]
    public string ResourceId { get; set; } = string.Empty;

    private Resource? Resource { get; set; }
    private IReadOnlyList<IdentityOption> IdentityOptions { get; set; } = [];
    private IReadOnlyList<ResourcePermissionGrant> InboundGrants { get; set; } = [];
    private IReadOnlyList<GrantGroup> GrantGroups { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> ResourcesById { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private IdentityOption? SelectedIdentity { get; set; }
    private IEnumerable<IdentityOption> SelectedIdentities =>
        SelectedIdentity is null ? [] : [SelectedIdentity];
    private string SelectedPermission { get; set; } = string.Empty;
    private string CustomPermission { get; set; } = string.Empty;
    private string? ProcedureMessage { get; set; }
    private bool GrantingPermission { get; set; }
    private string? RevokingPermissionKey { get; set; }
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private bool IsCustomPermission => string.Equals(SelectedPermission, CustomPermissionValue, StringComparison.Ordinal);
    private IReadOnlyList<PermissionOption> AvailablePermissionOptions =>
        Resource is null
            ? []
            : AllPermissionOptions
                .Where(option => option.IsAvailableFor(Resource))
                .ToArray();

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        if (Resource is null)
        {
            IdentityOptions = [];
            InboundGrants = [];
            GrantGroups = [];
            ResourcesById = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
            SelectedIdentity = null;
            return;
        }

        var resources = await ResourceManager.ListResourcesAsync();
        ResourcesById = resources
            .Append(Resource)
            .GroupBy(resource => resource.Id, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => group.First(),
                StringComparer.OrdinalIgnoreCase);
        IdentityOptions = resources
            .Where(resource =>
                !string.Equals(resource.Id, Resource.Id, StringComparison.OrdinalIgnoreCase) &&
                resource.IdentityBinding is not null)
            .Select(resource => new IdentityOption(
                ResourceIdentityReference.ForResource(resource.Id, resource.IdentityBinding!.Name),
                resource,
                GetIdentityKey(ResourceIdentityReference.ForResource(resource.Id, resource.IdentityBinding.Name))))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(resource => resource.Identity.ResourceId, StringComparer.OrdinalIgnoreCase)
            .ThenBy(resource => resource.Identity.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (SelectedIdentity is not null &&
            !IdentityOptions.Any(identity => string.Equals(identity.Key, SelectedIdentity.Key, StringComparison.Ordinal)))
        {
            SelectedIdentity = null;
        }

        InboundGrants = await ResourceManager.ListResourcePermissionGrantsAsync(
            new ResourcePermissionGrantQuery(TargetResourceId: Resource.Id));
        GrantGroups = InboundGrants
            .GroupBy(grant => GetIdentityKey(grant.Identity), StringComparer.OrdinalIgnoreCase)
            .Select(group => new GrantGroup(
                group.First().Identity,
                group
                    .Select(grant => grant.Permission)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .Order(StringComparer.OrdinalIgnoreCase)
                    .ToArray()))
            .OrderBy(group => FormatIdentityName(group.Identity), StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.Identity.ResourceId, StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.Identity.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (!string.IsNullOrWhiteSpace(SelectedPermission) &&
            !AvailablePermissionOptions.Any(option =>
                string.Equals(option.Value, SelectedPermission, StringComparison.Ordinal)))
        {
            SelectedPermission = string.Empty;
            CustomPermission = string.Empty;
        }
    }

    private async Task GrantPermission()
    {
        if (GrantingPermission || Resource is null)
        {
            return;
        }

        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            return;
        }

        var permission = ResolvePermission();
        if (!TryGetSelectedIdentity(out var identity))
        {
            ProcedureMessage = L["Select a resource identity."].Value;
            return;
        }

        if (string.IsNullOrWhiteSpace(permission))
        {
            ProcedureMessage = L["Select a permission."].Value;
            return;
        }

        GrantingPermission = true;
        ProcedureMessage = null;
        try
        {
            await ResourceManager.GrantResourcePermissionAsync(
                new GrantResourcePermissionCommand(
                    identity.Identity.ResourceId,
                    identity.Identity.Name,
                    Resource.Id,
                    permission));
            ProcedureMessage = L["Access permission assigned. Provision or reconcile the resource identity to apply provider-side changes."].Value;
            SelectedIdentity = null;
            SelectedPermission = string.Empty;
            CustomPermission = string.Empty;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            GrantingPermission = false;
        }
    }

    private async Task RevokePermission(ResourceIdentityReference identity, string permission)
    {
        if (Resource is null)
        {
            return;
        }

        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            return;
        }

        RevokingPermissionKey = GetPermissionKey(identity, permission);
        ProcedureMessage = null;
        try
        {
            await ResourceManager.RevokeResourcePermissionAsync(
                new RevokeResourcePermissionCommand(
                    identity.ResourceId,
                    identity.Name,
                    Resource.Id,
                    permission));
            ProcedureMessage = L["Access permission revoked. Provision or reconcile the resource identity to apply provider-side changes."].Value;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            RevokingPermissionKey = null;
        }
    }

    private string ResolvePermission() =>
        IsCustomPermission ? CustomPermission.Trim() : SelectedPermission.Trim();

    private string GetGrantButtonLabel() =>
        GrantingPermission
            ? L["Assigning access"].Value
            : L["Assign access"].Value;

    private string GetRevokeButtonLabel(ResourceIdentityReference identity, string permission) =>
        IsRevokingPermission(identity, permission)
            ? L["Revoking"].Value
            : L["Revoke"].Value;

    private bool IsRevokingPermission(ResourceIdentityReference identity, string permission) =>
        string.Equals(RevokingPermissionKey, GetPermissionKey(identity, permission), StringComparison.Ordinal);

    private static string GetPermissionKey(ResourceIdentityReference identity, string permission) =>
        $"{GetIdentityKey(identity)}\u001f{permission}";

    private static string GetIdentityKey(ResourceIdentityReference identity) =>
        $"{identity.ResourceId}\u001f{identity.Name}";

    private static string FormatIdentityOption(IdentityOption identity) =>
        $"{identity.Name} ({identity.IdentityLabel})";

    private void SearchIdentities(OptionsSearchEventArgs<IdentityOption> args)
    {
        var search = args.Text?.Trim() ?? string.Empty;
        args.Items = string.IsNullOrWhiteSpace(search)
            ? IdentityOptions
            : IdentityOptions.Where(identity => MatchesIdentitySearch(identity, search)).ToArray();
    }

    private static bool MatchesIdentitySearch(IdentityOption identity, string search)
    {
        return Contains(identity.Name, search) ||
            Contains(identity.IdentityLabel, search) ||
            Contains(identity.Identity.ResourceId, search) ||
            Contains(identity.Identity.Name, search) ||
            Contains(identity.Resource.DisplayName, search) ||
            Contains(identity.Resource.EffectiveTypeId, search) ||
            Contains(identity.Resource.ResourceClass.ToString(), search) ||
            Contains(identity.Resource.IdentityBinding?.ProviderId, search);
    }

    private static bool Contains(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);

    private bool TryGetSelectedIdentity([NotNullWhen(true)] out IdentityOption? identity)
    {
        identity = SelectedIdentity;
        return identity is not null;
    }

    private Task SetSelectedIdentity(IEnumerable<IdentityOption> identities)
    {
        SelectedIdentity = identities.FirstOrDefault();
        return Task.CompletedTask;
    }

    private string FormatIdentityName(ResourceIdentityReference identity) =>
        ResourcesById.GetValueOrDefault(identity.ResourceId)?.Name ?? identity.ResourceId;

    private RenderFragment IdentityLink(ResourceIdentityReference identity) => builder =>
    {
        var resource = ResourcesById.GetValueOrDefault(identity.ResourceId);
        var sequence = 0;
        builder.OpenElement(sequence++, resource is null ? "span" : "a");
        builder.AddAttribute(sequence++, "class", "resource-link generated-pill-link");
        if (resource is not null)
        {
            builder.AddAttribute(
                sequence++,
                "href",
                ResourceManagerRoutes.ResourceDetails(identity.ResourceId, ResourcePredefinedViewIds.Identity));
        }

        builder.AddContent(sequence++, resource?.Name ?? identity.ResourceId);
        builder.OpenElement(sequence++, "small");
        builder.AddContent(sequence++, FormatIdentityLabel(identity));
        builder.CloseElement();
        if (resource is not null)
        {
            builder.OpenElement(sequence++, "small");
            builder.AddContent(sequence++, resource.EffectiveTypeId);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string FormatIdentityLabel(ResourceIdentityReference identity) =>
        string.IsNullOrWhiteSpace(identity.Name)
            ? "Default identity"
            : identity.Name;

    private sealed record PermissionOption(
        string Label,
        string Value,
        PermissionOptionTarget Target)
    {
        public bool IsAvailableFor(Resource resource) => Target switch
        {
            PermissionOptionTarget.ConfigurationStore =>
                IsResourceType(resource, ConfigurationStoreResourceType) ||
                resource.ResourceClass == ResourceClass.Configuration,
            PermissionOptionTarget.SecretsVault =>
                IsResourceType(resource, SecretsVaultResourceType) ||
                resource.ResourceClass == ResourceClass.SecretsVault,
            PermissionOptionTarget.Volume => IsResourceType(resource, VolumeResourceType),
            PermissionOptionTarget.Network =>
                IsResourceType(resource, NetworkResourceType) ||
                IsResourceType(resource, VirtualNetworkResourceType),
            PermissionOptionTarget.DnsZone => IsResourceType(resource, DnsZoneResourceType),
            PermissionOptionTarget.LoadBalancer => IsResourceType(resource, LoadBalancerResourceType),
            PermissionOptionTarget.IdentityProvisioning => IsResourceType(resource, IdentityProvisioningResourceType),
            PermissionOptionTarget.LifecycleAction => resource.ResourceActions.Any(action =>
                action.Kind is ResourceActionKind.Start or
                    ResourceActionKind.Stop or
                    ResourceActionKind.Pause or
                    ResourceActionKind.Restart),
            PermissionOptionTarget.CustomAction => resource.ResourceActions.Any(action =>
                action.Kind == ResourceActionKind.Custom),
            PermissionOptionTarget.Always => true,
            _ => false
        };

        private static bool IsResourceType(Resource resource, string resourceType) =>
            string.Equals(resource.EffectiveTypeId, resourceType, StringComparison.OrdinalIgnoreCase);
    }

    private enum PermissionOptionTarget
    {
        Always,
        ConfigurationStore,
        SecretsVault,
        Volume,
        Network,
        DnsZone,
        LoadBalancer,
        IdentityProvisioning,
        LifecycleAction,
        CustomAction
    }

    private sealed record IdentityOption(
        ResourceIdentityReference Identity,
        Resource Resource,
        string Key)
    {
        public string Name => Resource.Name;

        public string IdentityLabel => FormatIdentityLabel(Identity);
    }

    private sealed record GrantGroup(
        ResourceIdentityReference Identity,
        IReadOnlyList<string> Permissions);
}
