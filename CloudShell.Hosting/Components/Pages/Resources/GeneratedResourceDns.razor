@using CloudShell.Abstractions.ControlPlane
@using CloudShell.Abstractions.ResourceManager
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    @if (Resource is null)
    {
        <EmptyState Title="@L["Resource not found"].Value"
                    Message="@L["The resource may have been removed or is no longer visible."].Value"
                    Compact="true" />
    }
    else
    {
        <GeneratedResourceViewLayout ResourceType="ResourceType"
                                     ResourceId="@ResourceId"
                                     Resource="Resource"
                                     ViewId="@ResourcePredefinedViewIds.Dns"
                                     Sections="@BuildSections()" />
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string ResourceId { get; set; } = string.Empty;

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    private Resource? Resource { get; set; }
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private IReadOnlyList<NameMappingView> InboundNameMappings { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> RelatedResources { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);

    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;

    private bool CanEditNetworking =>
        Resource is not null &&
        !IsReadOnly &&
        Resource.State is null or ResourceState.Stopped or ResourceState.Paused;

    private bool CanAddNameMapping =>
        CanEditNetworking &&
        Resource?.Endpoints.Count > 0;

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections()
    {
        var sections = new List<GeneratedResourceViewSection>
        {
            new("name-mappings", string.Empty, 0, RenderNameMappings())
        };

        sections.Add(new("dns-and-domain-names", L["DNS and domain names"], 100, RenderDnsAndDomainNames()));

        return sections;
    }

    private RenderFragment RenderNameMappings() => @<div class="blade-section-header">
        <div>
            <h3>@L["Name mappings"]</h3>
            <p>@GetNameMappingConfigurationMessage()</p>
        </div>
        <FluentButton Appearance="Appearance.Neutral"
                      Disabled="@(!CanAddNameMapping)"
                      OnClick="AddNameMapping">
            @L["Add name mapping"]
        </FluentButton>
    </div>;

    private RenderFragment RenderDnsAndDomainNames() => @<text>
        @if (InboundNameMappings.Count == 0)
        {
            <EmptyState Title="@L["No name mappings"].Value"
                        Message="@L["No DNS or domain names target this resource."].Value"
                        Compact="true" />
        }
        else
        {
            <div class="generated-list">
                @foreach (var exposure in InboundNameMappings)
                {
                    <GeneratedListItem Summary="@FormatNameMappingSummary(exposure.Mapping)"
                                       Metadata="@FormatNameMappingMetadata(exposure)">
                        <TitleContent>@ResourceLink(exposure.Mapping)</TitleContent>
                    </GeneratedListItem>
                }
            </div>
        }
    </text>;

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        DisplaySelection = await DisplaySettings.GetAsync();
        if (Resource is null)
        {
            InboundNameMappings = [];
            RelatedResources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
            return;
        }

        InboundNameMappings = await LoadInboundNameMappingsAsync();
        RelatedResources = await LoadRelatedResourcesAsync();
    }

    private string GetNameMappingConfigurationMessage()
    {
        if (IsReadOnly)
        {
            return L["Resource Manager is in read-only mode."].Value;
        }

        if (Resource?.State is ResourceState.Running or ResourceState.Starting or ResourceState.Stopping)
        {
            return L["Stop the resource before changing DNS or domain name mappings."].Value;
        }

        if (Resource?.Endpoints.Count == 0)
        {
            return L["This resource does not expose an endpoint that can be targeted by a name mapping."].Value;
        }

        return L["Create DNS or domain name mappings for this resource endpoint."].Value;
    }

    private async Task<IReadOnlyList<NameMappingView>> LoadInboundNameMappingsAsync()
    {
        if (Resource is null)
        {
            return [];
        }

        var mappings = await ResourceManager.ListResourcesAsync(
            new ResourceQuery(ResourceType: "cloudshell.nameMapping"));
        return mappings
            .Where(mapping => ResourceNameMappingDisplay.TargetsResource(mapping, Resource.Id))
            .Select(mapping => new NameMappingView(mapping))
            .OrderBy(mapping => ResourceNameMappingDisplay.GetHostName(mapping.Mapping), StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private async Task<IReadOnlyDictionary<string, Resource>> LoadRelatedResourcesAsync()
    {
        if (Resource is null)
        {
            return new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
        }

        var ids = InboundNameMappings.Select(mapping => mapping.Mapping.Id)
            .Concat(InboundNameMappings.Select(mapping => mapping.Mapping.ParentResourceId))
            .Concat(InboundNameMappings.Select(mapping => ResourceNameMappingDisplay.GetProviderResourceId(mapping.Mapping)))
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Select(id => id!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var resources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
        foreach (var id in ids)
        {
            var resource = string.Equals(Resource.Id, id, StringComparison.OrdinalIgnoreCase)
                ? Resource
                : await ResourceManager.GetResourceAsync(id);
            if (resource is not null)
            {
                resources[resource.Id] = resource;
            }
        }

        return resources;
    }

    private RenderFragment ResourceLink(Resource resource) =>
        @<ResourcePillLink Label="@GetResourceLabel(resource)"
                           Href="@BuildResourceRoute(resource.Id)"
                           Metadata="@resource.EffectiveTypeId" />;

    private Resource? FindRelatedResource(string resourceId)
    {
        if (Resource is not null &&
            string.Equals(Resource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return Resource;
        }

        return RelatedResources.GetValueOrDefault(resourceId);
    }

    private string GetResourceLabel(Resource resource) => DisplaySelection.GetResourceLabel(resource);

    private string FormatNameMappingSummary(Resource mapping) =>
        Resource is null
            ? ResourceNameMappingDisplay.GetHostName(mapping)
            : L["{0} -> {1}/{2}",
                ResourceNameMappingDisplay.GetHostName(mapping),
                GetResourceLabel(Resource),
                ResourceNameMappingDisplay.GetTargetEndpointName(mapping)].Value;

    private string FormatNameMappingMetadata(NameMappingView view)
    {
        var parts = new List<string>
        {
            L["Exposure: {0}", ResourceNameMappingDisplay.GetExposureLabel(view.Mapping)].Value,
            FormatNameMappingProvider(view.Mapping),
            L["Materialization: {0}", ResourceNameMappingDisplay.GetMaterializationLabel(view.Mapping)].Value
        };

        var zone = string.IsNullOrWhiteSpace(view.Mapping.ParentResourceId)
            ? null
            : FindRelatedResource(view.Mapping.ParentResourceId);
        if (zone is not null)
        {
            parts.Insert(0, L["Zone: {0}", GetResourceLabel(zone)].Value);
        }

        return string.Join(" | ", parts);
    }

    private string FormatNameMappingProvider(Resource mapping)
    {
        var providerResourceId = ResourceNameMappingDisplay.GetProviderResourceId(mapping);
        if (!string.IsNullOrWhiteSpace(providerResourceId))
        {
            var provider = FindRelatedResource(providerResourceId);
            return provider is null
                ? L["Provider: {0}", providerResourceId].Value
                : L["Provider: {0}", GetResourceLabel(provider)].Value;
        }

        return L["Provider: {0}", GetAttributeValue(mapping, ResourceAttributeNames.DnsProvider, "logical")].Value;
    }

    private static string GetAttributeValue(Resource resource, string name, string fallback) =>
        resource.ResourceAttributes.TryGetValue(name, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static string BuildResourceRoute(string resourceId) =>
        ResourceManagerRoutes.ResourceOverview(resourceId);

    private static string BuildAddNameMappingRoute(Resource resource)
    {
        var query = new Dictionary<string, string?>
        {
            ["type"] = "cloudshell.nameMapping",
            ["targetResourceId"] = resource.Id,
            ["targetEndpointName"] = resource.Endpoints.FirstOrDefault()?.Name,
            ["returnUrl"] = BuildResourceTabRoute(resource.Id, ResourcePredefinedViewIds.Dns)
        };
        var queryString = string.Join(
            "&",
            query
                .Where(parameter => !string.IsNullOrWhiteSpace(parameter.Value))
                .Select(parameter =>
                    $"{Uri.EscapeDataString(parameter.Key)}={Uri.EscapeDataString(parameter.Value!)}"));

        return string.IsNullOrWhiteSpace(queryString)
            ? "/resources/add"
            : $"/resources/add?{queryString}";
    }

    private void AddNameMapping()
    {
        if (CanAddNameMapping && Resource is not null)
        {
            Navigation.NavigateTo(BuildAddNameMappingRoute(Resource));
        }
    }

    private static string BuildResourceTabRoute(string resourceId, ResourceViewId tabId) =>
        ResourceManagerRoutes.ResourceDetails(resourceId, tabId);

    private sealed record NameMappingView(Resource Mapping);
}
