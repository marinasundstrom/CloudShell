@using System.Globalization
@using CloudShell.Abstractions.ControlPlane
@using CloudShell.Abstractions.ResourceManager
@inject IResourceManager ResourceManager
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject ICoreShellRouteService ShellRoutes
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    @if (Resource is null)
    {
        <EmptyState Title="@L["Resource not found"].Value"
                    Message="@L["The resource may have been removed or is no longer visible."].Value"
                    Compact="true" />
    }
    else if (!HasNetworkingContent && !HasPredefinedViewSections)
    {
        <EmptyState Title="@L["No networking"].Value"
                    Message="@L["This resource does not project endpoints or networking relationships."].Value"
                    Compact="true" />
    }
    else
    {
        <GeneratedResourceViewLayout ResourceType="ResourceType"
                                     ResourceId="@ResourceId"
                                     Resource="Resource"
                                     ViewId="@ResourcePredefinedViewIds.Endpoints"
                                     Sections="@BuildSections()" />
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string ResourceId { get; set; } = string.Empty;

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    private Resource? Resource { get; set; }
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private IReadOnlyList<NetworkEndpointMappingView> InboundNetworkMappings { get; set; } = [];
    private IReadOnlyList<LoadBalancerRouteView> InboundLoadBalancerRoutes { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> RelatedResources { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);

    private bool HasNetworkingContent =>
        Resource is not null &&
        (Resource.Endpoints.Count > 0 ||
         Resource.ResourceEndpointNetworkMappings.Count > 0 ||
         Resource.ResourceEndpointMappings.Count > 0 ||
         Resource.ResourceLoadBalancerRoutes.Count > 0 ||
         InboundNetworkMappings.Count > 0 ||
         InboundLoadBalancerRoutes.Count > 0 ||
         IsNetworkResource ||
         IsLoadBalancerResource);

    private bool HasPredefinedViewSections =>
        ResourceType?.ResourcePredefinedViewSections.Any(section =>
            section.ViewId == ResourcePredefinedViewIds.Endpoints) == true;

    private bool IsNetworkResource => Resource is not null &&
        (Resource.ResourceClass == ResourceClass.Network ||
         Resource.HasCapability(ResourceCapabilityIds.NetworkingProvider));

    private bool IsLoadBalancerResource => Resource is not null && HasLoadBalancerShape(Resource);

    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;

    private bool CanEditNetworking =>
        Resource is not null &&
        !IsReadOnly &&
        Resource.State is null or ResourceState.Stopped or ResourceState.Paused;

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections()
    {
        var sections = new List<GeneratedResourceViewSection>
        {
            new("endpoint-configuration", string.Empty, 0, RenderEndpointConfiguration())
        };

        if (Resource is null)
        {
            return sections;
        }

        if (Resource.Endpoints.Count > 0)
        {
            sections.Add(new("endpoints", string.Empty, 100, RenderEndpoints()));
        }

        if (Resource.ResourceEndpointNetworkMappings.Count > 0)
        {
            sections.Add(new("mapped-addresses", string.Empty, 200, RenderMappedAddresses()));
        }

        if (InboundNetworkMappings.Count > 0)
        {
            sections.Add(new("network-exposure", L["Network exposure"], 300, RenderNetworkExposure()));
        }

        if (InboundLoadBalancerRoutes.Count > 0)
        {
            sections.Add(new("load-balancer-exposure", L["Load balancer exposure"], 400, RenderLoadBalancerExposure()));
        }

        if (IsLoadBalancerResource)
        {
            sections.Add(new("load-balancing", L["Load balancing"], 500, RenderLoadBalancing()));
        }

        if (IsNetworkResource && !IsLoadBalancerResource)
        {
            sections.Add(new("networking", L["Networking"], 500, RenderNetworking()));
        }

        if (Resource.ResourceEndpointMappings.Count > 0)
        {
            sections.Add(new("endpoint-mappings", L["Endpoint mappings"], 600, RenderEndpointMappings()));
        }

        if (Resource.ResourceLoadBalancerRoutes.Count > 0)
        {
            sections.Add(new("load-balancer-routes", L["Load balancer routes"], 700, RenderLoadBalancerRoutes()));
        }

        if (ResourceDiagnosticDisplay.GetDiagnostics(Resource, RelatedResources) is { Count: > 0 } diagnostics)
        {
            sections.Add(new("diagnostics", L["Diagnostics"], 800, RenderDiagnostics(diagnostics)));
        }

        return sections;
    }

    private RenderFragment RenderEndpointConfiguration() => @<div class="blade-section-header">
        <div>
            <h3>@L["Endpoint configuration"]</h3>
            <p>@GetEndpointConfigurationMessage()</p>
        </div>
        <FluentButton Appearance="Appearance.Neutral"
                      Disabled="@(!CanEditNetworking)"
                      OnClick="OpenConfiguration">
            @L["Configure endpoints"]
        </FluentButton>
    </div>;

    private RenderFragment RenderEndpoints() => @<text>
        <div class="generated-section-heading">
            <h3>@L["Endpoints"]</h3>
            <p>@L["Endpoints are resource-owned protocol and target-port contracts. Network mappings decide where those endpoints are reachable."]</p>
        </div>
        <div class="endpoint-list">
            @foreach (var endpoint in Resource!.Endpoints)
            {
                <div class="generated-endpoint">
                    <div class="generated-endpoint-main">
                        <strong>@endpoint.Name</strong>
                        <dl class="endpoint-detail-list">
                            <dt>@L["Protocol"]</dt>
                            <dd>@FormatEndpointProtocol(endpoint)</dd>
                            <dt>@L["Target port"]</dt>
                            <dd>@FormatTargetPort(endpoint)</dd>
                            <dt>@L["Exposure"]</dt>
                            <dd>@FormatExposure(endpoint.Exposure)</dd>
                        </dl>
                    </div>
                </div>
            }
        </div>
    </text>;

    private RenderFragment RenderMappedAddresses() => @<text>
        <div class="generated-section-heading">
            <h3>@L["Mapped addresses"]</h3>
            <p>@L["Mapped addresses are topology-specific bindings created by a network, runtime, or provider for a resource endpoint."]</p>
        </div>
        <div class="endpoint-list">
            @foreach (var mapping in Resource!.ResourceEndpointNetworkMappings)
            {
                <div class="generated-endpoint">
                    <div class="generated-endpoint-main">
                        <strong>@mapping.Name</strong>
                        <dl class="endpoint-detail-list">
                            <dt>@L["Address"]</dt>
                            <dd><EndpointLink Address="@mapping.Address" EmptyText="@L["none"].Value" /></dd>
                            <dt>@L["Target endpoint"]</dt>
                            <dd>@EndpointReference(mapping.Target, Resource)</dd>
                            <dt>@L["Topology"]</dt>
                            <dd>@FormatEndpointNetworkMappingTopology(mapping)</dd>
                            <dt>@L["Exposure"]</dt>
                            <dd>@FormatExposure(mapping.Exposure)</dd>
                            <dt>@L["Provider"]</dt>
                            <dd>@FormatEndpointNetworkMappingProvider(mapping)</dd>
                        </dl>
                    </div>
                    <GeneratedRowActions>
                        <FluentButton Appearance="Appearance.Neutral"
                                      Title="@L["Copy address"]"
                                      Disabled="@string.IsNullOrWhiteSpace(mapping.Address)"
                                      OnClick="() => CopyEndpoint(mapping.Address)">
                            @L["Copy"]
                        </FluentButton>
                        @if (EndpointLink.CanLink(mapping.Address))
                        {
                            <FluentButton Appearance="Appearance.Neutral"
                                          Title="@L["Open address"]"
                                          OnClick="() => OpenEndpoint(mapping.Address)">
                                @L["Open"]
                            </FluentButton>
                        }
                    </GeneratedRowActions>
                </div>
            }
        </div>
    </text>;

    private RenderFragment RenderNetworkExposure() => @<div class="generated-list">
        @foreach (var exposure in InboundNetworkMappings)
        {
            <GeneratedListItem IconName="network"
                               Metadata="@FormatInboundNetworkMappingSummary(exposure)">
                <TitleContent>@ResourceLink(exposure.Network)</TitleContent>
                <SummaryContent>
                    @EndpointReference(exposure.Mapping.Source, exposure.Network)
                    <span aria-hidden="true">-&gt;</span>
                    @EndpointReference(exposure.Mapping.Target, Resource!)
                </SummaryContent>
            </GeneratedListItem>
        }
    </div>;

    private RenderFragment RenderLoadBalancerExposure() => @<div class="generated-list">
        @foreach (var exposure in InboundLoadBalancerRoutes)
        {
            var entrypoint = L["Entrypoint: {0}", exposure.Route.EntrypointName].Value;
            <GeneratedListItem IconName="load-balancer"
                               Metadata="@entrypoint">
                <TitleContent>@ResourceLink(exposure.LoadBalancer)</TitleContent>
                <SummaryContent>
                    @FormatLoadBalancerRouteMatch(exposure.Route)
                    <span aria-hidden="true">-&gt;</span>
                    @FormatLoadBalancerRouteTarget(exposure.Route.Target)
                </SummaryContent>
            </GeneratedListItem>
        }
    </div>;

    private RenderFragment RenderLoadBalancing() => @<dl class="detail-list">
        <dt>@L["Provider"]</dt>
        <dd>@GetAttributeValue(ResourceAttributeNames.LoadBalancerProvider, Resource!.Provider)</dd>
        <dt>@L["Host"]</dt>
        <dd>
            @if (GetLoadBalancerHostResourceId(Resource) is { } hostResourceId)
            {
                @ResourceLink(hostResourceId)
            }
            else
            {
                @L["Default container host"]
            }
        </dd>
        <dt>@L["Entrypoints"]</dt>
        <dd>@GetAttributeValue(ResourceAttributeNames.LoadBalancerEntrypointCount, Resource.Endpoints.Count.ToString(CultureInfo.InvariantCulture))</dd>
        <dt>@L["Routes"]</dt>
        <dd>@FormatLoadBalancerRouteCounts(Resource)</dd>
        <dt>@L["TLS"]</dt>
        <dd>@FormatEnabled(Resource.HasCapability(ResourceCapabilityIds.NetworkingTls))</dd>
    </dl>;

    private RenderFragment RenderNetworking() => @<dl class="detail-list">
        <dt>@L["Kind"]</dt>
        <dd>@FormatNetworkKind(GetAttributeValue(ResourceAttributeNames.NetworkKind, Resource!.Kind))</dd>
        <dt>@L["Host readiness"]</dt>
        <dd>@FormatNetworkReadiness()</dd>
        @if (Resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.NetworkProvisionedMappingCount))
        {
            <dt>@L["Provisioned mappings"]</dt>
            <dd>@GetAttributeValue(ResourceAttributeNames.NetworkProvisionedMappingCount, "0")</dd>
        }
        @if (GetMappingProviderIds().Length > 0)
        {
            <dt>@L["Mapping providers"]</dt>
            <dd>
                <div class="dependency-list">
                    @foreach (var providerId in GetMappingProviderIds())
                    {
                        @ResourceLink(providerId)
                    }
                </div>
            </dd>
        }
        <dt>@L["Endpoint mapper"]</dt>
        <dd>@FormatEnabled(Resource.HasCapability(ResourceCapabilityIds.NetworkingEndpointMapper))</dd>
        <dt>@L["Virtual network"]</dt>
        <dd>@FormatEnabled(Resource.HasCapability(ResourceCapabilityIds.NetworkingVirtualNetwork))</dd>
        <dt>@L["Ingress"]</dt>
        <dd>@FormatEnabled(Resource.HasCapability(ResourceCapabilityIds.NetworkingIngress))</dd>
        <dt>@L["Host network"]</dt>
        <dd>@FormatEnabled(Resource.HasCapability(ResourceCapabilityIds.NetworkingHostNetwork))</dd>
    </dl>;

    private RenderFragment RenderEndpointMappings() => @<div class="generated-list">
        @foreach (var mapping in Resource!.ResourceEndpointMappings)
        {
            <GeneratedListItem Title="@mapping.Name"
                               IconName="endpoint"
                               Metadata="@MappingProviderLabel(mapping)">
                <SummaryContent>
                    @EndpointReference(mapping.Source, Resource)
                    <span aria-hidden="true">-&gt;</span>
                    @EndpointReference(mapping.Target)
                </SummaryContent>
            </GeneratedListItem>
        }
    </div>;

    private RenderFragment RenderLoadBalancerRoutes() => @<div class="generated-list">
        @foreach (var route in Resource!.ResourceLoadBalancerRoutes)
        {
            var entrypoint = L["Entrypoint: {0}", route.EntrypointName].Value;
            <GeneratedListItem Title="@route.Name"
                               IconName="load-balancer"
                               Metadata="@entrypoint">
                <SummaryContent>
                    @FormatLoadBalancerRouteMatch(route)
                    <span aria-hidden="true">-&gt;</span>
                    @FormatLoadBalancerRouteTarget(route.Target)
                </SummaryContent>
            </GeneratedListItem>
        }
    </div>;

    private RenderFragment RenderDiagnostics(IReadOnlyList<ResourceDiagnosticView> diagnostics) =>
        @<ResourceDiagnosticList Diagnostics="@diagnostics" />;

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        DisplaySelection = await DisplaySettings.GetAsync();
        if (Resource is null)
        {
            InboundNetworkMappings = [];
            InboundLoadBalancerRoutes = [];
            RelatedResources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
            return;
        }

        InboundNetworkMappings = await LoadInboundNetworkMappingsAsync();
        InboundLoadBalancerRoutes = await LoadInboundLoadBalancerRoutesAsync();
        RelatedResources = await LoadRelatedResourcesAsync();
    }

    private string FormatEnabled(bool enabled) => enabled ? L["Enabled"] : L["Disabled"];

    private string FormatEndpointProtocol(ResourceEndpoint endpoint) =>
        string.IsNullOrWhiteSpace(endpoint.Protocol)
            ? L["unspecified"].Value
            : endpoint.Protocol;

    private string FormatTargetPort(ResourceEndpoint endpoint) =>
        endpoint.TargetPort is null
            ? L["not specified"].Value
            : endpoint.TargetPort.Value.ToString(CultureInfo.InvariantCulture);

    private string FormatEndpointNetworkMappingTopology(ResourceEndpointNetworkMapping mapping)
    {
        if (!string.IsNullOrWhiteSpace(mapping.NetworkResourceId))
        {
            var network = FindRelatedResource(mapping.NetworkResourceId);
            return network is null
                ? mapping.NetworkResourceId
                : GetResourceLabel(network);
        }

        return mapping.Exposure switch
        {
            ResourceExposureScope.Private => L["Private topology"].Value,
            ResourceExposureScope.Local => IsLocalHostBinding(mapping.Address)
                ? L["Host network"].Value
                : L["Local topology"].Value,
            ResourceExposureScope.Network => L["Network scoped"].Value,
            ResourceExposureScope.Public => L["Public exposure"].Value,
            _ => mapping.Exposure.ToString()
        };
    }

    private string FormatEndpointNetworkMappingProvider(ResourceEndpointNetworkMapping mapping)
    {
        if (string.IsNullOrWhiteSpace(mapping.ProviderResourceId))
        {
            return L["network"].Value;
        }

        var provider = FindRelatedResource(mapping.ProviderResourceId);
        return provider is null
            ? mapping.ProviderResourceId
            : GetResourceLabel(provider);
    }

    private string FormatExposure(ResourceExposureScope exposure) =>
        exposure switch
        {
            ResourceExposureScope.Private => L["private"].Value,
            ResourceExposureScope.Local => L["local"].Value,
            ResourceExposureScope.Network => L["network"].Value,
            ResourceExposureScope.Public => L["public"].Value,
            _ => exposure.ToString()
        };

    private static bool IsLocalHostBinding(string address)
    {
        if (!Uri.TryCreate(address, UriKind.Absolute, out var uri))
        {
            return false;
        }

        return string.Equals(uri.Host, "localhost", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(uri.Host, "127.0.0.1", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(uri.Host, "::1", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(uri.Host, "[::1]", StringComparison.OrdinalIgnoreCase);
    }

    private string GetEndpointConfigurationMessage()
    {
        if (IsReadOnly)
        {
            return L["Resource Manager is in read-only mode."].Value;
        }

        if (Resource?.State is ResourceState.Running or ResourceState.Starting or ResourceState.Stopping)
        {
            return L["Stop the resource before changing endpoint configuration."].Value;
        }

        return L["Define or update endpoints in the resource configuration view."].Value;
    }

    private string FormatNetworkReadiness()
    {
        if (Resource is null)
        {
            return L["Unknown"].Value;
        }

        var readiness = GetAttributeValue(ResourceAttributeNames.NetworkHostReadiness, "unknown");
        return readiness switch
        {
            "logicalOnly" => L["Logical only"].Value,
            "providerRequired" when GetMissingMappingProviderIds().Length == 0 => L["Ready"].Value,
            "providerRequired" => L["Provider missing"].Value,
            "ready" => L["Ready"].Value,
            _ => readiness
        };
    }

    private string FormatNetworkKind(string kind) =>
        kind switch
        {
            _ when string.Equals(kind, nameof(NetworkResourceKind.Logical), StringComparison.OrdinalIgnoreCase) => L["Logical"].Value,
            _ when string.Equals(kind, nameof(NetworkResourceKind.Virtual), StringComparison.OrdinalIgnoreCase) => L["Virtual"].Value,
            _ when string.Equals(kind, nameof(NetworkResourceKind.Host), StringComparison.OrdinalIgnoreCase) => L["Host"].Value,
            { Length: > 0 } => kind,
            _ => L["Unknown"].Value
        };

    private string[] GetMappingProviderIds() =>
        Resource?.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkMappingProviders, out var providers) == true
            ? providers
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray()
            : [];

    private string[] GetMissingMappingProviderIds() =>
        GetMappingProviderIds()
            .Where(providerId => !RelatedResources.ContainsKey(providerId) &&
                !string.Equals(Resource?.Id, providerId, StringComparison.OrdinalIgnoreCase))
            .ToArray();

    private async Task<IReadOnlyList<NetworkEndpointMappingView>> LoadInboundNetworkMappingsAsync()
    {
        if (Resource is null)
        {
            return [];
        }

        var networks = await ResourceManager.ListResourcesAsync(
            new ResourceQuery(ResourceClass: ResourceClass.Network));
        return networks
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    Resource.Id,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => GetResourceLabel(mapping.Network), StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private async Task<IReadOnlyList<LoadBalancerRouteView>> LoadInboundLoadBalancerRoutesAsync()
    {
        if (Resource is null)
        {
            return [];
        }

        var networks = await ResourceManager.ListResourcesAsync(
            new ResourceQuery(ResourceClass: ResourceClass.Network));
        return networks
            .Where(loadBalancer => !string.Equals(loadBalancer.Id, Resource.Id, StringComparison.OrdinalIgnoreCase))
            .Where(HasLoadBalancerShape)
            .SelectMany(loadBalancer => loadBalancer.ResourceLoadBalancerRoutes
                .Where(route => string.Equals(
                    route.Target.ResourceId,
                    Resource.Id,
                    StringComparison.OrdinalIgnoreCase))
                .Select(route => new LoadBalancerRouteView(loadBalancer, route)))
            .OrderBy(route => GetResourceLabel(route.LoadBalancer), StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Route.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private async Task<IReadOnlyDictionary<string, Resource>> LoadRelatedResourcesAsync()
    {
        if (Resource is null)
        {
            return new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
        }

        var ids = GeneratedResourceEndpointRelatedResourceIds.Create(
            Resource,
            InboundNetworkMappings.Select(mapping => new NetworkEndpointMappingRelationship(
                mapping.Network.Id,
                mapping.Mapping)),
            InboundLoadBalancerRoutes.Select(route => new LoadBalancerRouteRelationship(
                route.LoadBalancer.Id,
                route.Route)),
            GetMappingProviderIds(),
            GetLoadBalancerHostResourceId(Resource));
        var resources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
        foreach (var id in ids)
        {
            var resource = string.Equals(Resource.Id, id, StringComparison.OrdinalIgnoreCase)
                ? Resource
                : await ResourceManager.GetResourceAsync(id);
            if (resource is not null)
            {
                resources[resource.Id] = resource;
            }
        }

        return resources;
    }

    private RenderFragment EndpointReference(
        ResourceEndpointReference reference,
        Resource? fallbackResource = null) => builder =>
    {
        var resource = FindMappingResource(reference.ResourceId, fallbackResource);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        builder.OpenElement(0, "span");
        builder.OpenElement(1, "span");
        builder.AddContent(2, resource is null ? GetFallbackResourceLabel(reference.ResourceId) : GetResourceLabel(resource));
        builder.CloseElement();
        builder.AddContent(3, " / ");
        builder.OpenElement(4, "strong");
        builder.AddContent(5, reference.EndpointName);
        builder.CloseElement();
        if (endpoint is not null)
        {
            builder.AddContent(6, " ");
            builder.OpenElement(7, "small");
            builder.AddContent(8, FormatEndpointSummary(endpoint));
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string FormatEndpointSummary(ResourceEndpoint endpoint)
    {
        var protocol = FormatEndpointProtocol(endpoint);
        return endpoint.TargetPort is null
            ? protocol
            : L["{0}:{1}", protocol, endpoint.TargetPort.Value.ToString(CultureInfo.InvariantCulture)].Value;
    }

    private string FormatInboundNetworkMappingSummary(NetworkEndpointMappingView exposure)
    {
        var mappedAddress = GetEndpointNetworkMapping(exposure.Network, exposure.Mapping.Source.EndpointName)?.Address;
        var providerLabel = MappingProviderLabel(exposure.Mapping);
        return string.IsNullOrWhiteSpace(mappedAddress)
            ? providerLabel
            : L["{0} · {1}", mappedAddress, providerLabel].Value;
    }

    private static ResourceEndpointNetworkMapping? GetEndpointNetworkMapping(
        Resource resource,
        string endpointName) =>
        resource.ResourceEndpointNetworkMappings.FirstOrDefault(mapping => mapping.MatchesEndpoint(endpointName));

    private string MappingProviderLabel(ResourceEndpointMappingDefinition mapping)
    {
        var providerId = GetMappingProviderId(mapping);
        if (string.IsNullOrWhiteSpace(providerId))
        {
            return L["Provider: network"].Value;
        }

        var provider = FindRelatedResource(providerId);
        return provider is null
            ? L["Provider: {0}", GetFallbackResourceLabel(providerId)].Value
            : L["Provider: {0}", GetResourceLabel(provider)].Value;
    }

    private string? GetMappingProviderId(ResourceEndpointMappingDefinition mapping) =>
        FirstNonEmpty(mapping.ProviderResourceId, mapping.NetworkResourceId, mapping.Source.ResourceId);

    private Resource? FindMappingResource(string resourceId, Resource? fallbackResource = null)
    {
        if (fallbackResource is not null &&
            string.Equals(fallbackResource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return fallbackResource;
        }

        return FindRelatedResource(resourceId);
    }

    private RenderFragment ResourceLink(string resourceId)
    {
        var resource = FindRelatedResource(resourceId);
        var label = resource is null ? GetFallbackResourceLabel(resourceId) : GetResourceLabel(resource);
        return @<ResourcePillLink Label="@label"
                                  Href="@BuildResourceRoute(resourceId)"
                                  Resource="@resource"
                                  Metadata="@resource?.EffectiveTypeId" />;
    }

    private RenderFragment ResourceLink(Resource resource) =>
        @<ResourcePillLink Label="@GetResourceLabel(resource)"
                           Href="@BuildResourceRoute(resource.Id)"
                           Resource="@resource"
                           Metadata="@resource.EffectiveTypeId" />;

    private Resource? FindRelatedResource(string resourceId)
    {
        if (Resource is not null &&
            string.Equals(Resource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return Resource;
        }

        return RelatedResources.GetValueOrDefault(resourceId);
    }

    private string GetResourceLabel(Resource resource) => DisplaySelection.GetResourceLabel(resource);

    private static string GetFallbackResourceLabel(string resourceId) =>
        ResourceDisplayLabels.GetName(resourceId);

    private string FormatLoadBalancerRouteMatch(LoadBalancerRoute route)
    {
        if (route.Kind == LoadBalancerRouteKind.Tcp)
        {
            return L["TCP {0}", route.Match.Port?.ToString() ?? route.EntrypointName].Value;
        }

        var host = string.IsNullOrWhiteSpace(route.Match.Host)
            ? L["any host"].Value
            : route.Match.Host;
        return string.IsNullOrWhiteSpace(route.Match.PathPrefix)
            ? host
            : $"{host}{route.Match.PathPrefix}";
    }

    private string FormatLoadBalancerRouteTarget(LoadBalancerRouteTarget target)
    {
        var resource = FindRelatedResource(target.ResourceId);
        var label = resource is null ? GetFallbackResourceLabel(target.ResourceId) : GetResourceLabel(resource);
        if (!string.IsNullOrWhiteSpace(target.EndpointName))
        {
            return $"{label}/{target.EndpointName}";
        }

        return target.Port is null
            ? label
            : $"{label}:{target.Port.Value}";
    }

    private string FormatLoadBalancerRouteCounts(Resource resource)
    {
        var routeCount = GetAttributeValue(
            ResourceAttributeNames.LoadBalancerRouteCount,
            resource.ResourceLoadBalancerRoutes.Count.ToString(CultureInfo.InvariantCulture));
        var httpCount = GetAttributeValue(ResourceAttributeNames.LoadBalancerHttpRouteCount, "0");
        var tcpCount = GetAttributeValue(ResourceAttributeNames.LoadBalancerTcpRouteCount, "0");
        return L["{0} total ({1} HTTP, {2} TCP)", routeCount, httpCount, tcpCount].Value;
    }

    private static bool HasLoadBalancerShape(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.NetworkingLoadBalancer) ||
        resource.ResourceLoadBalancerRoutes.Count > 0 ||
        resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.LoadBalancerProvider);

    private static string? GetLoadBalancerHostResourceId(Resource resource)
    {
        var hostResourceId = resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.LoadBalancerHostResourceId);
        return string.IsNullOrWhiteSpace(hostResourceId) ||
            string.Equals(hostResourceId, "default", StringComparison.OrdinalIgnoreCase)
                ? null
                : hostResourceId;
    }

    private static string GetAttributeValue(Resource resource, string name, string fallback) =>
        resource.ResourceAttributes.TryGetValue(name, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private string GetAttributeValue(string name, string fallback) =>
        Resource is null ? fallback : GetAttributeValue(Resource, name, fallback);

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private string BuildResourceRoute(string resourceId) =>
        ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId);

    private string BuildResourceTabRoute(string resourceId, ResourceViewId tabId) =>
        ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId, tabId);

    private async Task CopyEndpoint(string address)
    {
        if (!string.IsNullOrWhiteSpace(address))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", address);
        }
    }

    private void OpenEndpoint(string address) =>
        Navigation.NavigateTo(address, forceLoad: true);

    private void OpenConfiguration()
    {
        if (Resource is not null)
        {
            Navigation.NavigateTo(BuildResourceTabRoute(Resource.Id, ResourcePredefinedViewIds.Configuration));
        }
    }

    private sealed record NetworkEndpointMappingView(
        Resource Network,
        ResourceEndpointMappingDefinition Mapping);

    private sealed record LoadBalancerRouteView(
        Resource LoadBalancer,
        LoadBalancerRoute Route);

}
