@using System.Globalization
@implements IDisposable
@inject IResourceManager ResourceManager
@inject IResourceHealthManager HealthChecks
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    <GeneratedResourceViewLayout ResourceType="ResourceType"
                                 ResourceId="@(ResourceId ?? string.Empty)"
                                 Resource="Resource"
                                 ViewId="@ResourcePredefinedViewIds.Health"
                                 Sections="@BuildSections()" />
</div>

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    private Resource? Resource { get; set; }
    private ResourceHealthSummary? Summary { get; set; }
    private IReadOnlyList<ResourceHealthSummary> Snapshots { get; set; } = [];
    private bool IsCheckingHealth { get; set; }
    private bool IsLoading { get; set; }
    private bool IsDisposed { get; set; }
    private bool AutoRefresh { get; set; } = true;
    private System.Threading.Timer? RefreshTimer { get; set; }
    private bool SupportsHealthChecks =>
        Resource?.ResourceHealthChecks.Count > 0 ||
        ResourceType?.ResourceProbeOptions.SupportsHealthChecks == true;

    protected override void OnInitialized()
    {
        RefreshTimer = new System.Threading.Timer(
            _ =>
            {
                if (!IsDisposed && AutoRefresh)
                {
                    _ = InvokeAsync(LoadHealthAsync);
                }
            },
            null,
            GetHealthCheckInterval(),
            GetHealthCheckInterval());
    }

    protected override Task OnParametersSetAsync() => LoadHealthAsync();

    private async Task LoadHealthAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId) || IsLoading || IsDisposed)
        {
            if (string.IsNullOrWhiteSpace(ResourceId))
            {
                Resource = null;
                Summary = null;
                Snapshots = [];
            }

            return;
        }

        IsLoading = true;
        try
        {
            Resource = await ResourceManager.GetResourceAsync(ResourceId);
            Summary = await HealthChecks.GetResourceHealthAsync(ResourceId);
            Snapshots = await HealthChecks.ListResourceHealthSnapshotsAsync(ResourceId, 20);
        }
        finally
        {
            IsLoading = false;
            if (!IsDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RefreshHealthAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId) || IsDisposed)
        {
            return;
        }

        IsCheckingHealth = true;
        try
        {
            Summary = await HealthChecks.RefreshResourceHealthAsync(ResourceId);
            Snapshots = await HealthChecks.ListResourceHealthSnapshotsAsync(ResourceId, 20);
        }
        finally
        {
            IsCheckingHealth = false;
        }
    }

    public void Dispose()
    {
        IsDisposed = true;
        RefreshTimer?.Dispose();
    }

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections() =>
    [
        new("health", string.Empty, 0, RenderHealth())
    ];

    private RenderFragment RenderHealth() => @<text>
        <ResourceActivityHeader Title="@L["Health"].Value"
                                Subtitle="@GetStatusText()"
                                ActionsClass="resource-monitoring-actions">
            <Actions>
                <FluentCheckbox @bind-Value="AutoRefresh">
                    @L["Auto-refresh"]
                </FluentCheckbox>
                @if (!AutoRefresh)
                {
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(IsCheckingHealth || IsLoading)"
                                  IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                                  OnClick="RefreshHealthAsync">
                        @(IsCheckingHealth ? L["Checking"] : L["Refresh"])
                    </FluentButton>
                }
                @if (ResourcePredefinedViewVisibility.HasRecoveryView(Resource))
                {
                    <FluentAnchor Appearance="Appearance.Neutral"
                                  IconStart="@(new Icons.Regular.Size20.ArrowReset())"
                                  Href="@BuildRecoveryRoute()">
                        @L["Recovery"]
                    </FluentAnchor>
                }
            </Actions>
        </ResourceActivityHeader>

        @if (Resource is null)
        {
            <EmptyState Title="@L["Resource unavailable"].Value"
                        Message="@L["The resource could not be loaded."].Value"
                        Compact="true" />
        }
        else if (Resource.ResourceHealthChecks.Count == 0 && Summary?.Checks.Count is not > 0)
        {
            <ResourceCallout Severity="@(SupportsHealthChecks ? ResourceSignalSeverity.Info : ResourceSignalSeverity.Warning)"
                             Title="@GetNoHealthChecksTitle()">
                <p>@GetNoHealthChecksMessage()</p>
                @if (SupportsHealthChecks)
                {
                    <p>@L["Health checks are registered on resources so the Control Plane can poll them, retain snapshots, and surface current and historical health in Resource Manager."]</p>
                }
            </ResourceCallout>
        }
        else
        {
            <div class="resource-activity-groups" aria-label="@L["Health summary"]">
                <span class="resource-activity-group">
                    <strong>@L["Status"]</strong>
                    <span class="health-pill @GetHealthClass(Summary?.Status)">
                        @GetHealthLabel(Summary?.Status)
                    </span>
                </span>
                <span class="resource-activity-group">
                    <strong>@L["Checks"]</strong>
                    <span>@GetCheckCountLabel()</span>
                </span>
                <span class="resource-activity-group">
                    <strong>@L["Last checked"]</strong>
                    <span>@GetCheckedAtLabel()</span>
                </span>
            </div>

            <ResourceHealthHistoryChart Title="@L["Recent polling"].Value"
                                        Checks="GetChartChecks()"
                                        Snapshots="Snapshots" />

            <div class="resource-activity-list">
                @foreach (var row in GetHealthCheckRows())
                {
                    <article class="resource-activity-event">
                        <div>
                            <div>
                                <strong>@row.Check.Name</strong>
                                <span>@row.Check.Type</span>
                            </div>
                            <span class="health-pill @GetHealthClass(row.Result?.Status)">
                                @GetHealthLabel(row.Result?.Status)
                            </span>
                        </div>
                        <p>@(row.Result?.Detail ?? GetPendingDetail())</p>
                        <footer>
                            <span>@FormatEndpoint(row.Check)</span>
                            <span>@FormatPath(row.Check)</span>
                            <span>@FormatInterval(row.Check)</span>
                        </footer>
                        @if (row.Result?.Uri is not null)
                        {
                            <footer>
                                <span>@L["Resolved URI"]</span>
                                <span>@row.Result.Uri</span>
                            </footer>
                        }
                        @if (row.Result?.ScopeObservations.Count > 0)
                        {
                            @foreach (var observation in row.Result.ScopeObservations)
                            {
                                <footer>
                                    <span>@FormatScope(observation)</span>
                                    <span>@FormatScopeDetail(observation)</span>
                                </footer>
                            }
                        }
                    </article>
                }
            </div>
        }
    </text>;

    private string GetStatusText()
    {
        if (Resource is null)
        {
            return L["Resource health checks"].Value;
        }

        if (Resource.ResourceHealthChecks.Count == 0)
        {
            return SupportsHealthChecks
                ? L["Health checks available"].Value
                : L["No configured health checks"].Value;
        }

        return Summary is null
            ? L["{0} configured check(s)", Resource.ResourceHealthChecks.Count].Value
            : L["{0} / checked {1}",
                GetHealthLabel(Summary.Status),
                Summary.CheckedAt.ToLocalTime().ToString("HH:mm:ss", CultureInfo.CurrentCulture)].Value;
    }

    private string GetCheckCountLabel()
    {
        if (Summary is null)
        {
            return L["{0} configured", Resource?.ResourceHealthChecks.Count ?? 0].Value;
        }

        var unhealthy = Summary.Checks.Count(check => check.Status == ResourceHealthStatus.Unhealthy);
        return unhealthy == 0
            ? L["{0} configured", Resource?.ResourceHealthChecks.Count ?? Summary.Checks.Count].Value
            : L["{0} unhealthy / {1} configured", unhealthy, Resource?.ResourceHealthChecks.Count ?? Summary.Checks.Count].Value;
    }

    private string GetNoHealthChecksTitle() =>
        SupportsHealthChecks
            ? L["No health checks enabled"].Value
            : L["No health checks configured"].Value;

    private string GetNoHealthChecksMessage() =>
        SupportsHealthChecks
            ? L["This resource type supports health checks, but this resource has not registered any health check endpoints yet."].Value
            : L["This resource does not declare health checks."].Value;

    private TimeSpan GetHealthCheckInterval() =>
        TimeSpan.FromSeconds(OrchestrationSettings.GetHealthCheckIntervalSettings().Seconds);

    private string GetCheckedAtLabel() =>
        Summary is null
            ? (IsCheckingHealth ? L["Checking"].Value : L["Not checked"].Value)
            : Summary.CheckedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.CurrentCulture);

    private IReadOnlyList<HealthCheckRow> GetHealthCheckRows()
    {
        if (Resource is null)
        {
            return [];
        }

        var results = Summary?.Checks ?? [];
        var checks = Resource.ResourceHealthChecks.Count > 0
            ? Resource.ResourceHealthChecks
            : results.Select(result => result.Check).ToArray();
        return checks
            .Select(check => new HealthCheckRow(
                check,
                results.FirstOrDefault(result => ReferenceEquals(result.Check, check) || result.Check == check)))
            .OrderBy(row => GetHealthRank(row.Result?.Status))
            .ThenBy(row => row.Check.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private string GetHealthLabel(ResourceHealthStatus? status)
    {
        if (status is null)
        {
            return IsCheckingHealth ? L["Checking"].Value : L["Not checked"].Value;
        }

        return status switch
        {
            ResourceHealthStatus.Healthy => L["Healthy"].Value,
            ResourceHealthStatus.Unhealthy => L["Unhealthy"].Value,
            _ => L["Unknown"].Value
        };
    }

    private string GetPendingDetail() =>
        IsCheckingHealth ? L["Checking"].Value : L["No result"].Value;

    private static string GetHealthClass(ResourceHealthStatus? status) =>
        status switch
        {
            ResourceHealthStatus.Healthy => "health-healthy",
            ResourceHealthStatus.Unhealthy => "health-unhealthy",
            ResourceHealthStatus.Unknown => "health-unknown",
            _ => "health-pending"
        };

    private static int GetHealthRank(ResourceHealthStatus? status) =>
        status switch
        {
            ResourceHealthStatus.Unhealthy => 0,
            ResourceHealthStatus.Unknown => 1,
            null => 2,
            ResourceHealthStatus.Healthy => 3,
            _ => 4
        };

    private string FormatEndpoint(ResourceHealthCheck check) =>
        string.IsNullOrWhiteSpace(check.EndpointName)
            ? L["default endpoint"].Value
            : check.EndpointName;

    private string BuildRecoveryRoute() =>
        ResourceManagerCompositionLinks.ResourceDetails(
            Composition,
            ResourceId ?? string.Empty,
            ResourcePredefinedViewIds.Recovery);

    private static string FormatPath(ResourceHealthCheck check)
    {
        var path = string.IsNullOrWhiteSpace(check.Path) ? "/" : check.Path;
        return check.Timeout is null
            ? path
            : $"{path} / {check.Timeout.Value.TotalSeconds:0.#}s";
    }

    private string FormatInterval(ResourceHealthCheck check) =>
        check.IntervalSeconds is null
            ? L["shared interval"].Value
            : L["every {0}s", check.IntervalSeconds].Value;

    private IReadOnlyList<ResourceHealthCheck> GetChartChecks() =>
        Resource?.ResourceHealthChecks.Count > 0
            ? Resource.ResourceHealthChecks
            : Summary?.Checks.Select(result => result.Check).ToArray() ?? [];

    private string FormatScope(ResourceHealthScopeObservation observation)
    {
        var displayName = string.IsNullOrWhiteSpace(observation.DisplayName)
            ? observation.ScopeId
            : observation.DisplayName;
        return L["{0} ({1})", displayName, observation.ScopeKind].Value;
    }

    private string FormatScopeDetail(ResourceHealthScopeObservation observation) =>
        L["{0} - {1}", GetHealthLabel(observation.Status), observation.Detail].Value;

    private sealed record HealthCheckRow(
        ResourceHealthCheck Check,
        ResourceHealthCheckResult? Result);
}
