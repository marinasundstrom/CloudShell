@using CloudShell.Abstractions.ControlPlane
@using CloudShell.Abstractions.ResourceManager
@inject IResourceManager ResourceManager
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject IStringLocalizer<SharedResource> L

    <div class="generated-resource-view">
        @if (!string.IsNullOrWhiteSpace(ProcedureMessage))
        {
            <ProcedureMessage Message="@ProcedureMessage" />
        }

    @if (Resource is null)
    {
        <div class="empty-state">
            <strong>@L["Resource not found"]</strong>
            <span>@L["The resource may have been removed or is no longer visible."]</span>
        </div>
    }
    else
    {
        <GeneratedResourceViewLayout ResourceType="ResourceType"
                                     ResourceId="@ResourceId"
                                     Resource="Resource"
                                     ViewId="@ResourcePredefinedViewIds.Identity"
                                     Sections="@BuildSections()" />
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string ResourceId { get; set; } = string.Empty;

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<ResourcePermissionGrant> InboundPermissionGrants { get; set; } = [];
    private IReadOnlyList<ResourcePermissionGrant> OutboundPermissionGrants { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> RelatedResources { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private ResourceIdentityProvisioningStatusResult? ProvisioningStatus { get; set; }
    private string? ProvisioningStatusError { get; set; }
    private string? ProcedureMessage { get; set; }
    private bool ProvisioningIdentity { get; set; }
    private bool UpdatingIdentity { get; set; }
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private bool IdentityEnabled => Resource?.IdentityBinding is not null;

    private bool HasPermissionGrants =>
        InboundPermissionGrants.Count > 0 ||
        OutboundPermissionGrants.Count > 0;

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections()
    {
        var sections = new List<GeneratedResourceViewSection>
        {
            new("resource-identity", L["Resource identity"], 0, RenderResourceIdentity())
        };

        if (Resource?.IdentityBinding is not null)
        {
            sections.Add(new("provisioning-status", L["Provisioning status"], 100, RenderProvisioningStatus()));
        }

        if (HasPermissionGrants)
        {
            sections.Add(new("permission-grants", L["Permission grants"], 200, RenderPermissionGrants()));
        }

        return sections;
    }

    private RenderFragment RenderResourceIdentity() => @<text>
        <GeneratedRowActions>
            <FluentCheckbox Value="@IdentityEnabled"
                            ValueChanged="SetIdentityEnabled"
                            Disabled="@(UpdatingIdentity || IsReadOnly)">
                @L["Enable identity"]
            </FluentCheckbox>
        </GeneratedRowActions>
        @if (Resource?.IdentityBinding is { } identity)
        {
            <dl class="detail-list">
                <dt>@L["Name"]</dt>
                <dd>@FormatIdentityName(identity)</dd>
                <dt>@L["Kind"]</dt>
                <dd>@identity.Kind</dd>
                <dt>@L["Provider"]</dt>
                <dd>@FormatIdentityProvider(identity)</dd>
                <dt>@L["Subject"]</dt>
                <dd>@FormatIdentitySubject(identity)</dd>
                @if (identity.IdentityScopes.Count > 0)
                {
                    <dt>@L["Scopes"]</dt>
                    <dd>
                        <div class="dependency-list">
                            @foreach (var scope in identity.IdentityScopes.Order(StringComparer.OrdinalIgnoreCase))
                            {
                                <span class="generated-pill-link">@scope</span>
                            }
                        </div>
                    </dd>
                }
                @if (identity.IdentityClaims.Count > 0)
                {
                    <dt>@L["Claims"]</dt>
                    <dd>
                        <div class="generated-list">
                            @foreach (var claim in identity.IdentityClaims.OrderBy(claim => claim.Key, StringComparer.OrdinalIgnoreCase))
                            {
                                <GeneratedListItem Title="@claim.Key"
                                                   Summary="@claim.Value" />
                            }
                        </div>
                    </dd>
                }
            </dl>
            <GeneratedRowActions>
                <FluentButton Appearance="Appearance.Neutral"
                              Disabled="@(ProvisioningIdentity || IsReadOnly)"
                              OnClick="ProvisionIdentity">
                    @GetProvisionIdentityButtonLabel()
                </FluentButton>
            </GeneratedRowActions>
            @if (IsReadOnly)
            {
                <ProcedureMessage Compact="true">
                    @L["Resource Manager is in read-only mode. Identity provisioning is disabled in this UI."]
                </ProcedureMessage>
            }
        }
        else
        {
            <div class="empty-state">
                <strong>@L["Identity not enabled"]</strong>
                <span>@L["Enable identity for this resource before provisioning identity or assigning access permissions."]</span>
            </div>
            @if (IsReadOnly)
            {
                <ProcedureMessage Compact="true">
                    @L["Resource Manager is in read-only mode. Identity changes are disabled in this UI."]
                </ProcedureMessage>
            }
        }
    </text>;

    private RenderFragment RenderProvisioningStatus() => @<text>
        @if (!string.IsNullOrWhiteSpace(ProvisioningStatusError))
        {
            <ProcedureMessage Message="@ProvisioningStatusError"
                              Compact="true" />
        }
        else if (ProvisioningStatus is null)
        {
            <p class="muted">@L["Provisioning status is unavailable."]</p>
        }
        else
        {
            <dl class="detail-list">
                <dt>@L["Provider"]</dt>
                <dd>@FormatProvisioningProvider()</dd>
            </dl>
            @if (ProvisioningStatus.Statuses.Count == 0)
            {
                <p class="muted">@L["No provisioning status was reported for this resource identity."]</p>
            }
            else
            {
                <div class="generated-list">
                    @foreach (var status in ProvisioningStatus.Statuses)
                    {
                        var observedAt = status.ObservedAt is { } timestamp
                            ? L["Observed {0}", timestamp.ToLocalTime().ToString("g")].Value
                            : null;
                        <GeneratedListItem Title="@FormatIdentityReference(status.Identity)"
                                           Summary="@status.State.ToString()"
                                           Metadata="@status.Detail"
                                           SecondaryMetadata="@observedAt" />
                    }
                </div>
            }
            @if (ProvisioningStatus.ProvisioningDiagnostics.Count > 0)
            {
                <div class="generated-list">
                    @foreach (var diagnostic in ProvisioningStatus.ProvisioningDiagnostics)
                    {
                        <GeneratedListItem Title="@diagnostic.Severity.ToString()"
                                           Summary="@diagnostic.Message"
                                           Metadata="@(diagnostic.Identity is null ? null : FormatIdentityReference(diagnostic.Identity))" />
                    }
                </div>
            }
        }
    </text>;

    private RenderFragment RenderPermissionGrants() => @<text>
        @if (OutboundPermissionGrants.Count > 0)
        {
            <div class="generated-list">
                @foreach (var grant in OutboundPermissionGrants)
                {
                    var title = L["Can access"].Value;
                    <GeneratedListItem Title="@title"
                                       Metadata="@grant.Permission">
                        <SummaryContent>@ResourceLink(grant.TargetResourceId)</SummaryContent>
                    </GeneratedListItem>
                }
            </div>
        }
        @if (InboundPermissionGrants.Count > 0)
        {
            <div class="generated-list">
                @foreach (var grant in InboundPermissionGrants)
                {
                    var summary = L["Can access this resource"].Value;
                    <GeneratedListItem Title="@FormatIdentityReference(grant.ResourceIdentity!)"
                                       Summary="@summary"
                                       Metadata="@grant.Permission" />
                }
            </div>
        }
    </text>;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        if (Resource is null)
        {
            InboundPermissionGrants = [];
            OutboundPermissionGrants = [];
            RelatedResources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
            ProvisioningStatus = null;
            ProvisioningStatusError = null;
            return;
        }

        InboundPermissionGrants = (await ResourceManager.ListResourcePermissionGrantsAsync(
                new ResourcePermissionGrantQuery(TargetResourceId: Resource.Id)))
            .Where(grant => grant.ResourceIdentity is not null)
            .ToArray();
        OutboundPermissionGrants = await LoadOutboundPermissionGrantsAsync();
        await LoadProvisioningStatusAsync();
        RelatedResources = await LoadRelatedResourcesAsync();
    }

    private async Task SetIdentityEnabled(bool enabled)
    {
        if (UpdatingIdentity || Resource is null)
        {
            return;
        }

        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            return;
        }

        UpdatingIdentity = true;
        ProcedureMessage = null;
        try
        {
            await ResourceManager.SetResourceIdentityAsync(
                new SetResourceIdentityCommand(
                    Resource.Id,
                    enabled ? ResourceIdentityBinding.RequireIdentity() : null));
            ProcedureMessage = enabled
                ? L["Identity enabled for this resource."].Value
                : L["Identity disabled for this resource."].Value;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            UpdatingIdentity = false;
        }
    }

    private string FormatIdentityName(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.Name)
            ? L["Default identity"].Value
            : identity.Name;

    private string FormatIdentityProvider(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.ProviderId)
            ? L["Default provider"].Value
            : identity.ProviderId;

    private string FormatProvisioningProvider() =>
        string.IsNullOrWhiteSpace(ProvisioningStatus?.ProviderId)
            ? L["Not resolved"].Value
            : ProvisioningStatus.ProviderId;

    private string FormatIdentitySubject(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.Subject)
            ? L["Not assigned"].Value
            : identity.Subject;

    private string FormatIdentityReference(ResourceIdentityReference identity)
    {
        var label = FindRelatedResource(identity.ResourceId) is { } resource
            ? ResourceDisplayLabels.GetQualifiedLabel(resource)
            : identity.ResourceId;
        if (string.IsNullOrWhiteSpace(identity.Name))
        {
            return label;
        }

        return $"{label} / {identity.Name}";
    }

    private async Task<IReadOnlyList<ResourcePermissionGrant>> LoadOutboundPermissionGrantsAsync()
    {
        if (Resource?.IdentityBinding is not { } identity)
        {
            return [];
        }

        return await ResourceManager.ListResourcePermissionGrantsAsync(
            new ResourcePermissionGrantQuery(
                Principal: ResourcePrincipalReference.ForResourceIdentity(Resource.Id, identity.Name)));
    }

    private async Task LoadProvisioningStatusAsync()
    {
        ProvisioningStatus = null;
        ProvisioningStatusError = null;
        if (Resource?.IdentityBinding is null)
        {
            return;
        }

        try
        {
            ProvisioningStatus = await ResourceManager.GetResourceIdentityProvisioningStatusAsync(Resource.Id);
        }
        catch (Exception exception)
        {
            ProvisioningStatusError = exception.Message;
        }
    }

    private async Task<IReadOnlyDictionary<string, Resource>> LoadRelatedResourcesAsync()
    {
        var ids = InboundPermissionGrants
            .Select(grant => grant.ResourceIdentity?.ResourceId)
            .Concat(OutboundPermissionGrants.Select(grant => grant.TargetResourceId))
            .OfType<string>()
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var resources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
        foreach (var id in ids)
        {
            var resource = string.Equals(Resource?.Id, id, StringComparison.OrdinalIgnoreCase)
                ? Resource
                : await ResourceManager.GetResourceAsync(id);
            if (resource is not null)
            {
                resources[resource.Id] = resource;
            }
        }

        return resources;
    }

    private Resource? FindRelatedResource(string resourceId)
    {
        if (Resource is not null &&
            string.Equals(Resource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return Resource;
        }

        return RelatedResources.GetValueOrDefault(resourceId);
    }

    private RenderFragment ResourceLink(string resourceId)
    {
        var resource = FindRelatedResource(resourceId);
        var label = ResourceDisplayLabels.GetLabel(resource, resourceId);
        return @<ResourcePillLink Label="@label"
                                  Href="@BuildResourceRoute(resourceId)"
                                  Metadata="@resource?.EffectiveTypeId" />;
    }

    private string GetProvisionIdentityButtonLabel() =>
        ProvisioningIdentity
            ? L["Provisioning identity"].Value
            : L["Provision an identity for this resource"].Value;

    private async Task ProvisionIdentity()
    {
        if (ProvisioningIdentity || Resource?.IdentityBinding is null || IsReadOnly)
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        ProvisioningIdentity = true;
        ProcedureMessage = null;
        try
        {
            var result = await ResourceManager.ProvisionResourceIdentityAsync(Resource.Id);
            var diagnostic = result.ProvisioningDiagnostics.FirstOrDefault();
            ProcedureMessage = diagnostic is null
                ? L["Provisioned an identity for this resource."].Value
                : diagnostic.Message;
            await LoadProvisioningStatusAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            ProvisioningIdentity = false;
        }
    }

    private static string BuildResourceRoute(string resourceId) =>
        ResourceManagerRoutes.ResourceDetails(resourceId, ResourcePredefinedViewIds.Identity);
}
