@using System.Globalization
@implements IDisposable
@inject IResourceMonitoringManager MonitoringManager
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    <GeneratedResourceViewLayout ResourceType="ResourceType"
                                 ResourceId="@(ResourceId ?? string.Empty)"
                                 ViewId="@ResourcePredefinedViewIds.Monitoring"
                                 Sections="@BuildSections()" />
</div>

@code {
    private static readonly TimeSpan AutoRefreshInterval = TimeSpan.FromSeconds(5);

    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    private ResourceMonitoringSnapshot? Snapshot { get; set; }
    private System.Threading.Timer? RefreshTimer { get; set; }
    private bool IsLoading { get; set; }
    private bool IsDisposed { get; set; }
    private bool AutoRefresh { get; set; } = true;

    protected override void OnInitialized()
    {
        RefreshTimer = new System.Threading.Timer(
            _ =>
            {
                if (!IsDisposed && AutoRefresh)
                {
                    _ = InvokeAsync(Refresh);
                }
            },
            null,
            AutoRefreshInterval,
            AutoRefreshInterval);
    }

    protected override Task OnParametersSetAsync() => Refresh();

    private async Task Refresh()
    {
        if (string.IsNullOrWhiteSpace(ResourceId) || IsLoading || IsDisposed)
        {
            return;
        }

        IsLoading = true;
        try
        {
            Snapshot = await MonitoringManager.GetResourceMonitoringAsync(ResourceId);
        }
        finally
        {
            IsLoading = false;
            if (!IsDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    public void Dispose()
    {
        IsDisposed = true;
        RefreshTimer?.Dispose();
    }

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections() =>
    [
        new("monitoring", string.Empty, 0, RenderMonitoring())
    ];

    private RenderFragment RenderMonitoring() => @<text>
        <ResourceActivityHeader Title="@L["Monitoring"].Value"
                                Subtitle="@GetStatusText()"
                                ActionsClass="resource-monitoring-actions">
            <Actions>
                <FluentCheckbox @bind-Value="AutoRefresh">
                    @L["Auto-refresh"]
                </FluentCheckbox>
                @if (!AutoRefresh)
                {
                    <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                                  Disabled="@IsLoading" OnClick="Refresh">
                        @(IsLoading ? L["Refreshing"] : L["Refresh"])
                    </FluentButton>
                }
            </Actions>
        </ResourceActivityHeader>

        @if (Snapshot is null)
        {
            <EmptyState Title="@L["Monitoring unavailable"].Value"
                        Message="@L["No resource monitoring snapshot is available for this resource."].Value"
                        Compact="true" />
        }
        else if (Snapshot.Metrics.Count == 0)
        {
            <EmptyState Title="@L["No metrics available"].Value"
                        Message="@(Snapshot.Message ?? L["The provider did not return any resource metrics for this snapshot."].Value)"
                        Compact="true" />
        }
        else
        {
            var quotaVisualization = BuildQuotaVisualization(Snapshot);

            <dl class="detail-list">
                <dt>@L["Provider"]</dt>
                <dd>@Snapshot.Provider</dd>
                <dt>@L["Last updated"]</dt>
                <dd>@Snapshot.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.CurrentCulture)</dd>
                @if (!string.IsNullOrWhiteSpace(Snapshot.Status))
                {
                    <dt>@L["Status"]</dt>
                    <dd>@Snapshot.Status</dd>
                }
            </dl>

            @if (quotaVisualization is not null)
            {
                <CloudShellQuotaChart UsedBytes="@quotaVisualization.UsedBytes"
                                      MaxSizeBytes="@quotaVisualization.MaxSizeBytes"
                                      UsedLabel="@L["Used"].Value"
                                      FreeLabel="@L["Unused"].Value"
                                      MaxSizeLabel="@L["Max size"].Value"
                                      WithinMaxSizeLabel="@L["Within max size"].Value"
                                      ExceededMaxSizeLabel="@L["Max size reached"].Value"
                                      AriaLabel="@L["Volume max-size utilization: {0} used of {1}.", FormatBytes(quotaVisualization.UsedBytes), FormatBytes(quotaVisualization.MaxSizeBytes)].Value" />
            }

            <SummaryMetricGrid AriaLabel="@L["Resource metrics"].Value">
                @foreach (var metric in Snapshot.Metrics)
                {
                    <SummaryMetricCard Title="@(metric.DisplayName ?? metric.Name)"
                                       Value="@FormatValue(metric)"
                                       Summary="@(metric.Description ?? metric.Name)"
                                       Compact="true" />
                }
            </SummaryMetricGrid>
        }
    </text>;

    private string GetStatusText()
    {
        if (Snapshot is null)
        {
            return L["Provider-observed resource metrics"].Value;
        }

        var updated = Snapshot.Timestamp.ToLocalTime().ToString("HH:mm:ss", CultureInfo.CurrentCulture);
        return string.IsNullOrWhiteSpace(Snapshot.Status)
            ? L["Updated {0}", updated].Value
            : L["{0} / updated {1}", Snapshot.Status, updated].Value;
    }

    private static string FormatValue(ResourceMetricSample metric) =>
        string.Equals(metric.Unit, "bytes", StringComparison.OrdinalIgnoreCase)
            ? FormatBytes(metric.Value)
            : string.Equals(metric.Unit, "%", StringComparison.Ordinal)
                ? $"{metric.Value.ToString("0.##", CultureInfo.InvariantCulture)}%"
                : $"{metric.Value.ToString("0.###", CultureInfo.InvariantCulture)} {metric.Unit}".TrimEnd();

    private static VolumeQuotaVisualization? BuildQuotaVisualization(ResourceMonitoringSnapshot snapshot)
    {
        var used = FindMetric(snapshot, "storage.volume.used");
        var maxSize = FindMetric(snapshot, "storage.volume.maxSize");
        if (used is null ||
            maxSize is null ||
            !IsByteMetric(used) ||
            !IsByteMetric(maxSize) ||
            maxSize.Value <= 0)
        {
            return null;
        }

        return new VolumeQuotaVisualization(used.Value, maxSize.Value);
    }

    private static ResourceMetricSample? FindMetric(ResourceMonitoringSnapshot snapshot, string name) =>
        snapshot.Metrics.FirstOrDefault(metric =>
            string.Equals(metric.Name, name, StringComparison.OrdinalIgnoreCase));

    private static bool IsByteMetric(ResourceMetricSample metric) =>
        string.Equals(metric.Unit, "bytes", StringComparison.OrdinalIgnoreCase);

    private static string FormatBytes(double value)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var unitIndex = 0;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return $"{value.ToString(unitIndex == 0 ? "0" : "0.##", CultureInfo.InvariantCulture)} {units[unitIndex]}";
    }

    private sealed record VolumeQuotaVisualization(
        double UsedBytes,
        double MaxSizeBytes);
}
