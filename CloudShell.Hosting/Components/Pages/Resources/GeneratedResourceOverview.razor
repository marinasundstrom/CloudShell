@using System.Globalization
@using System.Diagnostics.CodeAnalysis
@using CloudShell.Abstractions.Authorization
@using CloudShell.Abstractions.ResourceManager
@using CloudShell.Abstractions.ControlPlane
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Logging
@inject IResourceManager ResourceManager
@inject ILogManager LogManager
@inject IResourceHealthManager HealthManager
@inject ICloudShellAuthorizationService Authorization
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject ShellCatalog ShellCatalog
@inject ICoreShellRouteService ShellRoutes
@inject IStringLocalizer<SharedResource> L
@inject ILogger<GeneratedResourceOverview> Logger

    <div class="generated-resource-view">
        @if (!string.IsNullOrWhiteSpace(ProcedureMessage))
        {
            <ProcedureMessage Message="@ProcedureMessage" />
        }
    <ResourceProcedureSignals Signals="ProcedureSignals" />

    <GeneratedResourceViewLayout ResourceType="ResourceType"
                                 ResourceId="@Resource.Id"
                                 Resource="Resource"
                                 ViewId="@ResourcePredefinedViewIds.Overview"
                                 Sections="@BuildSections()" />
</div>

@code {
    [Parameter, EditorRequired]
    public Resource Resource { get; set; } = null!;

    [Parameter]
    public ResourceGroup? ResourceGroup { get; set; }

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    [Parameter]
    public EventCallback<Resource> ResourceUpdated { get; set; }

    private IReadOnlyList<Resource> ChildResources { get; set; } = [];
    private IReadOnlyList<Resource> DependentResources { get; set; } = [];
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private IReadOnlyList<LogSource> LogSources { get; set; } = [];
    private IReadOnlyList<NetworkEndpointMappingView> InboundNetworkMappings { get; set; } = [];
    private IReadOnlyList<LoadBalancerRouteView> InboundLoadBalancerRoutes { get; set; } = [];
    private IReadOnlyList<NameMappingView> InboundNameMappings { get; set; } = [];
    private IReadOnlyDictionary<string, Resource> RelatedResources { get; set; } =
        new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, IReadOnlyList<LogSource>> RelatedLogsByResourceId { get; set; } =
        new Dictionary<string, IReadOnlyList<LogSource>>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, ResourceHealthSummary> RelatedHealthByResourceId { get; set; } =
        new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, ResourceOperationCapabilities> RelatedCapabilitiesByResourceId { get; set; } =
        new Dictionary<string, ResourceOperationCapabilities>(StringComparer.OrdinalIgnoreCase);
    private ResourceOperationCapabilities Capabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private HashSet<string> ExecutingActionIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private string? ProcedureMessage { get; set; }
    private IReadOnlyList<ResourceProcedureSignal> ProcedureSignals { get; set; } = [];
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;

    private bool IsNetworkResource => Resource.ResourceClass == ResourceClass.Network ||
        Resource.HasCapability(ResourceCapabilityIds.NetworkingProvider);

    private bool IsLoadBalancerResource => HasLoadBalancerShape(Resource);

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        ChildResources = (await ResourceManager.ListResourceChildrenAsync(Resource.Id))
            .Where(DisplaySelection.ShowsResource)
            .ToArray();
        DependentResources = await LoadDependentResourcesAsync();
        LogSources = Authorization.CanReadLogs()
            ? await LogManager.ListLogSourcesAsync(new LogQuery(ResourceId: Resource.Id))
            : [];
        Capabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(Resource);
        InboundNetworkMappings = await LoadInboundNetworkMappingsAsync();
        InboundLoadBalancerRoutes = await LoadInboundLoadBalancerRoutesAsync();
        InboundNameMappings = await LoadInboundNameMappingsAsync();
        RelatedResources = await LoadRelatedResourcesAsync();
        RelatedLogsByResourceId = await LoadRelatedLogsAsync(RelatedResources.Keys);
        RelatedHealthByResourceId = await LoadRelatedHealthAsync(RelatedResources.Keys);
        RelatedCapabilitiesByResourceId = await LoadRelatedCapabilitiesAsync(RelatedResources.Keys);
    }

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections()
    {
        var sections = new List<GeneratedResourceViewSection>
        {
            new("essentials", L["Essentials"], 0, RenderEssentials())
        };

        if (ResourceNameMappingDisplay.IsNameMappingResource(Resource))
        {
            sections.Add(new("name-mapping", L["Name mapping"], 80, RenderNameMapping()));
        }

        if (HasRuntimeSection)
        {
            sections.Add(new("runtime", L["Runtime"], 100, RenderRuntime()));
        }

        if (GetOverviewDiagnostics() is { Count: > 0 } diagnostics)
        {
            sections.Add(new("diagnostics", L["Diagnostics"], 200, RenderDiagnostics(diagnostics)));
        }

        if (Resource.DependsOn.Count > 0 || ChildResources.Count > 0 || DependentResources.Count > 0)
        {
            sections.Add(new("relationships", L["Relationships"], 300, RenderRelationships()));
        }

        if (HasVisibleTelemetry)
        {
            sections.Add(new("observability", L["Telemetry"], 400, RenderTelemetry()));
        }

        return sections;
    }

    private bool HasRuntimeSection =>
        Resource.IdentityBinding is not null ||
        Resource.Endpoints.Count > 0 ||
        InboundNetworkMappings.Count > 0 ||
        InboundLoadBalancerRoutes.Count > 0 ||
        InboundNameMappings.Count > 0 ||
        IsNetworkResource ||
        IsLoadBalancerResource;

    private bool HasVisibleTelemetry =>
        LogSources.Count > 0 ||
        ResourcePredefinedViewVisibility.HasHealthView(Resource, ResourceType) ||
        Authorization.CanReadLogs() && Resource.EffectiveObservability.Logs ||
        Authorization.CanReadTraces() && Resource.EffectiveObservability.Traces ||
        Authorization.CanReadMetrics() && Resource.EffectiveObservability.Metrics;

    private IReadOnlyList<ResourceDiagnosticView> GetOverviewDiagnostics() =>
        ResourceActionReadinessDiagnostics.GetDiagnostics(Resource, Capabilities)
            .Concat(ResourceDiagnosticDisplay.GetDiagnostics(Resource, RelatedResources))
            .ToArray();

    private RenderFragment RenderEssentials() => @<dl class="detail-list">
        <dt>@L["Resource ID"]</dt>
        <dd>@Resource.Id</dd>
        <dt>@L["Name"]</dt>
        <dd>@DisplaySelection.GetResourceName(Resource)</dd>
        @if (DisplaySelection.ShouldShowDisplayName(Resource))
        {
            <dt>@L["Display name"]</dt>
            <dd>@Resource.DisplayName</dd>
        }
        <dt>@L["Type"]</dt>
        <dd>@Resource.EffectiveTypeId</dd>
        <dt>@L["Class"]</dt>
        <dd>@Resource.ResourceClass</dd>
        <dt>@L["Provider"]</dt>
        <dd>@Resource.Provider</dd>
        <dt>@L["Group"]</dt>
        <dd>@(ResourceGroup?.Name ?? L["Default group"])</dd>
        @if (TryFormatDeclarationPersistence(Resource, out var declarationPersistence))
        {
            <dt>@L["Declaration"]</dt>
            <dd>@declarationPersistence</dd>
        }
        @if (!string.IsNullOrWhiteSpace(Resource.ParentResourceId))
        {
            <dt>@L["Parent"]</dt>
            <dd>@ResourceLink(Resource.ParentResourceId)</dd>
        }
        @if (ResourceLifecycleDisplay.ShouldShowStatus(Resource))
        {
            <dt>@L["State"]</dt>
            <dd>
                <ResourceStateIndicator State="Resource.State" Variant="inline" />
            </dd>
        }
        <dt>@L["Version"]</dt>
        <dd>@Resource.Version</dd>
        <dt>@L["Updated"]</dt>
        <dd>@ResourceTimestampDisplay.FormatDateTime(Resource.LastUpdated)</dd>
    </dl>;

    private RenderFragment RenderNameMapping() => @<dl class="detail-list">
        <dt>@L["Host name"]</dt>
        <dd>@ResourceNameMappingDisplay.GetHostName(Resource)</dd>
        <dt>@L["Target"]</dt>
        <dd>@NameMappingTargetReference(Resource)</dd>
        @if (GetNameMappingEndpointAddress(Resource) is { } resolvedEndpoint)
        {
            <dt>@L["Resolved target endpoint"]</dt>
            <dd>
                <EndpointLink Address="@resolvedEndpoint" />
                <small class="muted">@L["Resolved from the target resource endpoint"]</small>
            </dd>
        }
        @if (!string.IsNullOrWhiteSpace(Resource.ParentResourceId))
        {
            <dt>@L["DNS zone"]</dt>
            <dd>@ResourceLink(Resource.ParentResourceId)</dd>
        }
        <dt>@L["Exposure"]</dt>
        <dd>@ResourceNameMappingDisplay.GetExposureLabel(Resource)</dd>
        <dt>@L["Provider"]</dt>
        <dd>@FormatNameMappingProvider(Resource)</dd>
        <dt>@L["Routing status"]</dt>
        <dd>@ResourceNameMappingDisplay.GetMaterializationLabel(Resource, Localize)</dd>
    </dl>;

    private RenderFragment RenderRuntime() => @<dl class="detail-list">
        @if (Resource.IdentityBinding is { } identity)
        {
            <dt>@L["Identity"]</dt>
            <dd>@FormatIdentitySummary(identity)</dd>
        }
        @if (Resource.Endpoints.Count > 0)
        {
            <dt>@L["Primary endpoint"]</dt>
            <dd><EndpointLink Address="@Resource.PrimaryEndpoint" EmptyText="@L["none"].Value" /></dd>
            <dt>@L["Endpoints"]</dt>
            <dd>
                <a class="resource-link" href="@BuildResourceTabRoute(Resource.Id, ResourcePredefinedViewIds.Endpoints)">
                    @L["{0} endpoint(s)", Resource.Endpoints.Count]
                </a>
            </dd>
        }
        @{
            var endpointMappings = GetOverviewEndpointMappings();
        }
        @if (endpointMappings.Count > 0)
        {
            <dt>@L["Endpoint mappings"]</dt>
            <dd>
                <div class="endpoint-list compact-endpoint-list">
                    @foreach (var mapping in endpointMappings)
                    {
                        <div>
                            <strong>@mapping.Name</strong>
                            <EndpointLink Address="@mapping.Address"
                                          Text="@mapping.Text"
                                          EmptyText="@L["none"].Value" />
                            <small>@mapping.Metadata</small>
                        </div>
                    }
                </div>
            </dd>
        }
        @if (InboundNetworkMappings.Count > 0 || InboundLoadBalancerRoutes.Count > 0)
        {
            <dt>@L["Exposure"]</dt>
            <dd>@FormatExposureSummary()</dd>
        }
        @if (InboundNameMappings.Count > 0)
        {
            <dt>@L["DNS"]</dt>
            <dd>
                <a class="resource-link" href="@BuildResourceTabRoute(Resource.Id, ResourcePredefinedViewIds.Dns)">
                    @FormatDnsSummary()
                </a>
            </dd>
        }
        @if (IsLoadBalancerResource)
        {
            <dt>@L["Load balancing"]</dt>
            <dd>@FormatLoadBalancerRouteCounts(Resource)</dd>
        }
        @if (IsNetworkResource && !IsLoadBalancerResource)
        {
            <dt>@L["Network readiness"]</dt>
            <dd>@FormatNetworkReadiness()</dd>
        }
    </dl>;

    private RenderFragment RenderDiagnostics(IReadOnlyList<ResourceDiagnosticView> diagnostics) =>
        @<ResourceDiagnosticList Diagnostics="@diagnostics" />;

    private RenderFragment RenderRelationships() => @<text>
        @if (Resource.DependsOn.Count > 0 || DependentResources.Count > 0)
        {
            <div class="generated-section-heading">
                <p>@L["Relationships include startup dependencies and typed resource references that affect service discovery, configuration, identity, storage, networking, and exposure."]</p>
            </div>
            <ResourceRelationshipGraph DependsOnTitle="@L["Depends on"].Value"
                                       DependsOn="@GetDependencyNodes()"
                                       EmptyDependsOnTitle="@L["None"].Value"
                                       EmptyDependsOnSummary="@L["No direct dependencies"].Value"
                                       CurrentCaption="@L["Current"].Value"
                                       CurrentLabel="@GetResourceLabel(Resource)"
                                       CurrentMetadata="@Resource.EffectiveTypeId"
                                       CurrentResource="Resource"
                                       UsedByTitle="@L["Used by"].Value"
                                       UsedBy="@GetDependentNodes()"
                                       EmptyUsedByTitle="@L["None"].Value"
                                       EmptyUsedBySummary="@L["No direct dependents"].Value" />
        }
        @if (ChildResources.Count > 0)
        {
            <dl class="detail-list">
                <dt>@L["Children"]</dt>
                <dd>
                    <div class="dependency-list">
                        @foreach (var child in ChildResources)
                        {
                            @ResourceLink(child)
                        }
                    </div>
                </dd>
            </dl>
        }
    </text>;

    private RenderFragment RenderTelemetry() => @<text>
        <dl class="detail-list">
            @if (ResourcePredefinedViewVisibility.HasHealthView(Resource, ResourceType))
            {
                <dt>@L["Health"]</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Resource.Id, ResourcePredefinedViewIds.Health)">
                        @FormatResourceHealthSummary()
                    </a>
                </dd>
            }
            @if (LogSources.Count > 0)
            {
                <dt>@L["Logs"]</dt>
                <dd>
                    <a class="resource-link" href="@BuildLogRoute(LogSources[0])">
                        @L["Open logs"]
                    </a>
                </dd>
            }
            <dt>@L["Signals"]</dt>
            <dd>@FormatTelemetrySummary()</dd>
        </dl>
        @if (Authorization.CanReadTraces() && Resource.EffectiveObservability.Traces)
        {
            <a class="resource-link" href="@BuildTraceRoute()">@L["Open traces"]</a>
        }
        @if (Authorization.CanReadMetrics() && Resource.EffectiveObservability.Metrics)
        {
            <a class="resource-link" href="@BuildMetricRoute()">@L["Open metrics"]</a>
        }
    </text>;

    private string FormatEnabled(bool enabled) => enabled ? L["Enabled"] : L["Disabled"];

    private string FormatIdentityName(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.Name)
            ? L["Default identity"].Value
            : identity.Name;

    private string FormatIdentityProvider(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.ProviderId)
            ? L["Default provider"].Value
            : identity.ProviderId;

    private string FormatIdentitySubject(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.Subject)
            ? L["Not assigned"].Value
            : identity.Subject;

    private string FormatIdentitySummary(ResourceIdentityBinding identity)
    {
        var name = FormatIdentityName(identity);
        return string.IsNullOrWhiteSpace(identity.Subject)
            ? L["{0} ({1})", name, FormatIdentityKind(identity.Kind)].Value
            : L["{0} ({1})", name, identity.Subject].Value;
    }

    private string FormatIdentityKind(ResourceIdentityBindingKind kind) =>
        kind switch
        {
            ResourceIdentityBindingKind.Provider => L["Provider-backed"].Value,
            ResourceIdentityBindingKind.Required => L["Required by resource"].Value,
            _ => L["Unknown"].Value
        };

    private bool TryFormatDeclarationPersistence(
        Resource resource,
        [NotNullWhen(true)] out string? persistence)
    {
        persistence = null;
        if (!resource.ResourceAttributes.TryGetValue(
                ResourceAttributeNames.DeclarationPersistence,
                out var value) ||
            !Enum.TryParse<ResourceDeclarationPersistence>(value, ignoreCase: true, out var parsed))
        {
            return false;
        }

        persistence = parsed == ResourceDeclarationPersistence.Persisted
            ? L["Persisted declaration"].Value
            : L["Startup declaration"].Value;
        return true;
    }

    private string FormatExposureSummary()
    {
        var parts = new List<string>();
        if (InboundNetworkMappings.Count > 0)
        {
            parts.Add(L["{0} network mapping(s)", InboundNetworkMappings.Count].Value);
        }

        if (InboundLoadBalancerRoutes.Count > 0)
        {
            parts.Add(L["{0} load-balancer route(s)", InboundLoadBalancerRoutes.Count].Value);
        }

        return string.Join(", ", parts);
    }

    private string FormatDnsSummary()
    {
        var firstHost = InboundNameMappings.Count == 0
            ? null
            : ResourceNameMappingDisplay.GetHostName(InboundNameMappings[0].Mapping);
        return InboundNameMappings.Count == 1 && !string.IsNullOrWhiteSpace(firstHost)
            ? firstHost
            : L["{0} name mapping(s)", InboundNameMappings.Count].Value;
    }

    private string FormatExposure(ResourceExposureScope exposure) =>
        exposure switch
        {
            ResourceExposureScope.Private => L["private"].Value,
            ResourceExposureScope.Local => L["local"].Value,
            ResourceExposureScope.Network => L["network"].Value,
            ResourceExposureScope.Public => L["public"].Value,
            _ => L["Unknown"].Value
        };

    private IReadOnlyList<EndpointMappingDisplay> GetOverviewEndpointMappings()
    {
        var mappings = new List<EndpointMappingDisplay>();
        foreach (var mapping in Resource.ResourceEndpointNetworkMappings
            .OrderBy(mapping => mapping.Target.EndpointName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(mapping => mapping.Name, StringComparer.OrdinalIgnoreCase))
        {
            mappings.Add(new EndpointMappingDisplay(
                mapping.Name,
                mapping.Address,
                null,
                L["{0} endpoint | {1}", mapping.Target.EndpointName, FormatExposure(mapping.Exposure)].Value));
        }

        foreach (var nameMapping in InboundNameMappings
            .Select(view => view.Mapping)
            .OrderBy(ResourceNameMappingDisplay.GetHostName, StringComparer.OrdinalIgnoreCase))
        {
            var address = GetNameMappingEndpointAddress(nameMapping);
            if (string.IsNullOrWhiteSpace(address))
            {
                continue;
            }

            mappings.Add(new EndpointMappingDisplay(
                ResourceNameMappingDisplay.GetHostName(nameMapping),
                address,
                ResourceNameMappingDisplay.GetHostName(nameMapping),
                L["{0} endpoint | {1} DNS name",
                    ResourceNameMappingDisplay.GetTargetEndpointName(nameMapping),
                    ResourceNameMappingDisplay.GetExposureLabel(nameMapping)].Value));
        }

        return mappings;
    }

    private string FormatTelemetrySummary()
    {
        var signals = new List<string>();
        if (Resource.EffectiveObservability.Logs)
        {
            signals.Add(L["logs"].Value);
        }

        if (Resource.EffectiveObservability.Traces)
        {
            signals.Add(L["traces"].Value);
        }

        if (Resource.EffectiveObservability.Metrics)
        {
            signals.Add(L["metrics"].Value);
        }

        return signals.Count == 0
            ? L["No telemetry signals"].Value
            : string.Join(", ", signals);
    }

    private string FormatResourceHealthSummary()
    {
        var checkCount = Resource.ResourceHealthChecks.Count;
        if (checkCount == 0 && ResourceType?.ResourceProbeOptions.SupportsHealthChecks == true)
        {
            return L["Health checks available"].Value;
        }

        if (RelatedHealthByResourceId.GetValueOrDefault(Resource.Id) is { } health)
        {
            var unhealthy = health.Checks.Count(check => check.Status == ResourceHealthStatus.Unhealthy);
            return unhealthy == 0
                ? L["{0} / {1} configured check(s)", health.Status, checkCount].Value
                : L["{0} / {1} unhealthy of {2} configured check(s)", health.Status, unhealthy, checkCount].Value;
        }

        return L["{0} configured check(s)", checkCount].Value;
    }

    private bool CanExecuteAction(ResourceAction action) =>
        !IsReadOnly && Capabilities.CanExecuteAction(action.Id);

    private bool IsExecutingAction(ResourceAction action) =>
        ExecutingActionIds.Contains(action.Id);

    private string GetActionButtonLabel(ResourceAction action)
    {
        if (IsExecutingAction(action))
        {
            return L["Working"].Value;
        }

        return action.Kind switch
        {
            ResourceActionKind.Start => L["Start"].Value,
            ResourceActionKind.Stop => L["Stop"].Value,
            ResourceActionKind.Pause => L["Pause"].Value,
            ResourceActionKind.Restart => L["Restart"].Value,
            _ => GetCustomActionCommandLabel(action)
        };
    }

    private static string GetCustomActionCommandLabel(ResourceAction action)
    {
        var words = action.DisplayName.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return words.Length == 0 ? action.Id : words[0];
    }

    private async Task ExecuteAction(ResourceAction action)
    {
        if (!CanExecuteAction(action) || IsExecutingAction(action))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
                ProcedureSignals = [];
            }

            return;
        }

        if (action.RequiresConfirmation)
        {
            var confirmed = await JS.InvokeAsync<bool>(
                "confirm",
                action.Description ??
                L["Start {0} for {1}?", action.DisplayName, GetResourceLabel(Resource)].Value);
            if (!confirmed)
            {
                return;
            }
        }

        ExecutingActionIds.Add(action.Id);
        ProcedureMessage = null;
        ProcedureSignals = [];
        try
        {
            var result = await ResourceManager.ExecuteResourceActionAsync(
                new ExecuteResourceActionCommand(
                    Resource.Id,
                    action.Id,
                    StartDependencies: ShouldStartDependencies(action),
                    IgnoreDependentWarning: true,
                    DependencyStartFailureBehavior: GetDependencyStartFailureBehavior()));
            ProcedureMessage = result.Message;
            ProcedureSignals = result.Signals;
            var resource = await ResourceManager.GetResourceAsync(Resource.Id);
            if (resource is not null)
            {
                await ResourceUpdated.InvokeAsync(resource);
                Capabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(resource);
            }
            else
            {
                Capabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(Resource);
            }
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = FormatOverviewActionFailure(exception);
            ProcedureSignals = [];
        }
        finally
        {
            ExecutingActionIds.Remove(action.Id);
        }
    }

    private string GetAttributeValue(string name, string fallback) =>
        Resource.ResourceAttributes.GetValueOrDefault(name) ?? fallback;

    private string FormatOverviewActionFailure(Exception exception)
    {
        Logger.LogWarning(
            exception,
            "Generated overview resource action failed for {ResourceId}",
            Resource.Id);

        return exception switch
        {
            HttpRequestException => L["CloudShell could not reach the Control Plane while running the resource action. Check connectivity and try again."].Value,
            _ => L["CloudShell could not run the resource action. Check the resource state and try again."].Value
        };
    }

    private static bool ShouldStartDependencies(ResourceAction action) =>
        action.Kind is ResourceActionKind.Start or ResourceActionKind.Restart;

    private DependencyStartFailureBehavior GetDependencyStartFailureBehavior() =>
        OrchestrationSettings.GetDependencyStartFailureSettings().Behavior;

    private string FormatNetworkReadiness()
    {
        var readiness = GetAttributeValue(ResourceAttributeNames.NetworkHostReadiness, "Unknown");
        return readiness switch
        {
            "logicalOnly" => L["Logical only"].Value,
            "providerRequired" when GetMissingMappingProviderIds().Length == 0 => L["Ready"].Value,
            "providerRequired" => L["Provider missing"].Value,
            "ready" => L["Ready"].Value,
            "unknown" => L["Unknown"].Value,
            _ => readiness
        };
    }

    private string[] GetMappingProviderIds() =>
        Resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkMappingProviders, out var providers)
            ? providers
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray()
            : [];

    private string[] GetMissingMappingProviderIds() =>
        GetMappingProviderIds()
            .Where(providerId => !RelatedResources.ContainsKey(providerId) &&
                !string.Equals(Resource.Id, providerId, StringComparison.OrdinalIgnoreCase))
            .ToArray();

    private async Task<IReadOnlyList<NetworkEndpointMappingView>> LoadInboundNetworkMappingsAsync()
    {
        var networks = await ResourceManager.ListResourcesAsync(
            new ResourceQuery(ResourceClass: ResourceClass.Network));
        return networks
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    Resource.Id,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => GetResourceLabel(mapping.Network), StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private async Task<IReadOnlyList<LoadBalancerRouteView>> LoadInboundLoadBalancerRoutesAsync()
    {
        var networks = await ResourceManager.ListResourcesAsync(
            new ResourceQuery(ResourceClass: ResourceClass.Network));
        return networks
            .Where(loadBalancer => !string.Equals(loadBalancer.Id, Resource.Id, StringComparison.OrdinalIgnoreCase))
            .Where(HasLoadBalancerShape)
            .SelectMany(loadBalancer => loadBalancer.ResourceLoadBalancerRoutes
                .Where(route => string.Equals(
                    route.Target.ResourceId,
                    Resource.Id,
                    StringComparison.OrdinalIgnoreCase))
                .Select(route => new LoadBalancerRouteView(loadBalancer, route)))
            .OrderBy(route => GetResourceLabel(route.LoadBalancer), StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Route.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private async Task<IReadOnlyList<NameMappingView>> LoadInboundNameMappingsAsync()
    {
        var mappings = await ResourceManager.ListResourcesAsync(
            new ResourceQuery(ResourceType: "cloudshell.nameMapping"));
        return mappings
            .Where(mapping => ResourceNameMappingDisplay.TargetsResource(mapping, Resource.Id))
            .Select(mapping => new NameMappingView(mapping))
            .OrderBy(mapping => ResourceNameMappingDisplay.GetHostName(mapping.Mapping), StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private RenderFragment EndpointReference(
        ResourceEndpointReference reference,
        Resource? fallbackResource = null) => builder =>
    {
        var resource = FindMappingResource(reference.ResourceId, fallbackResource);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        builder.OpenElement(0, "span");
        builder.OpenElement(1, "span");
        builder.AddContent(2, resource is null ? GetFallbackResourceLabel(reference.ResourceId) : GetResourceLabel(resource));
        builder.CloseElement();
        builder.AddContent(3, " / ");
        builder.OpenElement(4, "strong");
        builder.AddContent(5, reference.EndpointName);
        builder.CloseElement();
        if (endpoint is not null)
        {
            builder.AddContent(6, " ");
            builder.OpenElement(7, "small");
            builder.AddContent(8, FormatEndpointSummary(endpoint));
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string FormatEndpointSummary(ResourceEndpoint endpoint)
    {
        var protocol = string.IsNullOrWhiteSpace(endpoint.Protocol)
            ? L["Unspecified"].Value
            : endpoint.Protocol;
        return endpoint.TargetPort is null
            ? protocol
            : L["{0}:{1}", protocol, endpoint.TargetPort.Value.ToString(CultureInfo.InvariantCulture)].Value;
    }

    private string MappingProviderLabel(ResourceEndpointMappingDefinition mapping)
    {
        var providerId = GetMappingProviderId(mapping);
        if (string.IsNullOrWhiteSpace(providerId))
        {
            return L["Provider: network"].Value;
        }

        var provider = FindRelatedResource(providerId);
        return provider is null
            ? L["Provider: {0}", GetFallbackResourceLabel(providerId)].Value
            : L["Provider: {0}", GetResourceLabel(provider)].Value;
    }

    private string? GetMappingProviderId(ResourceEndpointMappingDefinition mapping) =>
        FirstNonEmpty(mapping.ProviderResourceId, mapping.NetworkResourceId, mapping.Source.ResourceId);

    private Resource? FindMappingResource(string resourceId, Resource? fallbackResource = null)
    {
        if (fallbackResource is not null &&
            string.Equals(fallbackResource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return fallbackResource;
        }

        return FindRelatedResource(resourceId);
    }

    private RenderFragment ResourceLink(string resourceId)
    {
        var resource = FindRelatedResource(resourceId);
        var label = resource is null ? GetFallbackResourceLabel(resourceId) : GetResourceLabel(resource);
        return @<ResourcePillLink Label="@label"
                                  Href="@BuildResourceRoute(resourceId)"
                                  Resource="@resource"
                                  Metadata="@resource?.EffectiveTypeId" />;
    }

    private RenderFragment ResourceLink(Resource resource) =>
        @<ResourcePillLink Label="@GetResourceLabel(resource)"
                           Href="@BuildResourceRoute(resource.Id)"
                           Resource="@resource"
                           Metadata="@resource.EffectiveTypeId" />;

    private Resource? FindRelatedResource(string resourceId)
    {
        if (string.Equals(Resource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return Resource;
        }

        return RelatedResources.GetValueOrDefault(resourceId);
    }

    private string GetResourceLabel(Resource resource) => DisplaySelection.GetResourceLabel(resource);

    private static string GetFallbackResourceLabel(string resourceId) =>
        ResourceDisplayLabels.GetName(resourceId);

    private IReadOnlyList<ResourceRelationshipNode> GetDependencyNodes() =>
        Resource.DependsOn
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(GetRelationshipResourceLabel, StringComparer.OrdinalIgnoreCase)
            .Select(dependencyId =>
            {
                var dependency = FindRelatedResource(dependencyId);
                return new ResourceRelationshipNode(
                    dependency is null ? GetFallbackResourceLabel(dependencyId) : GetResourceLabel(dependency),
                    dependency is null ? null : BuildResourceRoute(dependency.Id),
                    FormatRelationshipSummary(dependency, dependencyId),
                    FormatRelationshipMetadata(dependency),
                    dependency is null,
                    dependency is null ? null : GetRelationshipActions(dependency),
                    Resource: dependency);
            })
            .ToArray();

    private string GetRelationshipResourceLabel(string resourceId) =>
        FindRelatedResource(resourceId) is { } resource
            ? GetResourceLabel(resource)
            : GetFallbackResourceLabel(resourceId);

    private IReadOnlyList<ResourceRelationshipNode> GetDependentNodes() =>
        DependentResources
            .Select(dependent =>
                new ResourceRelationshipNode(
                    GetResourceLabel(dependent),
                    BuildResourceRoute(dependent.Id),
                    FormatRelationshipSummary(dependent, dependent.Id),
                    FormatRelationshipMetadata(dependent),
                    Actions: GetRelationshipActions(dependent),
                    Resource: dependent))
            .ToArray();

    private string FormatRelationshipSummary(Resource? resource, string resourceId)
    {
        if (resource is null)
        {
            return L["{0} is unavailable.", GetFallbackResourceLabel(resourceId)].Value;
        }

        var parts = new List<string>
        {
            L[ResourceRelationshipRoles.GetRole(resource)].Value
        };

        if (resource.State is not null)
        {
            parts.Add(L["State: {0}", resource.State].Value);
        }

        if (RelatedHealthByResourceId.GetValueOrDefault(resource.Id) is { } health)
        {
            parts.Add(L["Health: {0}", health.Status].Value);
        }

        if (GetRelationshipReadinessDiagnostic(resource) is { } readiness)
        {
            parts.Add(readiness);
        }

        return string.Join(" · ", parts);
    }

    private string FormatRelationshipMetadata(Resource? resource) =>
        resource is null
            ? L["Missing resource"].Value
            : resource.EffectiveTypeId;

    private async Task<IReadOnlyList<Resource>> LoadDependentResourcesAsync() =>
        (await ResourceManager.ListResourcesAsync())
            .Where(DisplaySelection.ShowsResource)
            .Where(candidate =>
                !string.Equals(candidate.Id, Resource.Id, StringComparison.OrdinalIgnoreCase) &&
                candidate.DependsOn.Contains(Resource.Id, StringComparer.OrdinalIgnoreCase))
            .OrderBy(DisplaySelection.GetResourceLabel, StringComparer.OrdinalIgnoreCase)
            .ThenBy(candidate => candidate.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private async Task<IReadOnlyDictionary<string, Resource>> LoadRelatedResourcesAsync()
    {
        var ids = Resource.DependsOn
            .Concat(ChildResources.Select(resource => resource.Id))
            .Concat(DependentResources.Select(resource => resource.Id))
            .Concat(InboundNetworkMappings.Select(mapping => mapping.Network.Id))
            .Concat(InboundLoadBalancerRoutes.Select(route => route.LoadBalancer.Id))
            .Concat(InboundNameMappings.Select(mapping => mapping.Mapping.Id))
            .Concat(InboundNameMappings.Select(mapping => mapping.Mapping.ParentResourceId))
            .Concat(InboundNameMappings.Select(mapping => ResourceNameMappingDisplay.GetProviderResourceId(mapping.Mapping)))
            .Concat(GetNameMappingRelatedResourceIds(Resource))
            .Concat(Resource.ResourceEndpointMappings.SelectMany(GetMappingResourceIds))
            .Concat(InboundNetworkMappings.SelectMany(mapping => GetMappingResourceIds(mapping.Mapping)))
            .Concat(Resource.ResourceLoadBalancerRoutes.Select(route => route.Target.ResourceId))
            .Concat(InboundLoadBalancerRoutes.Select(route => route.Route.Target.ResourceId))
            .Concat(GetMappingProviderIds())
            .Append(GetLoadBalancerHostResourceId(Resource))
            .Append(Resource.ParentResourceId)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Select(id => id!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var resources = new Dictionary<string, Resource>(StringComparer.OrdinalIgnoreCase);
        foreach (var id in ids)
        {
            var resource = ChildResources.FirstOrDefault(child =>
                string.Equals(child.Id, id, StringComparison.OrdinalIgnoreCase)) ??
                await ResourceManager.GetResourceAsync(id);
            if (resource is not null)
            {
                resources[resource.Id] = resource;
            }
        }

        return resources;
    }

    private async Task<IReadOnlyDictionary<string, IReadOnlyList<LogSource>>> LoadRelatedLogsAsync(
        IEnumerable<string> resourceIds)
    {
        if (!Authorization.CanReadLogs())
        {
            return new Dictionary<string, IReadOnlyList<LogSource>>(StringComparer.OrdinalIgnoreCase);
        }

        var requested = resourceIds
            .Append(Resource.Id)
            .Where(resourceId => !string.IsNullOrWhiteSpace(resourceId))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (requested.Count == 0)
        {
            return new Dictionary<string, IReadOnlyList<LogSource>>(StringComparer.OrdinalIgnoreCase);
        }

        var logs = await LogManager.ListLogSourcesAsync();
        return logs
            .Where(log => !string.IsNullOrWhiteSpace(log.ResourceId) && requested.Contains(log.ResourceId))
            .GroupBy(log => log.ResourceId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => (IReadOnlyList<LogSource>)group
                    .OrderBy(log => log.Name, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(log => log.Id, StringComparer.OrdinalIgnoreCase)
                    .ToArray(),
                StringComparer.OrdinalIgnoreCase);
    }

    private async Task<IReadOnlyDictionary<string, ResourceHealthSummary>> LoadRelatedHealthAsync(
        IEnumerable<string> resourceIds)
    {
        var requested = resourceIds
            .Append(Resource.Id)
            .Where(resourceId => !string.IsNullOrWhiteSpace(resourceId))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (requested.Count == 0)
        {
            return new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase);
        }

        var health = await HealthManager.ListResourceHealthAsync();
        return health
            .Where(item => requested.Contains(item.Key))
            .ToDictionary(item => item.Key, item => item.Value, StringComparer.OrdinalIgnoreCase);
    }

    private async Task<IReadOnlyDictionary<string, ResourceOperationCapabilities>> LoadRelatedCapabilitiesAsync(
        IEnumerable<string> resourceIds)
    {
        var requested = resourceIds
            .Append(Resource.Id)
            .Where(resourceId => !string.IsNullOrWhiteSpace(resourceId))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        return requested.Length == 0
            ? new Dictionary<string, ResourceOperationCapabilities>(StringComparer.OrdinalIgnoreCase)
            : await ResourceManager.GetResourceOperationCapabilitiesAsync(requested);
    }

    private string? GetRelationshipReadinessDiagnostic(Resource resource)
    {
        if (!RelatedCapabilitiesByResourceId.TryGetValue(resource.Id, out var capabilities))
        {
            return null;
        }

        var diagnostic = ResourceActionReadinessDiagnostics.GetDiagnostics(resource, capabilities).FirstOrDefault();
        return diagnostic is null
            ? null
            : diagnostic.Message;
    }

    private IReadOnlyList<ResourceRelationshipNodeAction> GetRelationshipActions(Resource resource)
    {
        var actions = new List<ResourceRelationshipNodeAction>
        {
            new(L["Open"].Value, BuildResourceRoute(resource.Id)),
            new(L["Activity"].Value, BuildActivityRoute(resource.Id))
        };

        if (ResourcePredefinedViewVisibility.HasHealthView(resource, FindResourceType(resource)))
        {
            actions.Add(new ResourceRelationshipNodeAction(L["Health"].Value, BuildResourceTabRoute(resource.Id, ResourcePredefinedViewIds.Health)));
        }

        if (RelatedLogsByResourceId.GetValueOrDefault(resource.Id) is { Count: > 0 } logs)
        {
            actions.Add(new ResourceRelationshipNodeAction(L["Logs"].Value, BuildLogRoute(resource.Id, logs)));
        }

        if (Authorization.CanReadTraces() && resource.EffectiveObservability.Traces)
        {
            actions.Add(new ResourceRelationshipNodeAction(L["Traces"].Value, BuildTraceRoute(resource.Id)));
        }

        return actions;
    }

    private IEnumerable<string?> GetMappingResourceIds(ResourceEndpointMappingDefinition mapping)
    {
        yield return mapping.Source.ResourceId;
        yield return mapping.Target.ResourceId;
        yield return mapping.NetworkResourceId;
        yield return mapping.ProviderResourceId;
    }

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private string FormatLoadBalancerRouteMatch(LoadBalancerRoute route)
    {
        if (route.Kind == LoadBalancerRouteKind.Tcp)
        {
            return L["TCP {0}", route.Match.Port?.ToString() ?? route.EntrypointName].Value;
        }

        var host = string.IsNullOrWhiteSpace(route.Match.Host)
            ? L["any host"].Value
            : route.Match.Host;
        return string.IsNullOrWhiteSpace(route.Match.PathPrefix)
            ? host
            : $"{host}{route.Match.PathPrefix}";
    }

    private string FormatLoadBalancerRouteTarget(LoadBalancerRouteTarget target)
    {
        var resource = FindRelatedResource(target.ResourceId);
        var label = resource is null ? GetFallbackResourceLabel(target.ResourceId) : GetResourceLabel(resource);
        if (!string.IsNullOrWhiteSpace(target.EndpointName))
        {
            return $"{label}/{target.EndpointName}";
        }

        return target.Port is null
            ? label
            : $"{label}:{target.Port.Value}";
    }

    private string FormatNameMappingSummary(Resource mapping) =>
        L["{0} -> {1}/{2}",
            ResourceNameMappingDisplay.GetHostName(mapping),
            GetResourceLabel(Resource),
            ResourceNameMappingDisplay.GetTargetEndpointName(mapping)].Value;

    private string? GetNameMappingEndpointAddress(Resource mapping) =>
        ResourceNameMappingDisplay.GetMappedEndpointAddress(
            mapping,
            FindRelatedResource(ResourceNameMappingDisplay.GetTargetResourceId(mapping)));

    private RenderFragment NameMappingTargetReference(Resource mapping)
    {
        var targetResourceId = ResourceNameMappingDisplay.GetTargetResourceId(mapping);
        var endpointName = ResourceNameMappingDisplay.GetTargetEndpointName(mapping);

        return @<span class="inline-resource-reference">
            @if (string.IsNullOrWhiteSpace(targetResourceId))
            {
                <span class="muted">@L["none"]</span>
            }
            else
            {
                @ResourceLink(targetResourceId)
                <span class="muted">/ @endpointName</span>
            }
        </span>;
    }

    private string FormatNameMappingMetadata(NameMappingView view)
    {
        var parts = new List<string>
        {
            L["Exposure: {0}", ResourceNameMappingDisplay.GetExposureLabel(view.Mapping)].Value,
            FormatNameMappingProvider(view.Mapping),
            L["Routing status: {0}", ResourceNameMappingDisplay.GetMaterializationLabel(view.Mapping, Localize)].Value
        };

        var zone = string.IsNullOrWhiteSpace(view.Mapping.ParentResourceId)
            ? null
            : FindRelatedResource(view.Mapping.ParentResourceId);
        if (zone is not null)
        {
            parts.Insert(0, L["Zone: {0}", GetResourceLabel(zone)].Value);
        }

        parts.AddRange(ResourceNameMappingDisplay.GetLocalHostNamePublishingMetadata(view.Mapping, Localize));

        return string.Join(" | ", parts);
    }

    private string FormatNameMappingProvider(Resource mapping)
    {
        var providerResourceId = ResourceNameMappingDisplay.GetProviderResourceId(mapping);
        if (!string.IsNullOrWhiteSpace(providerResourceId))
        {
            var provider = FindRelatedResource(providerResourceId);
            return provider is null
                ? L["Provider: {0}", GetFallbackResourceLabel(providerResourceId)].Value
                : L["Provider: {0}", GetResourceLabel(provider)].Value;
        }

        return L["Provider: {0}", GetAttributeValue(mapping, ResourceAttributeNames.DnsProvider, "logical")].Value;
    }

    private static string GetAttributeValue(Resource resource, string name, string fallback) =>
        resource.ResourceAttributes.TryGetValue(name, out var value) &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static IEnumerable<string?> GetNameMappingRelatedResourceIds(Resource resource)
    {
        if (!ResourceNameMappingDisplay.IsNameMappingResource(resource))
        {
            yield break;
        }

        yield return ResourceNameMappingDisplay.GetTargetResourceId(resource);
        yield return resource.ParentResourceId;
        yield return ResourceNameMappingDisplay.GetProviderResourceId(resource);
    }

    private static bool HasLoadBalancerShape(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.NetworkingLoadBalancer) ||
        resource.ResourceLoadBalancerRoutes.Count > 0 ||
        resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.LoadBalancerProvider);

    private static string? GetLoadBalancerHostResourceId(Resource resource)
    {
        var hostResourceId = resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.LoadBalancerHostResourceId);
        return string.IsNullOrWhiteSpace(hostResourceId) ||
            string.Equals(hostResourceId, "default", StringComparison.OrdinalIgnoreCase)
                ? null
                : hostResourceId;
    }

    private string FormatLoadBalancerRouteCounts(Resource resource)
    {
        var routeCount = GetAttributeValue(
            ResourceAttributeNames.LoadBalancerRouteCount,
            resource.ResourceLoadBalancerRoutes.Count.ToString(CultureInfo.InvariantCulture));
        var httpCount = GetAttributeValue(ResourceAttributeNames.LoadBalancerHttpRouteCount, "0");
        var tcpCount = GetAttributeValue(ResourceAttributeNames.LoadBalancerTcpRouteCount, "0");
        return L["{0} total ({1} HTTP, {2} TCP)", routeCount, httpCount, tcpCount].Value;
    }

    private string BuildResourceRoute(string resourceId) =>
        ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId);

    private string BuildResourceTabRoute(string resourceId, ResourceViewId tabId) =>
        ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId, tabId);

    private ResourceTypeContribution? FindResourceType(Resource resource) =>
        this.ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase));

    private string BuildLogRoute(LogSource log)
    {
        var query = new Dictionary<string, string?>
        {
            ["logSourceId"] = log.Id
        };

        return QueryHelpers.AddQueryString(
            BuildResourceTabRoute(Resource.Id, ResourcePredefinedViewIds.Logs),
            query);
    }

    private string BuildLogRoute(string resourceId, IReadOnlyList<LogSource> logs)
    {
        var query = new Dictionary<string, string?>();

        if (logs.Count == 1)
        {
            query["logSourceId"] = logs[0].Id;
        }

        return QueryHelpers.AddQueryString(
            BuildResourceTabRoute(resourceId, ResourcePredefinedViewIds.Logs),
            query);
    }

    private string BuildTraceRoute() =>
        BuildTraceRoute(Resource.Id);

    private string BuildTraceRoute(string resourceId) =>
        BuildResourceTabRoute(resourceId, ResourcePredefinedViewIds.Traces);

    private string BuildActivityRoute(string resourceId) =>
        BuildResourceTabRoute(resourceId, ResourcePredefinedViewIds.Activity);

    private string BuildMetricRoute() =>
        BuildResourceTabRoute(Resource.Id, ResourcePredefinedViewIds.Metrics);

    private async Task CopyEndpoint(string address)
    {
        if (!string.IsNullOrWhiteSpace(address))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", address);
        }
    }

    private void OpenEndpoint(string address) =>
        Navigation.NavigateTo(address, forceLoad: true);

    private string FormatHealthCheckDetails(ResourceHealthCheck healthCheck)
    {
        var endpoint = healthCheck.EndpointName ?? L["default endpoint"].Value;
        return healthCheck.Timeout is null
            ? L["{0} on {1}", healthCheck.Type, endpoint].Value
            : L["{0} on {1}, timeout {2}s", healthCheck.Type, endpoint, healthCheck.Timeout.Value.TotalSeconds].Value;
    }

    private string Localize(string value) => L[value].Value;

    private sealed record NetworkEndpointMappingView(
        Resource Network,
        ResourceEndpointMappingDefinition Mapping);

    private sealed record LoadBalancerRouteView(
        Resource LoadBalancer,
        LoadBalancerRoute Route);

    private sealed record NameMappingView(Resource Mapping);

    private sealed record EndpointMappingDisplay(
        string Name,
        string? Address,
        string? Text,
        string Metadata);

}
