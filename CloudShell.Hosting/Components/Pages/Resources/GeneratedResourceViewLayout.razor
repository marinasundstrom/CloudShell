@using CloudShell.Abstractions.ResourceManager

@foreach (var section in OrderedSections)
{
    <section class="generated-section">
        @if (!string.IsNullOrWhiteSpace(section.Title))
        {
            <h3>@section.Title</h3>
        }
        @section.Content
    </section>
}

@code {
    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    [Parameter, EditorRequired]
    public string ResourceId { get; set; } = string.Empty;

    [Parameter]
    public Resource? Resource { get; set; }

    [Parameter, EditorRequired]
    public ResourceViewId ViewId { get; set; }

    [Parameter]
    public IReadOnlyList<GeneratedResourceViewSection> Sections { get; set; } = [];

    private IReadOnlyList<GeneratedResourceViewSection> OrderedSections =>
        Sections
            .Concat(GetProviderSections())
            .OrderBy(section => section.Order)
            .ThenBy(section => section.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IEnumerable<GeneratedResourceViewSection> GetProviderSections()
    {
        if (ResourceType is null)
        {
            yield break;
        }

        foreach (var section in ResourceType.ResourcePredefinedViewSections
            .Where(section => section.ViewId == ViewId))
        {
            yield return new GeneratedResourceViewSection(
                section.Id,
                section.Title,
                section.Order,
                builder =>
                {
                    builder.OpenComponent<DynamicComponent>(0);
                    builder.AddAttribute(1, nameof(DynamicComponent.Type), section.ComponentType);
                    builder.AddAttribute(2, nameof(DynamicComponent.Parameters), BuildParameters(section));
                    builder.CloseComponent();
                });
        }
    }

    private Dictionary<string, object?> BuildParameters(ResourcePredefinedViewSectionContribution section)
    {
        var parameters = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
        AddParameterIfSupported(section, parameters, "ResourceId", ResourceId);
        AddParameterIfSupported(section, parameters, "ViewId", ViewId.Value);
        AddParameterIfSupported(section, parameters, "SectionId", section.Id);

        if (Resource is not null && section.ComponentType.GetProperty(nameof(Resource)) is not null)
        {
            parameters[nameof(Resource)] = Resource;
        }

        return parameters;
    }

    private static void AddParameterIfSupported(
        ResourcePredefinedViewSectionContribution section,
        Dictionary<string, object?> parameters,
        string name,
        object? value)
    {
        if (section.ComponentType.GetProperty(name) is not null)
        {
            parameters[name] = value;
        }
    }
}
