@page "/health"
@rendermode InteractiveServer
@implements IDisposable
@inject IResourceManager ResourceManager
@inject IResourceHealthManager HealthChecks
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject IStringLocalizer<SharedResource> L
@inject CoreShell.Composition.CompositionRegistry Composition

<PageTitle>@L["Health"]</PageTitle>

<PageHeading Eyebrow="@L["Workspace"].Value"
             Title="@L["Health"].Value"
             Description="@L["Review configured resource health checks and their latest probe results across the environment."].Value">
    <Actions>
        <span class="toolbar-meta">@GetHealthCheckIntervalLabel()</span>
        @if (GetSettingsRoute() is { } settingsRoute)
        {
            <FluentAnchor Appearance="Appearance.Neutral"
                          IconStart="@(new Icons.Regular.Size20.Settings())"
                          Href="@settingsRoute">
                @L["Health settings"]
            </FluentAnchor>
        }
        <FluentButton Appearance="Appearance.Neutral"
                      Disabled="@IsCheckingHealth"
                      IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      OnClick="RefreshHealthAsync">
            @(IsCheckingHealth ? L["Checking"] : L["Refresh"])
        </FluentButton>
    </Actions>
</PageHeading>

<SummaryMetricGrid AriaLabel="@L["Health summary"].Value">
    <SummaryMetricCard Title="@L["Resources with checks"].Value"
                       Value="@ResourcesWithHealthChecks.Count"
                       Summary="@L["{0} assessed check(s)", TotalConfiguredChecks].Value"
                       IconName="health-checks" />
    <SummaryMetricCard Title="@L["Healthy"].Value"
                       Value="@HealthyResourceCount"
                       Summary="@L["Latest probe status"].Value"
                       IconName="healthy" />
    <SummaryMetricCard Title="@L["Unhealthy"].Value"
                       Value="@UnhealthyResourceCount"
                       Summary="@L["Resources with failing checks"].Value"
                       IconName="unhealthy"
                       Warning="@(UnhealthyResourceCount > 0)" />
    <SummaryMetricCard Title="@L["Unknown"].Value"
                       Value="@UnknownResourceCount"
                       Summary="@L["Missing endpoint or inconclusive result"].Value"
                       IconName="unknown" />
</SummaryMetricGrid>

<section class="dashboard-grid">
    <ShellPanel Wide="true">
        <ShellPanelHeader Title="@L["Health checks"].Value"
                          Description="@L["Configured probes resolved from resource endpoint mappings."].Value">
            <Actions>
                <span class="toolbar-meta">@GetCheckedAtLabel()</span>
            </Actions>
        </ShellPanelHeader>

        @if (ResourcesWithHealthChecks.Count == 0)
        {
            <EmptyState Title="@L["No health checks configured"].Value"
                        Message="@L["Resources can opt into health checks through their resource configuration or provider probe options."].Value"
                        Compact="true" />
        }
        else
        {
            <ResourceTable>
                    <thead>
                        <tr>
                            <th>@L["Resource"]</th>
                            <th>@L["Check"]</th>
                            <th>@L["Endpoint"]</th>
                            <th>@L["Result"]</th>
                            <th>@L["Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var resource in HealthResourceRows)
                        {
                            var rows = GetHealthCheckRows(resource.Resource);
                            for (var index = 0; index < rows.Count; index++)
                            {
                                var row = rows[index];
                                <tr class="@(resource.Depth > 0 ? "contained-health-row" : null)">
                                    @if (index == 0)
                                    {
                                        <td rowspan="@rows.Count">
                                            <ResourceTableIdentity IconName="@resource.Resource.EffectiveTypeId"
                                                                   IconTitle="@resource.Resource.Kind"
                                                                   Summary="@GetResourceSummary(resource)">
                                                <TitleContent>
                                                    <span class="health-resource-title" style="@GetResourceTitleIndent(resource.Depth)">
                                                        @if (resource.Children.Count > 0)
                                                        {
                                                            <FluentButton Appearance="Appearance.Stealth"
                                                                          Title="@GetContainmentToggleLabel(resource)"
                                                                          AriaLabel="@GetContainmentToggleLabel(resource)"
                                                                          IconStart="@GetContainmentToggleIcon(resource)"
                                                                          OnClick="@(() => ToggleContainedResources(resource.Resource.Id))" />
                                                        }
                                                        <a class="resource-link" href="@BuildResourceRoute(resource.Resource.Id)">
                                                            @resource.Resource.EffectiveDisplayName
                                                        </a>
                                                    </span>
                                                    @if (resource.Children.Count > 0)
                                                    {
                                                        <span class="contained-health-summary">@GetContainedResourceSummary(resource.Children.Count)</span>
                                                    }
                                                </TitleContent>
                                            </ResourceTableIdentity>
                                        </td>
                                    }
                                    <td>
                                        <strong>@row.Check.Name</strong>
                                        <span>@row.Check.Type</span>
                                    </td>
                                    <td>
                                        <strong>@FormatEndpoint(row.Check)</strong>
                                        <span>@FormatPath(row.Check)</span>
                                    </td>
                                    <td>
                                        <strong>@(row.Result?.Detail ?? GetPendingDetail())</strong>
                                        <span>@(row.Result?.Uri?.ToString() ?? L["No resolved URI"].Value)</span>
                                    </td>
                                    <td>
                                        <HealthPill Status="row.Result?.Status" Label="@GetHealthLabel(row.Result?.Status)" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
            </ResourceTable>

            <div class="health-history-grid" aria-label="@L["Recent health polling history"]">
                @foreach (var resource in HealthResourceRows)
                {
                    <div class="health-history-resource @(resource.Depth > 0 ? "contained" : null)">
                        <a class="resource-link" href="@BuildResourceRoute(resource.Resource.Id)">
                            <strong>@resource.Resource.EffectiveDisplayName</strong>
                        </a>
                        <ResourceHealthHistoryChart Compact="true"
                                                    Checks="GetChartChecks(resource.Resource)"
                                                    Snapshots="GetHealthSnapshots(resource.Resource)"
                                                    Title="@L["Recent polling"].Value" />
                    </div>
                }
            </div>
        }
    </ShellPanel>

    <ShellPanel>
        <ShellPanelHeader Title="@L["Resources"].Value"
                          Description="@L["Latest aggregate health by resource."].Value" />

        @if (ResourcesWithHealthChecks.Count == 0)
        {
            <EmptyState Title="@L["Nothing to check"].Value"
                        Message="@L["No projected resources currently advertise health checks."].Value"
                        Compact="true" />
        }
        else
        {
            <ShellActivityList>
                @foreach (var resource in HealthResourceRows)
                {
                    var summary = GetHealthSummary(resource.Resource);
                    <ShellActivityLink Href="@BuildResourceRoute(resource.Resource.Id)"
                                       Title="@resource.Resource.EffectiveDisplayName"
                                       Summary="@GetActivitySummary(resource)">
                        <Leading>
                            <ResourceKindIcon Resource="@resource.Resource" />
                        </Leading>
                        <Trailing>
                            <HealthPill Status="summary?.Status" Label="@GetHealthLabel(summary?.Status)" />
                        </Trailing>
                    </ShellActivityLink>
                }
            </ShellActivityList>
        }
    </ShellPanel>
</section>

@code {
    private IReadOnlyList<Resource> Resources { get; set; } = [];

    private IReadOnlyDictionary<string, ResourceHealthSummary> HealthResults { get; set; } =
        new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase);

    private IReadOnlyDictionary<string, IReadOnlyList<ResourceHealthSummary>> HealthSnapshotsByResourceId { get; set; } =
        new Dictionary<string, IReadOnlyList<ResourceHealthSummary>>(StringComparer.OrdinalIgnoreCase);

    private HashSet<string> ExpandedContainedResourceIds { get; } =
        new(StringComparer.OrdinalIgnoreCase);

    private bool IsCheckingHealth { get; set; }

    private CancellationTokenSource? PollingCancellation { get; set; }

    private IReadOnlyList<Resource> ResourcesWithHealthChecks =>
        Resources
            .Where(HasHealthAssessment)
            .OrderBy(resource => GetHealthRank(GetHealthSummary(resource)?.Status))
            .ThenBy(resource => resource.EffectiveDisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<HealthResourceRow> HealthResourceRows => BuildHealthResourceRows();

    private int TotalConfiguredChecks =>
        ResourcesWithHealthChecks.Sum(GetHealthCheckCount);

    private int HealthyResourceCount =>
        ResourcesWithHealthChecks.Count(resource => GetHealthSummary(resource)?.Status == ResourceHealthStatus.Healthy);

    private int UnhealthyResourceCount =>
        ResourcesWithHealthChecks.Count(resource => GetHealthSummary(resource)?.Status == ResourceHealthStatus.Unhealthy);

    private int UnknownResourceCount =>
        ResourcesWithHealthChecks.Count(resource => GetHealthSummary(resource)?.Status == ResourceHealthStatus.Unknown);

    protected override async Task OnInitializedAsync()
    {
        Resources = await ResourceManager.ListResourcesAsync();
        await LoadHealthAsync();
        StartHealthPolling();
    }

    private async Task RefreshHealthAsync()
    {
        await RefreshHealthAsync(CancellationToken.None);
    }

    private async Task RefreshHealthAsync(CancellationToken cancellationToken)
    {
        IsCheckingHealth = true;
        try
        {
            HealthResults = await HealthChecks.RefreshResourceHealthAsync(cancellationToken);
            HealthSnapshotsByResourceId = await LoadHealthSnapshotsAsync(cancellationToken);
        }
        finally
        {
            IsCheckingHealth = false;
        }
    }

    private async Task LoadHealthAsync(CancellationToken cancellationToken = default)
    {
        IsCheckingHealth = true;
        try
        {
            HealthResults = await HealthChecks.ListResourceHealthAsync(cancellationToken);
            HealthSnapshotsByResourceId = await LoadHealthSnapshotsAsync(cancellationToken);
        }
        finally
        {
            IsCheckingHealth = false;
        }
    }

    private void StartHealthPolling()
    {
        PollingCancellation?.Cancel();
        PollingCancellation?.Dispose();

        PollingCancellation = new CancellationTokenSource();
        _ = PollHealthAsync(PollingCancellation.Token);
    }

    private async Task PollHealthAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(GetHealthCheckInterval(), cancellationToken);

                await InvokeAsync(async () =>
                {
                    Resources = await ResourceManager.ListResourcesAsync(cancellationToken: cancellationToken);
                    await LoadHealthAsync(cancellationToken);
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private IReadOnlyList<HealthResourceRow> BuildHealthResourceRows()
    {
        var resources = ResourcesWithHealthChecks;
        var resourceIds = resources
            .Select(resource => resource.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var childrenByContainer = resources
            .Where(resource => GetContainingResourceId(resource) is { } containerId && resourceIds.Contains(containerId))
            .GroupBy(resource => GetContainingResourceId(resource)!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => group
                    .OrderBy(resource => GetHealthRank(GetHealthSummary(resource)?.Status))
                    .ThenBy(resource => resource.EffectiveDisplayName, StringComparer.OrdinalIgnoreCase)
                    .ToArray(),
                StringComparer.OrdinalIgnoreCase);
        var rows = new List<HealthResourceRow>();
        foreach (var resource in resources)
        {
            if (GetContainingResourceId(resource) is { } containerId && resourceIds.Contains(containerId))
            {
                continue;
            }

            var children = childrenByContainer.GetValueOrDefault(resource.Id) ?? [];
            rows.Add(new HealthResourceRow(resource, 0, children));
            if (ExpandedContainedResourceIds.Contains(resource.Id))
            {
                rows.AddRange(children.Select(child => new HealthResourceRow(child, 1, [])));
            }
        }

        return rows;
    }

    private static string? GetContainingResourceId(Resource resource) =>
        !string.IsNullOrWhiteSpace(resource.ParentResourceId)
            ? resource.ParentResourceId
            : resource.OwnerResourceId;

    private void ToggleContainedResources(string resourceId)
    {
        if (!ExpandedContainedResourceIds.Add(resourceId))
        {
            ExpandedContainedResourceIds.Remove(resourceId);
        }
    }

    private Icon GetContainmentToggleIcon(HealthResourceRow row) =>
        ExpandedContainedResourceIds.Contains(row.Resource.Id)
            ? new Icons.Regular.Size16.ChevronDown()
            : new Icons.Regular.Size16.ChevronRight();

    private string GetContainmentToggleLabel(HealthResourceRow row) =>
        ExpandedContainedResourceIds.Contains(row.Resource.Id)
            ? L["Collapse contained resources"].Value
            : L["Expand contained resources"].Value;

    private string GetResourceSummary(HealthResourceRow row) =>
        row.Depth > 0
            ? L["Contained resource"].Value
            : row.Resource.Kind;

    private string GetActivitySummary(HealthResourceRow row)
    {
        var summary = L["{0} check(s)", GetHealthCheckCount(row.Resource)].Value;
        return row.Children.Count == 0
            ? summary
            : L["{0}; {1} contained resource(s)", summary, row.Children.Count].Value;
    }

    private string GetContainedResourceSummary(int count) =>
        L["{0} contained resource(s)", count].Value;

    private static string GetResourceTitleIndent(int depth) =>
        depth <= 0
            ? string.Empty
            : $"padding-left: {(depth * 1.25).ToString(System.Globalization.CultureInfo.InvariantCulture)}rem";

    private TimeSpan GetHealthCheckInterval() =>
        TimeSpan.FromSeconds(GetHealthCheckIntervalSeconds());

    private int GetHealthCheckIntervalSeconds() =>
        OrchestrationSettings.GetHealthCheckIntervalSettings().Seconds;

    private string GetHealthCheckIntervalLabel()
    {
        var settings = OrchestrationSettings.GetHealthCheckIntervalSettings();
        return settings.IsConfigured
            ? L["Polling every {0}s from appsettings", settings.Seconds].Value
            : L["Polling every {0}s from settings", settings.Seconds].Value;
    }

    private string? GetSettingsRoute() =>
        ResourceManagerCompositionLinks.ResourceManagerPage(
            Composition,
            ResourceManagerCompositionIds.ResourceSettingsPage,
            ResourceManagerRoutes.ResourceSettings);

    private ResourceHealthSummary? GetHealthSummary(Resource resource) =>
        HealthResults.GetValueOrDefault(resource.Id);

    private IReadOnlyList<ResourceHealthSummary> GetHealthSnapshots(Resource resource) =>
        HealthSnapshotsByResourceId.GetValueOrDefault(resource.Id) ?? [];

    private async Task<IReadOnlyDictionary<string, IReadOnlyList<ResourceHealthSummary>>> LoadHealthSnapshotsAsync(
        CancellationToken cancellationToken)
    {
        var resources = ResourcesWithHealthChecks;
        var snapshots = await Task.WhenAll(resources.Select(async resource =>
            new
            {
                resource.Id,
                Snapshots = await HealthChecks.ListResourceHealthSnapshotsAsync(resource.Id, 20, cancellationToken)
            }));

        return snapshots.ToDictionary(
            item => item.Id,
            item => item.Snapshots,
            StringComparer.OrdinalIgnoreCase);
    }

    private IReadOnlyList<HealthCheckRow> GetHealthCheckRows(Resource resource)
    {
        var results = GetHealthSummary(resource)?.Checks ?? [];
        var checks = GetChartChecks(resource);
        return checks
            .Select(check => new HealthCheckRow(
                check,
                results.FirstOrDefault(result => ReferenceEquals(result.Check, check) || result.Check == check)))
            .OrderBy(row => GetHealthRank(row.Result?.Status))
            .ThenBy(row => row.Check.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private string GetCheckedAtLabel()
    {
        var checkedAt = HealthResults.Values
            .OrderByDescending(summary => summary.CheckedAt)
            .FirstOrDefault()
            ?.CheckedAt;

        return checkedAt is null
            ? (IsCheckingHealth ? L["Checking"].Value : L["Not checked"].Value)
            : L["Checked {0}", checkedAt.Value.ToLocalTime().ToString("HH:mm:ss")].Value;
    }

    private string GetHealthLabel(ResourceHealthStatus? status)
    {
        if (status is null)
        {
            return IsCheckingHealth ? L["Checking"].Value : L["Not checked"].Value;
        }

        return status switch
        {
            ResourceHealthStatus.Healthy => L["Healthy"].Value,
            ResourceHealthStatus.Unhealthy => L["Unhealthy"].Value,
            _ => L["Unknown"].Value
        };
    }

    private string GetPendingDetail() =>
        IsCheckingHealth ? L["Checking"].Value : L["No result"].Value;

    private bool HasHealthAssessment(Resource resource) =>
        resource.ResourceHealthChecks.Count > 0 ||
        GetHealthSummary(resource)?.Checks.Count > 0;

    private int GetHealthCheckCount(Resource resource) =>
        resource.ResourceHealthChecks.Count > 0
            ? resource.ResourceHealthChecks.Count
            : GetHealthSummary(resource)?.Checks.Count ?? 0;

    private IReadOnlyList<ResourceHealthCheck> GetChartChecks(Resource resource) =>
        resource.ResourceHealthChecks.Count > 0
            ? resource.ResourceHealthChecks
            : GetHealthSummary(resource)?.Checks.Select(result => result.Check).ToArray() ?? [];

    private static int GetHealthRank(ResourceHealthStatus? status) =>
        status switch
        {
            ResourceHealthStatus.Unhealthy => 0,
            ResourceHealthStatus.Unknown => 1,
            null => 2,
            ResourceHealthStatus.Healthy => 3,
            _ => 4
        };

    private string FormatEndpoint(ResourceHealthCheck check) =>
        string.IsNullOrWhiteSpace(check.EndpointName)
            ? L["default endpoint"].Value
            : check.EndpointName;

    private static string FormatPath(ResourceHealthCheck check)
    {
        var path = string.IsNullOrWhiteSpace(check.Path) ? "/" : check.Path;
        return check.Timeout is null
            ? path
            : $"{path} / {check.Timeout.Value.TotalSeconds:0.#}s";
    }

    private string BuildResourceRoute(string resourceId) =>
        ResourceManagerCompositionLinks.ResourceDetails(
            Composition,
            resourceId,
            ResourcePredefinedViewIds.Health);

    public void Dispose()
    {
        PollingCancellation?.Cancel();
        PollingCancellation?.Dispose();
    }

    private sealed record HealthResourceRow(
        Resource Resource,
        int Depth,
        IReadOnlyList<Resource> Children);

    private sealed record HealthCheckRow(
        ResourceHealthCheck Check,
        ResourceHealthCheckResult? Result);
}
