@using System.Text.Json
@inject IResourceManager ResourceManager
@inject IEnumerable<ICertificateReferenceCatalog> CertificateCatalogs
@inject NavigationManager Navigation

<div class="type-registration">
    <FormPanel>
        <ResourceIdentityFields ResourceIdInputId="load-balancer-resource-id"
                                ResourceIdPlaceholder="public"
                                @bind-ResourceId="ResourceId" />

        <label for="load-balancer-provider">Provider</label>
        <FluentSelect TOption="string"
                      Id="load-balancer-provider"
                      @bind-Value="Provider"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="traefik">Traefik</FluentOption>
        </FluentSelect>

        <label for="load-balancer-host">Container host</label>
        <FluentSelect TOption="string"
                      Id="load-balancer-host"
                      @bind-Value="SelectedHostResourceId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default container host</FluentOption>
            @foreach (var host in GetHostCandidates())
            {
                <FluentOption TOption="string" Value="@host.Id">@ResourceDisplayLabels.GetLabel(host)</FluentOption>
            }
        </FluentSelect>

        <ResourceGroupSelect Id="load-balancer-group"
                             ResourceGroups="ResourceGroups"
                             @bind-Value="SelectedGroupId" />

        <ResourceEditorSection Title="Entrypoints">
            <FluentCheckbox @bind-Value="ExposeHttp">
                HTTP
            </FluentCheckbox>
            @if (ExposeHttp)
            {
                <label for="load-balancer-http-port">HTTP port</label>
                <FluentNumberField TValue="int" Id="load-balancer-http-port" Min="1" @bind-Value="HttpPort" />
            }

            <FluentCheckbox @bind-Value="ExposeHttps">
                HTTPS
            </FluentCheckbox>
            @if (ExposeHttps)
            {
                <label for="load-balancer-https-port">HTTPS port</label>
                <FluentNumberField TValue="int" Id="load-balancer-https-port" Min="1" @bind-Value="HttpsPort" />

                <label for="load-balancer-https-certificate">HTTPS certificate</label>
                <FluentSelect TOption="string"
                              Id="load-balancer-https-certificate"
                              @bind-Value="SelectedHttpsCertificateKey"
                              Appearance="Appearance.Outline">
                    <FluentOption TOption="string" Value="">No certificate</FluentOption>
                    @foreach (var certificate in GetCertificateCandidates())
                    {
                        <FluentOption TOption="string" Value="@certificate.Key">@certificate.Label</FluentOption>
                    }
                </FluentSelect>
            }

            <FluentCheckbox @bind-Value="ExposeTcp">
                TCP
            </FluentCheckbox>
            @if (ExposeTcp)
            {
                <label for="load-balancer-tcp-port">TCP port</label>
                <FluentNumberField TValue="int" Id="load-balancer-tcp-port" Min="1" @bind-Value="TcpPort" />
            }
        </ResourceEditorSection>

        <ResourceEditorSection Title="HTTP route">
            <FluentCheckbox @bind-Value="CreateHttpRoute">
                Add HTTP route
            </FluentCheckbox>

            @if (CreateHttpRoute)
            {
                <label for="load-balancer-http-host">Host</label>
                <FluentTextField Id="load-balancer-http-host" @bind-Value="HttpHost" Placeholder="app.local" />

                <label for="load-balancer-http-path">Path prefix</label>
                <FluentTextField Id="load-balancer-http-path" @bind-Value="HttpPathPrefix" Placeholder="/v1" />

                <label for="load-balancer-http-target">Target resource</label>
                <FluentSelect TOption="string"
                              Id="load-balancer-http-target"
                              @bind-Value="HttpTargetResourceId"
                              Appearance="Appearance.Outline">
                    <FluentOption TOption="string" Value="">Select a resource</FluentOption>
                    @foreach (var target in GetTargetCandidates())
                    {
                        <FluentOption TOption="string" Value="@target.Id">@ResourceDisplayLabels.GetLabel(target)</FluentOption>
                    }
                </FluentSelect>

                @if (GetTargetEndpoints(HttpTargetResourceId).Count > 0)
                {
                    <label for="load-balancer-http-target-endpoint">Target endpoint</label>
                    <FluentSelect TOption="string"
                                  Id="load-balancer-http-target-endpoint"
                                  @bind-Value="HttpTargetEndpointName"
                                  Appearance="Appearance.Outline">
                        <FluentOption TOption="string" Value="">Use target port</FluentOption>
                        @foreach (var endpoint in GetTargetEndpoints(HttpTargetResourceId))
                        {
                            <FluentOption TOption="string" Value="@endpoint.Name">@endpoint.Name</FluentOption>
                        }
                    </FluentSelect>
                }

                <label for="load-balancer-http-target-port">Target port</label>
                <FluentNumberField TValue="int?" Id="load-balancer-http-target-port" Min="1" @bind-Value="HttpTargetPort" />
            }
        </ResourceEditorSection>

        <ResourceEditorSection Title="TCP route">
            <FluentCheckbox @bind-Value="CreateTcpRoute">
                Add TCP route
            </FluentCheckbox>

            @if (CreateTcpRoute)
            {
                <label for="load-balancer-tcp-target">Target resource</label>
                <FluentSelect TOption="string"
                              Id="load-balancer-tcp-target"
                              @bind-Value="TcpTargetResourceId"
                              Appearance="Appearance.Outline">
                    <FluentOption TOption="string" Value="">Select a resource</FluentOption>
                    @foreach (var target in GetTargetCandidates())
                    {
                        <FluentOption TOption="string" Value="@target.Id">@ResourceDisplayLabels.GetLabel(target)</FluentOption>
                    }
                </FluentSelect>

                @if (GetTargetEndpoints(TcpTargetResourceId).Count > 0)
                {
                    <label for="load-balancer-tcp-target-endpoint">Target endpoint</label>
                    <FluentSelect TOption="string"
                                  Id="load-balancer-tcp-target-endpoint"
                                  @bind-Value="TcpTargetEndpointName"
                                  Appearance="Appearance.Outline">
                        <FluentOption TOption="string" Value="">Use target port</FluentOption>
                        @foreach (var endpoint in GetTargetEndpoints(TcpTargetResourceId))
                        {
                            <FluentOption TOption="string" Value="@endpoint.Name">@endpoint.Name</FluentOption>
                        }
                    </FluentSelect>
                }

                <label for="load-balancer-tcp-target-port">Target port</label>
                <FluentNumberField TValue="int?" Id="load-balancer-tcp-target-port" Min="1" @bind-Value="TcpTargetPort" />
            }
        </ResourceEditorSection>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FormPrimaryAction IconStart="@(new Icons.Regular.Size20.AddCircle())"
                           OnClick="Register" />
    </FormPanel>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string NetworkResourceType = "cloudshell.network";
    private const string VirtualNetworkResourceType = "cloudshell.virtualNetwork";
    private const string LoadBalancerResourceType = "cloudshell.loadBalancer";
    private const string TargetResourceQueryParameter = "targetResourceId";
    private const string TargetEndpointQueryParameter = "targetEndpointName";
    private const string RouteKindQueryParameter = "routeKind";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string Provider { get; set; } = "traefik";
    private string SelectedHostResourceId { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private bool ExposeHttp { get; set; } = true;
    private int HttpPort { get; set; } = 80;
    private bool ExposeHttps { get; set; } = true;
    private int HttpsPort { get; set; } = 443;
    private string SelectedHttpsCertificateKey { get; set; } = string.Empty;
    private bool ExposeTcp { get; set; }
    private int TcpPort { get; set; } = 5432;
    private bool CreateHttpRoute { get; set; } = true;
    private string HttpHost { get; set; } = "app.local";
    private string HttpPathPrefix { get; set; } = string.Empty;
    private string HttpTargetResourceId { get; set; } = string.Empty;
    private string HttpTargetEndpointName { get; set; } = string.Empty;
    private int? HttpTargetPort { get; set; }
    private bool CreateTcpRoute { get; set; }
    private string TcpTargetResourceId { get; set; } = string.Empty;
    private string TcpTargetEndpointName { get; set; } = string.Empty;
    private int? TcpTargetPort { get; set; } = 5432;
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];
    private IReadOnlyList<Resource> Resources { get; set; } = [];
    private IReadOnlyList<CertificateOption> CertificateOptions { get; set; } = [];
    private IReadOnlyDictionary<string, ResourceGroup> ResourceGroupsByResourceId { get; set; } =
        ResourceManagerUiAccess.EmptyGroupLookup;

    [CascadingParameter]
    public ResourceRegistrationNavigationContext? RegistrationNavigation { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
        Resources = await ResourceManager.ListResourcesAsync();
        ResourceGroupsByResourceId = await ResourceManagerUiAccess.CreateGroupLookupAsync(
            ResourceManager,
            Resources);
        var requestedTargetResourceId = GetRequestedTargetResourceId();
        if (!string.IsNullOrWhiteSpace(requestedTargetResourceId) &&
            ResourceGroupsByResourceId.TryGetValue(requestedTargetResourceId, out var requestedTargetGroup))
        {
            SelectedGroupId = requestedTargetGroup.Id;
        }

        var requestedRouteKind = GetRequestedRouteKind();
        var targetResourceId = requestedTargetResourceId ??
            GetTargetCandidates().FirstOrDefault()?.Id ??
            string.Empty;
        var targetEndpointName = GetRequestedTargetEndpointName(targetResourceId) ??
            GetTargetEndpoints(targetResourceId).FirstOrDefault()?.Name ??
            string.Empty;

        if (string.Equals(requestedRouteKind, "tcp", StringComparison.OrdinalIgnoreCase))
        {
            CreateHttpRoute = false;
            CreateTcpRoute = true;
            ExposeTcp = true;
            TcpTargetResourceId = targetResourceId;
            TcpTargetEndpointName = targetEndpointName;
        }
        else
        {
            HttpTargetResourceId = targetResourceId;
            HttpTargetEndpointName = targetEndpointName;
        }

        CertificateOptions = await LoadCertificateOptionsAsync();
        var certificateCandidates = GetCertificateCandidates();
        SelectedHttpsCertificateKey = certificateCandidates.Count == 1
            ? certificateCandidates[0].Key
            : string.Empty;

        if (!string.IsNullOrWhiteSpace(requestedTargetResourceId) &&
            Resources.FirstOrDefault(resource => string.Equals(resource.Id, requestedTargetResourceId, StringComparison.OrdinalIgnoreCase)) is { } requestedTarget)
        {
            Name = $"{ResourceDisplayLabels.GetLabel(requestedTarget)} load balancer";
            ResourceId = $"load-balancer:{CreateRouteId(requestedTarget.Name)}";
        }
    }

    private IReadOnlyList<Resource> GetHostCandidates() =>
        Resources
            .Where(resource => !string.Equals(resource.EffectiveTypeId, LoadBalancerResourceType, StringComparison.OrdinalIgnoreCase))
            .Where(IsContainerHostCandidate)
            .Where(IsInSelectedGroup)
            .OrderBy(ResourceDisplayLabels.GetLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private static bool IsContainerHostCandidate(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.ContainerHost) ||
        (resource.ResourceClass == ResourceClass.Infrastructure &&
            (resource.EffectiveTypeId.Contains("docker", StringComparison.OrdinalIgnoreCase) ||
                resource.EffectiveTypeId.Contains("host", StringComparison.OrdinalIgnoreCase)));

    private IReadOnlyList<Resource> GetTargetCandidates() =>
        GetAllTargetCandidates()
            .Where(IsInSelectedGroup)
            .ToArray();

    private IReadOnlyList<Resource> GetAllTargetCandidates() =>
        Resources
            .Where(resource => !IsNetworkBoundaryResource(resource))
            .Where(resource => !string.Equals(resource.EffectiveTypeId, LoadBalancerResourceType, StringComparison.OrdinalIgnoreCase))
            .Where(resource => resource.Endpoints.Count > 0 || resource.HasCapability(ResourceCapabilityIds.EndpointSource))
            .OrderBy(ResourceDisplayLabels.GetLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<ResourceEndpoint> GetTargetEndpoints(string resourceId) =>
        Resources
            .FirstOrDefault(resource => string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
            ?.Endpoints ?? [];

    private IReadOnlyList<CertificateOption> GetCertificateCandidates() =>
        CertificateOptions
            .Where(IsCertificateInSelectedGroup)
            .ToArray();

    private bool IsInSelectedGroup(Resource resource)
    {
        var group = ResourceManagerUiAccess.GetResourceGroup(ResourceGroupsByResourceId, resource.Id);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsCertificateInSelectedGroup(CertificateOption certificate)
    {
        if (!Resources.Any(resource => string.Equals(resource.Id, certificate.VaultResourceId, StringComparison.OrdinalIgnoreCase)))
        {
            return false;
        }

        var group = ResourceManagerUiAccess.GetResourceGroup(ResourceGroupsByResourceId, certificate.VaultResourceId);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsNetworkBoundaryResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, NetworkResourceType, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(resource.EffectiveTypeId, VirtualNetworkResourceType, StringComparison.OrdinalIgnoreCase);

    private string? GetRequestedTargetResourceId()
    {
        var requested = GetRequestedQueryValue(TargetResourceQueryParameter);
        return string.IsNullOrWhiteSpace(requested) ||
            !GetAllTargetCandidates().Any(resource => string.Equals(resource.Id, requested, StringComparison.OrdinalIgnoreCase))
                ? null
                : requested;
    }

    private string? GetRequestedTargetEndpointName(string targetResourceId)
    {
        var requested = GetRequestedQueryValue(TargetEndpointQueryParameter);
        return string.IsNullOrWhiteSpace(requested) ||
            !GetTargetEndpoints(targetResourceId).Any(endpoint => string.Equals(endpoint.Name, requested, StringComparison.OrdinalIgnoreCase))
                ? null
                : requested;
    }

    private string? GetRequestedRouteKind()
    {
        var requested = GetRequestedQueryValue(RouteKindQueryParameter);
        return string.Equals(requested, "tcp", StringComparison.OrdinalIgnoreCase)
            ? "tcp"
            : null;
    }

    private string? GetRequestedQueryValue(string name)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(name, out var values)
            ? values.ToString()
            : null;
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            ErrorMessage = "Name is required.";
            return;
        }

        var entrypoints = BuildEntrypoints();
        if (entrypoints.Count == 0)
        {
            ErrorMessage = "Select at least one entrypoint.";
            return;
        }

        var routes = BuildRoutes();
        if (ErrorMessage is not null)
        {
            return;
        }

        var normalizedResourceId = ResourceNameNormalizer.Normalize(ResourceId, "load-balancer");
        var displayName = ResourceDisplayNameDefaults.Resolve(ResourceId);
        var definition = new LoadBalancerResourceDefinition(
            normalizedResourceId,
            displayName,
            Provider,
            string.IsNullOrWhiteSpace(SelectedHostResourceId) ? null : SelectedHostResourceId,
            entrypoints,
            routes);

        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                LoadBalancerResourceType,
                normalizedResourceId,
                displayName,
                JsonSerializer.SerializeToElement(definition),
                string.IsNullOrWhiteSpace(SelectedGroupId) ? null : SelectedGroupId));

        Navigation.NavigateTo(GetReturnUrl());
    }

    private string GetReturnUrl() =>
        RegistrationNavigation?.GetReturnUrlOrDefault() ??
        ResourceRegistrationNavigationContext.DefaultReturnUrl;

    private IReadOnlyList<LoadBalancerEntrypoint> BuildEntrypoints()
    {
        var entrypoints = new List<LoadBalancerEntrypoint>();
        if (ExposeHttp)
        {
            entrypoints.Add(new LoadBalancerEntrypoint("http", ResourceEndpointProtocol.Http, Math.Max(1, HttpPort)));
        }

        if (ExposeHttps)
        {
            entrypoints.Add(new LoadBalancerEntrypoint(
                "https",
                ResourceEndpointProtocol.Https,
                Math.Max(1, HttpsPort),
                Certificate: ResolveSelectedCertificateReference(SelectedHttpsCertificateKey)));
        }

        if (ExposeTcp || CreateTcpRoute)
        {
            entrypoints.Add(new LoadBalancerEntrypoint(GetTcpEntrypointName(), ResourceEndpointProtocol.Tcp, Math.Max(1, TcpPort)));
        }

        return entrypoints;
    }

    private IReadOnlyList<LoadBalancerRoute> BuildRoutes()
    {
        var routes = new List<LoadBalancerRoute>();
        if (CreateHttpRoute)
        {
            if (!ExposeHttp)
            {
                ErrorMessage = "HTTP routes require the HTTP entrypoint.";
                return [];
            }

            if (string.IsNullOrWhiteSpace(HttpHost))
            {
                ErrorMessage = "HTTP routes require a host.";
                return [];
            }

            var target = BuildTarget(HttpTargetResourceId, HttpTargetEndpointName, HttpTargetPort, "HTTP");
            if (target is null)
            {
                return [];
            }

            routes.Add(new LoadBalancerRoute(
                CreateRouteId("http", HttpHost, HttpPathPrefix),
                string.IsNullOrWhiteSpace(HttpPathPrefix)
                    ? $"{HttpHost} to {ResourceDisplayLabels.GetLabel(Resources, HttpTargetResourceId)}"
                    : $"{HttpHost}{HttpPathPrefix} to {ResourceDisplayLabels.GetLabel(Resources, HttpTargetResourceId)}",
                LoadBalancerRouteKind.Http,
                "http",
                new LoadBalancerRouteMatch(
                    Host: HttpHost,
                    PathPrefix: string.IsNullOrWhiteSpace(HttpPathPrefix) ? null : HttpPathPrefix),
                target));
        }

        if (CreateTcpRoute)
        {
            var target = BuildTarget(TcpTargetResourceId, TcpTargetEndpointName, TcpTargetPort, "TCP");
            if (target is null)
            {
                return [];
            }

            routes.Add(new LoadBalancerRoute(
                CreateRouteId("tcp", TcpPort.ToString()),
                $"tcp {TcpPort} to {ResourceDisplayLabels.GetLabel(Resources, TcpTargetResourceId)}",
                LoadBalancerRouteKind.Tcp,
                GetTcpEntrypointName(),
                new LoadBalancerRouteMatch(Port: Math.Max(1, TcpPort)),
                target));
        }

        return routes;
    }

    private LoadBalancerRouteTarget? BuildTarget(
        string resourceId,
        string endpointName,
        int? port,
        string routeKind)
    {
        if (string.IsNullOrWhiteSpace(resourceId))
        {
            ErrorMessage = $"{routeKind} routes require a target resource.";
            return null;
        }

        var selectedEndpointName = string.IsNullOrWhiteSpace(endpointName)
            ? GetTargetEndpoints(resourceId).FirstOrDefault()?.Name
            : endpointName;

        if (string.IsNullOrWhiteSpace(selectedEndpointName) && port is null)
        {
            ErrorMessage = $"{routeKind} routes require a target endpoint or target port.";
            return null;
        }

        return new LoadBalancerRouteTarget(
            resourceId,
            string.IsNullOrWhiteSpace(selectedEndpointName) ? null : selectedEndpointName,
            port);
    }

    private string GetTcpEntrypointName() => $"tcp-{Math.Max(1, TcpPort)}";

    private CertificateReference? ResolveSelectedCertificateReference(string key) =>
        GetCertificateCandidates()
            .FirstOrDefault(certificate => string.Equals(certificate.Key, key, StringComparison.Ordinal))
            ?.ToReference();

    private async Task<IReadOnlyList<CertificateOption>> LoadCertificateOptionsAsync()
    {
        var options = new List<CertificateOption>();
        foreach (var catalog in CertificateCatalogs)
        {
            var certificates = await catalog.ListCertificatesAsync(Resources);
            options.AddRange(certificates.Select(CertificateOption.FromDescriptor));
        }

        return options
            .GroupBy(option => option.Key, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .OrderBy(option => option.Label, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static string CreateRouteId(params string?[] parts)
    {
        var value = string.Join(
            "-",
            parts
                .Where(part => !string.IsNullOrWhiteSpace(part))
                .Select(part => part!.Trim().ToLowerInvariant()));
        return new string(value
            .Select(character => char.IsLetterOrDigit(character) ? character : '-')
            .ToArray())
            .Trim('-');
    }

    private sealed record CertificateOption(
        string Key,
        string Label,
        string VaultResourceId,
        string Name,
        string? Version)
    {
        public CertificateReference ToReference() =>
            new(VaultResourceId, Name, Version);

        public static CertificateOption FromDescriptor(CertificateReferenceDescriptor descriptor)
        {
            var label = $"{ResourceDisplayLabels.GetName(descriptor.VaultResourceId)} / {descriptor.Name}";
            if (!string.IsNullOrWhiteSpace(descriptor.Version))
            {
                label += $" ({descriptor.Version})";
            }

            if (!string.IsNullOrWhiteSpace(descriptor.Subject))
            {
                label += $" - {descriptor.Subject}";
            }

            return new(
                CreateKey(descriptor.VaultResourceId, descriptor.Name, descriptor.Version),
                label,
                descriptor.VaultResourceId,
                descriptor.Name,
                descriptor.Version);
        }

        public static string CreateKey(
            string vaultResourceId,
            string name,
            string? version) =>
            $"{vaultResourceId}|{name}|{version}";
    }
}
