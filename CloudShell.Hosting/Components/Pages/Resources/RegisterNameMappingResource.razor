@using System.Text.Json
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <label for="name-mapping-zone">DNS zone</label>
        <FluentSelect TOption="string"
                      Id="name-mapping-zone"
                      @bind-Value="SelectedZoneResourceId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Select a DNS zone</FluentOption>
            @foreach (var zone in GetDnsZoneCandidates())
            {
                <FluentOption TOption="string" Value="@zone.Id">@ResourceDisplayLabels.GetLabel(zone)</FluentOption>
            }
        </FluentSelect>

        <ResourceIdentityFields ResourceIdInputId="name-mapping-resource-id"
                                ResourceIdPlaceholder="app-cloudshell-local"
                                @bind-ResourceId="ResourceId" />

        <label for="name-mapping-host">Host name</label>
        <FluentTextField Id="name-mapping-host" @bind-Value="HostName" Placeholder="app.cloudshell.local" />

        @if (ShouldWarnAboutLocalSuffix(HostName))
        {
            <ResourceCallout Severity="ResourceSignalSeverity.Warning"
                             Title="Local suffix warning"
                             Role="alert">
                <span>Names ending in .local may conflict with mDNS/Bonjour on the host network. Use them intentionally for local development and reconcile them only on hosts where this suffix is acceptable.</span>
            </ResourceCallout>
        }

        @if (IsSelectedZoneLocalHostNameProvider())
        {
            <ResourceCallout Severity="ResourceSignalSeverity.Info"
                             Title="Local host-name publishing"
                             Role="status">
                <span>This DNS zone uses local host-name publishing. Reconcile name mappings on the DNS zone to write exact host mappings to the configured hosts-file target.</span>
            </ResourceCallout>
        }

        <label for="name-mapping-target">Target resource</label>
        <FluentSelect TOption="string"
                      Id="name-mapping-target"
                      @bind-Value="TargetResourceId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Select a target</FluentOption>
            @foreach (var target in GetTargetCandidates())
            {
                <FluentOption TOption="string" Value="@target.Id">@ResourceDisplayLabels.GetLabel(target)</FluentOption>
            }
        </FluentSelect>

        @if (GetTargetEndpoints(TargetResourceId).Count > 0)
        {
            <label for="name-mapping-target-endpoint">Target endpoint</label>
            <FluentSelect TOption="string"
                          Id="name-mapping-target-endpoint"
                          @bind-Value="TargetEndpointName"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">Any endpoint</FluentOption>
                @foreach (var endpoint in GetTargetEndpoints(TargetResourceId))
                {
                    <FluentOption TOption="string" Value="@endpoint.Name">@endpoint.Name</FluentOption>
                }
            </FluentSelect>
        }

        <EnumValueSelect TEnum="ResourceExposureScope"
                         Id="name-mapping-exposure"
                         Label="Exposure"
                         @bind-Value="SelectedExposure" />

        <label for="name-mapping-provider">Publishing provider resource</label>
        <FluentSelect TOption="string"
                      Id="name-mapping-provider"
                      @bind-Value="ProviderResourceId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Use zone provider</FluentOption>
            @foreach (var provider in GetNamePublisherCandidates())
            {
                <FluentOption TOption="string" Value="@provider.Id">@ResourceDisplayLabels.GetLabel(provider)</FluentOption>
            }
        </FluentSelect>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FormPrimaryAction IconStart="@(new Icons.Regular.Size20.AddCircle())"
                           OnClick="Register" />
    </div>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string DnsZoneResourceType = "cloudshell.dnsZone";
    private const string NameMappingResourceType = "cloudshell.nameMapping";
    private const string NetworkResourceType = "cloudshell.network";
    private const string VirtualNetworkResourceType = "cloudshell.virtualNetwork";
    private const string LocalHostNamesProvider = "local-hostnames";
    private const string ZoneResourceQueryParameter = "zoneResourceId";
    private const string TargetResourceQueryParameter = "targetResourceId";
    private const string TargetEndpointQueryParameter = "targetEndpointName";
    private const string HostNameQueryParameter = "hostName";

    private string SelectedZoneResourceId { get; set; } = string.Empty;
    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string HostName { get; set; } = "app.cloudshell.local";
    private string TargetResourceId { get; set; } = string.Empty;
    private string TargetEndpointName { get; set; } = string.Empty;
    private string SelectedExposure { get; set; } = ResourceExposureScope.Public.ToString();
    private string ProviderResourceId { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<Resource> Resources { get; set; } = [];
    private IReadOnlyDictionary<string, ResourceGroup> ResourceGroupsByResourceId { get; set; } =
        ResourceManagerUiAccess.EmptyGroupLookup;

    [CascadingParameter]
    public ResourceRegistrationNavigationContext? RegistrationNavigation { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Resources = await ResourceManager.ListResourcesAsync();
        ResourceGroupsByResourceId = await ResourceManagerUiAccess.CreateGroupLookupAsync(
            ResourceManager,
            Resources);
        SelectedZoneResourceId = GetRequestedDnsZoneId() ??
            GetDnsZoneCandidates().FirstOrDefault()?.Id ??
            string.Empty;
        TargetResourceId = GetRequestedTargetResourceId() ??
            GetTargetCandidates().FirstOrDefault()?.Id ??
            string.Empty;
        TargetEndpointName = GetRequestedTargetEndpointName() ??
            GetTargetEndpoints(TargetResourceId).FirstOrDefault()?.Name ??
            string.Empty;
        if (GetRequestedHostName() is { } requestedHostName)
        {
            HostName = requestedHostName;
        }
        else if (GetSelectedZone() is { } zone &&
            Resources.FirstOrDefault(resource =>
                string.Equals(resource.Id, TargetResourceId, StringComparison.OrdinalIgnoreCase)) is { } target)
        {
            HostName = CreateDefaultHostName(target, zone);
            Name = HostName;
        }
    }

    private IReadOnlyList<Resource> GetDnsZoneCandidates() =>
        Resources
            .Where(resource =>
                string.Equals(resource.EffectiveTypeId, DnsZoneResourceType, StringComparison.OrdinalIgnoreCase) ||
                resource.HasCapability(ResourceCapabilityIds.NetworkingDnsZone))
            .OrderBy(ResourceDisplayLabels.GetLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetTargetCandidates() =>
        Resources
            .Where(resource => !IsDnsResource(resource))
            .Where(resource => !IsNetworkBoundaryResource(resource))
            .Where(resource => resource.Endpoints.Count > 0 || resource.HasCapability(ResourceCapabilityIds.EndpointSource))
            .Where(IsInSelectedZoneGroup)
            .OrderBy(ResourceDisplayLabels.GetLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetNamePublisherCandidates() =>
        Resources
            .Where(resource => resource.HasCapability(ResourceCapabilityIds.NetworkingNamePublisher))
            .Where(IsInSelectedZoneGroup)
            .OrderBy(ResourceDisplayLabels.GetLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<ResourceEndpoint> GetTargetEndpoints(string resourceId) =>
        Resources
            .FirstOrDefault(resource => string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
            ?.Endpoints ?? [];

    private Resource? GetSelectedZone() =>
        Resources.FirstOrDefault(resource =>
            string.Equals(resource.Id, SelectedZoneResourceId, StringComparison.OrdinalIgnoreCase));

    private string? GetRequestedDnsZoneId()
    {
        var requested = GetRequestedQueryValue(ZoneResourceQueryParameter);
        return string.IsNullOrWhiteSpace(requested) ||
            !GetDnsZoneCandidates().Any(resource => string.Equals(resource.Id, requested, StringComparison.OrdinalIgnoreCase))
                ? null
                : requested;
    }

    private string? GetRequestedTargetResourceId()
    {
        var requested = GetRequestedQueryValue(TargetResourceQueryParameter);
        return string.IsNullOrWhiteSpace(requested) ||
            !GetTargetCandidates().Any(resource => string.Equals(resource.Id, requested, StringComparison.OrdinalIgnoreCase))
                ? null
                : requested;
    }

    private string? GetRequestedTargetEndpointName()
    {
        var requested = GetRequestedQueryValue(TargetEndpointQueryParameter);
        return string.IsNullOrWhiteSpace(requested) ||
            !GetTargetEndpoints(TargetResourceId).Any(endpoint => string.Equals(endpoint.Name, requested, StringComparison.OrdinalIgnoreCase))
                ? null
                : requested;
    }

    private string? GetRequestedHostName() =>
        NormalizeNullable(GetRequestedQueryValue(HostNameQueryParameter));

    private string? GetRequestedQueryValue(string name)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue(name, out var values)
            ? values.ToString()
            : null;
    }

    private bool IsSelectedZoneLocalHostNameProvider()
    {
        var zone = GetSelectedZone();
        return zone is not null &&
            zone.ResourceAttributes.TryGetValue(ResourceAttributeNames.DnsProvider, out var provider) &&
            string.Equals(provider, LocalHostNamesProvider, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsInSelectedZoneGroup(Resource resource)
    {
        var zoneGroup = ResourceManagerUiAccess.GetResourceGroup(ResourceGroupsByResourceId, SelectedZoneResourceId);
        var group = ResourceManagerUiAccess.GetResourceGroup(ResourceGroupsByResourceId, resource.Id);
        return zoneGroup is null
            ? group is null
            : string.Equals(group?.Id, zoneGroup.Id, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDnsResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, DnsZoneResourceType, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(resource.EffectiveTypeId, NameMappingResourceType, StringComparison.OrdinalIgnoreCase);

    private static bool IsNetworkBoundaryResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, NetworkResourceType, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(resource.EffectiveTypeId, VirtualNetworkResourceType, StringComparison.OrdinalIgnoreCase);

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(SelectedZoneResourceId))
        {
            ErrorMessage = "DNS zone is required.";
            return;
        }

        if (!GetDnsZoneCandidates().Any(resource => string.Equals(resource.Id, SelectedZoneResourceId, StringComparison.OrdinalIgnoreCase)))
        {
            ErrorMessage = "DNS zone was not found.";
            return;
        }

        if (string.IsNullOrWhiteSpace(HostName))
        {
            ErrorMessage = "Host name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(TargetResourceId))
        {
            ErrorMessage = "Target resource is required.";
            return;
        }

        if (!GetTargetCandidates().Any(resource => string.Equals(resource.Id, TargetResourceId, StringComparison.OrdinalIgnoreCase)))
        {
            ErrorMessage = "Target resource must be in the DNS zone group and expose endpoints.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(ProviderResourceId) &&
            !GetNamePublisherCandidates().Any(resource => string.Equals(resource.Id, ProviderResourceId, StringComparison.OrdinalIgnoreCase)))
        {
            ErrorMessage = "Publishing provider resource must be in the DNS zone group and support name publishing.";
            return;
        }

        var exposure = GetExposure();
        if (NameMappingAuthoringConflicts.FindDuplicate(
                Resources,
                SelectedZoneResourceId,
                HostName,
                exposure) is { } conflict)
        {
            ErrorMessage = conflict.Message;
            return;
        }

        var resourceId = string.IsNullOrWhiteSpace(ResourceId)
            ? CreateMappingId(SelectedZoneResourceId, HostName)
            : NormalizeMappingId(SelectedZoneResourceId, ResourceId);
        var resourceName = string.IsNullOrWhiteSpace(ResourceId) ? HostName : ResourceId;
        var name = ResourceDisplayNameDefaults.Resolve(resourceName);
        var definition = new DnsNameMappingResourceDefinition(
            SelectedZoneResourceId,
            resourceId,
            name,
            HostName,
            TargetResourceId,
            GetTargetEndpointName(),
            exposure,
            string.IsNullOrWhiteSpace(ProviderResourceId) ? null : ProviderResourceId);
        var zoneGroup = ResourceManagerUiAccess.GetResourceGroup(ResourceGroupsByResourceId, SelectedZoneResourceId);

        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                NameMappingResourceType,
                resourceId,
                name,
                JsonSerializer.SerializeToElement(definition),
                zoneGroup?.Id));

        Navigation.NavigateTo(GetReturnUrl());
    }

    private string GetReturnUrl() =>
        RegistrationNavigation?.GetReturnUrlOrDefault() ??
        ResourceRegistrationNavigationContext.DefaultReturnUrl;

    private string? GetTargetEndpointName()
    {
        if (string.IsNullOrWhiteSpace(TargetEndpointName))
        {
            return null;
        }

        return GetTargetEndpoints(TargetResourceId)
            .Any(endpoint => string.Equals(endpoint.Name, TargetEndpointName, StringComparison.OrdinalIgnoreCase))
                ? TargetEndpointName
                : null;
    }

    private ResourceExposureScope GetExposure() =>
        Enum.TryParse<ResourceExposureScope>(SelectedExposure, out var exposure)
            ? exposure
            : ResourceExposureScope.Public;

    private static string CreateMappingId(string zoneResourceId, string hostName) =>
        $"{zoneResourceId.Trim()}:name:{CreateStableIdentifier(hostName)}";

    private static string NormalizeMappingId(string zoneResourceId, string name)
    {
        var normalized = name.Trim();
        return normalized.Contains(':', StringComparison.Ordinal)
            ? normalized
            : CreateMappingId(zoneResourceId, normalized);
    }

    private static string CreateDefaultHostName(Resource target, Resource zone)
    {
        var zoneName = zone.ResourceAttributes.TryGetValue(ResourceAttributeNames.DnsZoneName, out var value) &&
            !string.IsNullOrWhiteSpace(value)
                ? value.Trim().TrimStart('.')
                : zone.Name.Trim().TrimStart('.');
        var hostLabel = CreateStableIdentifier(target.Name);

        return string.IsNullOrWhiteSpace(zoneName)
            ? hostLabel
            : $"{hostLabel}.{zoneName}";
    }

    private static bool ShouldWarnAboutLocalSuffix(string value)
    {
        var normalized = value.Trim().TrimEnd('.');
        return normalized.Equals("local", StringComparison.OrdinalIgnoreCase) ||
            normalized.EndsWith(".local", StringComparison.OrdinalIgnoreCase);
    }

    private static string CreateStableIdentifier(string value)
    {
        var normalized = new string(value
            .Trim()
            .ToLowerInvariant()
            .Select(character => char.IsLetterOrDigit(character) ? character : '-')
            .ToArray())
            .Trim('-');

        return string.IsNullOrWhiteSpace(normalized) ? "name" : normalized;
    }

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();
}
