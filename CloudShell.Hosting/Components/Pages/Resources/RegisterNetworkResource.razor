@using System.Text.Json
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="provider-summary compact">
        <div class="provider-status">
            <span class="state-dot state-running"></span>
            <div>
                <strong>Logical networks</strong>
                <span>Create an orchestration network boundary that Compose or another orchestrator can map to its own networking model.</span>
            </div>
        </div>
    </div>

    <div class="form-panel">
        <label for="network-name">Name</label>
        <FluentTextField Id="network-name" @bind-Value="Name" />

        <label for="network-resource-id">Resource ID</label>
        <FluentTextField Id="network-resource-id" @bind-Value="ResourceId" Placeholder="network:app" />

        <FluentCheckbox @bind-Value="IsDefault">
            Default network
        </FluentCheckbox>

        <label for="network-group">Resource group</label>
        <FluentSelect TOption="string"
                      Id="network-group"
                      @bind-Value="SelectedGroupId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default group</FluentOption>
            @foreach (var group in ResourceGroups)
            {
                <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
            }
        </FluentSelect>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string NetworkResourceType = "cloudshell.network";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private bool IsDefault { get; set; }
    private string SelectedGroupId { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name))
        {
            ErrorMessage = "Name is required.";
            return;
        }

        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                NetworkResourceType,
                ResourceId,
                Name,
                JsonSerializer.SerializeToElement(new NetworkResourceDefinition(ResourceId, Name, IsDefault)),
                string.IsNullOrWhiteSpace(SelectedGroupId) ? null : SelectedGroupId));

        Navigation.NavigateTo("/resources");
    }
}
