@using System.Text.Json
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <ResourceIdentityFields ResourceIdInputId="network-resource-id"
                                ResourceIdPlaceholder="app"
                                @bind-ResourceId="ResourceId" />

        <FluentCheckbox @bind-Value="IsDefault">
            Default network
        </FluentCheckbox>

        <FluentCheckbox @bind-Value="CreateEndpointRequest">
            Endpoint request
        </FluentCheckbox>

        @if (CreateEndpointRequest)
        {
            <label for="network-endpoint-name">Endpoint name</label>
            <FluentTextField Id="network-endpoint-name" @bind-Value="EndpointName" />

            <EnumValueSelect TEnum="ResourceEndpointProtocol"
                             Id="network-endpoint-protocol"
                             Label="Protocol"
                             @bind-Value="SelectedProtocol" />

            <EndpointAssignmentEditor AssignmentId="network-endpoint-assignment"
                                      PortId="network-endpoint-port"
                                      ShowPortForAuto="true"
                                      Assignments="AllEndpointAssignments"
                                      @bind-Assignment="EndpointAssignment"
                                      @bind-Port="EndpointPort" />

            @if (RequiresHost)
            {
                <label for="network-endpoint-host">Host</label>
                <FluentTextField Id="network-endpoint-host" @bind-Value="EndpointHost" />

                <label for="network-endpoint-address">IP address</label>
                <FluentTextField Id="network-endpoint-address" @bind-Value="EndpointIPAddress" />
            }

            @if (IsPredefinedAssignment)
            {
                <label for="network-provider-endpoint">Provider endpoint</label>
                <FluentTextField Id="network-provider-endpoint" @bind-Value="ProviderEndpointId" />
            }

            <EnumValueSelect TEnum="ResourceExposureScope"
                             Id="network-endpoint-exposure"
                             Label="Exposure"
                             @bind-Value="SelectedExposure" />
        }

        <ResourceGroupSelect Id="network-group"
                             ResourceGroups="ResourceGroups"
                             @bind-Value="SelectedGroupId" />

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FormPrimaryAction OnClick="Register" />
    </div>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string NetworkResourceType = "cloudshell.network";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private bool IsDefault { get; set; }
    private bool CreateEndpointRequest { get; set; }
    private string EndpointName { get; set; } = "network";
    private string EndpointHost { get; set; } = "localhost";
    private string EndpointIPAddress { get; set; } = string.Empty;
    private int? EndpointPort { get; set; }
    private string ProviderEndpointId { get; set; } = string.Empty;
    private string SelectedProtocol { get; set; } = ResourceEndpointProtocol.Http.ToString();
    private ResourceEndpointAssignment EndpointAssignment { get; set; } =
        ResourceEndpointAssignment.ProviderDefault;
    private string SelectedExposure { get; set; } = ResourceExposureScope.Local.ToString();
    private string SelectedGroupId { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];

    private static readonly IReadOnlyList<ResourceEndpointAssignment> AllEndpointAssignments =
        Enum.GetValues<ResourceEndpointAssignment>();

    private bool IsPredefinedAssignment =>
        EndpointAssignment == ResourceEndpointAssignment.Predefined;

    private bool RequiresHost =>
        EndpointAssignment is ResourceEndpointAssignment.Manual or ResourceEndpointAssignment.Auto;

    protected override async Task OnInitializedAsync()
    {
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            ErrorMessage = "Name is required.";
            return;
        }

        var endpointRequests = BuildEndpointRequests();
        if (ErrorMessage is not null)
        {
            return;
        }

        var normalizedResourceId = ResourceNameNormalizer.Normalize(ResourceId, "network");
        var displayName = ResourceDisplayNameDefaults.Resolve(ResourceId);
        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                NetworkResourceType,
                normalizedResourceId,
                displayName,
                JsonSerializer.SerializeToElement(new NetworkResourceDefinition(
                    normalizedResourceId,
                    displayName,
                    IsDefault,
                    endpointRequests)),
                string.IsNullOrWhiteSpace(SelectedGroupId) ? null : SelectedGroupId));

        Navigation.NavigateTo("/resources");
    }

    private IReadOnlyList<ResourceEndpointRequest> BuildEndpointRequests()
    {
        if (!CreateEndpointRequest)
        {
            return [];
        }

        if (string.IsNullOrWhiteSpace(EndpointName))
        {
            ErrorMessage = "Endpoint name is required.";
            return [];
        }

        var assignment = EndpointAssignment;
        if (assignment == ResourceEndpointAssignment.Manual &&
            EndpointPort is null)
        {
            ErrorMessage = "Manual endpoints require a port.";
            return [];
        }

        if (assignment == ResourceEndpointAssignment.Predefined &&
            string.IsNullOrWhiteSpace(ProviderEndpointId))
        {
            ErrorMessage = "Provider endpoint is required.";
            return [];
        }

        return
        [
            new ResourceEndpointRequest(
                EndpointName,
                GetEndpointProtocol(),
                Host: string.IsNullOrWhiteSpace(EndpointHost) ? null : EndpointHost,
                Port: EndpointPort,
                IPAddress: string.IsNullOrWhiteSpace(EndpointIPAddress) ? null : EndpointIPAddress,
                Exposure: GetExposure(),
                Assignment: assignment,
                ProviderEndpointId: string.IsNullOrWhiteSpace(ProviderEndpointId) ? null : ProviderEndpointId)
        ];
    }

    private ResourceEndpointProtocol GetEndpointProtocol() =>
        Enum.TryParse<ResourceEndpointProtocol>(SelectedProtocol, out var protocol)
            ? protocol
            : ResourceEndpointProtocol.Http;

    private ResourceExposureScope GetExposure() =>
        Enum.TryParse<ResourceExposureScope>(SelectedExposure, out var exposure)
            ? exposure
            : ResourceExposureScope.Local;
}
