@using System.Text.Json
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <p class="muted">
            Use a Service when you need an explicit service unit or facade over target resources.
            Container apps can expose app-owned endpoints without a Service resource.
        </p>

        <label for="service-name">Name</label>
        <FluentTextField Id="service-name" @bind-Value="Name" />

        <label for="service-resource-id">Resource ID</label>
        <FluentTextField Id="service-resource-id" @bind-Value="ResourceId" Placeholder="service:api" />

        <ResourceGroupSelect Id="service-group"
                             ResourceGroups="ResourceGroups"
                             @bind-Value="SelectedGroupId" />

        <ResourceSelectionSection Title="Targets"
                                  Resources="GetTargetCandidates()"
                                  SelectedResourceIds="SelectedTargetIds" />

        <ResourceSelectionSection Title="Networks"
                                  Resources="GetNetworkCandidates()"
                                  SelectedResourceIds="SelectedNetworkIds" />

        <label for="service-port-name">Port name</label>
        <FluentTextField Id="service-port-name" @bind-Value="PortName" />

        <label for="service-target-port">Target port</label>
        <FluentNumberField TValue="int" Id="service-target-port" Min="1" @bind-Value="TargetPort" />

        <EndpointAssignmentEditor AssignmentId="service-port-assignment"
                                  PortId="service-port"
                                  PortLabel="Exposed port"
                                  @bind-Assignment="EndpointAssignment"
                                  @bind-Port="Port" />

        <label for="service-protocol">Protocol</label>
        <FluentSelect TOption="string"
                      Id="service-protocol"
                      @bind-Value="Protocol"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="tcp">TCP</FluentOption>
            <FluentOption TOption="string" Value="udp">UDP</FluentOption>
            <FluentOption TOption="string" Value="http">HTTP</FluentOption>
            <FluentOption TOption="string" Value="https">HTTPS</FluentOption>
        </FluentSelect>

        <EnumValueSelect TEnum="ResourceExposureScope"
                         Id="service-exposure"
                         Label="Exposure"
                         @bind-Value="SelectedExposure" />

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string NetworkResourceType = "cloudshell.network";
    private const string ServiceResourceType = "cloudshell.service";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private HashSet<string> SelectedTargetIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> SelectedNetworkIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private string PortName { get; set; } = "http";
    private int TargetPort { get; set; } = 80;
    private int? Port { get; set; }
    private string Protocol { get; set; } = "tcp";
    private ResourceEndpointAssignment EndpointAssignment { get; set; } = ResourceEndpointAssignment.Auto;
    private string SelectedExposure { get; set; } = ResourceExposureScope.Local.ToString();
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];
    private IReadOnlyList<Resource> Resources { get; set; } = [];
    private IReadOnlyDictionary<string, ResourceGroup> ResourceGroupsByResourceId { get; set; } =
        ResourceManagerUiAccess.EmptyGroupLookup;

    private bool IsManualAssignment =>
        EndpointAssignment == ResourceEndpointAssignment.Manual;

    protected override async Task OnInitializedAsync()
    {
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
        Resources = await ResourceManager.ListResourcesAsync();
        ResourceGroupsByResourceId = await ResourceManagerUiAccess.CreateGroupLookupAsync(
            ResourceManager,
            Resources);
    }

    private IReadOnlyList<Resource> GetTargetCandidates() =>
        Resources
            .Where(resource => !string.Equals(resource.EffectiveTypeId, ServiceResourceType, StringComparison.OrdinalIgnoreCase))
            .Where(resource => !string.Equals(resource.EffectiveTypeId, NetworkResourceType, StringComparison.OrdinalIgnoreCase))
            .Where(IsInSelectedGroup)
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetNetworkCandidates() =>
        Resources
            .Where(resource => string.Equals(resource.EffectiveTypeId, NetworkResourceType, StringComparison.OrdinalIgnoreCase))
            .Where(IsInSelectedGroup)
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private bool IsInSelectedGroup(Resource resource)
    {
        var group = ResourceManagerUiAccess.GetResourceGroup(ResourceGroupsByResourceId, resource.Id);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name))
        {
            ErrorMessage = "Name is required.";
            return;
        }

        if (SelectedTargetIds.Count == 0)
        {
            ErrorMessage = "Select at least one target resource.";
            return;
        }

        if (string.IsNullOrWhiteSpace(PortName) || TargetPort <= 0)
        {
            ErrorMessage = "Port name and target port are required.";
            return;
        }

        if (IsManualAssignment && Port is null)
        {
            ErrorMessage = "Manual endpoint assignment requires an exposed port.";
            return;
        }

        var exposure = Enum.TryParse<ResourceExposureScope>(SelectedExposure, out var parsedExposure)
            ? parsedExposure
            : ResourceExposureScope.Network;
        var assignedPort = IsManualAssignment ? Port : null;

        var definition = new ServiceResourceDefinition(
            ResourceId,
            Name,
            SelectedTargetIds.Select(resourceId => new ServiceTarget(resourceId)).ToArray(),
            [new ServicePort(PortName, TargetPort, assignedPort, Protocol, exposure)],
            SelectedNetworkIds.ToArray());

        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                ServiceResourceType,
                ResourceId,
                Name,
                JsonSerializer.SerializeToElement(definition),
                string.IsNullOrWhiteSpace(SelectedGroupId) ? null : SelectedGroupId));

        Navigation.NavigateTo("/resources");
    }

}
