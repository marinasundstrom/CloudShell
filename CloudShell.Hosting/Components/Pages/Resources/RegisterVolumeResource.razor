@using System.Text.Json
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization

<div class="type-registration">
    <div class="form-panel">
        <label for="volume-name">Name</label>
        <FluentTextField Id="volume-name" @bind-Value="Name" />

        <label for="volume-resource-id">Resource ID</label>
        <FluentTextField Id="volume-resource-id" @bind-Value="ResourceId" Placeholder="volume:data" />

        <ResourceGroupSelect Id="volume-group"
                             ResourceGroups="ResourceGroups"
                             @bind-Value="SelectedGroupId" />

        <label for="volume-provider">Provider</label>
        <FluentTextField Id="volume-provider"
                         Disabled="@HasSelectedStorage"
                         @bind-Value="Provider"
                         Placeholder="Local Storage" />

        <label for="volume-storage">Storage resource</label>
        <FluentSelect TOption="string"
                      Id="volume-storage"
                      Value="@SelectedStorageResourceId"
                      ValueChanged="ChangeSelectedStorageResource"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Direct filesystem path</FluentOption>
            @foreach (var storage in StorageResources)
            {
                <FluentOption TOption="string" Value="@storage.Id">@storage.Name</FluentOption>
            }
        </FluentSelect>

        <label for="volume-location">Volume path</label>
        <FluentTextField Id="volume-location"
                         @bind-Value="Location"
                         Placeholder="@GetLocationPlaceholder()" />

        <EnumValueSelect TEnum="VolumeAccessMode"
                         Id="volume-access-mode"
                         Label="Access mode"
                         LabelSelector="GetAccessModeLabel"
                         @bind-Value="SelectedAccessMode" />

        <FluentCheckbox @bind-Value="Persistent">
            Persistent
        </FluentCheckbox>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string VolumeResourceType = "cloudshell.volume";
    private const string StorageResourceQueryParameter = "storageResourceId";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private string SelectedStorageResourceId { get; set; } = string.Empty;
    private string Provider { get; set; } = string.Empty;
    private string Location { get; set; } = string.Empty;
    private string SelectedAccessMode { get; set; } = VolumeAccessMode.ReadWriteOnce.ToString();
    private bool Persistent { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];
    private IReadOnlyList<Resource> StorageResources { get; set; } = [];
    private IReadOnlyDictionary<string, ResourceGroup> StorageGroupsByResourceId { get; set; } =
        ResourceManagerUiAccess.EmptyGroupLookup;

    private bool HasSelectedStorage =>
        !string.IsNullOrWhiteSpace(SelectedStorageResourceId);

    protected override async Task OnInitializedAsync()
    {
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
        StorageGroupsByResourceId = ResourceManagerUiAccess.CreateGroupLookup(ResourceGroups);
        StorageResources = (await ResourceManager.ListResourcesAsync())
            .Where(resource => resource.HasCapability(ResourceCapabilityIds.StorageProvider))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        SelectedStorageResourceId = GetRequestedStorageResourceId() ?? string.Empty;
        ApplySelectedStorageGroup();
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name) || string.IsNullOrWhiteSpace(ResourceId))
        {
            ErrorMessage = "Name and resource ID are required.";
            return;
        }

        if (HasSelectedStorage && string.IsNullOrWhiteSpace(Location))
        {
            ErrorMessage = "Storage-owned volumes require a subpath.";
            return;
        }

        if (HasSelectedStorage && !CanManageSelectedStorage())
        {
            ErrorMessage = "You need manage permission on the selected Storage resource to create an owned volume.";
            return;
        }

        var definition = new VolumeResourceDefinition(
            ResourceId,
            Name,
            HasSelectedStorage ? GetSelectedStorageProvider() : NormalizeNullable(Provider),
            HasSelectedStorage ? null : NormalizeNullable(Location),
            Persistent,
            ParseAccessMode(),
            NormalizeNullable(SelectedStorageResourceId),
            HasSelectedStorage ? NormalizeNullable(Location) : null);

        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                VolumeResourceType,
                ResourceId,
                Name,
                JsonSerializer.SerializeToElement(definition),
                string.IsNullOrWhiteSpace(SelectedGroupId) ? null : SelectedGroupId,
                ResourceClass.Storage));

        Navigation.NavigateTo(HasSelectedStorage
            ? BuildStorageVolumesRoute(SelectedStorageResourceId)
            : "/resources");
    }

    private VolumeAccessMode ParseAccessMode() =>
        Enum.TryParse<VolumeAccessMode>(SelectedAccessMode, out var mode)
            ? mode
            : VolumeAccessMode.ReadWriteOnce;

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private string? GetRequestedStorageResourceId()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue(StorageResourceQueryParameter, out var values))
        {
            return null;
        }

        var requested = values.ToString();
        return string.IsNullOrWhiteSpace(requested) ||
            !StorageResources.Any(resource => string.Equals(resource.Id, requested, StringComparison.OrdinalIgnoreCase))
                ? null
                : requested;
    }

    private string? GetSelectedStorageProvider() =>
        StorageResources
            .FirstOrDefault(resource => string.Equals(resource.Id, SelectedStorageResourceId, StringComparison.OrdinalIgnoreCase))
            ?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.StorageProvider) ??
        StorageProviderNames.LocalStorage;

    private bool CanManageSelectedStorage() =>
        StorageResources
            .FirstOrDefault(resource => string.Equals(resource.Id, SelectedStorageResourceId, StringComparison.OrdinalIgnoreCase)) is { } storage &&
        ResourceManagerUiAccess.CanManageResource(Authorization, storage, StorageGroupsByResourceId);

    private void ChangeSelectedStorageResource(string? storageResourceId)
    {
        SelectedStorageResourceId = storageResourceId ?? string.Empty;
        ApplySelectedStorageGroup();
    }

    private void ApplySelectedStorageGroup()
    {
        if (string.IsNullOrWhiteSpace(SelectedStorageResourceId))
        {
            return;
        }

        SelectedGroupId = ResourceManagerUiAccess.GetResourceGroupId(
            StorageGroupsByResourceId,
            SelectedStorageResourceId) ?? string.Empty;
    }

    private static string BuildStorageVolumesRoute(string resourceId) =>
        $"/resources/{Uri.EscapeDataString(resourceId)}/details?tab=volumes";

    private string GetLocationPlaceholder() =>
        HasSelectedStorage ? "postgres-data" : "./data/postgres or /mnt/share/postgres";

    private static string GetAccessModeLabel(VolumeAccessMode mode) =>
        mode switch
        {
            VolumeAccessMode.ReadOnlyMany => "Read-only many",
            VolumeAccessMode.ReadWriteMany => "Read/write many",
            _ => "Read/write once"
        };
}
