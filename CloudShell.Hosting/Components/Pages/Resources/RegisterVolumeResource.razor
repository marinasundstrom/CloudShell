@using System.Text.Json
@inject IResourceManager ResourceManager
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <label for="volume-name">Name</label>
        <FluentTextField Id="volume-name" @bind-Value="Name" />

        <label for="volume-resource-id">Resource ID</label>
        <FluentTextField Id="volume-resource-id" @bind-Value="ResourceId" Placeholder="volume:data" />

        <label for="volume-group">Resource group</label>
        <FluentSelect TOption="string"
                      Id="volume-group"
                      @bind-Value="SelectedGroupId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default group</FluentOption>
            @foreach (var group in ResourceGroups)
            {
                <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
            }
        </FluentSelect>

        <label for="volume-provider">Provider</label>
        <FluentTextField Id="volume-provider" @bind-Value="Provider" Placeholder="local" />

        <label for="volume-location">Volume path</label>
        <FluentTextField Id="volume-location" @bind-Value="Location" Placeholder="./data/postgres or //nas/share/postgres" />

        <label for="volume-access-mode">Access mode</label>
        <FluentSelect TOption="string"
                      Id="volume-access-mode"
                      @bind-Value="SelectedAccessMode"
                      Appearance="Appearance.Outline">
            @foreach (var mode in Enum.GetValues<VolumeAccessMode>())
            {
                <FluentOption TOption="string" Value="@mode.ToString()">@GetAccessModeLabel(mode)</FluentOption>
            }
        </FluentSelect>

        <FluentCheckbox @bind-Value="Persistent">
            Persistent
        </FluentCheckbox>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private const string PlatformProviderId = "cloudshell.platform";
    private const string VolumeResourceType = "cloudshell.volume";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private string Provider { get; set; } = string.Empty;
    private string Location { get; set; } = string.Empty;
    private string SelectedAccessMode { get; set; } = VolumeAccessMode.ReadWriteOnce.ToString();
    private bool Persistent { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name) || string.IsNullOrWhiteSpace(ResourceId))
        {
            ErrorMessage = "Name and resource ID are required.";
            return;
        }

        var definition = new VolumeResourceDefinition(
            ResourceId,
            Name,
            NormalizeNullable(Provider),
            NormalizeNullable(Location),
            Persistent,
            ParseAccessMode());

        await ResourceManager.CreateResourceAsync(
            new CreateResourceCommand(
                PlatformProviderId,
                VolumeResourceType,
                ResourceId,
                Name,
                JsonSerializer.SerializeToElement(definition),
                string.IsNullOrWhiteSpace(SelectedGroupId) ? null : SelectedGroupId,
                ResourceClass.Storage));

        Navigation.NavigateTo("/resources");
    }

    private VolumeAccessMode ParseAccessMode() =>
        Enum.TryParse<VolumeAccessMode>(SelectedAccessMode, out var mode)
            ? mode
            : VolumeAccessMode.ReadWriteOnce;

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string GetAccessModeLabel(VolumeAccessMode mode) =>
        mode switch
        {
            VolumeAccessMode.ReadOnlyMany => "Read-only many",
            VolumeAccessMode.ReadWriteMany => "Read/write many",
            _ => "Read/write once"
        };
}
