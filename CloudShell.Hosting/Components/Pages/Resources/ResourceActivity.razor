@using System.Globalization
@inject IResourceEventManager ResourceEvents
@inject NavigationManager Navigation
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    <GeneratedResourceViewLayout ResourceType="ResourceType"
                                 ResourceId="@(ResourceId ?? string.Empty)"
                                 ViewId="@ResourcePredefinedViewIds.Activity"
                                 Sections="@BuildSections()" />
</div>

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    [Parameter]
    public string? TraceId { get; set; }

    [Parameter]
    public string? SpanId { get; set; }

    private IReadOnlyList<ResourceEvent> Events { get; set; } = [];
    private bool IsLoading { get; set; }
    private string? EventTypeFilter { get; set; }
    private string? TriggeredByFilter { get; set; }
    private string SelectedTimeRange { get; set; } = TimeRangeAll;

    private const string TimeRangeAll = "all";
    private const string TimeRangeOneHour = "1h";
    private const string TimeRangeDay = "24h";
    private const string TimeRangeWeek = "7d";

    protected override Task OnParametersSetAsync() => LoadEventsAsync();

    private Task Refresh() => LoadEventsAsync();

    private Task ApplyFilters() => LoadEventsAsync();

    private IReadOnlyList<GeneratedResourceViewSection> BuildSections() =>
    [
        new("activity", string.Empty, 0, RenderActivity())
    ];

    private RenderFragment RenderActivity() => @<text>
        <ResourceActivityHeader Title="@L["Activity"].Value" Subtitle="@GetEventCountLabel()">
            <Actions>
                <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                              Disabled="@IsLoading" OnClick="Refresh">
                    @(IsLoading ? L["Refreshing"] : L["Refresh"])
                </FluentButton>
            </Actions>
        </ResourceActivityHeader>

        <div class="resource-activity-filters">
            <div>
                <label for="resource-activity-event-type">@L["Event type"]</label>
                <FluentTextField Id="resource-activity-event-type" @bind-Value="EventTypeFilter"
                                 Placeholder="@L["Exact event type"]" />
            </div>
            <div>
                <label for="resource-activity-triggered-by">@L["Triggered by"]</label>
                <FluentTextField Id="resource-activity-triggered-by" @bind-Value="TriggeredByFilter"
                                 Placeholder="@L["Exact actor"]" />
            </div>
            <div>
                <label for="resource-activity-time-range">@L["Time range"]</label>
                <FluentSelect TOption="string" Id="resource-activity-time-range" @bind-Value="SelectedTimeRange"
                              Appearance="Appearance.Neutral">
                    <FluentOption TOption="string" Value="@TimeRangeAll">@L["All"]</FluentOption>
                    <FluentOption TOption="string" Value="@TimeRangeOneHour">@L["Last hour"]</FluentOption>
                    <FluentOption TOption="string" Value="@TimeRangeDay">@L["Last 24 hours"]</FluentOption>
                    <FluentOption TOption="string" Value="@TimeRangeWeek">@L["Last 7 days"]</FluentOption>
                </FluentSelect>
            </div>
            <div class="resource-activity-filter-actions">
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsLoading" OnClick="ApplyFilters">
                    @L["Apply"]
                </FluentButton>
                @if (HasActiveFilters)
                {
                    <FluentButton Appearance="Appearance.Neutral" Disabled="@IsLoading" OnClick="ClearFilters">
                        @L["Clear"]
                    </FluentButton>
                }
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(TraceId))
        {
            <p class="log-description">@L["Showing activity correlated with trace {0}.", FormatTraceId(TraceId)]</p>
        }
        @if (!string.IsNullOrWhiteSpace(SpanId))
        {
            <p class="log-description">@L["Showing activity correlated with span {0}.", FormatTraceId(SpanId)]</p>
        }

        @if (Events.Count == 0)
        {
            <EmptyState Title="@L["No activity"].Value" Message="@GetEmptyStateMessage()" Compact="true" />
        }
        else
        {
            <div class="resource-activity-groups" aria-label="@L["Activity groups"]">
                @foreach (var group in GetEventGroups())
                {
                    <span class="resource-activity-group @group.CssClass">
                        <strong>@group.DisplayName</strong>
                        <span>@group.Count</span>
                    </span>
                }
            </div>

            <div class="resource-activity-list">
                @foreach (var resourceEvent in Events)
                {
                    <article class="resource-activity-event">
                        <div>
                            <strong>@ResourceEventDisplayNames.GetDisplayName(resourceEvent.EventType, L)</strong>
                            <span>@FormatEventMetadata(resourceEvent)</span>
                            @if (!string.IsNullOrWhiteSpace(resourceEvent.TraceId))
                            {
                                <a class="resource-link" href="@BuildTraceRoute(resourceEvent)">
                                    @L["Trace {0}", FormatTraceId(resourceEvent.TraceId)]
                                </a>
                            }
                        </div>
                        <p>@resourceEvent.Message</p>
                        <footer>
                            <time datetime="@resourceEvent.Timestamp.ToString("O", CultureInfo.InvariantCulture)">
                                @FormatTimestamp(resourceEvent.Timestamp)
                            </time>
                            <div class="resource-activity-badges">
                                <span
                                    class="resource-activity-group @ResourceEventDisplayNames.GetGroupClass(resourceEvent.EventType)">
                                    @ResourceEventDisplayNames.GetGroupName(resourceEvent.EventType, L)
                                </span>
                                <span class="resource-activity-level @GetSeverityClass(resourceEvent.Severity)">
                                    @ResourceSignalSeverityParser.ToLevel(resourceEvent.Severity)
                                </span>
                            </div>
                        </footer>
                    </article>
                }
            </div>
        }
    </text>;

    private async Task ClearFilters()
    {
        EventTypeFilter = null;
        TriggeredByFilter = null;
        SelectedTimeRange = TimeRangeAll;
        if ((!string.IsNullOrWhiteSpace(TraceId) || !string.IsNullOrWhiteSpace(SpanId)) &&
            !string.IsNullOrWhiteSpace(ResourceId))
        {
            Navigation.NavigateTo(BuildActivityRoute(ResourceId), replace: true);
            return;
        }

        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            Events = [];
            return;
        }

        IsLoading = true;
        try
        {
            Events = await ResourceEvents.ListResourceEventsAsync(
                new ResourceEventQuery(
                    ResourceId: ResourceId,
                    EventType: NormalizeFilter(EventTypeFilter),
                    TriggeredBy: NormalizeFilter(TriggeredByFilter),
                    Since: GetSinceFilter(),
                    MaxEvents: 100,
                    TraceId: NormalizeFilter(TraceId),
                    SpanId: NormalizeFilter(SpanId)));
        }
        finally
        {
            IsLoading = false;
        }
    }

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(EventTypeFilter) ||
        !string.IsNullOrWhiteSpace(TriggeredByFilter) ||
        !string.IsNullOrWhiteSpace(TraceId) ||
        !string.IsNullOrWhiteSpace(SpanId) ||
        !string.Equals(SelectedTimeRange, TimeRangeAll, StringComparison.Ordinal);

    private string GetEventCountLabel() =>
        HasActiveFilters
            ? L["{0} matching events", Events.Count].Value
            : L["{0} events", Events.Count].Value;

    private string GetEmptyStateMessage() =>
        HasActiveFilters
            ? L["No resource activity events match the current filters."].Value
            : L["No resource activity events have been recorded."].Value;

    private IReadOnlyList<ResourceActivityGroup> GetEventGroups() =>
        Events
            .GroupBy(
                resourceEvent => ResourceEventDisplayNames.GetGroupName(resourceEvent.EventType, L),
                StringComparer.OrdinalIgnoreCase)
            .Select(group => new ResourceActivityGroup(
                group.Key,
                group.Count(),
                group
                    .Select(resourceEvent => ResourceEventDisplayNames.GetGroupOrder(resourceEvent.EventType))
                    .Min(),
                ResourceEventDisplayNames.GetGroupClass(group.First().EventType)))
            .OrderBy(group => group.Order)
            .ThenBy(group => group.DisplayName, StringComparer.CurrentCultureIgnoreCase)
            .ToArray();

    private DateTimeOffset? GetSinceFilter()
    {
        var now = DateTimeOffset.UtcNow;
        return SelectedTimeRange switch
        {
            TimeRangeOneHour => now.AddHours(-1),
            TimeRangeDay => now.AddDays(-1),
            TimeRangeWeek => now.AddDays(-7),
            _ => null
        };
    }

    private static string? NormalizeFilter(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private string FormatTriggeredBy(ResourceEvent resourceEvent) =>
        string.IsNullOrWhiteSpace(resourceEvent.TriggeredBy)
            ? L["Triggered by system"].Value
            : L["Triggered by {0}", resourceEvent.TriggeredBy].Value;

    private string FormatEventMetadata(ResourceEvent resourceEvent) =>
        L["{0} · {1}", resourceEvent.EventType, FormatTriggeredBy(resourceEvent)].Value;

    private static string BuildTraceRoute(ResourceEvent resourceEvent)
    {
        var query = new Dictionary<string, string?>
        {
            ["resourceId"] = resourceEvent.ResourceId,
            ["traceId"] = resourceEvent.TraceId
        };

        return Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            "/observability/traces",
            query);
    }

    private string BuildActivityRoute(string resourceId) =>
        ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Activity);

    private static string FormatTraceId(string traceId) =>
        traceId.Length <= 12
            ? traceId
            : traceId[^12..];

    private static string FormatTimestamp(DateTimeOffset timestamp) =>
        timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);

    private static string GetSeverityClass(ResourceSignalSeverity severity) =>
        severity switch
        {
            ResourceSignalSeverity.Warning => "warning",
            ResourceSignalSeverity.Error => "error",
            _ => "information"
        };

    private sealed record ResourceActivityGroup(
        string DisplayName,
        int Count,
        int Order,
        string CssClass);
}
