@using System.Globalization
@inject IResourceEventManager ResourceEvents
@inject IStringLocalizer<SharedResource> L

<div class="generated-resource-view">
    <section class="generated-section">
        <div class="resource-activity-header">
            <div>
                <h3>@L["Activity"]</h3>
                <span>@GetEventCountLabel()</span>
            </div>
            <FluentButton Appearance="Appearance.Neutral"
                          Disabled="@IsLoading"
                          OnClick="Refresh">
                @(IsLoading ? L["Refreshing"] : L["Refresh"])
            </FluentButton>
        </div>

        <div class="resource-activity-filters">
            <div>
                <label for="resource-activity-event-type">@L["Event type"]</label>
                <FluentTextField Id="resource-activity-event-type"
                                 @bind-Value="EventTypeFilter"
                                 Placeholder="@L["Exact event type"]" />
            </div>
            <div>
                <label for="resource-activity-triggered-by">@L["Triggered by"]</label>
                <FluentTextField Id="resource-activity-triggered-by"
                                 @bind-Value="TriggeredByFilter"
                                 Placeholder="@L["Exact actor"]" />
            </div>
            <div>
                <label for="resource-activity-time-range">@L["Time range"]</label>
                <FluentSelect TOption="string"
                              Id="resource-activity-time-range"
                              @bind-Value="SelectedTimeRange"
                              Appearance="Appearance.Neutral">
                    <FluentOption TOption="string" Value="@TimeRangeAll">@L["All"]</FluentOption>
                    <FluentOption TOption="string" Value="@TimeRangeOneHour">@L["Last hour"]</FluentOption>
                    <FluentOption TOption="string" Value="@TimeRangeDay">@L["Last 24 hours"]</FluentOption>
                    <FluentOption TOption="string" Value="@TimeRangeWeek">@L["Last 7 days"]</FluentOption>
                </FluentSelect>
            </div>
            <div class="resource-activity-filter-actions">
                <FluentButton Appearance="Appearance.Neutral"
                              Disabled="@IsLoading"
                              OnClick="ApplyFilters">
                    @L["Apply"]
                </FluentButton>
                @if (HasActiveFilters)
                {
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@IsLoading"
                                  OnClick="ClearFilters">
                        @L["Clear"]
                    </FluentButton>
                }
            </div>
        </div>

        @if (Events.Count == 0)
        {
            <div class="empty-state compact">
                <strong>@L["No activity"]</strong>
                <span>@GetEmptyStateMessage()</span>
            </div>
        }
        else
        {
            <div class="resource-activity-list">
                @foreach (var resourceEvent in Events)
                {
                    <article class="resource-activity-event">
                        <div>
                            <strong>@ResourceEventDisplayNames.GetDisplayName(resourceEvent.EventType, L)</strong>
                            <span>@FormatEventMetadata(resourceEvent)</span>
                        </div>
                        <p>@resourceEvent.Message</p>
                        <footer>
                            <time datetime="@resourceEvent.Timestamp.ToString("O", CultureInfo.InvariantCulture)">
                                @FormatTimestamp(resourceEvent.Timestamp)
                            </time>
                            <span class="resource-activity-level @GetLevelClass(resourceEvent.Level)">
                                @resourceEvent.Level
                            </span>
                        </footer>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private IReadOnlyList<ResourceEvent> Events { get; set; } = [];
    private bool IsLoading { get; set; }
    private string? EventTypeFilter { get; set; }
    private string? TriggeredByFilter { get; set; }
    private string SelectedTimeRange { get; set; } = TimeRangeAll;

    private const string TimeRangeAll = "all";
    private const string TimeRangeOneHour = "1h";
    private const string TimeRangeDay = "24h";
    private const string TimeRangeWeek = "7d";

    protected override Task OnParametersSetAsync() => LoadEventsAsync();

    private Task Refresh() => LoadEventsAsync();

    private Task ApplyFilters() => LoadEventsAsync();

    private async Task ClearFilters()
    {
        EventTypeFilter = null;
        TriggeredByFilter = null;
        SelectedTimeRange = TimeRangeAll;
        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            Events = [];
            return;
        }

        IsLoading = true;
        try
        {
            Events = await ResourceEvents.ListResourceEventsAsync(
                new ResourceEventQuery(
                    ResourceId: ResourceId,
                    EventType: NormalizeFilter(EventTypeFilter),
                    TriggeredBy: NormalizeFilter(TriggeredByFilter),
                    Since: GetSinceFilter(),
                    MaxEvents: 100));
        }
        finally
        {
            IsLoading = false;
        }
    }

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(EventTypeFilter) ||
        !string.IsNullOrWhiteSpace(TriggeredByFilter) ||
        !string.Equals(SelectedTimeRange, TimeRangeAll, StringComparison.Ordinal);

    private string GetEventCountLabel() =>
        HasActiveFilters
            ? L["{0} matching events", Events.Count].Value
            : L["{0} events", Events.Count].Value;

    private string GetEmptyStateMessage() =>
        HasActiveFilters
            ? L["No resource activity events match the current filters."].Value
            : L["No resource activity events have been recorded."].Value;

    private DateTimeOffset? GetSinceFilter()
    {
        var now = DateTimeOffset.UtcNow;
        return SelectedTimeRange switch
        {
            TimeRangeOneHour => now.AddHours(-1),
            TimeRangeDay => now.AddDays(-1),
            TimeRangeWeek => now.AddDays(-7),
            _ => null
        };
    }

    private static string? NormalizeFilter(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private string FormatTriggeredBy(ResourceEvent resourceEvent) =>
        string.IsNullOrWhiteSpace(resourceEvent.TriggeredBy)
            ? L["Triggered by system"].Value
            : L["Triggered by {0}", resourceEvent.TriggeredBy].Value;

    private string FormatEventMetadata(ResourceEvent resourceEvent) =>
        L["{0} · {1}", resourceEvent.EventType, FormatTriggeredBy(resourceEvent)].Value;

    private static string FormatTimestamp(DateTimeOffset timestamp) =>
        timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);

    private static string GetLevelClass(string? level) =>
        string.Equals(level, "Warning", StringComparison.OrdinalIgnoreCase)
            ? "warning"
            : string.Equals(level, "Error", StringComparison.OrdinalIgnoreCase)
                ? "error"
                : "information";
}
