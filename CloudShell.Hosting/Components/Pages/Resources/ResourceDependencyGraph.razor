@page "/resources/graph"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IResourceManager ResourceManager
@inject ResourceManagerDisplaySettings DisplaySettings
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@inject CloudShell.UI.Composition.CompositionRegistry Composition

<PageTitle>@L["Resource graph"]</PageTitle>

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Resource Manager"]</span>
        <h1>@L["Resource graph"]</h1>
        <p>@L["Visualize registered resources and their dependency relationships."]</p>
    </div>
    <div class="heading-actions">
        <FluentAnchor Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.Table())"
                      Href="@GetResourcesRoute()">
            @L["Table"]
        </FluentAnchor>
        <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      OnClick="RefreshAsync">
            @L["Refresh"]
        </FluentButton>
    </div>
</section>

<section class="resource-graph-page panel">
    @if (GraphResources.Count == 0)
    {
        <EmptyState Title="@L["No resources in this scope"].Value"
                    Message="@L["Resources that match Resource Manager display settings will appear here."].Value" />
    }
    else
    {
        <div class="resource-graph-summary">
            <div>
                <span>@L["Resources"]</span>
                <strong>@GraphResources.Count</strong>
            </div>
            <div>
                <span>@L["Dependencies"]</span>
                <strong>@DependencyCount</strong>
            </div>
        </div>
    }
    <div class="resource-graph-shell @(GraphResources.Count == 0 ? "empty" : null)">
        <svg class="resource-dependency-graph-canvas" role="img" aria-label="@L["Resource dependency graph"]"></svg>
        <div class="resource-graph-controls" aria-label="@L["Graph controls"]">
            <FluentButton Appearance="Appearance.Stealth"
                          Class="resource-graph-zoom-in"
                          Title="@L["Zoom in"]"
                          aria-label="@L["Zoom in"]">
                <FluentIcon Value="@(new Icons.Regular.Size20.ZoomIn())" />
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth"
                          Class="resource-graph-zoom-out"
                          Title="@L["Zoom out"]"
                          aria-label="@L["Zoom out"]">
                <FluentIcon Value="@(new Icons.Regular.Size20.ZoomOut())" />
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth"
                          Class="resource-graph-reset"
                          Title="@L["Reset view"]"
                          aria-label="@L["Reset view"]">
                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowReset())" />
            </FluentButton>
        </div>
    </div>
</section>

@code {
    private IJSObjectReference? Module { get; set; }

    private DotNetObjectReference<ResourceDependencyGraph>? DotNetReference { get; set; }

    private IReadOnlyList<GraphResource> GraphResources { get; set; } = [];

    private int DependencyCount =>
        GraphResources.Sum(resource => resource.DependsOn.Count);

    protected override async Task OnInitializedAsync()
    {
        ResourceManager.ResourcesChanged += OnResourcesChanged;
        await LoadGraphAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        DotNetReference = DotNetObjectReference.Create(this);
        Module = await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/CloudShell.Hosting/resource-dependency-graph.js");

        await Module.InvokeVoidAsync(
            "initializeResourceDependencyGraph",
            ".resource-dependency-graph-canvas",
            DotNetReference);
        await UpdateGraphAsync();
    }

    [JSInvokable]
    public void OpenResource(string resourceId)
    {
        if (string.IsNullOrWhiteSpace(resourceId))
        {
            return;
        }

        Navigation.NavigateTo(ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId));
    }

    private async Task RefreshAsync()
    {
        await LoadGraphAsync();
        await UpdateGraphAsync();
    }

    private async Task LoadGraphAsync()
    {
        var displaySelection = await DisplaySettings.GetAsync();
        var resources = (await ResourceManager.ListResourcesAsync())
            .Where(displaySelection.ShowsResource)
            .OrderBy(displaySelection.GetResourceSortLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var visibleIds = resources
            .Select(resource => resource.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        GraphResources = resources
            .Select(resource => new GraphResource(
                resource.Id,
                displaySelection.GetResourceLabel(resource),
                displaySelection.GetResourceName(resource),
                resource.EffectiveTypeId,
                resource.ResourceClass.ToString(),
                GetEndpointText(resource),
                GetStateLabel(resource),
                ResourceStateDisplay.GetStateClass(resource.State),
                ResourceManagerCompositionLinks.ResourceDetails(Composition, resource.Id),
                resource.DependsOn
                    .Where(visibleIds.Contains)
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToArray()))
            .ToArray();
    }

    private async Task UpdateGraphAsync()
    {
        if (Module is not null)
        {
            await Module.InvokeVoidAsync("updateResourceDependencyGraph", GraphResources);
        }
    }

    private async void OnResourcesChanged(object? sender, ResourceChangeNotification notification)
    {
        await InvokeAsync(async () =>
        {
            await LoadGraphAsync();
            await UpdateGraphAsync();
            StateHasChanged();
        });
    }

    private static string GetEndpointText(Resource resource)
    {
        var address = resource.ResourceEndpointNetworkMappings.FirstOrDefault()?.Address;
        if (!string.IsNullOrWhiteSpace(address))
        {
            return TryFormatEndpointHost(address) ?? address;
        }

        return resource.Endpoints.Count switch
        {
            0 => "No endpoints",
            1 => "1 endpoint",
            _ => $"{resource.Endpoints.Count} endpoints"
        };
    }

    private static string? TryFormatEndpointHost(string address)
    {
        if (!Uri.TryCreate(address, UriKind.Absolute, out var uri))
        {
            return null;
        }

        return uri.IsDefaultPort
            ? uri.Host
            : $"{uri.Host}:{uri.Port.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private static string GetStateLabel(Resource resource) =>
        resource.State?.ToString() ?? "No lifecycle status";

    private string GetResourcesRoute() =>
        ResourceManagerCompositionLinks.ResourceManagerPage(
            Composition,
            ResourceManagerCompositionIds.ResourcesPage,
            ResourceManagerRoutes.Resources);

    public async ValueTask DisposeAsync()
    {
        ResourceManager.ResourcesChanged -= OnResourcesChanged;

        if (Module is not null)
        {
            await Module.InvokeVoidAsync("disposeResourceDependencyGraph");
            await Module.DisposeAsync();
        }

        DotNetReference?.Dispose();
    }

    private sealed record GraphResource(
        string Id,
        string Label,
        string Name,
        string Type,
        string ResourceClass,
        string EndpointText,
        string StateLabel,
        string StateClass,
        string DetailUrl,
        IReadOnlyList<string> DependsOn);
}
