@page "/resources/graph"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IResourceManager ResourceManager
@inject ResourceManagerDisplaySettings DisplaySettings
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L
@inject ICoreShellRouteService ShellRoutes
@inject ShellCatalog ShellCatalog

<PageTitle>@L["Resource graph"]</PageTitle>

<PageHeading Eyebrow="@L["Resource Manager"].Value"
             Title="@L["Resource graph"].Value"
             Description="@L["Visualize registered resources and their dependency relationships."].Value">
    <Actions>
        <FluentAnchor Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.Table())"
                      Href="@GetResourcesRoute()">
            @L["Table"]
        </FluentAnchor>
        <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      OnClick="RefreshAsync">
            @L["Refresh"]
        </FluentButton>
    </Actions>
</PageHeading>

<section class="resource-graph-page panel">
    @if (Graph.Nodes.Count == 0)
    {
        <EmptyState Title="@L["No resources in this scope"].Value"
                    Message="@L["Resources that match Resource Manager display settings will appear here."].Value" />
    }
    else
    {
        <div class="resource-graph-summary">
            <div>
                <span>@L["Resources"]</span>
                <strong>@Graph.ResourceCount</strong>
            </div>
            <div>
                <span>@L["Dependencies"]</span>
                <strong>@Graph.DependencyCount</strong>
            </div>
            @if (IncludeNetworkTopologyOverlay)
            {
                <div>
                    <span>@L["Topology"]</span>
                    <strong>@Graph.TopologyCount</strong>
                </div>
            }
            <FluentCheckbox Class="resource-graph-topology-toggle"
                            Value="@IncludeImplicitResources"
                            ValueChanged="OnImplicitResourcesChanged">
                @L["Implicit resources"]
            </FluentCheckbox>
            <FluentCheckbox Class="resource-graph-topology-toggle"
                            Value="@IncludeNetworkTopologyOverlay"
                            ValueChanged="OnNetworkTopologyOverlayChanged">
                @L["Network topology"]
            </FluentCheckbox>
        </div>
    }
    <div class="resource-graph-shell @(Graph.Nodes.Count == 0 ? "empty" : null)">
        <svg class="resource-dependency-graph-canvas" role="img" aria-label="@L["Resource dependency graph"]"></svg>
        <div class="resource-graph-controls" aria-label="@L["Graph controls"]">
            <FluentButton Appearance="Appearance.Stealth"
                          Class="resource-graph-zoom-in"
                          Title="@L["Zoom in"]"
                          aria-label="@L["Zoom in"]">
                <FluentIcon Value="@(new Icons.Regular.Size20.ZoomIn())" />
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth"
                          Class="resource-graph-zoom-out"
                          Title="@L["Zoom out"]"
                          aria-label="@L["Zoom out"]">
                <FluentIcon Value="@(new Icons.Regular.Size20.ZoomOut())" />
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth"
                          Class="resource-graph-reset"
                          Title="@L["Reset view"]"
                          aria-label="@L["Reset view"]">
                <FluentIcon Value="@(new Icons.Regular.Size20.ArrowReset())" />
            </FluentButton>
        </div>
    </div>
</section>

@code {
    private IJSObjectReference? Module { get; set; }

    private DotNetObjectReference<ResourceDependencyGraph>? DotNetReference { get; set; }

    private ResourceDependencyGraphModel Graph { get; set; } = ResourceDependencyGraphModel.Empty;

    private bool IncludeNetworkTopologyOverlay { get; set; }

    private bool IncludeImplicitResources { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ResourceManager.ResourcesChanged += OnResourcesChanged;
        await LoadGraphAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        DotNetReference = DotNetObjectReference.Create(this);
        Module = await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/CloudShell.Hosting/resource-dependency-graph.js");

        await Module.InvokeVoidAsync(
            "initializeResourceDependencyGraph",
            ".resource-dependency-graph-canvas",
            DotNetReference);
        await UpdateGraphAsync();
    }

    [JSInvokable]
    public void OpenResource(string resourceId)
    {
        if (string.IsNullOrWhiteSpace(resourceId))
        {
            return;
        }

        Navigation.NavigateTo(ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId));
    }

    private async Task RefreshAsync()
    {
        await LoadGraphAsync();
        await UpdateGraphAsync();
    }

    private async Task LoadGraphAsync()
    {
        var displaySelection = await DisplaySettings.GetAsync();
        var allResources = await ResourceManager.ListResourcesAsync();
        var resources = allResources
            .Where(displaySelection.ShowsResource)
            .Where(resource => IncludeImplicitResources || !ResourceGraphVisibility.IsImplicitDefaultResource(resource))
            .OrderBy(displaySelection.GetResourceSortLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        Graph = ResourceDependencyGraphProjection.Create(
            resources,
            new ResourceDependencyGraphProjectionOptions
            {
                IncludeNetworkTopologyOverlay = IncludeNetworkTopologyOverlay,
                IncludeImplicitResources = IncludeImplicitResources,
                RelationshipResources = allResources,
                GetResourceLabel = displaySelection.GetResourceLabel,
                GetResourceName = displaySelection.GetResourceName,
                GetResourceTypeLabel = GetResourceTypeDisplayName,
                GetResourceIconName = GetResourceTypeIconName,
                CreateResourceDetailUrl = resource => ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resource.Id),
                GetStateClass = ResourceStateDisplay.GetStateClass
            });
    }

    private async Task UpdateGraphAsync()
    {
        if (Module is not null)
        {
            await Module.InvokeVoidAsync("updateResourceDependencyGraph", Graph);
        }
    }

    private async Task OnNetworkTopologyOverlayChanged(bool enabled)
    {
        IncludeNetworkTopologyOverlay = enabled;
        await LoadGraphAsync();
        await UpdateGraphAsync();
    }

    private async Task OnImplicitResourcesChanged(bool enabled)
    {
        IncludeImplicitResources = enabled;
        await LoadGraphAsync();
        await UpdateGraphAsync();
    }

    private async void OnResourcesChanged(object? sender, ResourceChangeNotification notification)
    {
        await InvokeAsync(async () =>
        {
            await LoadGraphAsync();
            await UpdateGraphAsync();
            StateHasChanged();
        });
    }

    private string GetResourcesRoute() =>
        ResourceManagerShellLinks.ResourceManagerPage(ShellRoutes,
            ResourceManagerShellIds.ResourcesPage,
            ResourceManagerRoutes.Resources);

    private string GetResourceTypeDisplayName(Resource resource) =>
        ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase))
            ?.DisplayName ??
        (string.Equals(resource.Kind, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase)
            ? resource.Kind
            : $"{resource.Kind} ({resource.EffectiveTypeId})");

    private string? GetResourceTypeIconName(Resource resource) =>
        ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase))
            ?.Icon ??
        FirstNonEmpty(resource.EffectiveTypeId, resource.ResourceClass.ToString(), resource.Kind);

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    public async ValueTask DisposeAsync()
    {
        ResourceManager.ResourcesChanged -= OnResourcesChanged;

        if (Module is not null)
        {
            await Module.InvokeVoidAsync("disposeResourceDependencyGraph");
            await Module.DisposeAsync();
        }

        DotNetReference?.Dispose();
    }
}
