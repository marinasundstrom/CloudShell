@inject IResourceManager ResourceManager
@inject IResourceRegistrationStore Registrations
@inject IEnumerable<IResourceAppSettingConfigurationProvider> AppSettingProviders
@inject IEnumerable<IResourceEnvironmentVariableConfigurationProvider> EnvironmentVariableProviders
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject IStringLocalizer<SharedResource> L

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <EmptyState Title="@L["Environment variables unavailable"].Value"
                Message="@ErrorMessage" />
}
else if ((AppSettingProvider is null && EnvironmentVariableProvider is null) || Resource is null)
{
    <EmptyState Title="@L["Environment unavailable"].Value"
                Message="@L["No provider is available to configure app settings or environment variables for this resource."].Value" />
}
else
{
    @if (IsReadOnly)
    {
        <ProcedureMessage Compact="true">
            @L["Resource Manager is in read-only mode. Environment editing is disabled in this UI."]
        </ProcedureMessage>
    }

    @if (AppSettingProvider is not null)
    {
        <ResourceEditorSection Class="resource-environment-editor">
            <HeaderContent>
                <strong>@L["App settings"]</strong>
            </HeaderContent>
            <Actions>
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsReadOnly" OnClick="AddAppSetting">
                    @L["Add setting"]
                </FluentButton>
            </Actions>
            <ChildContent>

            @if (AppSettings.Count == 0)
            {
                <EmptyState Title="@L["No app settings"].Value"
                            Message="@L["No app settings are configured."].Value"
                            Compact="true" />
            }
            else
            {
                @foreach (var setting in AppSettings)
                {
                    <div class="resource-environment-row" @key="setting">
                        <FluentTextField AriaLabel="@L["App setting name"]"
                                         Placeholder="ConnectionStrings:Default"
                                         Disabled="@IsReadOnly"
                                         @bind-Value="setting.Name" />
                        <select class="resource-environment-source"
                                aria-label="@L["App setting source"]"
                                disabled="@IsReadOnly"
                                @bind="setting.Source">
                            <option value="@EnvironmentVariableSource.Literal">@L["Custom value"]</option>
                            <option value="@EnvironmentVariableSource.Configuration">@L["Configuration entry"]</option>
                            <option value="@EnvironmentVariableSource.Secret">@L["Secret"]</option>
                        </select>

                        @if (setting.Source == EnvironmentVariableSource.Literal)
                        {
                            <FluentTextField AriaLabel="@L["App setting value"]"
                                             TextFieldType="@GetLiteralValueTextFieldType(setting.Name, setting.HasStoredSensitiveValue)"
                                             Placeholder="@GetLiteralValuePlaceholder(setting.HasStoredSensitiveValue)"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="setting.Value" />
                        }
                        else if (setting.Source == EnvironmentVariableSource.Configuration)
                        {
                            <select class="resource-environment-reference"
                                    aria-label="@L["Configuration store"]"
                                    disabled="@IsReadOnly"
                                    @bind="setting.ReferenceResourceId">
                                <option value="">@L["Select configuration store"]</option>
                                @foreach (var store in ConfigurationStores)
                                {
                                    <option value="@store.Id">@ResourceDisplayLabels.GetQualifiedLabel(store)</option>
                                }
                                @if (IsMissingConfigurationStore(setting.ReferenceResourceId))
                                {
                                    <option value="@setting.ReferenceResourceId">@FormatUnavailableReference(setting.ReferenceResourceId)</option>
                                }
                            </select>
                            <FluentTextField AriaLabel="@L["Configuration entry name"]"
                                             Placeholder="ConnectionStrings:Default"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="setting.ReferenceName" />
                            <FluentTextField AriaLabel="@L["Configuration entry version"]"
                                             Placeholder="@L["Version"]"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="setting.Version" />
                        }
                        else
                        {
                            <select class="resource-environment-reference"
                                    aria-label="@L["Secrets vault"]"
                                    disabled="@IsReadOnly"
                                    @bind="setting.ReferenceResourceId">
                                <option value="">@L["Select Secrets Vault"]</option>
                                @foreach (var vault in SecretsVaults)
                                {
                                    <option value="@vault.Id">@ResourceDisplayLabels.GetQualifiedLabel(vault)</option>
                                }
                                @if (IsMissingSecretsVault(setting.ReferenceResourceId))
                                {
                                    <option value="@setting.ReferenceResourceId">@FormatUnavailableReference(setting.ReferenceResourceId)</option>
                                }
                            </select>
                            <FluentTextField AriaLabel="@L["Secret name"]"
                                             Placeholder="ApiKey"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="setting.ReferenceName" />
                            <FluentTextField AriaLabel="@L["Secret version"]"
                                             Placeholder="@L["Version"]"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="setting.Version" />
                        }

                        <FluentButton Appearance="Appearance.Neutral" Disabled="@IsReadOnly" OnClick="() => RemoveAppSetting(setting)">
                            @L["Remove"]
                        </FluentButton>
                    </div>
                }
            }
            </ChildContent>
        </ResourceEditorSection>
    }

    @if (EnvironmentVariableProvider is not null)
    {
        <ResourceEditorSection Class="resource-environment-editor">
            <HeaderContent>
                <strong>@L["Environment variables"]</strong>
            </HeaderContent>
            <Actions>
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsReadOnly" OnClick="AddVariable">
                    @L["Add variable"]
                </FluentButton>
            </Actions>
            <ChildContent>

            @if (Variables.Count == 0)
            {
                <EmptyState Title="@L["No environment variables"].Value"
                            Message="@L["No environment variables are configured."].Value"
                            Compact="true" />
            }
            else
            {
                @foreach (var variable in Variables)
                {
                    <div class="resource-environment-row" @key="variable">
                        <FluentTextField AriaLabel="@L["Environment variable name"]"
                                         Placeholder="ASPNETCORE_ENVIRONMENT"
                                         Disabled="@IsReadOnly"
                                         @bind-Value="variable.Name" />
                        <select class="resource-environment-source"
                                aria-label="@L["Environment variable source"]"
                                disabled="@IsReadOnly"
                                @bind="variable.Source">
                            <option value="@EnvironmentVariableSource.Literal">@L["Custom value"]</option>
                            <option value="@EnvironmentVariableSource.Configuration">@L["Configuration entry"]</option>
                            <option value="@EnvironmentVariableSource.Secret">@L["Secret"]</option>
                        </select>

                        @if (variable.Source == EnvironmentVariableSource.Literal)
                        {
                            <FluentTextField AriaLabel="@L["Environment variable value"]"
                                             TextFieldType="@GetLiteralValueTextFieldType(variable.Name, variable.HasStoredSensitiveValue)"
                                             Placeholder="@GetLiteralValuePlaceholder(variable.HasStoredSensitiveValue)"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="variable.Value" />
                        }
                        else if (variable.Source == EnvironmentVariableSource.Configuration)
                        {
                            <select class="resource-environment-reference"
                                    aria-label="@L["Configuration store"]"
                                    disabled="@IsReadOnly"
                                    @bind="variable.ReferenceResourceId">
                                <option value="">@L["Select configuration store"]</option>
                                @foreach (var store in ConfigurationStores)
                                {
                                    <option value="@store.Id">@ResourceDisplayLabels.GetQualifiedLabel(store)</option>
                                }
                                @if (IsMissingConfigurationStore(variable.ReferenceResourceId))
                                {
                                    <option value="@variable.ReferenceResourceId">@FormatUnavailableReference(variable.ReferenceResourceId)</option>
                                }
                            </select>
                            <FluentTextField AriaLabel="@L["Configuration entry name"]"
                                             Placeholder="ConnectionStrings:Default"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="variable.ReferenceName" />
                            <FluentTextField AriaLabel="@L["Configuration entry version"]"
                                             Placeholder="@L["Version"]"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="variable.Version" />
                        }
                        else
                        {
                            <select class="resource-environment-reference"
                                    aria-label="@L["Secrets vault"]"
                                    disabled="@IsReadOnly"
                                    @bind="variable.ReferenceResourceId">
                                <option value="">@L["Select Secrets Vault"]</option>
                                @foreach (var vault in SecretsVaults)
                                {
                                    <option value="@vault.Id">@ResourceDisplayLabels.GetQualifiedLabel(vault)</option>
                                }
                                @if (IsMissingSecretsVault(variable.ReferenceResourceId))
                                {
                                    <option value="@variable.ReferenceResourceId">@FormatUnavailableReference(variable.ReferenceResourceId)</option>
                                }
                            </select>
                            <FluentTextField AriaLabel="@L["Secret name"]"
                                             Placeholder="ApiKey"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="variable.ReferenceName" />
                            <FluentTextField AriaLabel="@L["Secret version"]"
                                             Placeholder="@L["Version"]"
                                             Disabled="@IsReadOnly"
                                             @bind-Value="variable.Version" />
                        }

                        <FluentButton Appearance="Appearance.Neutral" Disabled="@IsReadOnly" OnClick="() => RemoveVariable(variable)">
                            @L["Remove"]
                        </FluentButton>
                    </div>
                }
            }
            </ChildContent>
        </ResourceEditorSection>
    }
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private IResourceAppSettingConfigurationProvider? AppSettingProvider { get; set; }
    private IResourceEnvironmentVariableConfigurationProvider? EnvironmentVariableProvider { get; set; }
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private string? LoadedResourceId { get; set; }
    private string? ErrorMessage { get; set; }
    private List<AppSettingInput> AppSettings { get; } = [];
    private List<EnvironmentVariableInput> Variables { get; } = [];
    private IReadOnlyList<Resource> ConfigurationStores { get; set; } = [];
    private IReadOnlyList<Resource> SecretsVaults { get; set; } = [];
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(LoadedResourceId, ResourceId, StringComparison.OrdinalIgnoreCase))
        {
            await LoadAsync();
        }

        if (Configuration is not null &&
            !ReferenceEquals(RegisteredConfiguration, Configuration) &&
            (AppSettingProvider is not null || EnvironmentVariableProvider is not null))
        {
            RegisteredConfiguration = Configuration;
            Configuration.SetApplyHandler(ApplyAsync);
        }
    }

    private async Task LoadAsync()
    {
        LoadedResourceId = ResourceId;
        ErrorMessage = null;
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        var resources = await ResourceManager.ListResourcesAsync();
        ConfigurationStores = resources
            .Where(IsConfigurationStore)
            .OrderBy(ResourceDisplayLabels.GetQualifiedLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        SecretsVaults = resources
            .Where(IsSecretsVault)
            .OrderBy(ResourceDisplayLabels.GetQualifiedLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        AppSettingProvider = Resource is null
            ? null
            : AppSettingProviders.FirstOrDefault(provider =>
                provider.CanConfigureAppSettings(Resource));
        EnvironmentVariableProvider = Resource is null
            ? null
            : EnvironmentVariableProviders.FirstOrDefault(provider =>
                provider.CanConfigureEnvironmentVariables(Resource));

        AppSettings.Clear();
        if (AppSettingProvider is not null && Resource is not null)
        {
            AppSettings.AddRange(AppSettingProvider
                .GetConfiguredAppSettings(Resource.Id)
                .Select(AppSettingInput.FromSetting));
        }

        Variables.Clear();
        if (EnvironmentVariableProvider is not null && Resource is not null)
        {
            Variables.AddRange(EnvironmentVariableProvider
                .GetConfiguredEnvironmentVariables(Resource.Id)
                .Select(EnvironmentVariableInput.FromAssignment));
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (IsReadOnly)
        {
            return ResourceManagerUiState.ReadOnlyResult();
        }

        if ((AppSettingProvider is null && EnvironmentVariableProvider is null) || Resource is null)
        {
            return ResourceProcedureResult.Completed("No app setting or environment variable provider is available.");
        }

        var invalidSetting = AppSettings.FirstOrDefault(setting => !setting.IsValid());
        if (invalidSetting is not null)
        {
            return ResourceProcedureResult.Completed(
                $"App setting '{invalidSetting.DisplayName}' is incomplete.");
        }

        var invalidVariable = Variables.FirstOrDefault(variable => !variable.IsValid());
        if (invalidVariable is not null)
        {
            return ResourceProcedureResult.Completed(
                $"Environment variable '{invalidVariable.DisplayName}' is incomplete.");
        }

        var registration = await ResourceManager.GetResourceRegistrationAsync(Resource.Id, cancellationToken);
        var group = await ResourceManager.GetResourceGroupForResourceAsync(Resource.Id, cancellationToken);
        var context = new ResourceProcedureContext(
            Resource,
            registration,
            group?.Id,
            Registrations);
        var results = new List<ResourceProcedureResult>();
        if (AppSettingProvider is not null)
        {
            results.Add(await AppSettingProvider.UpdateAppSettingsAsync(
                context,
                BuildAppSettings(),
                cancellationToken));
        }

        if (EnvironmentVariableProvider is not null)
        {
            results.Add(await EnvironmentVariableProvider.UpdateEnvironmentVariablesAsync(
                context,
                BuildAssignments(),
                cancellationToken));
        }

        return ResourceProcedureResult.Combine(results, "No settings were updated.");
    }

    private IReadOnlyList<AppSetting> BuildAppSettings() =>
        AppSettings
            .Where(setting => !string.IsNullOrWhiteSpace(setting.Name))
            .Select(setting => setting.ToSetting())
            .ToArray();

    private IReadOnlyList<EnvironmentVariableAssignment> BuildAssignments() =>
        Variables
            .Where(variable => !string.IsNullOrWhiteSpace(variable.Name))
            .Select(variable => variable.ToAssignment())
            .ToArray();

    private void AddAppSetting() => AppSettings.Add(new());

    private void RemoveAppSetting(AppSettingInput setting) => AppSettings.Remove(setting);

    private void AddVariable() => Variables.Add(new());

    private void RemoveVariable(EnvironmentVariableInput variable) => Variables.Remove(variable);

    private static bool IsConfigurationStore(Resource resource) =>
        resource.ResourceClass == ResourceClass.Configuration &&
        !IsSecretsVault(resource);

    private static bool IsSecretsVault(Resource resource) =>
        resource.ResourceClass == ResourceClass.SecretsVault ||
        string.Equals(resource.EffectiveTypeId, "secrets.vault", StringComparison.OrdinalIgnoreCase);

    private bool IsMissingConfigurationStore(string? resourceId) =>
        !string.IsNullOrWhiteSpace(resourceId) &&
        ConfigurationStores.All(resource =>
            !string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase));

    private bool IsMissingSecretsVault(string? resourceId) =>
        !string.IsNullOrWhiteSpace(resourceId) &&
        SecretsVaults.All(resource =>
            !string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase));

    private static string FormatUnavailableReference(string? resourceId) =>
        string.IsNullOrWhiteSpace(resourceId)
            ? "Missing resource"
            : $"{ResourceDisplayLabels.GetName(resourceId)} (missing resource)";

    private static TextFieldType GetLiteralValueTextFieldType(string? name, bool hasStoredSensitiveValue) =>
        hasStoredSensitiveValue || ResourceSettingDisplay.IsSensitiveLiteralName(name)
            ? TextFieldType.Password
            : TextFieldType.Text;

    private string? GetLiteralValuePlaceholder(bool hasStoredSensitiveValue) =>
        hasStoredSensitiveValue ? L["Stored value hidden"].Value : null;

    private sealed class AppSettingInput
    {
        public string? Name { get; set; }

        public string? OriginalName { get; set; }

        public EnvironmentVariableSource Source { get; set; }

        public string? Value { get; set; }

        public string? StoredSensitiveValue { get; set; }

        public string? ReferenceResourceId { get; set; }

        public string? ReferenceName { get; set; }

        public string? Version { get; set; }

        public string DisplayName =>
            string.IsNullOrWhiteSpace(Name) ? "(unnamed)" : Name.Trim();

        public bool HasStoredSensitiveValue =>
            Source == EnvironmentVariableSource.Literal &&
            !string.IsNullOrWhiteSpace(StoredSensitiveValue) &&
            string.Equals(OriginalName, Name, StringComparison.OrdinalIgnoreCase);

        public static AppSettingInput FromSetting(AppSetting setting)
        {
            if (setting.ConfigurationSetting is not null)
            {
                return new AppSettingInput
                {
                    Name = setting.Name,
                    OriginalName = setting.Name,
                    Source = EnvironmentVariableSource.Configuration,
                    ReferenceResourceId = setting.ConfigurationSetting.StoreResourceId,
                    ReferenceName = setting.ConfigurationSetting.SettingName,
                    Version = setting.ConfigurationSetting.Version
                };
            }

            if (setting.Secret is not null)
            {
                return new AppSettingInput
                {
                    Name = setting.Name,
                    OriginalName = setting.Name,
                    Source = EnvironmentVariableSource.Secret,
                    ReferenceResourceId = setting.Secret.VaultResourceId,
                    ReferenceName = setting.Secret.SecretName,
                    Version = setting.Secret.Version
                };
            }

            return new AppSettingInput
            {
                Name = setting.Name,
                OriginalName = setting.Name,
                Source = EnvironmentVariableSource.Literal,
                Value = ResourceSettingDisplay.IsSensitiveLiteralName(setting.Name) ? null : setting.Value,
                StoredSensitiveValue = ResourceSettingDisplay.IsSensitiveLiteralName(setting.Name)
                    ? setting.Value
                    : null
            };
        }

        public bool IsValid() =>
            string.IsNullOrWhiteSpace(Name) ||
            Source == EnvironmentVariableSource.Literal ||
            (!string.IsNullOrWhiteSpace(ReferenceResourceId) &&
             !string.IsNullOrWhiteSpace(ReferenceName));

        public AppSetting ToSetting()
        {
            var name = Name?.Trim() ?? string.Empty;
            return Source switch
            {
                EnvironmentVariableSource.Configuration => AppSetting.FromConfiguration(
                    name,
                    new ConfigurationSettingReference(
                        ReferenceResourceId?.Trim() ?? string.Empty,
                        ReferenceName?.Trim() ?? string.Empty,
                        Normalize(Version))),
                EnvironmentVariableSource.Secret => AppSetting.FromSecret(
                    name,
                    new SecretReference(
                        ReferenceResourceId?.Trim() ?? string.Empty,
                        ReferenceName?.Trim() ?? string.Empty,
                        Normalize(Version))),
                _ => AppSetting.Literal(name, ResolveLiteralValue())
            };
        }

        private string ResolveLiteralValue() =>
            HasStoredSensitiveValue && string.IsNullOrEmpty(Value)
                ? StoredSensitiveValue ?? string.Empty
                : Value ?? string.Empty;

        private static string? Normalize(string? value) =>
            string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private sealed class EnvironmentVariableInput
    {
        public string? Name { get; set; }

        public string? OriginalName { get; set; }

        public EnvironmentVariableSource Source { get; set; }

        public string? Value { get; set; }

        public string? StoredSensitiveValue { get; set; }

        public string? ReferenceResourceId { get; set; }

        public string? ReferenceName { get; set; }

        public string? Version { get; set; }

        public string DisplayName =>
            string.IsNullOrWhiteSpace(Name) ? "(unnamed)" : Name.Trim();

        public bool HasStoredSensitiveValue =>
            Source == EnvironmentVariableSource.Literal &&
            !string.IsNullOrWhiteSpace(StoredSensitiveValue) &&
            string.Equals(OriginalName, Name, StringComparison.OrdinalIgnoreCase);

        public static EnvironmentVariableInput FromAssignment(EnvironmentVariableAssignment assignment)
        {
            if (assignment.ConfigurationSetting is not null)
            {
                return new EnvironmentVariableInput
                {
                    Name = assignment.Name,
                    OriginalName = assignment.Name,
                    Source = EnvironmentVariableSource.Configuration,
                    ReferenceResourceId = assignment.ConfigurationSetting.StoreResourceId,
                    ReferenceName = assignment.ConfigurationSetting.SettingName,
                    Version = assignment.ConfigurationSetting.Version
                };
            }

            if (assignment.Secret is not null)
            {
                return new EnvironmentVariableInput
                {
                    Name = assignment.Name,
                    OriginalName = assignment.Name,
                    Source = EnvironmentVariableSource.Secret,
                    ReferenceResourceId = assignment.Secret.VaultResourceId,
                    ReferenceName = assignment.Secret.SecretName,
                    Version = assignment.Secret.Version
                };
            }

            return new EnvironmentVariableInput
            {
                Name = assignment.Name,
                OriginalName = assignment.Name,
                Source = EnvironmentVariableSource.Literal,
                Value = ResourceSettingDisplay.IsSensitiveLiteralName(assignment.Name) ? null : assignment.Value,
                StoredSensitiveValue = ResourceSettingDisplay.IsSensitiveLiteralName(assignment.Name)
                    ? assignment.Value
                    : null
            };
        }

        public bool IsValid() =>
            string.IsNullOrWhiteSpace(Name) ||
            Source == EnvironmentVariableSource.Literal ||
            (!string.IsNullOrWhiteSpace(ReferenceResourceId) &&
             !string.IsNullOrWhiteSpace(ReferenceName));

        public EnvironmentVariableAssignment ToAssignment()
        {
            var name = Name?.Trim() ?? string.Empty;
            return Source switch
            {
                EnvironmentVariableSource.Configuration => EnvironmentVariableAssignment.FromConfiguration(
                    name,
                    new ConfigurationSettingReference(
                        ReferenceResourceId?.Trim() ?? string.Empty,
                        ReferenceName?.Trim() ?? string.Empty,
                        Normalize(Version))),
                EnvironmentVariableSource.Secret => EnvironmentVariableAssignment.FromSecret(
                    name,
                    new SecretReference(
                        ReferenceResourceId?.Trim() ?? string.Empty,
                        ReferenceName?.Trim() ?? string.Empty,
                        Normalize(Version))),
                _ => new EnvironmentVariableAssignment(name, ResolveLiteralValue())
            };
        }

        private string ResolveLiteralValue() =>
            HasStoredSensitiveValue && string.IsNullOrEmpty(Value)
                ? StoredSensitiveValue ?? string.Empty
                : Value ?? string.Empty;

        private static string? Normalize(string? value) =>
            string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private enum EnvironmentVariableSource
    {
        Literal,
        Configuration,
        Secret
    }
}
