@page "/resources/settings"
@rendermode InteractiveServer
@inject IEnumerable<IResourceOrchestrator> Orchestrators
@inject IEnumerable<IContainerHostProvider> ContainerHostProviders
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject IResourceOrchestrationCatalog OrchestrationCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Resource Manager settings"]</PageTitle>

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Resource Manager"]</span>
        <h1>@L["Settings"]</h1>
        <p>@L["Choose which orchestrator handles lifecycle actions for the resource graph."]</p>
    </div>
    <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
        @L["Close"]
    </FluentButton>
</section>

<section class="registration-layout">
    <aside class="panel registration-options">
        <h2>@L["Orchestration"]</h2>
        <div class="selected-type-card">
            <span class="resource-kind-icon">O</span>
            <div>
                <strong>@GetCurrentOrchestratorName()</strong>
                <p>@L["Active orchestrator"]</p>
            </div>
        </div>
        <div class="selected-type-card">
            <span class="resource-kind-icon">H</span>
            <div>
                <strong>@L["{0}s", GetEffectiveHealthCheckInterval().Seconds]</strong>
                <p>@(GetEffectiveHealthCheckInterval().IsConfigured
                    ? L["Health interval from appsettings"]
                    : L["Health interval from settings"])</p>
            </div>
        </div>
    </aside>

    <div class="panel registration-host">
        <div class="panel-header">
            <div>
                <h2>@L["Resource orchestrator"]</h2>
                <p>@L["Changing orchestrators can alter how networking, public exposure, and lifecycle commands are applied."]</p>
            </div>
        </div>

        <div class="form-panel">
            <div class="procedure-message">
                <strong>@L["CloudShell modes"]</strong>
                <span>@L["Local dev mode uses the default orchestrator for Aspire-like local resources and resource-owned endpoints. On-premise mode selects an orchestrator such as Docker Compose to own lifecycle, networking, and exposure. Container host registration is independent from orchestrator selection."]</span>
            </div>

            @foreach (var warning in ConfigurationWarnings)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Configuration warning"]</strong>
                    <span>@warning</span>
                </div>
            }

            <label for="orchestrator-id">@L["Orchestrator"]</label>
            <FluentSelect TOption="string"
                          Id="orchestrator-id"
                          @bind-Value="SelectedOrchestratorId"
                          Appearance="Appearance.Outline">
                @foreach (var orchestrator in GetOrchestrators())
                {
                    <FluentOption TOption="string" Value="@orchestrator.Id">@orchestrator.DisplayName (@orchestrator.Id)</FluentOption>
                }
            </FluentSelect>

            <label for="container-host-id">@L["Preferred container host"]</label>
            <FluentSelect TOption="string"
                          Id="container-host-id"
                          @bind-Value="SelectedContainerHostId"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">@L["Host environment"]</FluentOption>
                @foreach (var host in ContainerHosts)
                {
                    <FluentOption TOption="string" Value="@host.Id">@host.DisplayName</FluentOption>
                }
            </FluentSelect>

            <label for="health-check-interval-seconds">@L["Health check interval"]</label>
            <FluentNumberField TValue="int"
                               Id="health-check-interval-seconds"
                               Min="@ResourceOrchestratorSelectionDefaults.MinimumHealthCheckIntervalSeconds.ToString()"
                               Max="@ResourceOrchestratorSelectionDefaults.MaximumHealthCheckIntervalSeconds.ToString()"
                               Step="1"
                               Disabled="@IsHealthCheckIntervalConfigured"
                               @bind-Value="SelectedHealthCheckIntervalSeconds" />
            <small>
                @if (IsHealthCheckIntervalConfigured)
                {
                    @L["appsettings ResourceManager:HealthCheckIntervalSeconds is overriding this setting."]
                }
                else
                {
                    @L["CloudShell probes supported resources on this interval while the Resources page is open."]
                }
            </small>

            @if (PendingChange)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Apply resource settings?"]</strong>
                    <span>@L["Existing resources are not migrated automatically when the orchestrator changes. The new settings apply to future lifecycle actions and health checks."]</span>
                    <div class="form-actions">
                        <FluentButton Appearance="Appearance.Neutral" OnClick="CancelChange">
                            @L["Cancel"]
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmChange">
                            @L["Apply settings"]
                        </FluentButton>
                    </div>
                </div>
            }
            else
            {
                <div class="form-actions">
                    <FluentButton Appearance="Appearance.Accent"
                                  Disabled="@(!CanApply)"
                                  OnClick="RequestChange">
                        @L["Apply"]
                    </FluentButton>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private string SelectedOrchestratorId { get; set; } = "default";
    private string? SelectedContainerHostId { get; set; }
    private int SelectedHealthCheckIntervalSeconds { get; set; } =
        ResourceOrchestratorSelectionDefaults.DefaultHealthCheckIntervalSeconds;
    private IReadOnlyList<ContainerHostOption> ContainerHosts { get; set; } = [];
    private IReadOnlyList<string> ConfigurationWarnings { get; set; } = [];
    private ResourceOrchestrationCatalogSnapshot OrchestrationSnapshot { get; set; } =
        ResourceOrchestrationCatalogSnapshot.Empty;
    private bool PendingChange { get; set; }

    private bool IsHealthCheckIntervalConfigured =>
        OrchestrationSettings.GetHealthCheckIntervalSettings().IsConfigured;

    private bool CanApply =>
        !string.Equals(
            SelectedOrchestratorId,
            OrchestrationSettings.Get().OrchestratorId,
            StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(
            NormalizeOptional(SelectedContainerHostId),
            OrchestrationSettings.Get().PreferredContainerHostId,
            StringComparison.OrdinalIgnoreCase) ||
        (!IsHealthCheckIntervalConfigured &&
            ResourceOrchestratorSelectionDefaults.NormalizeHealthCheckInterval(SelectedHealthCheckIntervalSeconds) !=
            OrchestrationSettings.Get().HealthCheckIntervalSeconds);

    protected override async Task OnInitializedAsync()
    {
        if (!Authorization.HasPermission(CloudShellPermissions.Resources.Manage))
        {
            Navigation.NavigateTo("/account/access-denied");
            return;
        }

        var selection = OrchestrationSettings.Get();
        SelectedOrchestratorId = selection.OrchestratorId;
        SelectedContainerHostId = selection.PreferredContainerHostId;
        SelectedHealthCheckIntervalSeconds = selection.HealthCheckIntervalSeconds;
        OrchestrationSnapshot = await OrchestrationCatalog.GetSnapshotAsync();
        ContainerHosts = GetContainerHosts();
        ConfigurationWarnings = GetConfigurationWarnings();
    }

    private IReadOnlyList<IResourceOrchestrator> GetOrchestrators() =>
        Orchestrators
            .OrderBy(orchestrator => orchestrator.Id == "default" ? 0 : 1)
            .ThenBy(orchestrator => orchestrator.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string GetCurrentOrchestratorName()
    {
        var current = OrchestrationSettings.Get().OrchestratorId;
        return GetOrchestrators().FirstOrDefault(orchestrator =>
                string.Equals(orchestrator.Id, current, StringComparison.OrdinalIgnoreCase))
            ?.DisplayName
            ?? current;
    }

    private void RequestChange()
    {
        PendingChange = true;
    }

    private void CancelChange()
    {
        var selection = OrchestrationSettings.Get();
        SelectedOrchestratorId = selection.OrchestratorId;
        SelectedContainerHostId = selection.PreferredContainerHostId;
        SelectedHealthCheckIntervalSeconds = selection.HealthCheckIntervalSeconds;
        ConfigurationWarnings = GetConfigurationWarnings();
        PendingChange = false;
    }

    private void ConfirmChange()
    {
        OrchestrationSettings.Select(
            SelectedOrchestratorId,
            SelectedContainerHostId,
            SelectedHealthCheckIntervalSeconds);
        SelectedHealthCheckIntervalSeconds = OrchestrationSettings.Get().HealthCheckIntervalSeconds;
        ConfigurationWarnings = GetConfigurationWarnings();
        PendingChange = false;
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private ResourceHealthCheckIntervalSettings GetEffectiveHealthCheckInterval() =>
        OrchestrationSettings.GetHealthCheckIntervalSettings();

    private IReadOnlyList<ContainerHostOption> GetContainerHosts() =>
        ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id))
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .Select(host => new ContainerHostOption(
                host.Id,
                host.IsDefault
                    ? $"{host.Name} ({L["default"]})"
                    : host.Name))
            .OrderBy(host => host.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<string> GetConfigurationWarnings()
    {
        var warnings = new List<string>();
        var hosts = GetContainerHostDefinitions();
        var selectedHostId = NormalizeOptional(SelectedContainerHostId);
        var hasDefaultHost = hosts.Any(host => host.IsDefault);

        if (!string.IsNullOrWhiteSpace(selectedHostId) &&
            !hosts.Any(host => string.Equals(host.Id, selectedHostId, StringComparison.OrdinalIgnoreCase)))
        {
            warnings.Add(L["Preferred container host '{0}' is not registered.", selectedHostId]);
        }

        foreach (var resource in OrchestrationSnapshot.Resources)
        {
            AddNetworkConfigurationWarnings(warnings, resource, OrchestrationSnapshot.Resources);

            var workload = TryReadWorkload(resource);
            if (workload?.Kind is not (ResourceWorkloadKind.ContainerImage or ResourceWorkloadKind.ContainerBuild))
            {
                continue;
            }

            var hostId = NormalizeOptional(workload.ContainerHostId) ?? selectedHostId;
            if (!string.IsNullOrWhiteSpace(hostId))
            {
                if (!hosts.Any(host => string.Equals(host.Id, hostId, StringComparison.OrdinalIgnoreCase)))
                {
                    warnings.Add(L["Container resource '{0}' references container host '{1}', but that host is not registered.", resource.Name, hostId]);
                }

                continue;
            }

            if (!hasDefaultHost)
            {
                warnings.Add(L["Container resource '{0}' does not specify a container host and no default container host is registered.", resource.Name]);
            }
        }

        return warnings
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private void AddNetworkConfigurationWarnings(
        List<string> warnings,
        Resource resource,
        IReadOnlyList<Resource> resources)
    {
        if (resource.ResourceClass != ResourceClass.Network ||
            !resource.HasCapability(ResourceCapabilityIds.NetworkingVirtualNetwork))
        {
            return;
        }

        if (!resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkHostReadiness, out var readiness) ||
            string.IsNullOrWhiteSpace(readiness))
        {
            return;
        }

        if (string.Equals(readiness, "logicalOnly", StringComparison.OrdinalIgnoreCase))
        {
            warnings.Add(L["Virtual network '{0}' is using host-local logical networking because no host networking service is active. Activate a gateway, load balancer, or network controller provider to configure real virtual-network routing.", resource.Name]);
            return;
        }

        if (!string.Equals(readiness, "providerRequired", StringComparison.OrdinalIgnoreCase) ||
            !resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkMappingProviders, out var providerList))
        {
            return;
        }

        var missingProviders = providerList
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(providerId => !resources.Any(candidate =>
                string.Equals(candidate.Id, providerId, StringComparison.OrdinalIgnoreCase)))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (missingProviders.Length == 0)
        {
            return;
        }

        warnings.Add(L["Virtual network '{0}' requires host networking provider '{1}', but it is not active on this host.", resource.Name, string.Join(", ", missingProviders)]);
    }

    private IReadOnlyList<ContainerHostDescriptor> GetContainerHostDefinitions()
    {
        var configuredHosts = ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id))
            .ToArray();
        var resourceHosts = OrchestrationSnapshot.ContainerHosts.Values;

        return configuredHosts
            .Concat(resourceHosts)
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .ToArray();
    }

    private ResourceWorkloadConfiguration? TryReadWorkload(Resource resource) =>
        OrchestrationSnapshot.Workloads.GetValueOrDefault(resource.Id);

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record ContainerHostOption(
        string Id,
        string DisplayName);
}
