@page "/resources/settings"
@using System.Text.Json
@rendermode InteractiveServer
@inject IEnumerable<IResourceOrchestrator> Orchestrators
@inject IEnumerable<IContainerEngineProvider> ContainerEngineProviders
@inject IEnumerable<IResourceOrchestrationDescriptorProvider> DescriptorProviders
@inject IResourceManagerStore ResourceManager
@inject IResourceRegistrationStore Registrations
@inject ResourceOrchestratorSelectionStore SelectionStore
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Resource Manager settings"]</PageTitle>

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Resource Manager"]</span>
        <h1>@L["Settings"]</h1>
        <p>@L["Choose which orchestrator handles lifecycle actions for the resource graph."]</p>
    </div>
    <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
        @L["Close"]
    </FluentButton>
</section>

<section class="registration-layout">
    <aside class="panel registration-options">
        <h2>@L["Orchestration"]</h2>
        <div class="selected-type-card">
            <span class="resource-kind-icon">O</span>
            <div>
                <strong>@GetCurrentOrchestratorName()</strong>
                <p>@L["Active orchestrator"]</p>
            </div>
        </div>
        <div class="selected-type-card">
            <span class="resource-kind-icon">H</span>
            <div>
                <strong>@L["{0}s", GetEffectiveHealthCheckInterval().Seconds]</strong>
                <p>@(GetEffectiveHealthCheckInterval().IsConfigured
                    ? L["Health interval from appsettings"]
                    : L["Health interval from settings"])</p>
            </div>
        </div>
    </aside>

    <div class="panel registration-host">
        <div class="panel-header">
            <div>
                <h2>@L["Resource orchestrator"]</h2>
                <p>@L["Changing orchestrators can alter how networking, public exposure, and lifecycle commands are applied."]</p>
            </div>
        </div>

        <div class="form-panel">
            <div class="procedure-message">
                <strong>@L["CloudShell modes"]</strong>
                <span>@L["Local dev mode uses the default orchestrator for Aspire-like local resources and resource-owned endpoints. On-premise mode selects an orchestrator such as Docker Compose to own lifecycle, networking, and exposure. Container engine registration is independent from orchestrator selection."]</span>
            </div>

            @foreach (var warning in ConfigurationWarnings)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Configuration warning"]</strong>
                    <span>@warning</span>
                </div>
            }

            <label for="orchestrator-id">@L["Orchestrator"]</label>
            <FluentSelect TOption="string"
                          Id="orchestrator-id"
                          @bind-Value="SelectedOrchestratorId"
                          Appearance="Appearance.Outline">
                @foreach (var orchestrator in GetOrchestrators())
                {
                    <FluentOption TOption="string" Value="@orchestrator.Id">@orchestrator.DisplayName (@orchestrator.Id)</FluentOption>
                }
            </FluentSelect>

            <label for="container-engine-id">@L["Preferred container engine"]</label>
            <FluentSelect TOption="string"
                          Id="container-engine-id"
                          @bind-Value="SelectedContainerEngineId"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">@L["Host environment"]</FluentOption>
                @foreach (var engine in ContainerEngines)
                {
                    <FluentOption TOption="string" Value="@engine.Id">@engine.DisplayName</FluentOption>
                }
            </FluentSelect>

            <label for="health-check-interval-seconds">@L["Health check interval"]</label>
            <FluentNumberField TValue="int"
                               Id="health-check-interval-seconds"
                               Min="@ResourceOrchestratorSelectionStore.MinimumHealthCheckIntervalSeconds.ToString()"
                               Max="@ResourceOrchestratorSelectionStore.MaximumHealthCheckIntervalSeconds.ToString()"
                               Step="1"
                               Disabled="@IsHealthCheckIntervalConfigured"
                               @bind-Value="SelectedHealthCheckIntervalSeconds" />
            <small>
                @if (IsHealthCheckIntervalConfigured)
                {
                    @L["appsettings ResourceManager:HealthCheckIntervalSeconds is overriding this setting."]
                }
                else
                {
                    @L["CloudShell probes supported resources on this interval while the Resources page is open."]
                }
            </small>

            @if (PendingChange)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Apply resource settings?"]</strong>
                    <span>@L["Existing resources are not migrated automatically when the orchestrator changes. The new settings apply to future lifecycle actions and health checks."]</span>
                    <div class="form-actions">
                        <FluentButton Appearance="Appearance.Neutral" OnClick="CancelChange">
                            @L["Cancel"]
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmChange">
                            @L["Apply settings"]
                        </FluentButton>
                    </div>
                </div>
            }
            else
            {
                <div class="form-actions">
                    <FluentButton Appearance="Appearance.Accent"
                                  Disabled="@(!CanApply)"
                                  OnClick="RequestChange">
                        @L["Apply"]
                    </FluentButton>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private string SelectedOrchestratorId { get; set; } = "default";
    private string? SelectedContainerEngineId { get; set; }
    private int SelectedHealthCheckIntervalSeconds { get; set; } =
        ResourceOrchestratorSelectionStore.DefaultHealthCheckIntervalSeconds;
    private IReadOnlyList<ContainerEngineOption> ContainerEngines { get; set; } = [];
    private IReadOnlyList<string> ConfigurationWarnings { get; set; } = [];
    private bool PendingChange { get; set; }

    private bool IsHealthCheckIntervalConfigured =>
        SelectionStore.GetHealthCheckIntervalSettings().IsConfigured;

    private bool CanApply =>
        !string.Equals(
            SelectedOrchestratorId,
            SelectionStore.Get().OrchestratorId,
            StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(
            NormalizeOptional(SelectedContainerEngineId),
            SelectionStore.Get().PreferredContainerEngineId,
            StringComparison.OrdinalIgnoreCase) ||
        (!IsHealthCheckIntervalConfigured &&
            ResourceOrchestratorSelectionStore.NormalizeHealthCheckInterval(SelectedHealthCheckIntervalSeconds) !=
            SelectionStore.Get().HealthCheckIntervalSeconds);

    protected override void OnInitialized()
    {
        if (!Authorization.HasPermission(CloudShellPermissions.Resources.Manage))
        {
            Navigation.NavigateTo("/account/access-denied");
            return;
        }

        var selection = SelectionStore.Get();
        SelectedOrchestratorId = selection.OrchestratorId;
        SelectedContainerEngineId = selection.PreferredContainerEngineId;
        SelectedHealthCheckIntervalSeconds = selection.HealthCheckIntervalSeconds;
        ContainerEngines = GetContainerEngines();
        ConfigurationWarnings = GetConfigurationWarnings();
    }

    private IReadOnlyList<IResourceOrchestrator> GetOrchestrators() =>
        Orchestrators
            .OrderBy(orchestrator => orchestrator.Id == "default" ? 0 : 1)
            .ThenBy(orchestrator => orchestrator.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string GetCurrentOrchestratorName()
    {
        var current = SelectionStore.Get().OrchestratorId;
        return GetOrchestrators().FirstOrDefault(orchestrator =>
                string.Equals(orchestrator.Id, current, StringComparison.OrdinalIgnoreCase))
            ?.DisplayName
            ?? current;
    }

    private void RequestChange()
    {
        PendingChange = true;
    }

    private void CancelChange()
    {
        var selection = SelectionStore.Get();
        SelectedOrchestratorId = selection.OrchestratorId;
        SelectedContainerEngineId = selection.PreferredContainerEngineId;
        SelectedHealthCheckIntervalSeconds = selection.HealthCheckIntervalSeconds;
        ConfigurationWarnings = GetConfigurationWarnings();
        PendingChange = false;
    }

    private void ConfirmChange()
    {
        SelectionStore.Select(
            SelectedOrchestratorId,
            SelectedContainerEngineId,
            SelectedHealthCheckIntervalSeconds);
        SelectedHealthCheckIntervalSeconds = SelectionStore.Get().HealthCheckIntervalSeconds;
        ConfigurationWarnings = GetConfigurationWarnings();
        PendingChange = false;
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private ResourceHealthCheckIntervalSettings GetEffectiveHealthCheckInterval() =>
        SelectionStore.GetHealthCheckIntervalSettings();

    private IReadOnlyList<ContainerEngineOption> GetContainerEngines() =>
        ContainerEngineProviders
            .Select(provider => provider.GetContainerEngine())
            .Where(engine => !string.IsNullOrWhiteSpace(engine.Id))
            .GroupBy(engine => engine.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .Select(engine => new ContainerEngineOption(
                engine.Id,
                engine.IsDefault
                    ? $"{engine.Name} ({L["default"]})"
                    : engine.Name))
            .OrderBy(engine => engine.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<string> GetConfigurationWarnings()
    {
        var warnings = new List<string>();
        var engines = GetContainerEngineDefinitions();
        var selectedEngineId = NormalizeOptional(SelectedContainerEngineId);
        var hasDefaultEngine = engines.Any(engine => engine.IsDefault);

        if (!string.IsNullOrWhiteSpace(selectedEngineId) &&
            !engines.Any(engine => string.Equals(engine.Id, selectedEngineId, StringComparison.OrdinalIgnoreCase)))
        {
            warnings.Add(L["Preferred container engine '{0}' is not registered.", selectedEngineId]);
        }

        foreach (var resource in ResourceManager.GetResources())
        {
            var workload = TryReadWorkload(resource);
            if (workload?.Kind is not (ResourceWorkloadKind.ContainerImage or ResourceWorkloadKind.ContainerBuild))
            {
                continue;
            }

            var engineId = NormalizeOptional(workload.ContainerEngineId) ?? selectedEngineId;
            if (!string.IsNullOrWhiteSpace(engineId))
            {
                if (!engines.Any(engine => string.Equals(engine.Id, engineId, StringComparison.OrdinalIgnoreCase)))
                {
                    warnings.Add(L["Container resource '{0}' references container engine '{1}', but that engine is not registered.", resource.Name, engineId]);
                }

                continue;
            }

            if (!hasDefaultEngine)
            {
                warnings.Add(L["Container resource '{0}' does not specify a container engine and no default container engine is registered.", resource.Name]);
            }
        }

        return warnings
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private IReadOnlyList<ContainerEngineResourceDefinition> GetContainerEngineDefinitions()
    {
        var configuredEngines = ContainerEngineProviders
            .Select(provider => provider.GetContainerEngine())
            .Where(engine => !string.IsNullOrWhiteSpace(engine.Id))
            .ToArray();
        var resourceEngines = ResourceManager
            .GetResources()
            .Select(TryReadContainerEngine)
            .Where(engine => engine is not null)
            .Select(engine => engine!)
            .ToArray();

        return configuredEngines
            .Concat(resourceEngines)
            .GroupBy(engine => engine.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .ToArray();
    }

    private ResourceWorkloadConfiguration? TryReadWorkload(CloudResource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            var workload = descriptor.Configuration.Deserialize<ResourceWorkloadConfiguration>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
            return workload;
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private ContainerEngineResourceDefinition? TryReadContainerEngine(CloudResource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            if (!descriptor.ResourceType.Equals(ContainerEngineResourceTypes.ContainerEngine, StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            return descriptor.Configuration.Deserialize<ContainerEngineResourceDefinition>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record ContainerEngineOption(
        string Id,
        string DisplayName);
}
