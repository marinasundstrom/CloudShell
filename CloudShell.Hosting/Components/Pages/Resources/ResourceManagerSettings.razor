@page "/resources/settings"
@rendermode InteractiveServer
@inject IEnumerable<IResourceOrchestrator> Orchestrators
@inject IEnumerable<IContainerHostProvider> ContainerHostProviders
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject IResourceOrchestrationCatalog OrchestrationCatalog
@inject ResourceManagerDisplaySettings DisplaySettings
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject IStringLocalizer<SharedResource> L

@if (!IsEmbedded)
{
    <PageTitle>@L["Resource Manager settings"]</PageTitle>
}

@if (!IsEmbedded)
{
    <PageHeading Eyebrow="@L["Resource Manager"].Value"
                 Title="@L["Settings"].Value"
                 Description="@(IsReadOnly
                     ? L["Resource Manager is in read-only mode. Settings changes are disabled in this UI."].Value
                     : L["Choose which orchestrator handles lifecycle actions for the resource graph."].Value)"
                 ActionsClass="">
        <Actions>
            <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
                @L["Close"]
            </FluentButton>
        </Actions>
    </PageHeading>
}

<section class="@GetSettingsHostClass()">
    @if (ShowGeneralSettings)
    {
        @if (!IsEmbedded)
        {
            <ShellPanelHeader Title="@L["General"].Value"
                              Description="@L["Configure Resource Manager display behavior and inventory visibility."].Value" />
        }

        <div class="form-panel">
            @if (IsReadOnly)
            {
                <ProcedureMessage>
                    <strong>@L["Read-only mode"]</strong>
                    <span>@L["Resource Manager settings can be inspected, but changes are disabled by host configuration."]</span>
                </ProcedureMessage>
            }

            <fieldset class="form-fieldset">
                <legend>@L["Resource labels"]</legend>
                <div class="checkbox-stack">
                    <FluentCheckbox @bind-Value="SelectedEnableDisplayNames"
                                    Disabled="@IsReadOnly">
                        @L["Use display names"]
                    </FluentCheckbox>
                    <small>
                        @L["Shows resource display names in Resource Manager. When disabled, Resource Manager uses resource names as the primary labels. Default: {0}.", GetDefaultDisplayText(DisplaySelection.DefaultEnableDisplayNames)]
                    </small>
                </div>
            </fieldset>

            <fieldset class="form-fieldset">
                <legend>@L["Inventory visibility"]</legend>
                <div class="checkbox-stack">
                    <FluentCheckbox @bind-Value="SelectedShowRuntimeManagedResources"
                                    Disabled="@(IsReadOnly || !CanShowRuntimeManagedResources)">
                        @L["Show runtime-managed resources"]
                    </FluentCheckbox>
                    <small>
                        @if (!CanShowRuntimeManagedResources)
                        {
                            @L["You need permission to inspect runtime-managed resources."]
                        }
                        else
                        {
                            @L["Allows hidden runtime-managed artifacts to appear when hidden resources are shown. These resources are view-only. Default: {0}.", GetDefaultDisplayText(DisplaySelection.DefaultShowRuntimeManagedResources)]
                        }
                    </small>
                </div>
                <div class="checkbox-stack">
                    <FluentCheckbox @bind-Value="SelectedShowHiddenResources"
                                    Disabled="@IsReadOnly">
                        @L["Show hidden resources"]
                    </FluentCheckbox>
                    <small>
                        @L["Shows resources whose visibility is hidden. Hidden runtime-managed artifacts also require runtime-managed inspection. Default: {0}.", GetDefaultDisplayText(DisplaySelection.DefaultShowHiddenResources)]
                    </small>
                </div>
            </fieldset>
        </div>
    }

    @if (ShowOrchestrationSettings)
    {
        @if (!IsEmbedded)
        {
            <ShellPanelHeader Title="@L["Orchestration"].Value"
                              Description="@L["Configure how Resource Manager applies lifecycle, dependency, and host orchestration."].Value" />
        }

        <div class="form-panel">
            <ProcedureMessage>
                <strong>@L["CloudShell modes"]</strong>
                <span>@L["Local dev mode uses the default orchestrator for Aspire-like local resources and resource-owned endpoints. On-premise mode selects an orchestrator such as Docker Compose to own lifecycle, networking, and exposure. Container host registration is independent from orchestrator selection."]</span>
            </ProcedureMessage>

            @if (IsReadOnly)
            {
                <ProcedureMessage>
                    <strong>@L["Read-only mode"]</strong>
                    <span>@L["Resource Manager settings can be inspected, but changes are disabled by host configuration."]</span>
                </ProcedureMessage>
            }

            @foreach (var warning in ConfigurationWarnings)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Configuration warning"]</strong>
                    <span>@warning</span>
                </div>
            }

            <label for="orchestrator-id">@L["Orchestrator"]</label>
            <FluentSelect TOption="string"
                          Id="orchestrator-id"
                          @bind-Value="SelectedOrchestratorId"
                          Disabled="@IsReadOnly"
                          Appearance="Appearance.Outline">
                @foreach (var orchestrator in GetOrchestrators())
                {
                    <FluentOption TOption="string" Value="@orchestrator.Id">@orchestrator.DisplayName (@orchestrator.Id)</FluentOption>
                }
            </FluentSelect>

            <label for="container-host-id">@L["Preferred container host"]</label>
            <FluentSelect TOption="string"
                          Id="container-host-id"
                          @bind-Value="SelectedContainerHostId"
                          Disabled="@IsReadOnly"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">@L["Host environment"]</FluentOption>
                @foreach (var host in ContainerHosts)
                {
                    <FluentOption TOption="string" Value="@host.Id">@host.DisplayName</FluentOption>
                }
            </FluentSelect>

            <label for="health-check-interval-seconds">@L["Health check interval"]</label>
            <FluentNumberField TValue="int"
                               Id="health-check-interval-seconds"
                               Min="@ResourceOrchestratorSelectionDefaults.MinimumHealthCheckIntervalSeconds.ToString()"
                               Max="@ResourceOrchestratorSelectionDefaults.MaximumHealthCheckIntervalSeconds.ToString()"
                               Step="1"
                               Disabled="@(IsReadOnly || IsHealthCheckIntervalConfigured)"
                               @bind-Value="SelectedHealthCheckIntervalSeconds" />
            <small>
                @if (IsHealthCheckIntervalConfigured)
                {
                    @L["appsettings ResourceManager:HealthCheckIntervalSeconds is overriding this setting."]
                }
                else
                {
                    @L["CloudShell probes supported resources on this interval while the Resources page is open."]
                }
            </small>

            <label for="dependency-start-failure-behavior">@L["Dependency start failures"]</label>
            <FluentSelect TOption="string"
                          Id="dependency-start-failure-behavior"
                          @bind-Value="SelectedDependencyStartFailureBehavior"
                          Disabled="@(IsReadOnly || IsDependencyStartFailureBehaviorConfigured)"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="@DependencyStartFailureBehavior.FailAction.ToString()">
                    @L["Stop requested action"]
                </FluentOption>
                <FluentOption TOption="string" Value="@DependencyStartFailureBehavior.WarnAndContinue.ToString()">
                    @L["Warn and continue"]
                </FluentOption>
            </FluentSelect>
            <small>
                @if (IsDependencyStartFailureBehaviorConfigured)
                {
                    @L["appsettings ResourceManager:DependencyStartFailureBehavior is overriding this setting."]
                }
                else
                {
                    @L["Controls whether Start and Restart stop when dependency auto-start fails, or continue after recording a warning."]
                }
            </small>
        </div>
    }

    <div class="form-panel">
        @if (PendingChange)
        {
            <div class="procedure-confirmation">
                <strong>@L["Apply resource settings?"]</strong>
                <span>@L["Existing resources are not migrated automatically when the orchestrator changes. The new settings apply to inventory display, future lifecycle actions, and health checks."]</span>
                <div class="form-actions">
                    <FluentButton Appearance="Appearance.Neutral" OnClick="CancelChange">
                        @L["Cancel"]
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmChange">
                        @L["Apply settings"]
                    </FluentButton>
                </div>
            </div>
        }
        else
        {
            <FormPrimaryAction Text="@L["Apply"].Value"
                               IconStart="@(new Icons.Regular.Size20.Save())"
                               Disabled="@(!CanApply)"
                               OnClick="RequestChange" />
        }
    </div>
</section>

@code {
    private const string ViewAll = "all";
    private const string ViewGeneral = "general";
    private const string ViewOrchestration = "orchestration";

    [Parameter]
    public bool IsEmbedded { get; set; }

    [Parameter]
    public string View { get; set; } = ViewAll;

    private bool ShowGeneralSettings =>
        string.Equals(View, ViewAll, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(View, ViewGeneral, StringComparison.OrdinalIgnoreCase);

    private bool ShowOrchestrationSettings =>
        string.Equals(View, ViewAll, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(View, ViewOrchestration, StringComparison.OrdinalIgnoreCase);

    private string GetSettingsHostClass() =>
        IsEmbedded
            ? "resource-manager-settings-stack"
            : "panel registration-host resource-manager-settings-stack";

    private string SelectedOrchestratorId { get; set; } = "default";
    private string? SelectedContainerHostId { get; set; }
    private int SelectedHealthCheckIntervalSeconds { get; set; } =
        ResourceOrchestratorSelectionDefaults.DefaultHealthCheckIntervalSeconds;
    private string SelectedDependencyStartFailureBehavior { get; set; } =
        DependencyStartFailureBehavior.FailAction.ToString();
    private bool SelectedEnableDisplayNames { get; set; } = true;
    private bool SelectedShowRuntimeManagedResources { get; set; }
    private bool SelectedShowHiddenResources { get; set; }
    private IReadOnlyList<ContainerHostOption> ContainerHosts { get; set; } = [];
    private IReadOnlyList<string> ConfigurationWarnings { get; set; } = [];
    private ResourceOrchestrationCatalogSnapshot OrchestrationSnapshot { get; set; } =
        ResourceOrchestrationCatalogSnapshot.Empty;
    private bool PendingChange { get; set; }
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;

    private bool IsHealthCheckIntervalConfigured =>
        OrchestrationSettings.GetHealthCheckIntervalSettings().IsConfigured;

    private bool IsDependencyStartFailureBehaviorConfigured =>
        OrchestrationSettings.GetDependencyStartFailureSettings().IsConfigured;

    private bool CanShowRuntimeManagedResources =>
        DisplaySelection.CanShowRuntimeManagedResources;

    private bool CanApply =>
        !IsReadOnly && HasPendingSettingsChange();

    protected override async Task OnInitializedAsync()
    {
        if (!Authorization.HasPermission(CloudShellPermissions.Resources.Manage))
        {
            Navigation.NavigateTo("/account/access-denied");
            return;
        }

        var selection = OrchestrationSettings.Get();
        SelectedOrchestratorId = selection.OrchestratorId;
        SelectedContainerHostId = selection.PreferredContainerHostId;
        SelectedHealthCheckIntervalSeconds = selection.HealthCheckIntervalSeconds;
        SelectedDependencyStartFailureBehavior = GetEffectiveDependencyStartFailureBehavior().Behavior.ToString();
        await ApplyDisplaySelectionAsync();
        OrchestrationSnapshot = await OrchestrationCatalog.GetSnapshotAsync();
        ContainerHosts = GetContainerHosts();
        ConfigurationWarnings = GetConfigurationWarnings();
    }

    private bool HasPendingSettingsChange()
    {
        var selection = OrchestrationSettings.Get();
        var display = DisplaySelection;

        return !string.Equals(
                SelectedOrchestratorId,
                selection.OrchestratorId,
                StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(
                NormalizeOptional(SelectedContainerHostId),
                selection.PreferredContainerHostId,
                StringComparison.OrdinalIgnoreCase) ||
            (!IsHealthCheckIntervalConfigured &&
                ResourceOrchestratorSelectionDefaults.NormalizeHealthCheckInterval(SelectedHealthCheckIntervalSeconds) !=
                selection.HealthCheckIntervalSeconds) ||
            (!IsDependencyStartFailureBehaviorConfigured &&
                GetSelectedDependencyStartFailureBehavior() != selection.DependencyStartFailureBehavior) ||
            SelectedEnableDisplayNames != display.EnableDisplayNames ||
            (display.CanShowRuntimeManagedResources &&
                SelectedShowRuntimeManagedResources != display.ShowRuntimeManagedResources) ||
            SelectedShowHiddenResources != display.ShowHiddenResources;
    }

    private IReadOnlyList<IResourceOrchestrator> GetOrchestrators() =>
        Orchestrators
            .OrderBy(orchestrator => orchestrator.Id == "default" ? 0 : 1)
            .ThenBy(orchestrator => orchestrator.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private void RequestChange()
    {
        if (IsReadOnly)
        {
            return;
        }

        PendingChange = true;
    }

    private async Task CancelChange()
    {
        var selection = OrchestrationSettings.Get();
        SelectedOrchestratorId = selection.OrchestratorId;
        SelectedContainerHostId = selection.PreferredContainerHostId;
        SelectedHealthCheckIntervalSeconds = selection.HealthCheckIntervalSeconds;
        SelectedDependencyStartFailureBehavior = GetEffectiveDependencyStartFailureBehavior().Behavior.ToString();
        await ApplyDisplaySelectionAsync();
        ConfigurationWarnings = GetConfigurationWarnings();
        PendingChange = false;
    }

    private async Task ConfirmChange()
    {
        if (IsReadOnly)
        {
            PendingChange = false;
            return;
        }

        OrchestrationSettings.Select(
            SelectedOrchestratorId,
            SelectedContainerHostId,
            SelectedHealthCheckIntervalSeconds,
            GetSelectedDependencyStartFailureBehavior());
        await DisplaySettings.SelectAsync(
            SelectedEnableDisplayNames,
            SelectedShowRuntimeManagedResources,
            SelectedShowHiddenResources);
        SelectedHealthCheckIntervalSeconds = OrchestrationSettings.Get().HealthCheckIntervalSeconds;
        SelectedDependencyStartFailureBehavior = GetEffectiveDependencyStartFailureBehavior().Behavior.ToString();
        await ApplyDisplaySelectionAsync();
        ConfigurationWarnings = GetConfigurationWarnings();
        PendingChange = false;
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private ResourceDependencyStartFailureSettings GetEffectiveDependencyStartFailureBehavior() =>
        OrchestrationSettings.GetDependencyStartFailureSettings();

    private async Task ApplyDisplaySelectionAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        SelectedEnableDisplayNames = DisplaySelection.EnableDisplayNames;
        SelectedShowRuntimeManagedResources = DisplaySelection.ShowRuntimeManagedResources;
        SelectedShowHiddenResources = DisplaySelection.ShowHiddenResources;
    }

    private DependencyStartFailureBehavior GetSelectedDependencyStartFailureBehavior() =>
        Enum.TryParse<DependencyStartFailureBehavior>(
            SelectedDependencyStartFailureBehavior,
            ignoreCase: true,
            out var behavior) &&
        Enum.IsDefined(behavior)
            ? behavior
            : DependencyStartFailureBehavior.FailAction;

    private string GetDefaultDisplayText(bool value) =>
        value ? L["enabled"].Value : L["disabled"].Value;

    private IReadOnlyList<ContainerHostOption> GetContainerHosts() =>
        ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id))
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .Select(host => new ContainerHostOption(
                host.Id,
                host.IsDefault
                    ? $"{host.Name} ({L["default"]})"
                    : host.Name))
            .OrderBy(host => host.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<string> GetConfigurationWarnings()
    {
        var warnings = new List<string>();
        var hosts = GetContainerHostDefinitions();
        var selectedHostId = NormalizeOptional(SelectedContainerHostId);
        var hasDefaultHost = hosts.Any(host => host.IsDefault);

        if (!string.IsNullOrWhiteSpace(selectedHostId) &&
            !hosts.Any(host => string.Equals(host.Id, selectedHostId, StringComparison.OrdinalIgnoreCase)))
        {
            warnings.Add(L["Preferred container host '{0}' is not registered.", selectedHostId]);
        }

        foreach (var resource in OrchestrationSnapshot.Resources)
        {
            AddNetworkConfigurationWarnings(warnings, resource, OrchestrationSnapshot.Resources);

            var workload = TryReadWorkload(resource);
            if (workload?.Kind is not (ResourceWorkloadKind.ContainerImage or ResourceWorkloadKind.ContainerBuild))
            {
                continue;
            }

            var hostId = NormalizeOptional(workload.ContainerHostId) ?? selectedHostId;
            if (!string.IsNullOrWhiteSpace(hostId))
            {
                if (!hosts.Any(host => string.Equals(host.Id, hostId, StringComparison.OrdinalIgnoreCase)))
                {
                    warnings.Add(L["Container resource '{0}' references container host '{1}', but that host is not registered.", DisplaySelection.GetResourceLabel(resource), hostId]);
                }

                continue;
            }

            if (!hasDefaultHost)
            {
                warnings.Add(L["Container resource '{0}' does not specify a container host and no default container host is registered.", DisplaySelection.GetResourceLabel(resource)]);
            }
        }

        return warnings
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private void AddNetworkConfigurationWarnings(
        List<string> warnings,
        Resource resource,
        IReadOnlyList<Resource> resources)
    {
        if (resource.ResourceClass != ResourceClass.Network ||
            !resource.HasCapability(ResourceCapabilityIds.NetworkingVirtualNetwork))
        {
            return;
        }

        if (!resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkHostReadiness, out var readiness) ||
            string.IsNullOrWhiteSpace(readiness))
        {
            return;
        }

        if (string.Equals(readiness, "logicalOnly", StringComparison.OrdinalIgnoreCase))
        {
            warnings.Add(L["Virtual network '{0}' is using host-local logical networking because no host networking service is active. Activate a gateway, load balancer, or network controller provider to configure real virtual-network routing.", DisplaySelection.GetResourceLabel(resource)]);
            return;
        }

        if (!string.Equals(readiness, "providerRequired", StringComparison.OrdinalIgnoreCase) ||
            !resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkMappingProviders, out var providerList))
        {
            return;
        }

        var missingProviders = providerList
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(providerId => !resources.Any(candidate =>
                string.Equals(candidate.Id, providerId, StringComparison.OrdinalIgnoreCase)))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (missingProviders.Length == 0)
        {
            return;
        }

        warnings.Add(L["Virtual network '{0}' requires host networking provider '{1}', but it is not active on this host.", DisplaySelection.GetResourceLabel(resource), string.Join(", ", missingProviders)]);
    }

    private IReadOnlyList<ContainerHostDescriptor> GetContainerHostDefinitions()
    {
        var configuredHosts = ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id))
            .ToArray();
        var resourceHosts = OrchestrationSnapshot.ContainerHosts.Values;

        return configuredHosts
            .Concat(resourceHosts)
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .ToArray();
    }

    private ResourceWorkloadConfiguration? TryReadWorkload(Resource resource) =>
        OrchestrationSnapshot.Workloads.GetValueOrDefault(resource.Id);

    private static string? NormalizeOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed record ContainerHostOption(
        string Id,
        string DisplayName);
}
