@page "/resources/not-found"
@rendermode InteractiveServer
@inject ICoreShellRouteService ShellRoutes
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Resource not found"]</PageTitle>

<PageHeading Eyebrow="@L["Resource Manager"].Value"
             Title="@L["Resource not found"].Value"
             Description="@L["The requested resource could not be found in this CloudShell environment."].Value">
    <Actions>
        <FluentAnchor Appearance="Appearance.Neutral" Href="@GetResourcesRoute()">
            @L["Open Resources"]
        </FluentAnchor>
    </Actions>
</PageHeading>

<section class="panel">
    <EmptyState Title="@L["Resource not found"].Value"
                Message="@GetMessage()">
        <dl class="detail-list compact">
            <dt>@L["Resource ID"]</dt>
            <dd>@(string.IsNullOrWhiteSpace(ResourceId) ? L["None"].Value : ResourceId)</dd>
        </dl>
    </EmptyState>
</section>

@code {
    [SupplyParameterFromQuery(Name = "resourceId")]
    private string? ResourceId { get; set; }

    private string GetMessage() =>
        string.IsNullOrWhiteSpace(ResourceId)
            ? L["No resource ID was provided."].Value
            : L["Resource '{0}' may have been removed, renamed, or is no longer visible.", ResourceId].Value;

    private string GetResourcesRoute() =>
        ResourceManagerShellLinks.ResourceManagerPage(ShellRoutes,
            ResourceManagerShellIds.ResourcesPage,
            ResourceManagerRoutes.Resources);
}
