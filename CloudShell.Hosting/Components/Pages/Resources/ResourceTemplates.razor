@page "/resources/templates"
@rendermode InteractiveServer
@using CloudShell.ResourceModel
@inject IResourceManager ResourceManager
@inject IResourceTemplateManager Templates
@inject ICoreShellToastService Toasts
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Resource templates"]</PageTitle>

@{
    var selectedExportScope = ExportScopes.FirstOrDefault(scope =>
        string.Equals(scope.Id, SelectedExportScopeId, StringComparison.OrdinalIgnoreCase));
    var isReadOnly = ResourceManagerUiOptions.Value.ReadOnly;
    var canImport = !isReadOnly &&
        Authorization.HasPermission(CloudShellPermissions.Resources.Create) &&
        Authorization.CanAccessResourceGroup(
            "__new_resource_group",
            CloudShellPermissions.ResourceGroups.Create);
}

<PageHeading Eyebrow="@L["Resource Manager"].Value"
             Title="@L["Resource templates"].Value"
             Description="@L["Export and apply ResourceDefinition templates through Resource Manager."].Value">
    <Actions>
        <FluentButton Appearance="Appearance.Neutral" OnClick="BackToResources">
            @L["Back to resources"]
        </FluentButton>
    </Actions>
</PageHeading>

@if (StatusMessage is not null)
{
    <ProcedureMessage Message="@StatusMessage" />
}

<section class="template-layout">
    <div class="panel template-panel">
        <ShellPanelHeader Title="@L["Export resources"].Value"
                          Description="@L["CloudShell exports the selected resource scope as ResourceDefinition entries."].Value" />

        <label for="template-format">@L["Template format"]</label>
        <FluentSelect TOption="string"
                      Id="template-format"
                      @bind-Value="SelectedTemplateFormatValue"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="@ResourceTemplateFormat.Yaml.ToString()">YAML</FluentOption>
            <FluentOption TOption="string" Value="@ResourceTemplateFormat.Json.ToString()">JSON</FluentOption>
        </FluentSelect>

        <label for="export-scope">@L["Export scope"]</label>
        <FluentSelect TOption="string"
                      Id="export-scope"
                      @bind-Value="SelectedExportScopeId"
                      Appearance="Appearance.Outline">
            @foreach (var scope in ExportScopes)
            {
                <FluentOption TOption="string" Value="@scope.Id">@scope.Name</FluentOption>
            }
        </FluentSelect>

        @if (selectedExportScope is not null)
        {
            <div class="template-summary">
                <strong>@selectedExportScope.Name</strong>
                <span>@L["{0} registered resources", selectedExportScope.ResourceIds.Count]</span>
            </div>
        }

        <FormPrimaryAction Text="@L["Export template"].Value"
                           IconStart="@(new Icons.Regular.Size20.DocumentSave())"
                           Disabled="@(selectedExportScope is null || IsBusy)"
                           OnClick="ExportSelectedScope" />

        @if (!string.IsNullOrWhiteSpace(ExportDocument))
        {
            <label for="export-document">@L["Template {0}", TemplateFormatName]</label>
            <FluentTextArea Id="export-document"
                            Class="template-json"
                            ReadOnly="true"
                            Rows="24"
                            Value="@ExportDocument" />
        }
    </div>

    <div class="panel template-panel">
        <ShellPanelHeader Title="@L["Import group"].Value"
                          Description="@L["Paste a ResourceTemplate YAML or JSON document and apply it through Resource Manager."].Value" />

        @if (isReadOnly)
        {
            <ProcedureMessage Compact="true">
                @L["Resource Manager is in read-only mode. Template import is disabled in this UI."]
            </ProcedureMessage>
        }

        <label for="import-document">@L["Template {0}", TemplateFormatName]</label>
        <FluentTextArea Id="import-document"
                        Class="template-json"
                        Rows="24"
                        Placeholder="@L["Paste a ResourceTemplate {0} document", TemplateFormatName]"
                        ReadOnly="@isReadOnly"
                        @bind-Value="ImportDocument" />

        <FormActions>
            <FluentButton Appearance="Appearance.Neutral" OnClick="ClearImport">
                @L["Clear"]
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent"
                          IconStart="@(new Icons.Regular.Size20.ArrowUpload())"
                          Disabled="@(!canImport || string.IsNullOrWhiteSpace(ImportDocument) || IsBusy)"
                          OnClick="ImportTemplate">
                @L["Apply template"]
            </FluentButton>
        </FormActions>

        @if (isReadOnly)
        {
            <small class="template-note">@L["Import is disabled because Resource Manager is in read-only mode."]</small>
        }
        else if (!canImport)
        {
            <small class="template-note">@L["Import requires permission to create resource groups and resources."]</small>
        }
    </div>
</section>

@if (Diagnostics.Count > 0)
{
    <section class="panel template-diagnostics">
        <h2>@L["Template diagnostics"]</h2>
        @foreach (var diagnostic in Diagnostics)
        {
            <div class="template-diagnostic @diagnostic.Severity.ToString().ToLowerInvariant()">
                <strong>@diagnostic.Severity</strong>
                <span>@(diagnostic.Target ?? L["ResourceTemplate"].Value)</span>
                <p>@diagnostic.Message</p>
            </div>
        }
    </section>
}

@code {
    private const string UngroupedExportScopeId = "__ungrouped";
    private const string ExportToastId = "cloudshell.resource-manager.templates.export";

    private string? SelectedExportScopeId { get; set; }
    private string SelectedTemplateFormatValue { get; set; } = ResourceTemplateFormat.Yaml.ToString();
    private string? ExportDocument { get; set; }
    private string? ImportDocument { get; set; }
    private string? StatusMessage { get; set; }
    private bool IsBusy { get; set; }
    private IReadOnlyList<ResourceGroup> Groups { get; set; } = [];
    private IReadOnlyList<TemplateExportScope> ExportScopes { get; set; } = [];
    private List<ResourceDefinitionDiagnostic> Diagnostics { get; } = [];
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private ResourceTemplateFormat SelectedTemplateFormat =>
        Enum.TryParse<ResourceTemplateFormat>(
            SelectedTemplateFormatValue,
            ignoreCase: true,
            out var format)
            ? format
            : ResourceTemplateFormat.Yaml;
    private string TemplateFormatName =>
        SelectedTemplateFormat == ResourceTemplateFormat.Json ? "JSON" : "YAML";

    protected override async Task OnInitializedAsync()
    {
        await LoadGroupsAsync();
    }

    private void BackToResources() => Navigation.NavigateTo("/resources");

    private async Task ExportSelectedScope()
    {
        if (string.IsNullOrWhiteSpace(SelectedExportScopeId))
        {
            return;
        }

        IsBusy = true;
        Diagnostics.Clear();
        StatusMessage = null;

        try
        {
            var scope = ExportScopes.FirstOrDefault(scope =>
                string.Equals(scope.Id, SelectedExportScopeId, StringComparison.OrdinalIgnoreCase))
                ?? throw new InvalidOperationException("The selected export scope could not be found.");
            var metadata = string.IsNullOrWhiteSpace(scope.ResourceGroupId)
                ? null
                : new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                {
                    ["resourceGroup.id"] = scope.ResourceGroupId
                };
            var result = await Templates.ExportResourceTemplateAsync(
                new ResourceTemplateExportRequest(
                    scope.Name,
                    scope.ResourceIds,
                    Metadata: metadata));
            ExportDocument = ResourceTemplateSerializer.SerializeTemplate(
                result.Template,
                SelectedTemplateFormat);
            ImportDocument = ExportDocument;
            Diagnostics.AddRange(result.Diagnostics);
            StatusMessage = L["Exported {0} resources.", result.Template.Resources.Count].Value;
            await Toasts.PublishAsync(new CoreShellToastRequest(
                L["Resource template exported"].Value,
                L["Exported {0} resources to {1}.", result.Template.Resources.Count, TemplateFormatName].Value,
                CoreShellNotificationSeverity.Success,
                CoreShellNotificationStatus.Succeeded,
                Id: ExportToastId));
        }
        catch (Exception exception)
        {
            StatusMessage = exception.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task ImportTemplate()
    {
        if (IsReadOnly)
        {
            StatusMessage = L["Resource Manager is in read-only mode."].Value;
            return;
        }

        if (string.IsNullOrWhiteSpace(ImportDocument))
        {
            return;
        }

        IsBusy = true;
        Diagnostics.Clear();
        StatusMessage = null;

        try
        {
            var template = ResourceTemplateSerializer.DeserializeTemplate(
                ImportDocument,
                SelectedTemplateFormat);
            var result = await Templates.ApplyResourceTemplateAsync(template);
            Diagnostics.AddRange(result.Diagnostics);
            if (!result.IsCommitted)
            {
                StatusMessage = L["Template apply failed."].Value;
                return;
            }

            await LoadGroupsAsync();
            StatusMessage = L[
                "Applied template {0} with {1} resources.",
                result.Template.Name,
                result.Template.Resources.Count].Value;
        }
        catch (Exception exception)
        {
            StatusMessage = exception.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void ClearImport()
    {
        ImportDocument = null;
        Diagnostics.Clear();
        StatusMessage = null;
    }

    private async Task LoadGroupsAsync()
    {
        Groups = await ResourceManager.ListResourceGroupsAsync();
        var resources = await ResourceManager.ListResourcesAsync();
        var groupedResourceIds = Groups
            .SelectMany(group => group.ResourceIds)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var exportScopes = Groups
            .Select(group => new TemplateExportScope(
                group.Id,
                group.Name,
                group.ResourceIds,
                ResourceGroupId: group.Id))
            .ToList();
        var ungroupedResourceIds = resources
            .Select(resource => resource.Id)
            .Where(resourceId => !groupedResourceIds.Contains(resourceId))
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        if (ungroupedResourceIds.Length > 0)
        {
            exportScopes.Add(new TemplateExportScope(
                UngroupedExportScopeId,
                L["Ungrouped resources"].Value,
                ungroupedResourceIds,
                ResourceGroupId: null));
        }

        ExportScopes = exportScopes;
        if (SelectedExportScopeId is null ||
            ExportScopes.All(scope =>
                !string.Equals(scope.Id, SelectedExportScopeId, StringComparison.OrdinalIgnoreCase)))
        {
            SelectedExportScopeId = ExportScopes.FirstOrDefault()?.Id;
        }
    }

    private sealed record TemplateExportScope(
        string Id,
        string Name,
        IReadOnlyList<string> ResourceIds,
        string? ResourceGroupId);
}
