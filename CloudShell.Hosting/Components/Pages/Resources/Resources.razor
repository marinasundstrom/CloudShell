@page "/resources"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@inject IResourceManager ResourceManager
@inject ILogManager LogManager
@inject ShellCatalog ShellCatalog
@inject ResourceHealthCheckService HealthChecks
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Resources"]</PageTitle>
<FluentMenuProvider />

@{
    var allResources = ResourceInventory;
    var normalResources = allResources.Where(IsNormalInventoryResource).ToArray();
    var groups = ResourceGroups;
    var resourceClasses = GetResourceClassOptions(normalResources);
    var resourceTypes = GetResourceTypeOptions(normalResources);
    var resourceGroupFilters = GetResourceGroupFilterOptions(groups);
    var rows = BuildRows(allResources);
    SetPaginationTotal(rows.Count);
    var pagedRows = GetPagedRows(rows);
    var selected = SelectedResource;
}

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Resource Manager"]</span>
        <h1>@L["Resources"]</h1>
        <p>@L["Explore registered resources, project groups, endpoints, dependencies, and nested sub-resources."]</p>
    </div>
    <div class="heading-actions">
        <FluentButton Appearance="Appearance.Neutral" OnClick="RefreshResourcesAsync">
            @(IsCheckingHealth ? L["Checking..."] : L["Refresh"])
        </FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="OpenTemplates">
            @L["Templates"]
        </FluentButton>
        @if (CanOpenSettings)
        {
            <FluentButton Appearance="Appearance.Neutral" OnClick="OpenSettings">
                @L["Settings"]
            </FluentButton>
        }
        @if (!IsReadOnly && Authorization.CanAccessResourceGroup(
            "__new_resource_group",
            CloudShellPermissions.ResourceGroups.Create))
        {
            <FluentButton Appearance="Appearance.Neutral" OnClick="CreateGroup">
                @L["Create group"]
            </FluentButton>
        }
        @if (!IsReadOnly && Authorization.HasPermission(CloudShellPermissions.Resources.Create))
        {
            <FluentButton Appearance="Appearance.Accent" OnClick="AddResource">
                @L["Add resource"]
            </FluentButton>
        }
    </div>
</section>

@if (ProcedureMessage is not null)
{
    <div class="procedure-message">@ProcedureMessage</div>
}

@if (IsReadOnly)
{
    <div class="procedure-message">@L["Resource Manager is in read-only mode. Resource creation, lifecycle actions, updates, and deletes are disabled in this UI."]</div>
}

@if (PendingAction is not null)
{
    <div class="procedure-confirmation">
        @if (PendingAction.RequiresDependencyChoice)
        {
            <strong>@PendingAction.Action.DisplayName @PendingAction.Resource.Name?</strong>
            <span>@GetDependencyConfirmationMessage(PendingAction)</span>
            <div class="form-actions">
                <FluentButton Appearance="Appearance.Accent" OnClick="() => ConfirmResourceAction(startDependencies: true)">
                    @L["Yes"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Neutral" OnClick="() => ConfirmResourceAction(startDependencies: false)">
                    @L["No, only this resource"]
                </FluentButton>
            </div>
        }
        else if (PendingAction.RequiresDependentWarning)
        {
            <strong>@PendingAction.Action.DisplayName @PendingAction.Resource.Name?</strong>
            <span>@GetDependentWarningMessage(PendingAction)</span>
            <div class="form-actions">
                <FluentButton Appearance="Appearance.Neutral" OnClick="CancelResourceAction">
                    @L["No"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmDependentWarning">
                    @L["Yes, I'm sure"]
                </FluentButton>
            </div>
        }
        else
        {
            <strong>@PendingAction.Action.DisplayName @PendingAction.Resource.Name?</strong>
            <span>@GetConfirmationMessage(PendingAction.Resource, PendingAction.Action)</span>
            <div class="form-actions">
                <FluentButton Appearance="Appearance.Neutral" OnClick="CancelResourceAction">
                    @L["Cancel"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="() => ConfirmResourceAction()">
                    @PendingAction.Action.DisplayName
                </FluentButton>
            </div>
        }
    </div>
}

<section class="resource-explorer @(selected is null ? "resource-explorer-no-blade" : null)">
    <div class="resource-list panel">
        <div class="inventory-toolbar">
            <div class="inventory-filters">
                <div class="inventory-filter name-filter">
                    <label for="resource-name-filter">@L["Name"]</label>
                    <FluentSearch Id="resource-name-filter" @bind-Value="NameFilter" Placeholder="@L["Filter by resource name"]" />
                </div>
                <div class="inventory-filter">
                    <label for="resource-class-filter">@L["Class"]</label>
                    <FluentSelect TOption="ResourceClassFilterOption"
                                  Id="resource-class-filter"
                                  Class="inventory-select"
                                  Items="@resourceClasses"
                                  OptionText="@(resourceClass => resourceClass.DisplayName)"
                                  OptionValue="@(resourceClass => resourceClass.Id)"
                                  SelectedOption="@GetSelectedClassOption(resourceClasses)"
                                  SelectedOptionChanged="ChangeClassFilter"
                                  Appearance="Appearance.Neutral" />
                </div>
                <div class="inventory-filter">
                    <label for="resource-type-filter">@L["Type"]</label>
                    <FluentSelect TOption="ResourceTypeFilterOption"
                                  Id="resource-type-filter"
                                  Class="inventory-select"
                                  Items="@resourceTypes"
                                  OptionText="@(type => type.DisplayName)"
                                  OptionValue="@(type => type.Id)"
                                  SelectedOption="@GetSelectedTypeOption(resourceTypes)"
                                  SelectedOptionChanged="ChangeTypeFilter"
                                  Appearance="Appearance.Neutral" />
                </div>
                <div class="inventory-filter">
                    <label for="resource-group-filter">@L["Resource group"]</label>
                    <FluentSelect TOption="ResourceGroupFilterOption"
                                  Id="resource-group-filter"
                                  Class="inventory-select"
                                  Items="@resourceGroupFilters"
                                  OptionText="@(group => group.DisplayName)"
                                  OptionValue="@(group => group.Id)"
                                  SelectedOption="@GetSelectedResourceGroupOption(resourceGroupFilters)"
                                  SelectedOptionChanged="ChangeResourceGroupFilter"
                                  Appearance="Appearance.Neutral" />
                </div>
                @if (HasActiveFilters)
                {
                    <FluentButton Appearance="Appearance.Neutral" OnClick="ClearFilters">
                        @L["Clear"]
                    </FluentButton>
                }
            </div>
            <div class="toolbar-meta">@GetPaginationRangeLabel(rows.Count)</div>
        </div>

        <div class="resource-list-header">
            <span>@L["Name"]</span>
            <span>@L["Type"]</span>
            <span>@L["Group"]</span>
            <span>@L["State"]</span>
            <span>@L["Health"]</span>
            <span>@L["Endpoint"]</span>
            <span>@L["Actions"]</span>
        </div>

        <div class="resource-tree" role="treegrid" aria-label="@L["Resources"]">
            @foreach (var row in pagedRows)
            {
                var resource = row.Resource;
                var group = GetGroup(resource);
                <div class="resource-tree-row @(selected?.Id == resource.Id ? "selected" : null)"
                     role="row"
                     @onclick="() => OpenResource(resource)">
                    <div class="resource-name-cell" style="--resource-depth: @row.Depth">
                        @if (row.ChildCount > 0)
                        {
                            <button class="tree-toggle"
                                    title="@L["Toggle sub-resources"]"
                                    @onclick="() => ToggleResource(resource.Id)"
                                    @onclick:stopPropagation="true">
                                @(CollapsedResourceIds.Contains(resource.Id) ? "+" : "-")
                            </button>
                        }
                        else
                        {
                            <span class="tree-spacer"></span>
                        }

                        <span class="resource-kind-icon">@GetResourceGlyph(resource.Kind)</span>
                        <div>
                            @if (resource.DetailRoute is not null)
                            {
                                <a class="resource-link"
                                   href="@resource.DetailRoute"
                                   @onclick:stopPropagation="true">@resource.Name</a>
                            }
                            else
                            {
                                <strong>@resource.Name</strong>
                            }
                            @if (row.ChildCount > 0)
                            {
                                <small>@L["{0} sub-resources", row.ChildCount]</small>
                            }
                        </div>
                    </div>
                    <span>@resource.Kind</span>
                    <span>@(group?.Name ?? L["Default group"])</span>
                    <span>
                        @if (ResourceLifecycleDisplay.ShouldShowStatus(resource))
                        {
                            <span class="state-pill @GetStateClass(resource.State)">@resource.State</span>
                        }
                    </span>
                    <span>@HealthIndicator(resource)</span>
                    <span class="endpoint">@EndpointLink(resource.PrimaryEndpoint)</span>
                    <span class="resource-row-actions" @onclick:stopPropagation="true">
                        @ResourceActionControls(resource, includeDetailsAction: true)
                    </span>
                </div>
            }

            @if (rows.Count == 0)
            {
                <div class="empty-state">
                    <strong>@L["No resources in this scope"]</strong>
                    <span>@L["Change the scope or filter to view other resources."]</span>
                </div>
            }
        </div>

        @if (rows.Count > 0)
        {
            <div class="resource-pagination">
                <div class="inventory-filter page-size-filter">
                    <label for="resource-page-size">@L["Rows per page"]</label>
                    <FluentSelect TOption="int"
                                  Id="resource-page-size"
                                  Class="page-size-select"
                                  Items="@PageSizes"
                                  OptionText="@(size => size.ToString())"
                                  OptionValue="@(size => size.ToString())"
                                  SelectedOption="@Pagination.ItemsPerPage"
                                  SelectedOptionChanged="ChangePageSizeAsync"
                                  Appearance="Appearance.Neutral" />
                </div>
                <div class="pagination-controls">
                    <span class="pagination-range">@GetPaginationRangeLabel(rows.Count)</span>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(Pagination.CurrentPageIndex == 0)"
                                  Title="@L["First page"]"
                                  OnClick="GoToFirstPageAsync">
                        &lt;&lt;
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(Pagination.CurrentPageIndex == 0)"
                                  Title="@L["Previous page"]"
                                  OnClick="GoToPreviousPageAsync">
                        &lt;
                    </FluentButton>
                    <span>@L["Page {0} of {1}", Pagination.CurrentPageIndex + 1, GetLastPageIndex(rows.Count) + 1]</span>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(Pagination.CurrentPageIndex >= GetLastPageIndex(rows.Count))"
                                  Title="@L["Next page"]"
                                  OnClick="() => GoToNextPageAsync(rows.Count)">
                        &gt;
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(Pagination.CurrentPageIndex >= GetLastPageIndex(rows.Count))"
                                  Title="@L["Last page"]"
                                  OnClick="() => GoToLastPageAsync(rows.Count)">
                        &gt;&gt;
                    </FluentButton>
                </div>
            </div>
        }
    </div>

    @if (selected is not null)
    {
        var group = GetGroup(selected);
        var parent = selected.ParentResourceId is null
            ? null
            : allResources.FirstOrDefault(resource =>
                string.Equals(resource.Id, selected.ParentResourceId, StringComparison.OrdinalIgnoreCase));
        var children = allResources
            .Where(resource => string.Equals(resource.ParentResourceId, selected.Id, StringComparison.OrdinalIgnoreCase))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        <aside class="resource-blade panel">
            @if (parent is not null)
            {
                <button class="parent-link" @onclick="() => SelectResource(parent)">
                    @L["Back to {0}", parent.Name]
                </button>
            }

            <div class="detail-heading">
                <span class="resource-kind-icon large">@GetResourceGlyph(selected.Kind)</span>
                <div>
                    <h2>@selected.Name</h2>
                    <p>@selected.Kind</p>
                </div>
                <button type="button"
                        class="blade-dismiss"
                        title="@L["Dismiss details"]"
                        aria-label="@L["Dismiss details"]"
                        @onclick="DismissResource">
                    x
                </button>
            </div>

            @if (ResourceLifecycleDisplay.ShouldShowStatus(selected))
            {
                <div class="blade-status">
                    <span class="state-dot @GetStateClass(selected.State)"></span>
                    <strong>@selected.State</strong>
                    <span>@L["Updated {0}", selected.LastUpdated.ToLocalTime().ToString("HH:mm:ss")]</span>
                </div>
            }

            @if (selected.ResourceHealthChecks.Count > 0)
            {
                var health = GetHealthSummary(selected);
                <div class="blade-status health-status">
                    <span class="state-dot @GetHealthClass(health?.Status)"></span>
                    <strong>@GetHealthLabel(health)</strong>
                    @if (health is not null)
                    {
                        <span>@L["Checked {0}", health.CheckedAt.ToLocalTime().ToString("HH:mm:ss")]</span>
                    }
                </div>
            }

            @if (selected.DetailRoute is not null)
            {
                <div class="blade-actions">
                    <FluentButton Appearance="Appearance.Accent" OnClick="() => Navigation.NavigateTo(selected.DetailRoute)">
                        @L["Open resource"]
                    </FluentButton>
                    @ResourceActionControls(selected)
                    @if (CanManage(selected) && HasProviderConfiguration(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => OpenResourceDetails(selected)">
                            @L["Details"]
                        </FluentButton>
                    }
                    @if (CanDelete(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => PromptDelete(selected)">
                            @L["Delete"]
                        </FluentButton>
                    }
                </div>
            }
            else
            {
                <div class="blade-actions">
                    @ResourceActionControls(selected)
                    <FluentButton Appearance="Appearance.Neutral" OnClick="() => OpenResourceDetails(selected)">
                        @L["Details"]
                    </FluentButton>
                    @if (CanDelete(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => PromptDelete(selected)">
                            @L["Delete"]
                        </FluentButton>
                    }
                </div>
            }

            @if (DeleteConfirmationResourceId == selected.Id)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Delete registration?"]</strong>
                    <span>@L["The provider will commit the delete procedure for this resource."]</span>
                    <div class="form-actions">
                        <FluentButton Appearance="Appearance.Neutral" OnClick="CancelDelete">
                            @L["Cancel"]
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="() => DeleteResource(selected)">
                            @L["Delete"]
                        </FluentButton>
                    </div>
                </div>
            }

            <section class="blade-section">
                <h3>@L["Essentials"]</h3>
                <dl class="detail-list">
                    <dt>@L["Type"]</dt>
                    <dd>@selected.EffectiveTypeId</dd>
                    <dt>@L["Resource group"]</dt>
                    <dd>@(group?.Name ?? L["Default group"])</dd>
                    <dt>@L["Region"]</dt>
                    <dd>@selected.Region</dd>
                    <dt>@L["Version"]</dt>
                    <dd>@selected.Version</dd>
                    @if (!selected.IsNormalResource ||
                        selected.Source != ResourceSource.User ||
                        selected.ManagementMode != ResourceManagementMode.UserManaged ||
                        !string.IsNullOrWhiteSpace(selected.OwnerResourceId))
                    {
                        <dt>@L["Source"]</dt>
                        <dd>@selected.Source</dd>
                        <dt>@L["Management"]</dt>
                        <dd>@selected.ManagementMode</dd>
                        <dt>@L["Visibility"]</dt>
                        <dd>@selected.Visibility</dd>
                        @if (!string.IsNullOrWhiteSpace(selected.OwnerResourceId))
                        {
                            <dt>@L["Owner"]</dt>
                            <dd>@FormatResourceName(selected.OwnerResourceId)</dd>
                        }
                    }
                    <dt>@L["Resource ID"]</dt>
                    <dd>@selected.Id</dd>
                </dl>
            </section>

            @if (children.Length > 0)
            {
                <section class="blade-section">
                    <h3>@L["Sub-resources"]</h3>
                    <div class="subresource-list">
                        @foreach (var child in children)
                        {
                            <button @onclick="() => SelectResource(child)">
                                <span class="resource-kind-icon">@GetResourceGlyph(child.Kind)</span>
                                <span>
                                    <strong>@child.Name</strong>
                                    <small>@child.Kind</small>
                                </span>
                                @if (ResourceLifecycleDisplay.ShouldShowStatus(child))
                                {
                                    <span class="state-dot @GetStateClass(child.State)"></span>
                                }
                            </button>
                        }
                    </div>
                </section>
            }

            <section class="blade-section">
                <h3>@L["Endpoints"]</h3>
                <div class="endpoint-list">
                    @foreach (var endpoint in selected.Endpoints)
                    {
                        <div>
                            <strong>@endpoint.Name</strong>
                            @EndpointLink(endpoint.Address)
                            <small>@endpoint.Protocol @endpoint.Exposure</small>
                        </div>
                    }
                </div>
            </section>

            @if (IsLoadBalancerResource(selected))
            {
                <section class="blade-section">
                    <h3>@L["Load balancing"]</h3>
                    <dl class="detail-list">
                        <dt>@L["Provider"]</dt>
                        <dd>@GetAttributeValue(selected, ResourceAttributeNames.LoadBalancerProvider, selected.Provider)</dd>
                        <dt>@L["Host"]</dt>
                        <dd>
                            @if (GetLoadBalancerHostResourceId(selected) is { } hostResourceId)
                            {
                                @FormatResourceName(hostResourceId)
                            }
                            else
                            {
                                @L["Default container host"]
                            }
                        </dd>
                        <dt>@L["Entrypoints"]</dt>
                        <dd>@GetAttributeValue(selected, ResourceAttributeNames.LoadBalancerEntrypointCount, selected.Endpoints.Count.ToString(CultureInfo.InvariantCulture))</dd>
                        <dt>@L["Routes"]</dt>
                        <dd>@FormatLoadBalancerRouteCounts(selected)</dd>
                    </dl>
                </section>
            }

            @if (IsNetworkResource(selected) && !IsLoadBalancerResource(selected))
            {
                <section class="blade-section">
                    <h3>@L["Networking"]</h3>
                    <dl class="detail-list">
                        <dt>@L["Kind"]</dt>
                        <dd>@GetAttributeValue(selected, ResourceAttributeNames.NetworkKind, selected.Kind)</dd>
                        <dt>@L["Host readiness"]</dt>
                        <dd>@FormatNetworkReadiness(selected)</dd>
                        @if (selected.ResourceAttributes.ContainsKey(ResourceAttributeNames.NetworkProvisionedMappingCount))
                        {
                            <dt>@L["Provisioned mappings"]</dt>
                            <dd>@GetAttributeValue(selected, ResourceAttributeNames.NetworkProvisionedMappingCount, "0")</dd>
                        }
                        @if (GetMappingProviderIds(selected).Length > 0)
                        {
                            <dt>@L["Mapping providers"]</dt>
                            <dd>@string.Join(", ", GetMappingProviderIds(selected))</dd>
                        }
                    </dl>
                </section>
            }

            @if (selected.ResourceEndpointMappings.Count > 0)
            {
                <section class="blade-section">
                    <h3>@L["Endpoint mappings"]</h3>
                    <div class="endpoint-list">
                        @foreach (var mapping in selected.ResourceEndpointMappings)
                        {
                            <div>
                                <strong>@mapping.Name</strong>
                                <span>@FormatMappingSummary(mapping, selected)</span>
                                <small>@FormatMappingProvider(mapping)</small>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (selected.ResourceLoadBalancerRoutes.Count > 0)
            {
                <section class="blade-section">
                    <h3>@L["Load balancer routes"]</h3>
                    <div class="endpoint-list">
                        @foreach (var route in selected.ResourceLoadBalancerRoutes)
                        {
                            <div>
                                <strong>@route.Name</strong>
                                <span>@FormatLoadBalancerRoute(route)</span>
                                <small>@L["Entrypoint: {0}", route.EntrypointName]</small>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (GetInboundNetworkMappings(selected).Length > 0)
            {
                <section class="blade-section">
                    <h3>@L["Network exposure"]</h3>
                    <div class="endpoint-list">
                        @foreach (var exposure in GetInboundNetworkMappings(selected))
                        {
                            <div>
                                <strong>@exposure.Network.Name</strong>
                                <span>@FormatMappingSummary(exposure.Mapping, exposure.Network)</span>
                                <small>@FormatMappingProvider(exposure.Mapping)</small>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (GetInboundLoadBalancerRoutes(selected).Length > 0)
            {
                <section class="blade-section">
                    <h3>@L["Load balancer exposure"]</h3>
                    <div class="endpoint-list">
                        @foreach (var exposure in GetInboundLoadBalancerRoutes(selected))
                        {
                            <div>
                                <strong>@exposure.LoadBalancer.Name</strong>
                                <span>@FormatLoadBalancerRoute(exposure.Route)</span>
                                <small>@L["Entrypoint: {0}", exposure.Route.EntrypointName]</small>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (GetInboundNameMappings(selected).Length > 0)
            {
                <section class="blade-section">
                    <h3>@L["DNS and domain names"]</h3>
                    <div class="endpoint-list">
                        @foreach (var exposure in GetInboundNameMappings(selected))
                        {
                            <div>
                                <strong>@GetNameMappingHostName(exposure.Mapping)</strong>
                                <span>@FormatNameMappingSummary(exposure.Mapping, selected)</span>
                                <small>@FormatNameMappingMetadata(exposure.Mapping)</small>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (selected.DependsOn.Count > 0)
            {
                <section class="blade-section">
                    <h3>@L["Dependencies"]</h3>
                    <div class="dependency-list">
                        @foreach (var dependency in selected.DependsOn)
                        {
                            <span>@dependency</span>
                        }
                    </div>
                </section>
            }
        </aside>
    }
</section>

@code {
    private const string PageQueryParameter = "page";
    private const string PageSizeQueryParameter = "pageSize";
    private const string AllResourceGroupsFilter = "__all";
    private const string AllResourceClassesFilter = "__all";
    private const string AllResourceTypesFilter = "__all";
    private const string UngroupedScope = "__ungrouped";
    private static readonly IReadOnlyList<int> PageSizes = [10, 25, 50, 100];
    private readonly HashSet<string> CollapsedResourceIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly SemaphoreSlim HealthRefreshLock = new(1, 1);
    private readonly PaginationState Pagination = new()
    {
        ItemsPerPage = 25
    };
    private string? nameFilter;
    private string selectedClassFilter = AllResourceClassesFilter;
    private string selectedTypeFilter = AllResourceTypesFilter;
    private string selectedResourceGroupFilter = AllResourceGroupsFilter;
    private int lastUrlPageIndex = -1;
    private int lastUrlPageSize = -1;
    private Resource? SelectedResource { get; set; }
    private string? DeleteConfirmationResourceId { get; set; }
    private string? ProcedureMessage { get; set; }
    private string? ExecutingActionKey { get; set; }
    private PendingResourceAction? PendingAction { get; set; }
    private bool IsCheckingHealth { get; set; }
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private IReadOnlyDictionary<string, ResourceHealthSummary> HealthResults { get; set; } =
        new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase);
    private CancellationTokenSource? ResourcePollingCancellation { get; set; }
    private Task? ResourcePollingTask { get; set; }
    private bool IsDisposed { get; set; }
    private IReadOnlyList<Resource> ResourceInventory { get; set; } = [];
    private IReadOnlyList<ResourceGroup> ResourceGroups { get; set; } = [];
    private IReadOnlyDictionary<string, ResourceGroup> ResourceGroupsByResourceId { get; set; } =
        new Dictionary<string, ResourceGroup>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, ResourceOperationCapabilities> ResourceCapabilities { get; set; } =
        new Dictionary<string, ResourceOperationCapabilities>(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyDictionary<string, IReadOnlyList<LogDescriptor>> LogsByResourceId { get; set; } =
        new Dictionary<string, IReadOnlyList<LogDescriptor>>(StringComparer.OrdinalIgnoreCase);

    private string? NameFilter
    {
        get => nameFilter;
        set
        {
            if (string.Equals(nameFilter, value, StringComparison.Ordinal))
            {
                return;
            }

            nameFilter = value;
            ResetPagination();
        }
    }

    private string SelectedTypeFilter
    {
        get => selectedTypeFilter;
        set
        {
            if (string.Equals(selectedTypeFilter, value, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            selectedTypeFilter = value;
            ResetPagination();
        }
    }

    private string SelectedClassFilter
    {
        get => selectedClassFilter;
        set
        {
            if (string.Equals(selectedClassFilter, value, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            selectedClassFilter = value;
            ResetPagination();
        }
    }

    private string SelectedResourceGroupFilter
    {
        get => selectedResourceGroupFilter;
        set
        {
            if (string.Equals(selectedResourceGroupFilter, value, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            selectedResourceGroupFilter = value;
            ResetPagination();
        }
    }

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(NameFilter) ||
        SelectedClassFilter != AllResourceClassesFilter ||
        SelectedTypeFilter != AllResourceTypesFilter ||
        SelectedResourceGroupFilter != AllResourceGroupsFilter;

    private bool CanOpenSettings =>
        Authorization.HasPermission(CloudShellPermissions.Resources.Manage) &&
        ShellCatalog.GetViewRoute(ResourceManagerViews.ResourceSettings) is not null;

    protected override async Task OnInitializedAsync()
    {
        ResourceManager.ResourcesChanged += OnResourcesChanged;
        ApplyPaginationFromUrl();
        await LoadResourceModelAsync();

        ResourcePollingCancellation = new CancellationTokenSource();
        ResourcePollingTask = PollResourcesAsync(ResourcePollingCancellation.Token);

        await RefreshResourceHealthAsync(ResourcePollingCancellation.Token);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        UpdatePaginationUrl();
    }

    private IReadOnlyList<ResourceRow> BuildRows(IReadOnlyList<Resource> allResources)
    {
        var scoped = allResources
            .Where(IsNormalInventoryResource)
            .Where(IsInSelectedResourceGroup)
            .ToArray();
        var scopedIds = scoped.Select(resource => resource.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var childrenByParent = scoped
            .Where(resource => resource.ParentResourceId is not null)
            .GroupBy(resource => resource.ParentResourceId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.OrderBy(resource => resource.Name).ToArray(), StringComparer.OrdinalIgnoreCase);

        HashSet<string>? visibleIds = null;
        if (HasActiveListFilters())
        {
            visibleIds = scoped
                .Where(MatchesListFilters)
                .Select(resource => resource.Id)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            foreach (var resource in scoped.Where(resource => visibleIds.Contains(resource.Id)))
            {
                var parentId = resource.ParentResourceId;
                while (parentId is not null && scopedIds.Contains(parentId) && visibleIds.Add(parentId))
                {
                    parentId = scoped.First(item => item.Id == parentId).ParentResourceId;
                }
            }
        }

        var rows = new List<ResourceRow>();
        var roots = scoped
            .Where(resource => resource.ParentResourceId is null || !scopedIds.Contains(resource.ParentResourceId))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase);

        foreach (var root in roots)
        {
            AddResourceRow(root, 0, childrenByParent, visibleIds, rows);
        }

        return rows;
    }

    private void AddResourceRow(
        Resource resource,
        int depth,
        IReadOnlyDictionary<string, Resource[]> childrenByParent,
        HashSet<string>? visibleIds,
        List<ResourceRow> rows)
    {
        if (visibleIds is not null && !visibleIds.Contains(resource.Id))
        {
            return;
        }

        var children = childrenByParent.GetValueOrDefault(resource.Id) ?? [];
        rows.Add(new ResourceRow(resource, depth, children.Length));

        if (CollapsedResourceIds.Contains(resource.Id) && visibleIds is null)
        {
            return;
        }

        foreach (var child in children)
        {
            AddResourceRow(child, depth + 1, childrenByParent, visibleIds, rows);
        }
    }

    private static bool IsNormalInventoryResource(Resource resource) =>
        resource.Visibility == ResourceVisibility.Normal;

    private bool IsInSelectedResourceGroup(Resource resource)
    {
        var group = GetGroup(resource);
        return SelectedResourceGroupFilter switch
        {
            AllResourceGroupsFilter => true,
            UngroupedScope => group is null,
            _ => string.Equals(group?.Id, SelectedResourceGroupFilter, StringComparison.OrdinalIgnoreCase)
        };
    }

    private bool HasActiveListFilters() =>
        !string.IsNullOrWhiteSpace(NameFilter) ||
        SelectedClassFilter != AllResourceClassesFilter ||
        SelectedTypeFilter != AllResourceTypesFilter;

    private bool MatchesListFilters(Resource resource) =>
        MatchesNameFilter(resource) &&
        MatchesClassFilter(resource) &&
        MatchesTypeFilter(resource);

    private bool MatchesNameFilter(Resource resource) =>
        string.IsNullOrWhiteSpace(NameFilter) ||
        resource.Name.Contains(NameFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchesClassFilter(Resource resource) =>
        SelectedClassFilter == AllResourceClassesFilter ||
        string.Equals(resource.ResourceClass.ToString(), SelectedClassFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchesTypeFilter(Resource resource) =>
        SelectedTypeFilter == AllResourceTypesFilter ||
        string.Equals(resource.EffectiveTypeId, SelectedTypeFilter, StringComparison.OrdinalIgnoreCase);

    private ResourceGroup? GetGroup(Resource resource) =>
        ResourceGroupsByResourceId.GetValueOrDefault(resource.Id);

    private async Task LoadResourceModelAsync()
    {
        ResourceInventory = await ResourceManager.ListResourcesAsync();
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
        ResourceCapabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(
            ResourceInventory.Select(resource => resource.Id).ToArray());

        var logs = await LogManager.ListLogsAsync();
        LogsByResourceId = logs
            .Where(log => !string.IsNullOrWhiteSpace(log.ResourceId))
            .GroupBy(log => log.ResourceId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => (IReadOnlyList<LogDescriptor>)group.ToArray(),
                StringComparer.OrdinalIgnoreCase);

        var groupsByResourceId = new Dictionary<string, ResourceGroup>(StringComparer.OrdinalIgnoreCase);
        foreach (var resource in ResourceInventory)
        {
            var group = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);
            if (group is not null)
            {
                groupsByResourceId[resource.Id] = group;
            }
        }

        ResourceGroupsByResourceId = groupsByResourceId;
        if (SelectedResource is not null)
        {
            SelectedResource = ResourceInventory.FirstOrDefault(resource =>
                string.Equals(resource.Id, SelectedResource.Id, StringComparison.OrdinalIgnoreCase));
        }
    }

    private IReadOnlyList<ResourceTypeFilterOption> GetResourceTypeOptions(IReadOnlyList<Resource> resources) =>
    [
        new ResourceTypeFilterOption(AllResourceTypesFilter, L["All types"].Value),
        .. resources
            .GroupBy(resource => resource.EffectiveTypeId, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var resource = group.First();
                var displayName = string.Equals(resource.Kind, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase)
                    ? resource.Kind
                    : $"{resource.Kind} ({resource.EffectiveTypeId})";
                return new ResourceTypeFilterOption(resource.EffectiveTypeId, displayName);
            })
            .OrderBy(type => type.DisplayName, StringComparer.OrdinalIgnoreCase)
    ];

    private IReadOnlyList<ResourceGroupFilterOption> GetResourceGroupFilterOptions(IReadOnlyList<ResourceGroup> groups) =>
    [
        new ResourceGroupFilterOption(AllResourceGroupsFilter, L["All resource groups"].Value),
        .. groups.Select(group => new ResourceGroupFilterOption(group.Id, group.Name)),
        new ResourceGroupFilterOption(UngroupedScope, L["Default group"].Value)
    ];

    private ResourceTypeFilterOption GetSelectedTypeOption(IReadOnlyList<ResourceTypeFilterOption> resourceTypes) =>
        resourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, SelectedTypeFilter, StringComparison.OrdinalIgnoreCase))
        ?? resourceTypes[0];

    private IReadOnlyList<ResourceClassFilterOption> GetResourceClassOptions(IReadOnlyList<Resource> resources) =>
    [
        new ResourceClassFilterOption(AllResourceClassesFilter, L["All classes"].Value),
        .. resources
            .Select(resource => resource.ResourceClass)
            .Distinct()
            .OrderBy(resourceClass => resourceClass.ToString(), StringComparer.OrdinalIgnoreCase)
            .Select(resourceClass => new ResourceClassFilterOption(
                resourceClass.ToString(),
                GetResourceClassDisplayName(resourceClass)))
    ];

    private ResourceClassFilterOption GetSelectedClassOption(IReadOnlyList<ResourceClassFilterOption> resourceClasses) =>
        resourceClasses.FirstOrDefault(resourceClass =>
            string.Equals(resourceClass.Id, SelectedClassFilter, StringComparison.OrdinalIgnoreCase))
        ?? resourceClasses[0];

    private ResourceGroupFilterOption GetSelectedResourceGroupOption(IReadOnlyList<ResourceGroupFilterOption> resourceGroups) =>
        resourceGroups.FirstOrDefault(group =>
            string.Equals(group.Id, SelectedResourceGroupFilter, StringComparison.OrdinalIgnoreCase))
        ?? resourceGroups[0];

