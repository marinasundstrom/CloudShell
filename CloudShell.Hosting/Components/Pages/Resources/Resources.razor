@page "/resources"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using CloudShell.Abstractions.Authorization
@using System.Globalization
@using Microsoft.Extensions.Logging
@inject IResourceManager ResourceManager
@inject IResourceEventManager ResourceEvents
@inject ILogManager LogManager
@inject ShellCatalog ShellCatalog
@inject IResourceHealthManager HealthChecks
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject ResourceManagerDisplaySettings DisplaySettings
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject CloudShell.UI.Composition.CompositionRegistry Composition
@inject IStringLocalizer<SharedResource> L
@inject ILogger<Resources> Logger

<PageTitle>@L["Resources"]</PageTitle>
<FluentMenuProvider />

@{
    var allResources = ResourceInventory;
    var inventoryResources = allResources.Where(IsVisibleInInventory).ToArray();
    var groups = ResourceGroups;
    var resourceClasses = GetResourceClassOptions(inventoryResources);
    var resourceTypes = GetResourceTypeOptions(inventoryResources);
    var resourceGroupFilters = GetResourceGroupFilterOptions(groups);
    var rows = BuildRows(allResources);
    SetPaginationTotal(rows.Count);
    var pagedRows = GetPagedRows(rows);
    var selected = SelectedResource;
}

<PageHeading Eyebrow="@L["Resource Manager"].Value"
             Title="@L["Resources"].Value"
             Description="@L["Explore registered resources, project groups, endpoints, dependencies, and nested sub-resources."].Value">
    <Actions>
        <FluentAnchor Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.ShareAndroid())"
                      Href="@GetResourceGraphRoute()">
            @L["Graph"]
        </FluentAnchor>
        <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                      OnClick="RefreshResourcesAsync">
            @(IsCheckingHealth ? L["Checking..."] : L["Refresh"])
        </FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="OpenTemplates">
            @L["Templates"]
        </FluentButton>
        @if (CanOpenSettings)
        {
            <FluentButton Appearance="Appearance.Neutral" IconStart="@(new Icons.Regular.Size20.Settings())"
                          OnClick="OpenSettings">
                @L["Settings"]
            </FluentButton>
        }
        @if (!IsReadOnly && Authorization.CanAccessResourceGroup(
            "__new_resource_group",
            CloudShellPermissions.ResourceGroups.Create))
        {
            <FluentButton Appearance="Appearance.Neutral" OnClick="CreateGroup">
                @L["Create group"]
            </FluentButton>
        }
        @if (!IsReadOnly && Authorization.HasPermission(CloudShellPermissions.Resources.Create))
        {
            <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.AddCircle())"
                          OnClick="AddResource">
                @L["Add resource"]
            </FluentButton>
        }
    </Actions>
</PageHeading>

@if (ProcedureMessage is not null)
{
    <ProcedureMessage Message="@ProcedureMessage" />
}
<ResourceProcedureSignals Signals="ProcedureSignals" />

@if (IsReadOnly)
{
    <ProcedureMessage>
        @L["Resource Manager is in read-only mode. Resource creation, lifecycle actions, updates, and deletes are disabled in this UI."]
    </ProcedureMessage>
}

@if (PendingAction is not null)
{
    <div class="procedure-confirmation">
        @if (PendingAction.RequiresDependencyChoice)
        {
            <strong>@PendingAction.Action.DisplayName @GetResourceLabel(PendingAction.Resource)?</strong>
            <span>@GetDependencyConfirmationMessage(PendingAction)</span>
            <FormActions>
                <FluentButton Appearance="Appearance.Accent" OnClick="() => ConfirmResourceAction(startDependencies: true)">
                    @L["Yes"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Neutral" OnClick="() => ConfirmResourceAction(startDependencies: false)">
                    @L["No, only this resource"]
                </FluentButton>
            </FormActions>
        }
        else if (PendingAction.RequiresDependentWarning)
        {
            <strong>@PendingAction.Action.DisplayName @GetResourceLabel(PendingAction.Resource)?</strong>
            <span>@GetDependentWarningMessage(PendingAction)</span>
            <FormActions>
                <FluentButton Appearance="Appearance.Neutral" OnClick="CancelResourceAction">
                    @L["No"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmDependentWarning">
                    @L["Yes, I'm sure"]
                </FluentButton>
            </FormActions>
        }
        else
        {
            <strong>@PendingAction.Action.DisplayName @GetResourceLabel(PendingAction.Resource)?</strong>
            <span>@GetConfirmationMessage(PendingAction.Resource, PendingAction.Action)</span>
            <FormActions>
                <FluentButton Appearance="Appearance.Neutral" OnClick="CancelResourceAction">
                    @L["Cancel"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="() => ConfirmResourceAction()">
                    @PendingAction.Action.DisplayName
                </FluentButton>
            </FormActions>
        }
    </div>
}

<section class="resource-explorer @(selected is null ? "resource-explorer-no-blade" : null)">
    <div class="resource-list panel">
        <div class="inventory-toolbar">
            <div class="inventory-filters">
                <div class="inventory-filter name-filter">
                    <label for="resource-name-filter">@L["Name"]</label>
                    <FluentSearch Id="resource-name-filter" @bind-Value="NameFilter"
                                  Placeholder="@L["Filter by resource"]" />
                </div>
                <div class="inventory-filter">
                    <label for="resource-class-filter">@L["Class"]</label>
                    <FluentSelect TOption="ResourceClassFilterOption" Id="resource-class-filter"
                                  Class="inventory-select" Items="@resourceClasses"
                                  OptionText="@(resourceClass => resourceClass.DisplayName)"
                                  OptionValue="@(resourceClass => resourceClass.Id)"
                                  SelectedOption="@GetSelectedClassOption(resourceClasses)"
                                  SelectedOptionChanged="ChangeClassFilter" Appearance="Appearance.Neutral" />
                </div>
                <div class="inventory-filter">
                    <label for="resource-type-filter">@L["Type"]</label>
                    <FluentSelect TOption="ResourceTypeFilterOption" Id="resource-type-filter" Class="inventory-select"
                                  Items="@resourceTypes" OptionText="@(type => type.DisplayName)" OptionValue="@(type => type.Id)"
                                  SelectedOption="@GetSelectedTypeOption(resourceTypes)" SelectedOptionChanged="ChangeTypeFilter"
                                  Appearance="Appearance.Neutral" />
                </div>
                <div class="inventory-filter">
                    <label for="resource-group-filter">@L["Resource group"]</label>
                    <FluentSelect TOption="ResourceGroupFilterOption" Id="resource-group-filter"
                                  Class="inventory-select" Items="@resourceGroupFilters"
                                  OptionText="@(group => group.DisplayName)" OptionValue="@(group => group.Id)"
                                  SelectedOption="@GetSelectedResourceGroupOption(resourceGroupFilters)"
                                  SelectedOptionChanged="ChangeResourceGroupFilter" Appearance="Appearance.Neutral" />
                </div>
                @if (HasActiveFilters)
                {
                    <FluentButton Appearance="Appearance.Neutral" OnClick="ClearFilters">
                        @L["Clear"]
                    </FluentButton>
                }
            </div>
            <div class="toolbar-meta">@GetPaginationRangeLabel(rows.Count)</div>
        </div>

        <div class="resource-list-header">
            <span>@L["Resource"]</span>
            <span>@L["Type"]</span>
            <span>@L["Group"]</span>
            <span>@L["State"]</span>
            <span>@L["Health"]</span>
            <span>@L["Endpoint"]</span>
            <span>@L["Actions"]</span>
        </div>

        <div class="resource-tree" role="treegrid" aria-label="@L["Resources"]">
            @foreach (var row in pagedRows)
            {
                var resource = row.Resource;
                var group = GetGroup(resource);
                <div class="resource-tree-row @(selected?.Id == resource.Id ? "selected" : null)" role="row"
                     @onclick="() => OpenResource(resource)">
                    <div class="resource-name-cell" style="--resource-depth: @row.Depth">
                        @if (row.ChildCount > 0)
                        {
                            <button class="tree-toggle" title="@L["Toggle sub-resources"]"
                                    @onclick="() => ToggleResource(resource.Id)" @onclick:stopPropagation="true">
                                @(CollapsedResourceIds.Contains(resource.Id) ? "+" : "-")
                            </button>
                        }
                        else
                        {
                            <span class="tree-spacer"></span>
                        }

                        <ResourceKindIcon Resource="resource" />
                        <ResourceAttentionIndicator Signal="GetAttentionSignal(resource)" />
                        <div>
                            @if (resource.DetailRoute is not null)
                            {
                                <a class="resource-link" href="@resource.DetailRoute"
                                   @onclick:stopPropagation="true">@GetResourceLabel(resource)</a>
                            }
                            else
                            {
                                <strong>@GetResourceLabel(resource)</strong>
                            }
                            @if (row.ChildCount > 0)
                            {
                                <small>@L["{0} sub-resources", row.ChildCount]</small>
                            }
                        </div>
                    </div>
                    <span>@resource.Kind</span>
                    <span>@(group?.Name ?? L["Default group"])</span>
                    <span>
                        @if (ResourceLifecycleDisplay.ShouldShowStatus(resource))
                        {
                            <ResourceStateIndicator State="resource.State" ProgressLabel="@GetLifecycleProgressLabel(resource)"
                                                    Variant="pill" />
                        }
                    </span>
                    <span>@HealthIndicator(resource)</span>
                    <span class="endpoint">
                        @{
                            var preferredEndpoint = GetPreferredEndpointDisplay(resource);
                        }
                        <EndpointLink Address="@preferredEndpoint.Address"
                                      Text="@preferredEndpoint.Text"
                                      EmptyText="@L["n/a"].Value"
                                      EmptyClass="muted"
                                      StopClickPropagation="true" />
                        @if (!string.IsNullOrWhiteSpace(preferredEndpoint.Source))
                        {
                            <small>@preferredEndpoint.Source</small>
                        }
                    </span>
                    <span class="resource-row-actions" @onclick:stopPropagation="true">
                        @ResourceActionControls(resource, includeDetailsAction: true)
                    </span>
                </div>
            }

            @if (rows.Count == 0)
            {
                <EmptyState Title="@L["No resources in this scope"].Value"
                            Message="@L["Change the scope or filter to view other resources."].Value" />
            }
        </div>

        @if (rows.Count > 0)
        {
            <div class="resource-pagination">
                <div class="inventory-filter page-size-filter">
                    <label for="resource-page-size">@L["Rows per page"]</label>
                    <FluentSelect TOption="int" Id="resource-page-size" Class="page-size-select" Items="@PageSizes"
                                  OptionText="@(size => size.ToString())" OptionValue="@(size => size.ToString())"
                                  SelectedOption="@Pagination.ItemsPerPage" SelectedOptionChanged="ChangePageSizeAsync"
                                  Appearance="Appearance.Neutral" />
                </div>
                <div class="pagination-controls">
                    <span class="pagination-range">@GetPaginationRangeLabel(rows.Count)</span>
                    <FluentButton Appearance="Appearance.Neutral" Disabled="@(Pagination.CurrentPageIndex == 0)"
                                  Title="@L["First page"]" OnClick="GoToFirstPageAsync">
                        &lt;&lt;
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Neutral" Disabled="@(Pagination.CurrentPageIndex == 0)"
                                  Title="@L["Previous page"]" OnClick="GoToPreviousPageAsync">
                        &lt;
                    </FluentButton>
                    <span>@L["Page {0} of {1}", Pagination.CurrentPageIndex + 1, GetLastPageIndex(rows.Count) + 1]</span>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(Pagination.CurrentPageIndex >= GetLastPageIndex(rows.Count))" Title="@L["Next page"]"
                                  OnClick="() => GoToNextPageAsync(rows.Count)">
                        &gt;
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@(Pagination.CurrentPageIndex >= GetLastPageIndex(rows.Count))" Title="@L["Last page"]"
                                  OnClick="() => GoToLastPageAsync(rows.Count)">
                        &gt;&gt;
                    </FluentButton>
                </div>
            </div>
        }
    </div>

    @if (selected is not null)
    {
        var group = GetGroup(selected);
        var parent = selected.ParentResourceId is null
            ? null
            : allResources.FirstOrDefault(resource =>
                string.Equals(resource.Id, selected.ParentResourceId, StringComparison.OrdinalIgnoreCase));
        var children = allResources
            .Where(resource => string.Equals(resource.ParentResourceId, selected.Id, StringComparison.OrdinalIgnoreCase))
            .OrderBy(GetResourceSortLabel, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var dependents = GetDependentResources(selected);

        <aside class="resource-blade panel">
            @if (parent is not null)
            {
                <button class="parent-link" @onclick="() => SelectResource(parent)">
                    @L["Back to {0}", GetResourceLabel(parent)]
                </button>
            }

            <div class="detail-heading">
                <ResourceKindIcon Resource="selected" Class="resource-kind-icon large" />
                <div>
                    <h2>@GetResourceLabel(selected)</h2>
                    <p>@selected.Kind</p>
                </div>
                <FluentButton class="blade-dismiss" IconStart="new Icons.Regular.Size20.Dismiss()"
                              title="@L["Dismiss details"]" aria-label="@L["Dismiss details"]" OnClick="DismissResource">

                </FluentButton>
            </div>

            <ResourceStatusSummary Resource="selected"
                                   HealthSummary="GetHealthSummary(selected)"
                                   IsCheckingHealth="IsCheckingHealth"
                                   LifecycleProgressLabel="@GetLifecycleProgressLabel(selected)"
                                   Class="resource-blade-status-summary" />
            <ResourceFailureSummary Resource="selected" Class="resource-blade-failure-summary" />

            @if (selected.DetailRoute is not null)
            {
                <div class="blade-actions">
                    <FluentButton Appearance="Appearance.Accent" OnClick="() => Navigation.NavigateTo(selected.DetailRoute)">
                        @L["Open resource"]
                    </FluentButton>
                    @ResourceActionControls(selected)
                    @if (CanOpenGeneratedDetails(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => OpenResourceDetails(selected)">
                            @L["Details"]
                        </FluentButton>
                    }
                    @if (CanDelete(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => PromptDelete(selected)">
                            @L["Delete"]
                        </FluentButton>
                    }
                </div>
            }
            else
            {
                <div class="blade-actions">
                    @ResourceActionControls(selected)
                    <FluentButton Appearance="Appearance.Neutral" OnClick="() => OpenResourceDetails(selected)">
                        @L["Details"]
                    </FluentButton>
                    @if (CanDelete(selected))
                    {
                        <FluentButton Appearance="Appearance.Neutral" IconStart="new Icons.Regular.Size20.Delete()"
                                      OnClick="() => PromptDelete(selected)">
                            @L["Delete"]
                        </FluentButton>
                    }
                </div>
            }

            <ResourceStartupDeclarationAlert Resource="selected" />

            @if (GetBladeReadinessDiagnostics(selected) is { Count: > 0 } readinessDiagnostics)
            {
                <section class="blade-section">
                    <h3>@L["Readiness"]</h3>
                    <ResourceDiagnosticList Diagnostics="@readinessDiagnostics" />
                </section>
            }

            @if (DeleteConfirmationResourceId == selected.Id)
            {
                <div class="procedure-confirmation">
                    <strong>@L["Delete registration?"]</strong>
                    <span>@L["The provider will commit the delete procedure for this resource."]</span>
                    <FormActions>
                        <FluentButton Appearance="Appearance.Neutral" OnClick="CancelDelete">
                            @L["Cancel"]
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="() => DeleteResource(selected)">
                            @L["Delete"]
                        </FluentButton>
                    </FormActions>
                </div>
            }

            <section class="blade-section">
                <h3>@L["Essentials"]</h3>
                <dl class="detail-list">
                    <dt>@L["Resource ID"]</dt>
                    <dd>@selected.Id</dd>
                    <dt>@L["Name"]</dt>
                    <dd>@DisplaySelection.GetResourceName(selected)</dd>
                    @if (DisplaySelection.ShouldShowDisplayName(selected))
                    {
                        <dt>@L["Display name"]</dt>
                        <dd>@selected.DisplayName</dd>
                    }
                    <dt>@L["Type"]</dt>
                    <dd>@selected.EffectiveTypeId</dd>
                    <dt>@L["Resource group"]</dt>
                    <dd>@(group?.Name ?? L["Default group"])</dd>
                    <dt>@L["Region"]</dt>
                    <dd>@selected.Region</dd>
                    <dt>@L["Version"]</dt>
                    <dd>@selected.Version</dd>
                    @if (!selected.IsNormalResource ||
                        selected.Source != ResourceSource.User ||
                        selected.ManagementMode != ResourceManagementMode.UserManaged ||
                        !string.IsNullOrWhiteSpace(selected.OwnerResourceId))
                    {
                        <dt>@L["Source"]</dt>
                        <dd>@selected.Source</dd>
                        <dt>@L["Management"]</dt>
                        <dd>@selected.ManagementMode</dd>
                        <dt>@L["Visibility"]</dt>
                        <dd>@selected.Visibility</dd>
                        @if (!string.IsNullOrWhiteSpace(selected.OwnerResourceId))
                        {
                            <dt>@L["Owner"]</dt>
                            <dd>@FormatResourceName(selected.OwnerResourceId)</dd>
                        }
                    }
                </dl>
            </section>

            @if (children.Length > 0)
            {
                <section class="blade-section">
                    <h3>@L["Sub-resources"]</h3>
                    <div class="subresource-list">
                        @foreach (var child in children)
                        {
                            <button @onclick="() => SelectResource(child)">
                                <ResourceKindIcon Resource="child" />
                                <span>
                                    <strong>@GetResourceLabel(child)</strong>
                                    <small>@child.Kind</small>
                                </span>
                                @if (ResourceLifecycleDisplay.ShouldShowStatus(child))
                                {
                                    <ResourceStateIndicator State="child.State" ProgressLabel="@GetLifecycleProgressLabel(child)" />
                                }
                            </button>
                        }
                    </div>
                </section>
            }

            <section class="blade-section">
                <h3>@L["Endpoints"]</h3>
                <div class="endpoint-list">
                    @foreach (var endpoint in selected.Endpoints)
                    {
                        <div>
                            <strong>@endpoint.Name</strong>
                            <span>@FormatEndpointSummary(endpoint)</span>
                            @if (GetEndpointNetworkMapping(selected, endpoint.Name) is { } mapping)
                            {
                                <EndpointLink Address="@mapping.Address"
                                              EmptyText="@L["n/a"].Value"
                                              EmptyClass="muted"
                                              StopClickPropagation="true" />
                            }
                            <small>@FormatExposure(endpoint.Exposure)</small>
                        </div>
                    }
                </div>
            </section>

            @if (IsLoadBalancerResource(selected))
            {
                <section class="blade-section">
                    <h3>@L["Load balancing"]</h3>
                    <dl class="detail-list">
                        <dt>@L["Provider"]</dt>
                        <dd>@GetAttributeValue(selected, ResourceAttributeNames.LoadBalancerProvider, selected.Provider)</dd>
                        <dt>@L["Host"]</dt>
                        <dd>
                            @if (GetLoadBalancerHostResourceId(selected) is { } hostResourceId)
                            {
                                @FormatResourceName(hostResourceId)
                            }
                            else
                            {
                                @L["Default container host"]
                            }
                        </dd>
                        <dt>@L["Entrypoints"]</dt>
                        <dd>@GetAttributeValue(selected, ResourceAttributeNames.LoadBalancerEntrypointCount,
                                                                                                                                                                selected.Endpoints.Count.ToString(CultureInfo.InvariantCulture))</dd>
                            <dt>@L["Routes"]</dt>
                            <dd>@FormatLoadBalancerRouteCounts(selected)</dd>
                        </dl>
                    </section>
                }

                @if (IsNetworkResource(selected) && !IsLoadBalancerResource(selected))
                {
                    <section class="blade-section">
                        <h3>@L["Networking"]</h3>
                        <dl class="detail-list">
                            <dt>@L["Kind"]</dt>
                            <dd>@GetAttributeValue(selected, ResourceAttributeNames.NetworkKind, selected.Kind)</dd>
                            <dt>@L["Host readiness"]</dt>
                            <dd>@FormatNetworkReadiness(selected)</dd>
                            @if (selected.ResourceAttributes.ContainsKey(ResourceAttributeNames.NetworkProvisionedMappingCount))
                            {
                                <dt>@L["Provisioned mappings"]</dt>
                                <dd>@GetAttributeValue(selected, ResourceAttributeNames.NetworkProvisionedMappingCount, "0")</dd>
                            }
                            @if (GetMappingProviderIds(selected).Length > 0)
                            {
                                <dt>@L["Mapping providers"]</dt>
                                <dd>@string.Join(", ", GetMappingProviderIds(selected))</dd>
                            }
                        </dl>
                    </section>
                }

                @if (selected.ResourceEndpointMappings.Count > 0)
                {
                    <section class="blade-section">
                        <h3>@L["Endpoint mappings"]</h3>
                        <div class="endpoint-list">
                            @foreach (var mapping in selected.ResourceEndpointMappings)
                            {
                                <div>
                                    <strong>@mapping.Name</strong>
                                    <span>@FormatMappingSummary(mapping, selected)</span>
                                    <small>@FormatMappingProvider(mapping)</small>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (selected.ResourceLoadBalancerRoutes.Count > 0)
                {
                    <section class="blade-section">
                        <h3>@L["Load balancer routes"]</h3>
                        <div class="endpoint-list">
                            @foreach (var route in selected.ResourceLoadBalancerRoutes)
                            {
                                <div>
                                    <strong>@route.Name</strong>
                                    <span>@FormatLoadBalancerRoute(route)</span>
                                    <small>@L["Entrypoint: {0}", route.EntrypointName]</small>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (GetInboundNetworkMappings(selected).Length > 0)
                {
                    <section class="blade-section">
                        <h3>@L["Network exposure"]</h3>
                        <div class="endpoint-list">
                            @foreach (var exposure in GetInboundNetworkMappings(selected))
                            {
                                <div>
                                    <strong>@GetResourceLabel(exposure.Network)</strong>
                                    <span>@FormatMappingSummary(exposure.Mapping, exposure.Network)</span>
                                    <small>@FormatMappingProvider(exposure.Mapping)</small>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (GetInboundLoadBalancerRoutes(selected).Length > 0)
                {
                    <section class="blade-section">
                        <h3>@L["Load balancer exposure"]</h3>
                        <div class="endpoint-list">
                            @foreach (var exposure in GetInboundLoadBalancerRoutes(selected))
                            {
                                <div>
                                    <strong>@GetResourceLabel(exposure.LoadBalancer)</strong>
                                    <span>@FormatLoadBalancerRoute(exposure.Route)</span>
                                    <small>@L["Entrypoint: {0}", exposure.Route.EntrypointName]</small>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (GetInboundNameMappings(selected).Length > 0)
                {
                    <section class="blade-section">
                        <h3>@L["DNS and domain names"]</h3>
                        <div class="endpoint-list">
                            @foreach (var exposure in GetInboundNameMappings(selected))
                            {
                                <div>
                                    <strong>
                                        <EndpointLink Address="@GetNameMappingEndpointAddress(exposure.Mapping)"
                                                      Text="@ResourceNameMappingDisplay.GetHostName(exposure.Mapping)"
                                                      EmptyText="@ResourceNameMappingDisplay.GetHostName(exposure.Mapping)" />
                                    </strong>
                                    <span>@FormatNameMappingSummary(exposure.Mapping, selected)</span>
                                    <small>@FormatNameMappingMetadata(exposure.Mapping)</small>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (selected.DependsOn.Count > 0)
                {
                    <section class="blade-section">
                        <h3>@L["Dependencies"]</h3>
                        <div class="dependency-list">
                            @foreach (var dependency in selected.DependsOn
                                .Distinct(StringComparer.OrdinalIgnoreCase)
                                .OrderBy(dependencyId => dependencyId, StringComparer.OrdinalIgnoreCase))
                            {
                                @ResourceRelationshipLink(dependency)
                            }
                        </div>
                    </section>
                }

                @if (dependents.Count > 0)
                {
                    <section class="blade-section">
                        <h3>@L["Used by"]</h3>
                        <div class="dependency-list">
                            @foreach (var dependent in dependents)
                            {
                                @ResourceRelationshipLink(dependent)
                            }
                        </div>
                    </section>
                }
            </aside>
        }
    </section>

@code {
    private const string PageQueryParameter = "page";
    private const string PageSizeQueryParameter = "pageSize";
    private const string AllResourceGroupsFilter = "__all";
    private const string AllResourceClassesFilter = "__all";
    private const string AllResourceTypesFilter = "__all";
    private const string UngroupedScope = "__ungrouped";
    private static readonly IReadOnlyList<int> PageSizes = [10, 25, 50, 100];
    private readonly HashSet<string> CollapsedResourceIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly SemaphoreSlim HealthRefreshLock = new(1, 1);
    private readonly PaginationState Pagination = new()
    {
        ItemsPerPage = 25
    };
    private string? nameFilter;
    private string selectedClassFilter = AllResourceClassesFilter;
    private string selectedTypeFilter = AllResourceTypesFilter;
    private string selectedResourceGroupFilter = AllResourceGroupsFilter;
    private int lastUrlPageIndex = -1;
    private int lastUrlPageSize = -1;
    private Resource? SelectedResource { get; set; }
    private string? DeleteConfirmationResourceId { get; set; }
    private string? ProcedureMessage { get; set; }
    private IReadOnlyList<ResourceProcedureSignal> ProcedureSignals { get; set; } = [];
    private HashSet<string> ExecutingActionKeys { get; } = new(StringComparer.OrdinalIgnoreCase);
    private PendingResourceAction? PendingAction { get; set; }
    private bool IsCheckingHealth { get; set; }
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private IReadOnlyDictionary<string, ResourceHealthSummary> HealthResults { get; set; } =
        new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase);
