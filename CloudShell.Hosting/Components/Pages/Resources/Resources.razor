            .GroupBy(resource => resource.EffectiveTypeId, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var resource = group.First();
                var displayName = string.Equals(resource.Kind, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase)
                    ? resource.Kind
                    : $"{resource.Kind} ({resource.EffectiveTypeId})";
                return new ResourceTypeFilterOption(resource.EffectiveTypeId, displayName);
            })
            .OrderBy(type => type.DisplayName, StringComparer.OrdinalIgnoreCase)
    ];

