    private IReadOnlyList<ResourceRow> BuildRows(IReadOnlyList<Resource> allResources)
    {
        var scoped = allResources
            .Where(IsVisibleInInventory)
            .Where(IsInSelectedResourceGroup)
            .ToArray();
        var scopedIds = scoped.Select(resource => resource.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var childrenByParent = scoped
            .Where(resource => resource.ParentResourceId is not null)
            .GroupBy(resource => resource.ParentResourceId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.OrderBy(GetResourceSortLabel).ToArray(),
StringComparer.OrdinalIgnoreCase);

        HashSet<string>? visibleIds = null;
        if (HasActiveListFilters())
        {
            visibleIds = scoped
                .Where(MatchesListFilters)
                .Select(resource => resource.Id)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            foreach (var resource in scoped.Where(resource => visibleIds.Contains(resource.Id)))
            {
                var parentId = resource.ParentResourceId;
                while (parentId is not null && scopedIds.Contains(parentId) && visibleIds.Add(parentId))
                {
                    parentId = scoped.First(item => item.Id == parentId).ParentResourceId;
                }
            }
        }

        var rows = new List<ResourceRow>();
        var roots = scoped
            .Where(resource => resource.ParentResourceId is null || !scopedIds.Contains(resource.ParentResourceId))
            .OrderBy(GetResourceSortLabel, StringComparer.OrdinalIgnoreCase);

        foreach (var root in roots)
        {
            AddResourceRow(root, 0, childrenByParent, visibleIds, rows);
        }

        return rows;
    }

    private void AddResourceRow(
        Resource resource,
        int depth,
        IReadOnlyDictionary<string, Resource[]> childrenByParent,
        HashSet<string>? visibleIds,
        List<ResourceRow> rows)
    {
        if (visibleIds is not null && !visibleIds.Contains(resource.Id))
        {
            return;
        }

        var children = childrenByParent.GetValueOrDefault(resource.Id) ?? [];
        rows.Add(new ResourceRow(resource, depth, children.Length));

        if (CollapsedResourceIds.Contains(resource.Id) && visibleIds is null)
        {
            return;
        }

        foreach (var child in children)
        {
            AddResourceRow(child, depth + 1, childrenByParent, visibleIds, rows);
        }
    }

