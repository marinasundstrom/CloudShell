    private async Task RequestResourceAction(Resource resource, ResourceAction action)
    {
        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            ProcedureSignals = [];
            return;
        }

        var stoppedDependencies = ShouldStartDependencies(action)
            ? GetStoppedDependencies(resource)
            : [];
        var activeDependents = ShouldWarnDependents(action)
            ? GetActiveDependents(resource)
            : [];
        if (activeDependents.Count > 0)
        {
            PendingAction = new PendingResourceAction(
                resource,
                action,
                stoppedDependencies,
                activeDependents,
                RequiresDependencyChoice: false,
                RequiresDependentWarning: true);
            ProcedureMessage = null;
            ProcedureSignals = [];
            return;
        }

        if (stoppedDependencies.Count > 0)
        {
            PendingAction = new PendingResourceAction(
                resource,
                action,
                stoppedDependencies,
                activeDependents,
                RequiresDependencyChoice: true,
                RequiresDependentWarning: false);
            ProcedureMessage = null;
            ProcedureSignals = [];
            return;
        }

        if (action.RequiresConfirmation)
        {
            PendingAction = new PendingResourceAction(
                resource,
                action,
                [],
                [],
                RequiresDependencyChoice: false,
                RequiresDependentWarning: false);
            ProcedureMessage = null;
            ProcedureSignals = [];
            return;
        }

        await ExecuteResourceAction(resource, action, startDependencies: false);
    }

    private async Task ConfirmResourceAction(bool startDependencies = false)
    {
        if (PendingAction is null)
        {
            return;
        }

        var pending = PendingAction;
        PendingAction = null;
        await ExecuteResourceAction(pending.Resource, pending.Action, startDependencies);
    }

    private async Task ConfirmDependentWarning()
    {
        if (PendingAction is null)
        {
            return;
        }

        var pending = PendingAction;
        if (pending.StoppedDependencies.Count > 0)
        {
            PendingAction = pending with
            {
                RequiresDependencyChoice = true,
                RequiresDependentWarning = false
            };
            return;
        }

        PendingAction = null;
        await ExecuteResourceAction(pending.Resource, pending.Action, startDependencies: false);
    }

    private void CancelResourceAction() => PendingAction = null;

    private async Task ExecuteResourceAction(
        Resource resource,
        ResourceAction action,
        bool startDependencies)
    {
        if (IsReadOnly)
        {
            ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            ProcedureSignals = [];
            return;
        }

        ExecutingActionKeys.Add(GetActionKey(resource, action));
        ProcedureMessage = null;
        ProcedureSignals = [];
        try
        {
            var result = await ResourceManager.ExecuteResourceActionAsync(
                resource,
                action,
                startDependencies,
                ignoreDependentWarning: true,
                dependencyStartFailureBehavior: GetDependencyStartFailureBehavior());
            ProcedureMessage = result.Message;
            ProcedureSignals = result.Signals;
            await RefreshResourcesAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
            ProcedureSignals = [];
        }
        finally
        {
            ExecutingActionKeys.Remove(GetActionKey(resource, action));
        }
    }

    private IReadOnlyList<Resource> GetStoppedDependencies(Resource resource)
    {
        var dependencies = new List<Resource>();
        CollectStoppedDependencies(
            resource,
            dependencies,
            new HashSet<string>(StringComparer.OrdinalIgnoreCase));
        return dependencies;
    }

    private void CollectStoppedDependencies(
        Resource resource,
        List<Resource> dependencies,
        HashSet<string> visited)
    {
        if (!visited.Add(resource.Id))
        {
            return;
        }

        foreach (var dependencyId in resource.DependsOn.Distinct(StringComparer.OrdinalIgnoreCase))
        {
            var dependency = ResourceInventory.FirstOrDefault(resource =>
                string.Equals(resource.Id, dependencyId, StringComparison.OrdinalIgnoreCase));
            if (dependency is null)
            {
                continue;
            }

            CollectStoppedDependencies(dependency, dependencies, visited);
            if (dependency.State is not null and not ResourceState.Running &&
                dependencies.All(item => !string.Equals(item.Id, dependency.Id, StringComparison.OrdinalIgnoreCase)))
            {
                dependencies.Add(dependency);
            }
        }
    }

    private IReadOnlyList<Resource> GetActiveDependents(Resource resource) =>
        ResourceInventory
            .Where(candidate => candidate.DependsOn.Contains(resource.Id, StringComparer.OrdinalIgnoreCase))
            .Where(candidate => IsActiveDependencyState(candidate.State))
            .OrderBy(candidate => candidate.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetDependentResources(Resource resource) =>
        ResourceInventory
            .Where(candidate => !string.Equals(candidate.Id, resource.Id, StringComparison.OrdinalIgnoreCase))
            .Where(candidate => candidate.DependsOn.Contains(resource.Id, StringComparer.OrdinalIgnoreCase))
            .OrderBy(GetResourceSortLabel, StringComparer.OrdinalIgnoreCase)
            .ThenBy(candidate => candidate.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private bool CanManage(Resource resource) =>
        !IsReadOnly &&
        IsUserManagedNormalResource(resource) &&
        GetCapabilities(resource).CanManage;

    private bool CanOpenGeneratedDetails(Resource resource)
    {
        var group = GetGroup(resource);
        return ResourceManagerUiAccess.CanReadResource(Authorization, resource, group?.Id);
    }

    private bool CanDelete(Resource resource) =>
        !IsReadOnly &&
        IsUserManagedNormalResource(resource) &&
        GetCapabilities(resource).CanDelete;

    private bool CanExecuteAction(Resource resource, ResourceAction action) =>
        !IsReadOnly &&
        IsUserManagedNormalResource(resource) &&
        GetCapabilities(resource).CanExecuteAction(action.Id);

    private string GetActionTitle(Resource resource, ResourceAction action)
    {
        if (IsReadOnly)
        {
            return $"{action.DisplayName} unavailable. Resource Manager is in read-only mode.";
        }

        if (!IsUserManagedNormalResource(resource))
        {
            return $"{action.DisplayName} unavailable. Resource is not user-managed.";
        }

        var reason = GetCapabilities(resource).GetActionUnavailableReason(action.Id);
        if (!string.IsNullOrWhiteSpace(reason))
        {
            return $"{action.DisplayName} unavailable. {reason}";
        }

        return action.DisplayName;
    }

    private ResourceOperationCapabilities GetCapabilities(Resource resource) =>
        ResourceCapabilities.GetValueOrDefault(resource.Id) ??
        ResourceOperationCapabilities.None(resource.Id);

    private IReadOnlyList<ResourceDiagnosticView> GetBladeReadinessDiagnostics(Resource resource) =>
        ResourceActionReadinessDiagnostics.GetDiagnostics(resource, GetCapabilities(resource));

    private static bool IsNetworkResource(Resource resource) =>
        resource.ResourceClass == ResourceClass.Network ||
        resource.HasCapability(ResourceCapabilityIds.NetworkingProvider);

    private static bool IsLoadBalancerResource(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.NetworkingLoadBalancer) ||
        resource.ResourceLoadBalancerRoutes.Count > 0 ||
        resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.LoadBalancerProvider);

    private static string GetAttributeValue(
        Resource resource,
        string name,
        string fallback) =>
        resource.ResourceAttributes.GetValueOrDefault(name) ?? fallback;

    private string FormatNetworkReadiness(Resource resource)
    {
        var readiness = GetAttributeValue(resource, ResourceAttributeNames.NetworkHostReadiness, "unknown");
        return readiness switch
        {
            "logicalOnly" => L["Logical only"].Value,
            "providerRequired" when GetMissingMappingProviderIds(resource).Length == 0 => L["Ready"].Value,
            "providerRequired" => L["Provider missing"].Value,
            "ready" => L["Ready"].Value,
            _ => readiness
        };
    }

    private static string[] GetMappingProviderIds(Resource resource) =>
        resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.NetworkMappingProviders, out var providers)
            ? providers
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray()
            : [];

    private string[] GetMissingMappingProviderIds(Resource resource) =>
        GetMappingProviderIds(resource)
            .Where(providerId => !ResourceInventory.Any(candidate =>
                string.Equals(candidate.Id, providerId, StringComparison.OrdinalIgnoreCase)))
            .ToArray();

    private NetworkEndpointMappingView[] GetInboundNetworkMappings(Resource resource) =>
        ResourceInventory
            .Where(candidate => candidate.ResourceClass == ResourceClass.Network)
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    resource.Id,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => mapping.Network.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private LoadBalancerRouteView[] GetInboundLoadBalancerRoutes(Resource resource) =>
        ResourceInventory
            .Where(IsLoadBalancerResource)
            .Where(loadBalancer => !string.Equals(loadBalancer.Id, resource.Id, StringComparison.OrdinalIgnoreCase))
            .SelectMany(loadBalancer => loadBalancer.ResourceLoadBalancerRoutes
                .Where(route => string.Equals(
                    route.Target.ResourceId,
                    resource.Id,
                    StringComparison.OrdinalIgnoreCase))
                .Select(route => new LoadBalancerRouteView(loadBalancer, route)))
            .OrderBy(route => route.LoadBalancer.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Route.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private NameMappingView[] GetInboundNameMappings(Resource resource) =>
        ResourceInventory
            .Where(ResourceNameMappingDisplay.IsNameMappingResource)
            .Where(mapping => ResourceNameMappingDisplay.TargetsResource(mapping, resource.Id))
            .Select(mapping => new NameMappingView(mapping))
            .OrderBy(mapping => ResourceNameMappingDisplay.GetHostName(mapping.Mapping), StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string FormatMappingSummary(
        ResourceEndpointMappingDefinition mapping,
        Resource? sourceResource = null) =>
        $"{FormatEndpointReference(mapping.Source, sourceResource)} -> {FormatEndpointReference(mapping.Target)}";

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        Resource? fallbackResource = null)
    {
        var resource = ResolveMappingResource(reference.ResourceId, fallbackResource);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var summary = endpoint is null
            ? null
            : $" ({FormatEndpointSummary(endpoint)})";
        return $"{(resource is null ? GetFallbackResourceLabel(reference.ResourceId) : GetResourceLabel(resource))}/{reference.EndpointName}{summary}";
    }

    private string FormatEndpointSummary(ResourceEndpoint endpoint)
    {
        var protocol = string.IsNullOrWhiteSpace(endpoint.Protocol)
            ? L["unspecified"].Value
            : endpoint.Protocol;
        return endpoint.TargetPort is null
            ? protocol
            : L["{0}:{1}", protocol, endpoint.TargetPort.Value.ToString(CultureInfo.InvariantCulture)].Value;
    }

    private string FormatExposure(ResourceExposureScope exposure) =>
        exposure switch
        {
            ResourceExposureScope.Private => L["private"].Value,
            ResourceExposureScope.Local => L["local"].Value,
            ResourceExposureScope.Network => L["network"].Value,
            ResourceExposureScope.Public => L["public"].Value,
            _ => exposure.ToString()
        };

    private static ResourceEndpointNetworkMapping? GetEndpointNetworkMapping(
        Resource resource,
        string endpointName) =>
        resource.ResourceEndpointNetworkMappings.FirstOrDefault(mapping => mapping.MatchesEndpoint(endpointName));

    private string FormatMappingProvider(ResourceEndpointMappingDefinition mapping)
    {
        var providerId = FirstNonEmpty(mapping.ProviderResourceId, mapping.NetworkResourceId, mapping.Source.ResourceId);
        if (string.IsNullOrWhiteSpace(providerId))
        {
            return L["Provider: network"].Value;
        }

        var provider = ResolveMappingResource(providerId);
        return provider is null
            ? L["Provider: {0}", GetFallbackResourceLabel(providerId)].Value
            : L["Provider: {0}", GetResourceLabel(provider)].Value;
    }

    private Resource? ResolveMappingResource(string resourceId, Resource? fallbackResource = null)
    {
        if (fallbackResource is not null &&
            string.Equals(fallbackResource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return fallbackResource;
        }

        return ResourceInventory.FirstOrDefault(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase));
    }

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private string FormatLoadBalancerRoute(LoadBalancerRoute route) =>
        $"{FormatLoadBalancerRouteMatch(route)} -> {FormatLoadBalancerRouteTarget(route.Target)}";

    private string FormatLoadBalancerRouteMatch(LoadBalancerRoute route)
    {
        if (route.Kind == LoadBalancerRouteKind.Tcp)
        {
            return L["TCP {0}", route.Match.Port?.ToString() ?? route.EntrypointName].Value;
        }

        var host = string.IsNullOrWhiteSpace(route.Match.Host)
            ? L["any host"].Value
            : route.Match.Host;
        return string.IsNullOrWhiteSpace(route.Match.PathPrefix)
            ? host
            : $"{host}{route.Match.PathPrefix}";
    }

    private string FormatLoadBalancerRouteTarget(LoadBalancerRouteTarget target)
    {
        var resource = ResolveMappingResource(target.ResourceId);
        var label = resource is null ? GetFallbackResourceLabel(target.ResourceId) : GetResourceLabel(resource);
        if (!string.IsNullOrWhiteSpace(target.EndpointName))
        {
            return $"{label}/{target.EndpointName}";
        }

        return target.Port is null
            ? label
            : $"{label}:{target.Port.Value}";
    }

    private string FormatNameMappingSummary(Resource mapping, Resource target) =>
        L["{0} -> {1}/{2}",
            ResourceNameMappingDisplay.GetHostName(mapping),
            GetResourceLabel(target),
            ResourceNameMappingDisplay.GetTargetEndpointName(mapping)].Value;

    private string? GetNameMappingEndpointAddress(Resource mapping)
    {
        var targetResourceId = ResourceNameMappingDisplay.GetTargetResourceId(mapping);
        var target = string.IsNullOrWhiteSpace(targetResourceId)
            ? null
            : ResolveMappingResource(targetResourceId);

        return ResourceNameMappingDisplay.GetMappedEndpointAddress(mapping, target);
    }

    private EndpointDisplay GetPreferredEndpointDisplay(Resource resource)
    {
        var nameMapping = GetInboundNameMappings(resource)
            .Select(mapping => new
            {
                Mapping = mapping.Mapping,
                Address = GetNameMappingEndpointAddress(mapping.Mapping)
            })
            .FirstOrDefault(mapping => !string.IsNullOrWhiteSpace(mapping.Address));
        if (nameMapping is not null)
        {
            return new EndpointDisplay(
                nameMapping.Address,
                ResourceNameMappingDisplay.GetHostName(nameMapping.Mapping),
                L["DNS name"].Value);
        }

        return string.Equals(resource.PrimaryEndpoint, "none", StringComparison.OrdinalIgnoreCase)
            ? new EndpointDisplay(null, null, null)
            : new EndpointDisplay(resource.PrimaryEndpoint, null, null);
    }

    private string FormatNameMappingMetadata(Resource mapping)
    {
        var parts = new List<string>
        {
            L["Exposure: {0}", ResourceNameMappingDisplay.GetExposureLabel(mapping)].Value,
            FormatNameMappingProvider(mapping),
            L["Materialization: {0}", ResourceNameMappingDisplay.GetMaterializationLabel(mapping, Localize)].Value
        };

        var zone = string.IsNullOrWhiteSpace(mapping.ParentResourceId)
            ? null
            : ResolveMappingResource(mapping.ParentResourceId);
        if (zone is not null)
        {
            parts.Insert(0, L["Zone: {0}", GetResourceLabel(zone)].Value);
        }

        return string.Join(" | ", parts);
    }

    private string FormatNameMappingProvider(Resource mapping)
    {
        var providerResourceId = ResourceNameMappingDisplay.GetProviderResourceId(mapping);
        if (!string.IsNullOrWhiteSpace(providerResourceId))
        {
            var provider = ResolveMappingResource(providerResourceId);
            return provider is null
                ? L["Provider: {0}", GetFallbackResourceLabel(providerResourceId)].Value
                : L["Provider: {0}", GetResourceLabel(provider)].Value;
        }

        return L["Provider: {0}", GetAttributeValue(mapping, ResourceAttributeNames.DnsProvider, "logical")].Value;
    }

    private static string? GetLoadBalancerHostResourceId(Resource resource)
    {
        var hostResourceId = resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.LoadBalancerHostResourceId);
        return string.IsNullOrWhiteSpace(hostResourceId) ||
            string.Equals(hostResourceId, "default", StringComparison.OrdinalIgnoreCase)
                ? null
                : hostResourceId;
    }

    private string FormatResourceName(string resourceId) =>
        FindResource(resourceId) is { } resource
                ? GetResourceLabel(resource)
                : GetFallbackResourceLabel(resourceId);

    private static string GetFallbackResourceLabel(string resourceId) =>
        ResourceDisplayLabels.GetName(resourceId);

    private Resource? FindResource(string resourceId) =>
        ResourceInventory.FirstOrDefault(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase));

    private RenderFragment ResourceRelationshipLink(string resourceId)
    {
        var resource = FindResource(resourceId);
        if (resource is null)
        {
            return @<ResourcePillLink Label="@GetFallbackResourceLabel(resourceId)"
                                      Metadata="@L["Missing resource"].Value" />;
        }

        return ResourceRelationshipLink(resource);
    }

    private RenderFragment ResourceRelationshipLink(Resource resource) =>
        @<ResourcePillLink Label="@GetResourceLabel(resource)"
                           Href="@ResourceManagerRoutes.ResourceOverview(resource.Id)"
                           Resource="@resource"
                           Metadata="@resource.EffectiveTypeId" />;

    private string FormatLoadBalancerRouteCounts(Resource resource)
    {
        var routeCount = GetAttributeValue(
            resource,
            ResourceAttributeNames.LoadBalancerRouteCount,
            resource.ResourceLoadBalancerRoutes.Count.ToString(CultureInfo.InvariantCulture));
        var httpCount = GetAttributeValue(resource, ResourceAttributeNames.LoadBalancerHttpRouteCount, "0");
        var tcpCount = GetAttributeValue(resource, ResourceAttributeNames.LoadBalancerTcpRouteCount, "0");
        return L["{0} total ({1} HTTP, {2} TCP)", routeCount, httpCount, tcpCount].Value;
    }

    private bool IsExecutingAction(Resource resource, ResourceAction action) =>
        ExecutingActionKeys.Contains(GetActionKey(resource, action));

    private string GetLifecycleStatusLabel(Resource resource) =>
        GetLifecycleProgressLabel(resource) ?? resource.State?.ToString() ?? ResourceState.Unknown.ToString();

    private string? GetLifecycleProgressLabel(Resource resource)
    {
        var action = resource.ResourceActions.FirstOrDefault(action => IsExecutingAction(resource, action));
        return action?.Kind switch
        {
            ResourceActionKind.Start => L["Starting"].Value,
            ResourceActionKind.Stop => L["Stopping"].Value,
            ResourceActionKind.Pause => L["Pausing"].Value,
            ResourceActionKind.Restart => L["Restarting"].Value,
            _ => null
        };
    }

    private ResourceHealthSummary? GetHealthSummary(Resource resource) =>
        HealthResults.GetValueOrDefault(resource.Id);

    private RenderFragment HealthIndicator(Resource resource) => builder =>
    {
        if (resource.ResourceHealthChecks.Count == 0)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "muted");
            builder.AddContent(2, L["n/a"]);
            builder.CloseElement();
            return;
        }

        var health = GetHealthSummary(resource);
        builder.OpenComponent<HealthPill>(3);
        builder.AddAttribute(4, "Status", health?.Status);
        builder.AddAttribute(5, "Label", GetHealthLabel(health));
        builder.CloseComponent();
    };

    private string GetHealthLabel(ResourceHealthSummary? health)
    {
        if (health is null)
        {
            return IsCheckingHealth ? L["Checking"].Value : L["Not checked"].Value;
        }

        return health.Status switch
        {
            ResourceHealthStatus.Healthy => L["Healthy"].Value,
            ResourceHealthStatus.Unhealthy => L["Unhealthy"].Value,
            _ => L["Unknown"].Value
        };
    }

    private static string GetActionKey(Resource resource, ResourceAction action) =>
        GetActionKey(resource.Id, action.Id);

    private static string GetActionKey(string resourceId, string actionId) =>
        $"{resourceId}:{actionId}";

    private void TrackResourceActionNotification(ResourceChangeNotification notification)
    {
        if (string.IsNullOrWhiteSpace(notification.ResourceId) ||
            string.IsNullOrWhiteSpace(notification.ActionId))
        {
            return;
        }

        var key = GetActionKey(notification.ResourceId, notification.ActionId);
        if (notification.Kind == ResourceChangeKind.ResourceActionStarted)
        {
            ExecutingActionKeys.Add(key);
        }
        else if (notification.Kind is ResourceChangeKind.ResourceActionExecuted
            or ResourceChangeKind.ResourceActionFailed)
        {
            ExecutingActionKeys.Remove(key);
        }
    }

    private RenderFragment ResourceActionControls(
        Resource resource,
        bool includeDetailsAction = false) => builder =>
    {
        var logs = GetLogs(resource);
        if (resource.ResourceActions.Count == 0 && logs.Count == 0 && !includeDetailsAction)
        {
            return;
        }

        var sequence = 0;
        foreach (var action in resource.ResourceActions.Where(IsInlineAction))
        {
            builder.OpenComponent<FluentButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-icon-button");
            builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "Style", "width: 2rem; min-width: 2rem;");
            builder.AddAttribute(sequence++, "Title", GetActionTitle(resource, action));
            builder.AddAttribute(sequence++, "Disabled",
                !CanExecuteAction(resource, action) || IsExecutingAction(resource, action));
            builder.AddAttribute(sequence++, "OnClick",
                EventCallback.Factory.Create<MouseEventArgs>(
                    this,
                    () => RequestResourceAction(resource, action)));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
            {
                AddActionIcon(buttonBuilder, action.EffectivePresentation.Icon);
            }));
            builder.CloseComponent();
        }

        var overflowActions = resource.ResourceActions
            .Where(action => !IsInlineAction(action))
            .ToArray();

        if (overflowActions.Length == 0 && !includeDetailsAction)
        {
            if (logs.Count > 0)
            {
                builder.OpenComponent<FluentButton>(sequence++);
                builder.AddAttribute(sequence++, "Class", "action-icon-button");
                builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
                builder.AddAttribute(sequence++, "Style", "width: 2rem; min-width: 2rem;");
                builder.AddAttribute(sequence++, "Title", GetLogsActionLabel(logs.Count));
                builder.AddAttribute(sequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => OpenLogs(resource)));
                builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
                {
                    AddIcon(buttonBuilder, new Icons.Regular.Size20.DocumentText());
                }));
                builder.CloseComponent();
            }

            return;
        }

        builder.OpenComponent<FluentMenuButton>(sequence++);
        builder.AddAttribute(sequence++, "Class", "action-overflow-button");
        builder.AddAttribute(sequence++, "UseMenuService", true);
        builder.AddAttribute(sequence++, "ButtonAppearance", Appearance.Neutral);
        builder.AddAttribute(sequence++, "ButtonStyle", "width: 2rem; min-width: 2rem;");
        builder.AddAttribute(sequence++, "ButtonContent", (RenderFragment)(buttonBuilder =>
        {
            AddIcon(buttonBuilder, new Icons.Regular.Size20.MoreVertical());
        }));
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(menuBuilder =>
        {
            var menuSequence = 0;
            foreach (var action in overflowActions)
            {
                menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                menuBuilder.AddAttribute(menuSequence++, "Disabled",
                    !CanExecuteAction(resource, action) || IsExecutingAction(resource, action));
                menuBuilder.AddAttribute(menuSequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => RequestResourceAction(resource, action)));
                menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                {
                    itemBuilder.OpenElement(0, "span");
                    itemBuilder.AddAttribute(1, "class", "menu-action-content");
                    AddActionIcon(itemBuilder, action.EffectivePresentation.Icon, 2);
                    itemBuilder.OpenElement(5, "span");
                    itemBuilder.AddContent(6, IsExecutingAction(resource, action)
                        ? L["Working"]
                        : action.DisplayName);
                    itemBuilder.CloseElement();
                    itemBuilder.CloseElement();
                }));
                menuBuilder.CloseComponent();
            }

            if (logs.Count > 0)
            {
                menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                menuBuilder.AddAttribute(menuSequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => OpenLogs(resource)));
                menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                {
                    itemBuilder.OpenElement(0, "span");
                    itemBuilder.AddAttribute(1, "class", "menu-action-content");
                    AddIcon(itemBuilder, new Icons.Regular.Size20.DocumentText(), 2);
                    itemBuilder.OpenElement(5, "span");
                    itemBuilder.AddContent(6, GetLogsActionLabel(logs.Count));
                    itemBuilder.CloseElement();
                    itemBuilder.CloseElement();
                }));
                menuBuilder.CloseComponent();
            }

            if (includeDetailsAction)
            {
                menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                menuBuilder.AddAttribute(menuSequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => OpenResourceDetails(resource)));
                menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                {
                    itemBuilder.OpenElement(0, "span");
                    itemBuilder.AddAttribute(1, "class", "menu-action-content");
                    AddIcon(itemBuilder, new Icons.Regular.Size20.AppsListDetail(), 2);
                    itemBuilder.OpenElement(5, "span");
                    itemBuilder.AddContent(6, L["Details"]);
                    itemBuilder.CloseElement();
                    itemBuilder.CloseElement();
                }));
                menuBuilder.CloseComponent();
            }
        }));
        builder.CloseComponent();
    };

    private static bool IsInlineAction(ResourceAction action) =>
        action.EffectivePresentation.DisplayStyle == ResourceActionDisplayStyle.Inline;

    private static void AddActionIcon(
        RenderTreeBuilder builder,
        ResourceActionIcon actionIcon,
        int sequence = 0) =>
        AddIcon(builder, GetActionIcon(actionIcon), sequence);

    private static void AddIcon(
        RenderTreeBuilder builder,
        Icon icon,
        int sequence = 0)
    {
        builder.OpenComponent<FluentIcon<Icon>>(sequence);
        builder.AddAttribute(sequence + 1, "Class", "action-icon");
        builder.AddAttribute(sequence + 2, "Value", icon);
        builder.CloseComponent();
    }

    private static Icon GetActionIcon(ResourceActionIcon actionIcon) => actionIcon switch
    {
        ResourceActionIcon.Start => new Icons.Regular.Size20.PlayCircle(),
        ResourceActionIcon.Stop => new Icons.Regular.Size20.RecordStop(),
        ResourceActionIcon.Pause => new Icons.Regular.Size20.PauseCircle(),
        ResourceActionIcon.Restart => new Icons.Regular.Size20.ArrowSync(),
        _ => new Icons.Regular.Size20.AppsListDetail()
    };

    private string GetConfirmationMessage(Resource resource, ResourceAction action) =>
        action.Description ??
        L["This will request the {0} action for {1}.", action.DisplayName, GetResourceLabel(resource)].Value;

    private string GetDependencyConfirmationMessage(PendingResourceAction pending)
    {
        var names = string.Join(", ", pending.StoppedDependencies.Select(dependency => dependency.Name));
        return L[
            "The following dependencies are not running: {0}. Start them as well?",
            names].Value;
    }

    private string GetDependentWarningMessage(PendingResourceAction pending)
    {
        var names = string.Join(", ", pending.ActiveDependents.Select(dependent => dependent.Name));
        return L[
            "The following running resources depend on this resource: {0}. Stopping it may disrupt them. Do you want to stop the resource?",
            names].Value;
    }

    private static bool ShouldStartDependencies(ResourceAction action) =>
        action.Kind is ResourceActionKind.Start or ResourceActionKind.Restart;

    private DependencyStartFailureBehavior GetDependencyStartFailureBehavior() =>
        OrchestrationSettings.GetDependencyStartFailureSettings().Behavior;

    private static bool ShouldWarnDependents(ResourceAction action) =>
        action.Kind is ResourceActionKind.Stop or ResourceActionKind.Restart;

    private static bool IsActiveDependencyState(ResourceState? state) =>
        state is not null and not ResourceState.Stopped and not ResourceState.Unknown;

    private string GetLogsActionLabel(int logCount) =>
        logCount == 1 ? L["Logs"].Value : L["Logs ({0})", logCount].Value;

    private string GetResourceClassDisplayName(ResourceClass resourceClass) => resourceClass switch
    {
        ResourceClass.Executable => L["Executable"].Value,
        ResourceClass.Project => L["Project"].Value,
        ResourceClass.Container => L["Container"].Value,
        ResourceClass.Service => L["Service"].Value,
        ResourceClass.Network => L["Network"].Value,
        ResourceClass.Configuration => L["Configuration"].Value,
        ResourceClass.Infrastructure => L["Infrastructure"].Value,
        ResourceClass.SecretsVault => L["Secrets Vault"].Value,
        _ => L["Generic"].Value
    };

