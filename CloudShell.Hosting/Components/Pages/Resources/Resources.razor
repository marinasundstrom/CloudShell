    private async Task LoadResourceModelAsync()
    {
        ResourceInventory = await ResourceManager.ListResourcesAsync();
        ResourceGroups = await ResourceManager.ListResourceGroupsAsync();
        ResourceCapabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(
            ResourceInventory.Select(resource => resource.Id).ToArray());
        ResourceFailureSignals = await LoadResourceFailureSignalsAsync(ResourceInventory);
        await RestoreActiveLifecycleTransitionsAsync(ResourceInventory);

        var logs = Authorization.CanReadLogs()
            ? await LogManager.ListLogSourcesAsync()
            : [];
        LogsByResourceId = logs
            .Where(log => !string.IsNullOrWhiteSpace(log.ResourceId))
            .GroupBy(log => log.ResourceId!, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => (IReadOnlyList<LogSource>)group.ToArray(),
                StringComparer.OrdinalIgnoreCase);

        ResourceGroupsByResourceId = await ResourceManagerUiAccess.CreateGroupLookupAsync(
            ResourceManager,
            ResourceInventory);
        if (SelectedResource is not null)
        {
            SelectedResource = ResourceInventory.FirstOrDefault(resource =>
                string.Equals(resource.Id, SelectedResource.Id, StringComparison.OrdinalIgnoreCase));
        }
    }

    private async Task<IReadOnlyDictionary<string, ResourceFailureSignal>> LoadResourceFailureSignalsAsync(
        IReadOnlyList<Resource> resources)
    {
        if (resources.Count == 0)
        {
            return new Dictionary<string, ResourceFailureSignal>(StringComparer.OrdinalIgnoreCase);
        }

        var resourceIds = resources
            .Select(resource => resource.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var maxEvents = Math.Clamp(resources.Count * 20, 100, 1000);

        try
        {
            var events = await ResourceEvents.ListResourceEventsAsync(new ResourceEventQuery(MaxEvents: maxEvents));
            return events
                .Where(resourceEvent => resourceIds.Contains(resourceEvent.ResourceId))
                .GroupBy(resourceEvent => resourceEvent.ResourceId, StringComparer.OrdinalIgnoreCase)
                .Select(group => new
                {
                    ResourceId = group.Key,
                    Failure = resources.FirstOrDefault(resource =>
                        string.Equals(resource.Id, group.Key, StringComparison.OrdinalIgnoreCase)) is { } resource
                        ? ResourceFailureSignalResolver.GetActiveFailure(resource, group)
                        : null
                })
                .Where(item => item.Failure is not null)
                .ToDictionary(
                    item => item.ResourceId,
                    item => item.Failure!,
                    StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to load resource activity failure signals.");
            return new Dictionary<string, ResourceFailureSignal>(StringComparer.OrdinalIgnoreCase);
        }
    }

    private async Task RestoreActiveLifecycleTransitionsAsync(IReadOnlyList<Resource> resources)
    {
        if (resources.Count == 0)
        {
            return;
        }

        var resourceIds = resources
            .Select(resource => resource.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var maxEvents = Math.Clamp(resources.Count * 20, 100, 1000);

        try
        {
            var events = await ResourceEvents.ListResourceEventsAsync(new ResourceEventQuery(MaxEvents: maxEvents));
            foreach (var transition in ResourceLifecycleTransitionResolver.GetActiveTransitions(events))
            {
                if (resourceIds.Contains(transition.ResourceId))
                {
                    ExecutingActionKeys.Add(GetActionKey(transition.ResourceId, transition.ActionId));
                }
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to restore active resource lifecycle transitions.");
        }
    }

    private ResourceFailureSignal? GetFailureSignal(Resource resource) =>
        ResourceFailureSignals.TryGetValue(resource.Id, out var failure)
            ? failure
            : null;

    private ResourceAttentionSignal? GetAttentionSignal(Resource resource)
    {
        if (GetFailureSignal(resource) is { } failure)
        {
            return new ResourceAttentionSignal(
                failure.Severity,
                ResourceFailureSignalDisplay.GetTooltip(failure, L));
        }

        if (ResourceLifecycleDisplay.HasStateHealthIncongruity(resource, GetHealthSummary(resource)))
        {
            return new ResourceAttentionSignal(
                ResourceSignalSeverity.Warning,
                L["Potential bad state: health checks report healthy while the resource is {0}. Verify the lifecycle state, health probe target, and possible leftover process.",
                    resource.State?.ToString() ?? L["not running"].Value].Value);
        }

        return null;
    }

    private IReadOnlyList<ResourceTypeFilterOption> GetResourceTypeOptions(IReadOnlyList<Resource> resources) =>
    [
        new ResourceTypeFilterOption(AllResourceTypesFilter, L["All types"].Value),
