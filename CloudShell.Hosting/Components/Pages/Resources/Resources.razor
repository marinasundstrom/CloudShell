    private async Task RefreshResourcesAsync() => await RefreshResourceHealthAsync();

    private async Task RefreshResourceHealthAsync(CancellationToken cancellationToken = default)
    {
        if (IsDisposed ||
            !await HealthRefreshLock.WaitAsync(0, cancellationToken))
        {
            return;
        }

        try
        {
            await InvokeAsync(() =>
            {
                IsCheckingHealth = true;
                StateHasChanged();
            });

            var resources = ResourceManager.GetResources();
            var healthResults = await HealthChecks.CheckAsync(resources, cancellationToken);

            await InvokeAsync(() =>
            {
                HealthResults = healthResults;
                StateHasChanged();
            });
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        finally
        {
            if (!IsDisposed)
            {
                await InvokeAsync(() =>
                {
                    IsCheckingHealth = false;
                    StateHasChanged();
                });
            }

            HealthRefreshLock.Release();
        }
    }

    private async Task PollResourceHealthAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(GetHealthCheckInterval(), cancellationToken);
                await RefreshResourceHealthAsync(cancellationToken);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private TimeSpan GetHealthCheckInterval() =>
        TimeSpan.FromSeconds(SelectionStore.GetHealthCheckIntervalSettings().Seconds);

    public async ValueTask DisposeAsync()
    {
        IsDisposed = true;

        if (HealthPollingCancellation is not null)
        {
            await HealthPollingCancellation.CancelAsync();
        }

        if (HealthPollingTask is not null)
        {
            try
            {
                await HealthPollingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        HealthPollingCancellation?.Dispose();
        HealthRefreshLock.Dispose();
    }

