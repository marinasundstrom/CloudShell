    private async Task RefreshResourcesAsync()
    {
        await LoadResourceModelAsync();
        await RefreshResourceHealthAsync();
    }

    private void OnResourcesChanged(object? sender, ResourceChangeNotification notification)
    {
        if (IsDisposed)
        {
            return;
        }

        TrackResourceActionNotification(notification);
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            await RefreshResourcesAsync();
            StateHasChanged();
        });
    }

    private async Task RefreshResourceHealthAsync(CancellationToken cancellationToken = default)
    {
        if (IsDisposed ||
            !await HealthRefreshLock.WaitAsync(0, cancellationToken))
        {
            return;
        }

        try
        {
            await InvokeAsync(() =>
            {
                IsCheckingHealth = true;
                StateHasChanged();
            });

            var healthResults = await HealthChecks.ListResourceHealthAsync(cancellationToken);

            await InvokeAsync(() =>
            {
                HealthResults = healthResults;
                StateHasChanged();
            });
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        finally
        {
            if (!IsDisposed)
            {
                await InvokeAsync(() =>
                {
                    IsCheckingHealth = false;
                    StateHasChanged();
                });
            }

            HealthRefreshLock.Release();
        }
    }

    private async Task PollResourcesAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(GetHealthCheckInterval(), cancellationToken);
                await InvokeAsync(RefreshResourcesAsync);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private TimeSpan GetHealthCheckInterval() =>
        TimeSpan.FromSeconds(OrchestrationSettings.GetHealthCheckIntervalSettings().Seconds);

    public async ValueTask DisposeAsync()
    {
        IsDisposed = true;
        ResourceManager.ResourcesChanged -= OnResourcesChanged;

        if (ResourcePollingCancellation is not null)
        {
            await ResourcePollingCancellation.CancelAsync();
        }

        if (ResourcePollingTask is not null)
        {
            try
            {
                await ResourcePollingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        ResourcePollingCancellation?.Dispose();
    }

