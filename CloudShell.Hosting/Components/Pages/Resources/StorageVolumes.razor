@inject IResourceManager ResourceManager
@inject IResourceOrchestrationCatalog OrchestrationCatalog
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

@if (Storage is null)
{
    <EmptyState Title="Storage unavailable"
                Message="The storage resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Volumes</h3>
                <p>Manage volumes owned by this Storage resource.</p>
            </div>
            <ResourcePermissionBoundary Resource="Storage"
                                        ResourceGroupId="@StorageGroup?.Id"
                                        Permission="@CloudShellPermissions.Resources.Manage"
                                        GlobalPermission="@CloudShellPermissions.Resources.Create"
                                        RequireWritableResourceManager="true">
                <FluentButton Appearance="Appearance.Accent"
                              IconStart="@(new Icons.Regular.Size20.AddCircle())"
                              OnClick="CreateVolume">
                    Add volume
                </FluentButton>
            </ResourcePermissionBoundary>
        </div>
        @if (Volumes.Count == 0)
        {
            <EmptyState Title="No volumes"
                        Message="No volumes are owned by this Storage resource." />
        }
        else
        {
            <ProcedureMessage Compact="true">
                This Storage resource cannot be deleted while it owns volumes.
            </ProcedureMessage>
            <div class="generated-list">
                @foreach (var volume in Volumes)
                {
                    <ResourceListItem Resource="volume.Volume"
                                      Summary="@GetVolumeSummary(volume)"
                                      Metadata="@GetVolumeMetadata(volume)">
                        <TitleContent>
                            <a class="resource-link" href="@BuildResourceRoute(volume.Volume.Id)">
                                @ResourceDisplayLabels.GetLabel(volume.Volume)
                            </a>
                        </TitleContent>
                        <ChildContent>
                            <ResourcePermissionBoundary Resource="volume.Volume"
                                                        ResourceGroupsByResourceId="ResourceGroupsByResourceId"
                                                        Permission="@CloudShellPermissions.Resources.Manage"
                                                        RequireWritableResourceManager="true">
                                <span class="inline-actions">
                                    <FluentButton Appearance="Appearance.Neutral"
                                                  OnClick="@(() => ManageVolume(volume.Volume.Id))">
                                        Manage
                                    </FluentButton>
                                </span>
                            </ResourcePermissionBoundary>
                        </ChildContent>
                    </ResourceListItem>
                }
            </div>
        }
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Storage { get; set; }
    private ResourceGroup? StorageGroup { get; set; }
    private IReadOnlyDictionary<string, ResourceGroup> ResourceGroupsByResourceId { get; set; } =
        ResourceManagerUiAccess.EmptyGroupLookup;
    private IReadOnlyList<StorageVolumeView> Volumes { get; set; } = [];

    protected override async Task OnParametersSetAsync()
    {
        Storage = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        if (Storage is null)
        {
            StorageGroup = null;
            Volumes = [];
            return;
        }

        StorageGroup = await ResourceManager.GetResourceGroupForResourceAsync(Storage.Id);
        ResourceGroupsByResourceId = ResourceManagerUiAccess.CreateGroupLookup(
            await ResourceManager.ListResourceGroupsAsync());
        var resources = await ResourceManager.ListResourcesAsync();
        var children = await ResourceManager.ListResourceChildrenAsync(Storage.Id);
        var orchestrationSnapshot = await OrchestrationCatalog.GetSnapshotAsync();
        Volumes = children
            .Where(IsOwnedVolume)
            .Select(volume => new StorageVolumeView(
                volume,
                GetConsumersForVolume(volume, resources, orchestrationSnapshot)))
            .OrderBy(volume => ResourceDisplayLabels.GetLabel(volume.Volume), StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private bool IsOwnedVolume(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, "cloudshell.volume", StringComparison.OrdinalIgnoreCase) &&
        (string.Equals(resource.ParentResourceId, Storage?.Id, StringComparison.OrdinalIgnoreCase) ||
            resource.ResourceAttributes.TryGetValue(ResourceAttributeNames.VolumeStorageResourceId, out var storageResourceId) &&
            string.Equals(storageResourceId, Storage?.Id, StringComparison.OrdinalIgnoreCase));

    private static string GetVolumeSubPath(Resource volume) =>
        volume.ResourceAttributes.TryGetValue(ResourceAttributeNames.VolumeSubPath, out var subPath) &&
        !string.IsNullOrWhiteSpace(subPath)
            ? subPath
            : "provider default";

    private static IReadOnlyList<StorageVolumeConsumerView> GetConsumersForVolume(
        Resource volume,
        IReadOnlyList<Resource> resources,
        ResourceOrchestrationCatalogSnapshot orchestrationSnapshot) =>
        resources
            .Where(resource => !string.Equals(resource.Id, volume.Id, StringComparison.OrdinalIgnoreCase))
            .Select(resource => new StorageVolumeConsumerView(
                resource,
                GetMountsForVolume(resource, volume.Id, orchestrationSnapshot)))
            .Where(consumer =>
                consumer.Mounts.Count > 0 ||
                consumer.Resource.DependsOn.Any(dependency =>
                    string.Equals(dependency, volume.Id, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(consumer => consumer.Resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private static IReadOnlyList<ResourceVolumeMount> GetMountsForVolume(
        Resource resource,
        string volumeId,
        ResourceOrchestrationCatalogSnapshot orchestrationSnapshot) =>
        orchestrationSnapshot.Workloads.TryGetValue(resource.Id, out var workload)
            ? workload.WorkloadVolumeMounts
                .Where(mount => string.Equals(
                    mount.NormalizedVolumeReference,
                    volumeId,
                    StringComparison.OrdinalIgnoreCase))
                .OrderBy(mount => mount.NormalizedTargetPath, StringComparer.OrdinalIgnoreCase)
                .ToArray()
            : [];

    private static string GetVolumeSummary(StorageVolumeView volume)
    {
        var subPath = GetVolumeSubPath(volume.Volume);
        return volume.Consumers.Count == 0
            ? $"{subPath} - no consumers"
            : $"{subPath} - {volume.Consumers.Count} consumer{Pluralize(volume.Consumers.Count)}";
    }

    private string GetVolumeMetadata(StorageVolumeView volume)
    {
        var parts = new List<string>
        {
            volume.Volume.EffectiveTypeId
        };

        var materializationSummaries = volume.Consumers
            .Select(GetConsumerMountMaterialization)
            .Where(summary => !string.IsNullOrWhiteSpace(summary))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        if (materializationSummaries.Length > 0)
        {
            parts.Add($"Storage: {string.Join(", ", materializationSummaries)}");
        }

        return string.Join(" - ", parts);
    }

    private string? GetConsumerMountMaterialization(StorageVolumeConsumerView consumer)
    {
        var label = ResourceVolumeMountDisplay.GetMaterializationSummary(consumer.Resource, Localize);
        return label is null
            ? null
            : $"{ResourceDisplayLabels.GetLabel(consumer.Resource)}: {label}";
    }

    private static string Pluralize(int count) =>
        count == 1 ? string.Empty : "s";

    private static string BuildResourceRoute(string resourceId) =>
        ResourceManagerRoutes.ResourceOverview(resourceId);

    private static string BuildManageResourceRoute(string resourceId) =>
        ResourceManagerRoutes.ResourceDetails(resourceId, ResourcePredefinedViewIds.Configuration);

    private static string BuildResourceTabRoute(string resourceId, ResourceViewId tabId) =>
        ResourceManagerRoutes.ResourceDetails(resourceId, tabId);

    private static string BuildCreateVolumeRoute(string storageResourceId) =>
        Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            "/resources/add",
            new Dictionary<string, string?>
            {
                ["type"] = "cloudshell.volume",
                ["storageResourceId"] = storageResourceId,
                ["returnUrl"] = BuildResourceTabRoute(storageResourceId, ResourcePredefinedViewIds.Volumes)
            });

    private void CreateVolume()
    {
        if (Storage is not null)
        {
            Navigation.NavigateTo(BuildCreateVolumeRoute(Storage.Id));
        }
    }

    private void ManageVolume(string resourceId) =>
        Navigation.NavigateTo(BuildManageResourceRoute(resourceId));

    private string Localize(string value) => L[value].Value;

    private sealed record StorageVolumeView(
        Resource Volume,
        IReadOnlyList<StorageVolumeConsumerView> Consumers);

    private sealed record StorageVolumeConsumerView(
        Resource Resource,
        IReadOnlyList<ResourceVolumeMount> Mounts);
}
