        tab.ComponentType == typeof(GeneratedResourceIdentity) ||
        tab.ComponentType == typeof(GeneratedResourceAccessControl) ||
        tab.ComponentType == typeof(ResourceActivity) ||
        tab.ComponentType == typeof(GeneratedResourceHealth) ||
        tab.ComponentType == typeof(GeneratedResourceRecovery) ||
        tab.ComponentType == typeof(GeneratedResourceMonitoring) ||
        tab.ComponentType == typeof(GeneratedResourceUsage) ||
