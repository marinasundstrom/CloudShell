@page "/resources/{ResourceId}/edit"
@page "/resources/{ResourceId}/details"
@rendermode InteractiveServer
@inject IResourceManager ResourceManager
@inject ILogManager LogManager
@inject IResourceMonitoringManager MonitoringManager
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IJSRuntime JS
@inject ResourceHealthCheckService HealthChecks
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject IStringLocalizer<SharedResource> L
@inject IServiceProvider Services
@implements IDisposable

<PageTitle>@L["Resource details"]</PageTitle>
<FluentMenuProvider />

@{
    var resource = Resource;
    var group = ResourceGroup;
    var resourceType = resource is null
        ? null
        : ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase));
    var hasDefaultIdentityProvider = HasDefaultIdentityProvider();
    var tabs = BuildTabs(
        resource,
        resourceType,
        ResourceLogs.Count > 0,
        HasResourceMonitoring,
        hasDefaultIdentityProvider);
    var selectedTab = GetSelectedTab(tabs);
    var selectedTabIssue = GetSelectedTabIssue(tabs);
    var isGeneratedOverview = selectedTabIssue is null &&
        selectedTab?.ComponentType == typeof(GeneratedResourceOverview);
    var isReadOnly = ResourceManagerUiOptions.Value.ReadOnly;
    var canApplyResourceChanges = selectedTab?.ShowsApplyButton == true &&
        CanApplyResourceChanges();
}

<section class="page-heading compact">
    <div class="resource-page-title">
        <span class="eyebrow">@L["Resource Manager"]</span>
        <div class="resource-title-line">
            @if (resource is not null)
            {
                <ResourceKindIcon Resource="resource" Class="resource-kind-icon resource-title-icon" />
            }
            <div class="resource-title-name">
                <h1>@(resource is null ? L["Resource"] : GetResourceLabel(resource))</h1>
            </div>
        </div>
        <p>@(resource is null ? L["Generated details and provider-contributed views for this resource."] :
                                                                                    GetResourceSubtitle(resource))</p>
        </div>
        <div class="heading-actions resource-detail-actions">
            @if (resource is not null)
            {
                @ResourceActionControls(resource)
                @if (ResourceLogs.Count > 0)
                {
                    <FluentButton Appearance="Appearance.Neutral" Title="@GetLogsActionLabel(ResourceLogs.Count)"
                                  IconStart="new Icons.Regular.Size20.DocumentText()" OnClick="OpenLogs">
                        @GetLogsActionLabel(ResourceLogs.Count)
                    </FluentButton>
                }
                @if (CanDeleteResource(resource))
                {
                    <FluentButton Appearance="Appearance.Neutral" Disabled="@IsDeleting"
                                  IconStart="new Icons.Regular.Size20.Delete()" OnClick="() => PromptDelete(resource)">
                        @L["Delete"]
                    </FluentButton>
                }
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="new Icons.Regular.Size20.Dismiss()" OnClick="Cancel">
                @L["Close"]
            </FluentButton>
            @if (canApplyResourceChanges)
            {
                <FluentButton Appearance="Appearance.Accent" Disabled="@(ConfigurationContext?.CanApply != true || IsApplying)"
                              IconStart="new Icons.Regular.Size20.Checkmark()" OnClick="ApplyChanges">
                    @(IsApplying ? L["Applying"] : L["Apply"])
                </FluentButton>
            }
        </div>
    </section>

    @if (resource is not null)
    {
        <ResourceStartupDeclarationAlert Resource="resource" />
    }

    @if (ProcedureMessage is not null)
    {
        <div class="procedure-message">@ProcedureMessage</div>
    }

    @if (isReadOnly)
    {
        <div class="procedure-message">@L["Resource Manager is in read-only mode. Resource lifecycle actions and updates are disabled in this UI."]</div>
    }

    @if (ConfirmDelete && resource is not null)
    {
        <div class="procedure-confirmation">
            <strong>@L["Delete registration?"]</strong>
            <span>@L["The provider will commit the delete procedure for this resource."]</span>
            <div class="form-actions">
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsDeleting" OnClick="CancelDelete">
                    @L["Cancel"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" Disabled="@IsDeleting" OnClick="DeleteResource">
                    @(IsDeleting ? L["Deleting"] : L["Delete"])
                </FluentButton>
            </div>
        </div>
    }

    @if (PendingRestart is not null)
    {
        <div class="procedure-confirmation" role="alert">
            <strong>@L["Restart {0}?", PendingRestart.ResourceName]</strong>
            <span>@PendingRestart.Message</span>
            <div class="form-actions">
                <FluentButton Appearance="Appearance.Accent" Disabled="@(IsRestarting || IsReadOnly)"
                              OnClick="RestartPendingResource">
                    @(IsRestarting ? L["Restarting"] : L["Restart now"])
                </FluentButton>
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsRestarting" OnClick="DismissRestartPrompt">
                    @L["Later"]
                </FluentButton>
            </div>
        </div>
    }

    <section class="registration-layout">
        <aside class="panel registration-options">
            @if (resource is not null)
            {
                <ResourceStatusSummary Resource="resource"
                                       HealthSummary="HealthSummary"
                                       IsCheckingHealth="IsCheckingHealth"
                                       LifecycleProgressLabel="@GetLifecycleProgressLabel(resource)" />
            }

            @if (tabs.Count > 0)
            {
                <div class="resource-tab-list" role="tablist" aria-label="@L["Resource views"]">
                    @foreach (var tabGroup in BuildTabGroups(tabs))
                    {
                        <div class="resource-tab-group" role="group" aria-label="@tabGroup.Title">
                            @if (!string.IsNullOrWhiteSpace(tabGroup.Title))
                            {
                                <span class="resource-tab-group-title">@tabGroup.Title</span>
                            }
                            @foreach (var tab in tabGroup.Tabs)
                            {
                                <button class="@GetTabButtonClass(tab, selectedTab)" type="button" role="tab"
                                        aria-selected="@(selectedTab?.Id == tab.Id)" @onclick="() => SelectTab(tab.Id)">
                                    @if (!string.IsNullOrWhiteSpace(tab.Icon))
                                    {
                                        <FluentIcon Value="@ResourceViewIcons.FromName(tab.Icon)" />
                                    }
                                    <span>@tab.Title</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </aside>

        <div class="panel registration-host">
            @if (resource is null)
            {
                <EmptyState Title="@L["Resource not found"].Value"
                            Message="@L["The resource may have been removed or is no longer visible."].Value" />
            }
            else if (selectedTabIssue is not null)
            {
                <EmptyState Title="@selectedTabIssue.Title"
                            Message="@selectedTabIssue.Message">
                    <FluentAnchor Appearance="Appearance.Neutral" Href="@selectedTabIssue.RecoveryHref">
                        @selectedTabIssue.RecoveryLabel
                    </FluentAnchor>
                </EmptyState>
            }
            else if (selectedTab is null)
            {
                <EmptyState Title="@L["No resource selected"].Value"
                            Message="@L["Select a resource to inspect its projected details."].Value" />
            }
            else
            {
                <div class="panel-header">
                    <div>
                        <h2>@selectedTab.Title</h2>
                        <p>@(resourceType?.DisplayName ?? resource.EffectiveTypeId)</p>
                    </div>
                </div>
                @if (isGeneratedOverview)
                {
                    <GeneratedResourceOverview Resource="resource" ResourceGroup="group" ResourceType="resourceType"
                                               ResourceUpdated="HandleResourceUpdated" />
                }
                else
                {
                    <CascadingValue Value="ConfigurationContext">
                        <CascadingValue Name="@ResourceManagerCascadingParameterNames.ReadOnly" Value="IsReadOnly">
                            <DynamicComponent Type="selectedTab.ComponentType" @key="GetContentKey(resource, selectedTab)"
                                              Parameters="@BuildComponentParameters(resource, resourceType, selectedTab)" />
                        </CascadingValue>
                    </CascadingValue>
                }
            }
        </div>
    </section>

@code {
    private static readonly ResourceViewId GeneratedOverviewTabId = ResourcePredefinedViewIds.Overview;
    private static readonly ResourceViewId GeneratedEndpointsTabId = ResourcePredefinedViewIds.Endpoints;
    private static readonly ResourceViewId GeneratedDnsTabId = ResourcePredefinedViewIds.Dns;
    private static readonly ResourceViewId GeneratedIdentityTabId = ResourcePredefinedViewIds.Identity;
    private static readonly ResourceViewId GeneratedAccessControlTabId = ResourcePredefinedViewIds.AccessControl;
    private static readonly ResourceViewId GeneratedStorageVolumesTabId = ResourcePredefinedViewIds.Volumes;
    private static readonly ResourceViewId GeneratedActivityTabId = ResourcePredefinedViewIds.Activity;
    private static readonly ResourceViewId GeneratedMonitoringTabId = ResourcePredefinedViewIds.Monitoring;
    private static readonly ResourceViewId GeneratedLogsTabId = ResourcePredefinedViewIds.Logs;
    private static readonly ResourceViewId GeneratedTracesTabId = ResourcePredefinedViewIds.Traces;
    private static readonly ResourceViewId GeneratedMetricsTabId = ResourcePredefinedViewIds.Metrics;

    [Parameter]
    public string? ResourceId { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    private string? RequestedQueryTabId { get; set; }

    [SupplyParameterFromQuery(Name = "traceId")]
    private string? RequestedTraceId { get; set; }

    [SupplyParameterFromQuery(Name = "spanId")]
    private string? RequestedSpanId { get; set; }

    [SupplyParameterFromQuery(Name = "logId")]
    private string? RequestedLogId { get; set; }

    [SupplyParameterFromQuery(Name = "scopeResourceId")]
    private string? RequestedScopeResourceId { get; set; }

    private ResourceConfigurationContext? ConfigurationContext { get; set; }
    private Resource? Resource { get; set; }
    private ResourceGroup? ResourceGroup { get; set; }
    private ResourceHealthSummary? HealthSummary { get; set; }
    private IReadOnlyList<LogDescriptor> ResourceLogs { get; set; } = [];
    private bool HasResourceMonitoring { get; set; }
    private ResourceOperationCapabilities OperationCapabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private HashSet<string> ExecutingActionIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private ResourceViewId? SelectedTabId { get; set; }
    private string? ProcedureMessage { get; set; }
    private PendingResourceRestart? PendingRestart { get; set; }
    private bool IsApplying { get; set; }
    private bool IsRestarting { get; set; }
    private bool IsDeleting { get; set; }
    private bool IsCheckingHealth { get; set; }
    private bool ConfirmDelete { get; set; }
    private int ResourceContentVersion { get; set; }

    protected override void OnInitialized()
    {
        ResourceManager.ResourcesChanged += OnResourcesChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        if (Resource is null)
        {
            NavigateToResourceNotFound();
            return;
        }

        var resource = Resource;
        ResourceGroup = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);

        if (!ResourceManagerUiAccess.CanReadResource(Authorization, resource, ResourceGroup?.Id))
        {
            Navigation.NavigateTo("/account/access-denied");
        }

        await LoadResourceAffordancesAsync(resource);

        SelectedTabId = null;
        if (ResourceViewId.TryParse(RequestedQueryTabId, out var requestedTabId))
        {
            SelectedTabId = requestedTabId;
        }

        if (ConfigurationContext?.ResourceId != resource.Id)
        {
            if (ConfigurationContext is not null)
            {
                ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
            }

            ConfigurationContext = new ResourceConfigurationContext(resource.Id);
            ConfigurationContext.StateChanged += HandleConfigurationStateChanged;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private void NavigateToResourceNotFound()
    {
        ResourceLogs = [];
        HealthSummary = null;
        IsCheckingHealth = false;
        HasResourceMonitoring = false;
        OperationCapabilities = ResourceOperationCapabilities.None(string.Empty);
        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            Navigation.NavigateTo(ResourceManagerRoutes.ResourceNotFound(ResourceId), replace: true);
        }
    }

    private void SelectTab(ResourceViewId tabId)
    {
        SelectedTabId = tabId;
        ProcedureMessage = null;
        PendingRestart = null;
        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            Navigation.NavigateTo(
                ResourceManagerRoutes.ResourceDetails(ResourceId, tabId),
                replace: true);
        }

        if (ConfigurationContext is not null)
        {
            ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
            ConfigurationContext = new ResourceConfigurationContext(ConfigurationContext.ResourceId);
            ConfigurationContext.StateChanged += HandleConfigurationStateChanged;
        }
    }

    private ResourceTabContribution? GetSelectedTab(IReadOnlyList<ResourceTabContribution> tabs)
    {
        if (GetSelectedTabIssue(tabs) is not null)
        {
            return null;
        }

        if (SelectedTabId is { } selectedTabId)
        {
            return tabs.FirstOrDefault(tab => tab.Id == selectedTabId);
        }

        return tabs.FirstOrDefault();
    }

    private ResourceViewSelectionIssue? GetSelectedTabIssue(IReadOnlyList<ResourceTabContribution> tabs)
    {
        if (string.IsNullOrWhiteSpace(RequestedQueryTabId))
        {
            return null;
        }

        var requested = RequestedQueryTabId.Trim();
        if (!ResourceViewId.TryParse(requested, out var requestedTabId))
        {
            return CreateResourceViewSelectionIssue(
                L["Resource view '{0}' is not a valid view ID.", requested].Value);
        }

        return tabs.Any(tab => tab.Id == requestedTabId)
            ? null
            : CreateResourceViewSelectionIssue(
                L["Resource view '{0}' is not available for this resource.", requested].Value);
    }

    private ResourceViewSelectionIssue CreateResourceViewSelectionIssue(string message) =>
        new(
            L["Resource view not found"].Value,
            message,
            L["Open overview"].Value,
            string.IsNullOrWhiteSpace(ResourceId)
                ? ResourceManagerRoutes.Resources
                : ResourceManagerRoutes.ResourceOverview(ResourceId));

    private async Task ApplyChanges()
    {
        if (ConfigurationContext is null || !CanApplyResourceChanges())
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        IsApplying = true;
        try
        {
            var result = await ConfigurationContext.ApplyAsync();
            ProcedureMessage = result.Message;
            PendingRestart = CreatePendingRestart(result);
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = L["Apply failed: {0}", exception.Message].Value;
            PendingRestart = null;
        }
        finally
        {
            IsApplying = false;
        }
    }

    private PendingResourceRestart? CreatePendingRestart(ResourceProcedureResult result)
    {
        if (!result.RestartRequired)
        {
            return null;
        }

        var resourceId = string.IsNullOrWhiteSpace(result.RestartResourceId)
            ? Resource?.Id
            : result.RestartResourceId;
        if (string.IsNullOrWhiteSpace(resourceId))
        {
            return null;
        }

        var resourceName = Resource is not null &&
            string.Equals(resourceId, Resource.Id, StringComparison.OrdinalIgnoreCase)
            ? GetResourceLabel(Resource)
            : resourceId;
        var message = string.IsNullOrWhiteSpace(result.RestartMessage)
            ? L["This change requires a restart before it takes effect."].Value
            : result.RestartMessage;

        return new PendingResourceRestart(resourceId, resourceName, message);
    }

    private async Task RestartPendingResource()
    {
        if (PendingRestart is null || IsReadOnly)
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        IsRestarting = true;
        try
        {
            var result = await ResourceManager.RestartResourceAsync(
                PendingRestart.ResourceId,
                ignoreDependentWarning: true);
            ProcedureMessage = result.Message;
            PendingRestart = null;

            await ReloadResourceAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            IsRestarting = false;
        }
    }

    private void DismissRestartPrompt() => PendingRestart = null;

    private void PromptDelete(Resource resource)
    {
        if (!CanDeleteResource(resource))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        ProcedureMessage = null;
        PendingRestart = null;
        ConfirmDelete = true;
    }

    private void CancelDelete() => ConfirmDelete = false;

    private async Task DeleteResource()
    {
        if (Resource is null)
        {
            ConfirmDelete = false;
            return;
        }

        if (!CanDeleteResource(Resource))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            ConfirmDelete = false;
            return;
        }

        IsDeleting = true;
        ProcedureMessage = null;
        try
        {
            await ResourceManager.DeleteResourceAsync(Resource.Id);
            ConfirmDelete = false;
            Navigation.NavigateTo("/resources");
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            IsDeleting = false;
        }
    }

    private void HandleConfigurationStateChanged() => InvokeAsync(StateHasChanged);

    private void OnResourcesChanged(object? sender, ResourceChangeNotification notification)
    {
        var currentResourceId = Resource?.Id ?? ResourceId;
        if (string.IsNullOrWhiteSpace(currentResourceId) ||
            !AffectsResource(notification, currentResourceId))
        {
            return;
        }

        TrackResourceActionNotification(notification);
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            await ReloadResourceAsync();
            ResourceContentVersion++;
            StateHasChanged();
        });
    }

    private async Task HandleResourceUpdated(Resource resource)
    {
        Resource = resource;
        ResourceGroup = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);
        await LoadResourceAffordancesAsync(resource);
        ResourceContentVersion++;
    }

    private async Task ReloadResourceAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            return;
        }

        Resource = await ResourceManager.GetResourceAsync(ResourceId);
        ResourceGroup = Resource is null
            ? null
            : await ResourceManager.GetResourceGroupForResourceAsync(Resource.Id);
        if (Resource is not null)
        {
            await LoadResourceAffordancesAsync(Resource);
        }
    }

    private async Task LoadResourceAffordancesAsync(Resource resource)
    {
        ResourceLogs = await LogManager.ListLogsAsync(new LogQuery(ResourceId: resource.Id));
        HasResourceMonitoring = resource.HasCapability(ResourceCapabilityIds.Monitoring) &&
            await MonitoringManager.HasResourceMonitoringAsync(resource.Id);
        OperationCapabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(resource);
        await RefreshResourceHealthAsync(resource);
    }

    private async Task RefreshResourceHealthAsync(Resource resource)
    {
        HealthSummary = null;
        if (resource.ResourceHealthChecks.Count == 0)
        {
            IsCheckingHealth = false;
            return;
        }

        IsCheckingHealth = true;
        try
        {
            var healthResults = await HealthChecks.CheckAsync(new[] { resource });
            HealthSummary = healthResults.GetValueOrDefault(resource.Id);
        }
        finally
        {
            IsCheckingHealth = false;
        }
    }

    private static bool AffectsResource(
        ResourceChangeNotification notification,
        string resourceId) =>
        string.Equals(notification.ResourceId, resourceId, StringComparison.OrdinalIgnoreCase) ||
        notification.Resources.Any(affectedResourceId =>
            string.Equals(affectedResourceId, resourceId, StringComparison.OrdinalIgnoreCase));

    private void TrackResourceActionNotification(ResourceChangeNotification notification)
    {
        if (string.IsNullOrWhiteSpace(notification.ActionId))
        {
            return;
        }

        if (notification.Kind == ResourceChangeKind.ResourceActionStarted)
        {
            ExecutingActionIds.Add(notification.ActionId);
        }
        else if (notification.Kind is ResourceChangeKind.ResourceActionExecuted
            or ResourceChangeKind.ResourceActionFailed)
        {
            ExecutingActionIds.Remove(notification.ActionId);
        }
    }

    private string GetContentKey(Resource resource, ResourceTabContribution selectedTab) =>
        $"{resource.Id}:{selectedTab.Id}:{ResourceContentVersion}";

    private Dictionary<string, object?> BuildComponentParameters(
        Resource resource,
        ResourceTypeContribution? resourceType,
        ResourceTabContribution selectedTab)
    {
        var parameters = new Dictionary<string, object?>
        {
            ["ResourceId"] = resource.Id
        };

        if (resourceType is not null && IsGeneratedPredefinedView(selectedTab))
        {
            parameters["ResourceType"] = resourceType;
        }

        if (selectedTab.Id == GeneratedActivityTabId)
        {
            parameters["TraceId"] = RequestedTraceId;
            parameters["SpanId"] = RequestedSpanId;
        }
        else if (selectedTab.Id == GeneratedLogsTabId)
        {
            parameters["LogId"] = RequestedLogId;
            parameters["TraceId"] = RequestedTraceId;
        }
        else if (selectedTab.Id == GeneratedTracesTabId)
        {
            parameters["TraceId"] = RequestedTraceId;
            parameters["ScopeResourceId"] = RequestedScopeResourceId;
        }
        else if (selectedTab.Id == GeneratedMetricsTabId)
        {
            parameters["ScopeResourceId"] = RequestedScopeResourceId;
        }

        return parameters;
    }

    private static bool IsGeneratedPredefinedView(ResourceTabContribution tab) =>
        tab.ComponentType == typeof(GeneratedResourceIdentity) ||
        tab.ComponentType == typeof(GeneratedResourceAccessControl) ||
        tab.ComponentType == typeof(ResourceActivity) ||
        tab.ComponentType == typeof(GeneratedResourceMonitoring) ||
        tab.ComponentType == typeof(GeneratedResourceEndpoints) ||
        tab.ComponentType == typeof(GeneratedResourceDns);

    private static IReadOnlyList<ResourceTabContribution> BuildTabs(
        Resource? resource,
        ResourceTypeContribution? resourceType,
        bool hasResourceLogs,
        bool hasResourceMonitoring,
        bool hasDefaultIdentityProvider)
    {
        var contributedTabs = resourceType?.ResourceTabs ?? [];
        var tabs = new List<ResourceTabContribution>();
        if (!contributedTabs.Any(tab => tab.Id == GeneratedOverviewTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedOverviewTabId,
                "Overview",
                -100,
                typeof(GeneratedResourceOverview),
                GroupTitle: ResourceTabGroupTitles.General,
                Icon: GetPredefinedViewIcon(GeneratedOverviewTabId)));
        }

        if (ResourcePredefinedViewVisibility.HasEndpointsView(resource) &&
            !contributedTabs.Any(tab => tab.Id == GeneratedEndpointsTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedEndpointsTabId,
                "Endpoints",
                -80,
                typeof(GeneratedResourceEndpoints),
                GroupTitle: ResourceTabGroupTitles.Networking,
                Icon: GetPredefinedViewIcon(GeneratedEndpointsTabId)));
        }

        if (ResourcePredefinedViewVisibility.HasDnsView(resource) &&
            !contributedTabs.Any(tab => tab.Id == GeneratedDnsTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedDnsTabId,
                "DNS",
                -70,
                typeof(GeneratedResourceDns),
                GroupTitle: ResourceTabGroupTitles.Networking,
                Icon: GetPredefinedViewIcon(GeneratedDnsTabId)));
        }

        if (ResourcePredefinedViewVisibility.HasIdentityView(resource, hasDefaultIdentityProvider) &&
            !contributedTabs.Any(tab => tab.Id == GeneratedIdentityTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedIdentityTabId,
                "Identity",
                -90,
                typeof(GeneratedResourceIdentity),
                GroupTitle: ResourceTabGroupTitles.Management,
                Icon: GetPredefinedViewIcon(GeneratedIdentityTabId)));
        }

        if (ResourcePredefinedViewVisibility.HasAccessControlView(resource, hasDefaultIdentityProvider) &&
            !contributedTabs.Any(tab => tab.Id == GeneratedAccessControlTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedAccessControlTabId,
                "Access control",
                85,
                typeof(GeneratedResourceAccessControl),
                GroupTitle: ResourceTabGroupTitles.Management,
                Icon: GetPredefinedViewIcon(GeneratedAccessControlTabId)));
        }

        if (ResourcePredefinedViewVisibility.HasStorageVolumesView(resource) &&
            !contributedTabs.Any(tab => tab.Id == GeneratedStorageVolumesTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedStorageVolumesTabId,
                "Volumes",
                20,
                typeof(StorageVolumes),
                GroupTitle: ResourceTabGroupTitles.Storage,
                Icon: GetPredefinedViewIcon(GeneratedStorageVolumesTabId)));
        }

        if (!contributedTabs.Any(tab => tab.Id == GeneratedActivityTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedActivityTabId,
                "Activity",
                90,
                typeof(ResourceActivity),
                GroupTitle: ResourceTabGroupTitles.Management,
                Icon: GetPredefinedViewIcon(GeneratedActivityTabId)));
        }

        if (hasResourceMonitoring &&
            !contributedTabs.Any(tab => tab.Id == GeneratedMonitoringTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedMonitoringTabId,
                "Monitoring",
                80,
                typeof(GeneratedResourceMonitoring),
                GroupTitle: ResourceTabGroupTitles.Management,
                Icon: GetPredefinedViewIcon(GeneratedMonitoringTabId)));
        }

        if (resourceType?.UpdateComponentType is not null &&
            !contributedTabs.Any(tab => tab.Id == ResourcePredefinedViewIds.Configuration))
        {
            tabs.Add(new ResourceTabContribution(
                ResourcePredefinedViewIds.Configuration,
                "Configuration",
                0,
                resourceType.UpdateComponentType,
                ShowsApplyButton: true,
                GroupTitle: ResourceTabGroupTitles.General,
                Icon: GetPredefinedViewIcon(ResourcePredefinedViewIds.Configuration)));
        }

        if (ResourcePredefinedViewVisibility.HasEnvironmentView(resource) &&
            !contributedTabs.Any(tab => tab.Id == ResourcePredefinedViewIds.Environment))
        {
            tabs.Add(new ResourceTabContribution(
                ResourcePredefinedViewIds.Environment,
                "Environment",
                80,
                typeof(ResourceEnvironmentVariables),
                ShowsApplyButton: true,
                GroupTitle: ResourceTabGroupTitles.Management,
                Icon: GetPredefinedViewIcon(ResourcePredefinedViewIds.Environment)));
        }

        if (hasResourceLogs &&
            !contributedTabs.Any(tab => tab.Id == GeneratedLogsTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedLogsTabId,
                "Logs",
                70,
                typeof(CloudShell.Hosting.Components.Pages.Logs.ResourceLogs),
                GroupTitle: ResourceTabGroupTitles.Telemetry,
                Icon: GetPredefinedViewIcon(GeneratedLogsTabId)));
        }

        if (resource?.EffectiveObservability.Traces == true &&
            !contributedTabs.Any(tab => tab.Id == GeneratedTracesTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedTracesTabId,
                "Traces",
                80,
                typeof(CloudShell.Hosting.Components.Pages.Observability.ResourceTraces),
                GroupTitle: ResourceTabGroupTitles.Telemetry,
                Icon: GetPredefinedViewIcon(GeneratedTracesTabId)));
        }

        if (resource?.EffectiveObservability.Metrics == true &&
            !contributedTabs.Any(tab => tab.Id == GeneratedMetricsTabId))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedMetricsTabId,
                "Metrics",
                90,
                typeof(CloudShell.Hosting.Components.Pages.Observability.ResourceMetrics),
                GroupTitle: ResourceTabGroupTitles.Telemetry,
                Icon: GetPredefinedViewIcon(GeneratedMetricsTabId)));
        }

        return tabs
            .Concat(contributedTabs)
            .OrderBy(GetResourceTabOrder)
            .ThenBy(tab => tab.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private bool HasDefaultIdentityProvider()
    {
        var configuredProviders = Services.GetService(typeof(ResourceIdentityProviderCatalog)) as ResourceIdentityProviderCatalog ??
            new ResourceIdentityProviderCatalog();
        var declarations = Services.GetService(typeof(ResourceDeclarationStore)) as ResourceDeclarationStore;
        var effectiveProviders = declarations?.CreateIdentityProviderCatalog(configuredProviders) ?? configuredProviders;

        return effectiveProviders.DefaultProvider is not null;
    }

    private static int GetResourceTabOrder(ResourceTabContribution tab)
    {
        if (tab.Id == GeneratedOverviewTabId)
        {
            return int.MinValue;
        }

        if (tab.Id == GeneratedIdentityTabId)
        {
            return int.MaxValue - 2;
        }

        if (tab.Id == GeneratedAccessControlTabId)
        {
            return int.MaxValue - 1;
        }

        if (tab.Id == GeneratedActivityTabId)
        {
            return int.MaxValue;
        }

        if (tab.Id == ResourcePredefinedViewIds.Environment)
        {
            return int.MaxValue - 2;
        }

        return tab.Order;
    }

    private static IReadOnlyList<ResourceTabGroup> BuildTabGroups(
        IReadOnlyList<ResourceTabContribution> tabs)
    {
        var groups = new List<ResourceTabGroup>();
        foreach (var tab in tabs)
        {
            var groupId = tab.GroupId;
            var groupTitle = ResolveResourceTabGroupTitle(tab);
            var currentGroup = groups.FirstOrDefault(group =>
                string.Equals(group.Id, groupId, StringComparison.OrdinalIgnoreCase));
            if (currentGroup is null)
            {
                currentGroup = new ResourceTabGroup(groupId, groupTitle, []);
                groups.Add(currentGroup);
            }

            currentGroup.Tabs.Add(tab);
        }

        return groups
            .Select((group, index) => new { Group = group, Index = index })
            .OrderBy(item => GetResourceTabGroupOrder(item.Group.Id))
            .ThenBy(item => item.Index)
            .Select(item => item.Group)
            .ToArray();
    }

    private static int GetResourceTabGroupOrder(string groupId) =>
        groupId switch
        {
            ResourceTabGroupIds.Telemetry => 90,
            ResourceTabGroupIds.Management => 100,
            _ => 0
        };

    private static string ResolveResourceTabGroupTitle(ResourceTabContribution tab) =>
        !string.IsNullOrWhiteSpace(tab.GroupTitle)
            ? tab.GroupTitle.Trim()
            : tab.GroupId switch
            {
                ResourceTabGroupIds.General => ResourceTabGroupTitles.General,
                ResourceTabGroupIds.Application => ResourceTabGroupTitles.Application,
                ResourceTabGroupIds.Networking => ResourceTabGroupTitles.Networking,
                ResourceTabGroupIds.Storage => ResourceTabGroupTitles.Storage,
                ResourceTabGroupIds.Environment => ResourceTabGroupTitles.Environment,
                ResourceTabGroupIds.Telemetry => ResourceTabGroupTitles.Telemetry,
                ResourceTabGroupIds.Management => ResourceTabGroupTitles.Management,
                ResourceTabGroupIds.Runtime => ResourceTabGroupTitles.Runtime,
                ResourceTabGroupIds.Entries => ResourceTabGroupTitles.Entries,
                ResourceTabGroupIds.Secrets => ResourceTabGroupTitles.Secrets,
                _ => tab.GroupId
            };

    private static string? GetPredefinedViewIcon(ResourceViewId id) =>
        ResourcePredefinedViews.TryGet(id, out var definition)
            ? definition.Icon
            : null;

    private string GetTabButtonClass(
        ResourceTabContribution tab,
        ResourceTabContribution? selectedTab)
    {
        var classes = new List<string> { "resource-tab-button" };
        if (selectedTab?.Id == tab.Id)
        {
            classes.Add("active");
        }

        return string.Join(" ", classes);
    }

    private RenderFragment ResourceActionControls(Resource resource) => builder =>
    {
        if (resource.ResourceActions.Count == 0)
        {
            return;
        }

        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "inline-actions");

        foreach (var action in resource.ResourceActions.Where(IsInlineAction))
        {
            builder.OpenComponent<FluentButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-icon-button");
            builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "Title", GetActionTitle(action));
            builder.AddAttribute(sequence++, "Disabled", !CanExecuteAction(action) || IsExecutingAction(action));
            builder.AddAttribute(sequence++, "OnClick",
                EventCallback.Factory.Create<MouseEventArgs>(this, () => ExecuteAction(action)));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
            {
                AddActionIcon(buttonBuilder, action.EffectivePresentation.Icon);
            }));
            builder.CloseComponent();
        }

        var overflowActions = resource.ResourceActions
            .Where(action => !IsInlineAction(action))
            .ToArray();
        if (overflowActions.Length > 0)
        {
            builder.OpenComponent<FluentMenuButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-overflow-button");
            builder.AddAttribute(sequence++, "UseMenuService", true);
            builder.AddAttribute(sequence++, "ButtonAppearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "ButtonContent", (RenderFragment)(buttonBuilder =>
            {
                AddIcon(buttonBuilder, new Icons.Regular.Size20.MoreVertical());
            }));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(menuBuilder =>
            {
                var menuSequence = 0;
                foreach (var action in overflowActions)
                {
                    menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                    menuBuilder.AddAttribute(menuSequence++, "Disabled", !CanExecuteAction(action) || IsExecutingAction(action));
                    menuBuilder.AddAttribute(menuSequence++, "OnClick",
                        EventCallback.Factory.Create<MouseEventArgs>(this, () => ExecuteAction(action)));
                    menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                    {
                        itemBuilder.OpenElement(0, "span");
                        itemBuilder.AddAttribute(1, "class", "menu-action-content");
                        AddActionIcon(itemBuilder, action.EffectivePresentation.Icon, 2);
                        itemBuilder.OpenElement(5, "span");
                        itemBuilder.AddContent(6, IsExecutingAction(action) ? L["Working"] : action.DisplayName);
                        itemBuilder.CloseElement();
                        itemBuilder.CloseElement();
                    }));
                    menuBuilder.CloseComponent();
                }
            }));
            builder.CloseComponent();
        }

        builder.CloseElement();
    };

    private static bool IsInlineAction(ResourceAction action) =>
        action.EffectivePresentation.DisplayStyle == ResourceActionDisplayStyle.Inline;

    private bool CanExecuteAction(ResourceAction action) =>
        !IsReadOnly && OperationCapabilities.CanExecuteAction(action.Id);

    private string GetActionTitle(ResourceAction action)
    {
        if (IsReadOnly)
        {
            return $"{action.DisplayName} unavailable. Resource Manager is in read-only mode.";
        }

        var reason = OperationCapabilities.GetActionUnavailableReason(action.Id);
        if (!string.IsNullOrWhiteSpace(reason))
        {
            return $"{action.DisplayName} unavailable. {reason}";
        }

        return action.DisplayName;
    }

    private bool CanApplyResourceChanges() =>
        !IsReadOnly && OperationCapabilities.CanManage;

    private bool CanDeleteResource(Resource resource) =>
        !IsReadOnly &&
        resource.IsNormalResource &&
        resource.Source == ResourceSource.User &&
        resource.ManagementMode == ResourceManagementMode.UserManaged &&
        OperationCapabilities.CanDelete;

    private bool IsExecutingAction(ResourceAction action) =>
        ExecutingActionIds.Contains(action.Id);

    private string GetLifecycleStatusLabel(Resource resource) =>
        GetLifecycleProgressLabel(resource) ?? resource.State?.ToString() ?? ResourceState.Unknown.ToString();

    private string? GetLifecycleProgressLabel(Resource resource)
    {
        var action = resource.ResourceActions.FirstOrDefault(IsExecutingAction);
        return action?.Kind switch
        {
            ResourceActionKind.Start => L["Starting"].Value,
            ResourceActionKind.Stop => L["Stopping"].Value,
            ResourceActionKind.Pause => L["Pausing"].Value,
            ResourceActionKind.Restart => L["Restarting"].Value,
            _ => null
        };
    }

    private async Task ExecuteAction(ResourceAction action)
    {
        if (Resource is null || !CanExecuteAction(action) || IsExecutingAction(action))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        if (action.RequiresConfirmation)
        {
            var confirmed = await JS.InvokeAsync<bool>(
                "confirm",
                action.Description ??
                L["Start {0} for {1}?", action.DisplayName, GetResourceLabel(Resource)].Value);
            if (!confirmed)
            {
                return;
            }
        }

        ExecutingActionIds.Add(action.Id);
        ProcedureMessage = null;
        PendingRestart = null;
        try
        {
            var result = await ResourceManager.ExecuteResourceActionAsync(
                new ExecuteResourceActionCommand(
                    Resource.Id,
                    action.Id,
                    StartDependencies: ShouldStartDependencies(action),
                    IgnoreDependentWarning: true,
                    DependencyStartFailureBehavior: GetDependencyStartFailureBehavior()));
            ProcedureMessage = result.Message;
            await ReloadResourceAsync();
            ResourceContentVersion++;
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            ExecutingActionIds.Remove(action.Id);
        }
    }

    private void OpenLogs()
    {
        if (Resource is null || ResourceLogs.Count == 0)
        {
            return;
        }

        var query = new Dictionary<string, string?>
        {
            ["tab"] = ResourcePredefinedViewIds.Logs.Value
        };

        if (ResourceLogs.Count == 1)
        {
            query["logId"] = ResourceLogs[0].Id;
        }

        Navigation.NavigateTo(Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            ResourceManagerRoutes.ResourceDetails(Resource.Id),
            query));
    }

    private string GetLogsActionLabel(int logCount) =>
        logCount == 1 ? L["Logs"].Value : L["Logs ({0})", logCount].Value;

    private static bool ShouldStartDependencies(ResourceAction action) =>
        action.Kind is ResourceActionKind.Start or ResourceActionKind.Restart;

    private DependencyStartFailureBehavior GetDependencyStartFailureBehavior() =>
        OrchestrationSettings.GetDependencyStartFailureSettings().Behavior;

    private static void AddActionIcon(
        RenderTreeBuilder builder,
        ResourceActionIcon actionIcon,
        int sequence = 0) =>
        AddIcon(builder, GetActionIcon(actionIcon), sequence);

    private static void AddIcon(
        RenderTreeBuilder builder,
        Icon icon,
        int sequence = 0)
    {
        builder.OpenComponent<FluentIcon<Icon>>(sequence);
        builder.AddAttribute(sequence + 1, "Class", "action-icon");
        builder.AddAttribute(sequence + 2, "Value", icon);
        builder.CloseComponent();
    }

    private static Icon GetActionIcon(ResourceActionIcon actionIcon) => actionIcon switch
    {
        ResourceActionIcon.Start => new Icons.Regular.Size20.PlayCircle(),
        ResourceActionIcon.Stop => new Icons.Regular.Size20.RecordStop(),
        ResourceActionIcon.Pause => new Icons.Regular.Size20.PauseCircle(),
        ResourceActionIcon.Restart => new Icons.Regular.Size20.ArrowSync(),
        _ => new Icons.Regular.Size20.AppsListDetail()
    };

    private static string GetStateClass(ResourceState? state) => state switch
    {
        ResourceState.Running => "state-running",
        ResourceState.Starting => "state-starting",
        ResourceState.Stopping => "state-stopping",
        ResourceState.Paused => "state-paused",
        ResourceState.Degraded => "state-degraded",
        ResourceState.Stopped => "state-stopped",
        _ => "state-unknown"
    };

    public void Dispose()
    {
        ResourceManager.ResourcesChanged -= OnResourcesChanged;

        if (ConfigurationContext is not null)
        {
            ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
        }
    }

    private string GetResourceLabel(Resource resource) => DisplaySelection.GetResourceLabel(resource);

    private string GetResourceSubtitle(Resource resource) =>
        DisplaySelection.EnableDisplayNames
            ? L["{0} / {1}", resource.Kind, resource.Id].Value
            : resource.Kind;

    private sealed record PendingResourceRestart(
        string ResourceId,
        string ResourceName,
        string Message);

    private sealed record ResourceViewSelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);

    private sealed record ResourceTabGroup(
        string Id,
        string Title,
        List<ResourceTabContribution> Tabs);
}
