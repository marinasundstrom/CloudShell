@page "/resources/{ResourceId}/edit"
@page "/resources/{ResourceId}/details"
@rendermode InteractiveServer
@inject IResourceManager ResourceManager
@inject ILogManager LogManager
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IJSRuntime JS
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<PageTitle>@L["Resource details"]</PageTitle>
<FluentMenuProvider />

@{
    var resource = Resource;
    var group = ResourceGroup;
    var resourceType = resource is null
        ? null
        : ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase));
    var tabs = BuildTabs(resource, resourceType);
    var selectedTab = tabs.FirstOrDefault(tab => tab.Id == SelectedTabId) ?? tabs.FirstOrDefault();
    var isGeneratedOverview = selectedTab?.ComponentType == typeof(GeneratedResourceOverview);
    var isReadOnly = ResourceManagerUiOptions.Value.ReadOnly;
    var canApplyResourceChanges = selectedTab?.ShowsApplyButton == true &&
        CanApplyResourceChanges();
}

<section class="page-heading compact">
    <div class="resource-page-title">
        <span class="eyebrow">@L["Resource Manager"]</span>
        <div class="resource-title-line">
            @if (resource?.State is { } state)
            {
                <span class="state-dot @GetStateClass(state)"
                      title="@L["State: {0}", state]"
                      aria-label="@L["State: {0}", state]"></span>
            }
            <h1>@(resource is null ? L["Resource"] : GetResourceLabel(resource))</h1>
        </div>
        <p>@(resource is null ? L["Generated details and provider-contributed views for this resource."] : GetResourceSubtitle(resource))</p>
    </div>
    <div class="heading-actions resource-detail-actions">
        @if (resource is not null)
        {
            @ResourceActionControls(resource)
            @if (ResourceLogs.Count > 0)
            {
                <FluentButton Appearance="Appearance.Neutral"
                              Title="@GetLogsActionLabel(ResourceLogs.Count)"
                              OnClick="OpenLogs">
                    @GetLogsActionLabel(ResourceLogs.Count)
                </FluentButton>
            }
        }
        <FluentButton Appearance="Appearance.Neutral" OnClick="Cancel">
            @L["Close"]
        </FluentButton>
        @if (canApplyResourceChanges)
        {
            <FluentButton Appearance="Appearance.Accent"
                          Disabled="@(ConfigurationContext?.CanApply != true || IsApplying)"
                          OnClick="ApplyChanges">
                @(IsApplying ? L["Applying"] : L["Apply"])
            </FluentButton>
        }
    </div>
</section>

@if (ProcedureMessage is not null)
{
    <div class="procedure-message">@ProcedureMessage</div>
}

@if (isReadOnly)
{
    <div class="procedure-message">@L["Resource Manager is in read-only mode. Resource lifecycle actions and updates are disabled in this UI."]</div>
}

@if (PendingRestart is not null)
{
    <div class="procedure-confirmation" role="alert">
        <strong>@L["Restart {0}?", PendingRestart.ResourceName]</strong>
        <span>@PendingRestart.Message</span>
        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent"
                          Disabled="@(IsRestarting || IsReadOnly)"
                          OnClick="RestartPendingResource">
                @(IsRestarting ? L["Restarting"] : L["Restart now"])
            </FluentButton>
            <FluentButton Appearance="Appearance.Neutral"
                          Disabled="@IsRestarting"
                          OnClick="DismissRestartPrompt">
                @L["Later"]
            </FluentButton>
        </div>
    </div>
}

<section class="registration-layout">
    <aside class="panel registration-options">
        <h2>@L["Resource"]</h2>
        @if (resource is not null)
        {
            <div class="selected-type-card">
                <span class="resource-kind-icon">@GetTypeGlyph(resource)</span>
                <div>
                    <strong>@GetResourceLabel(resource)</strong>
                    <p>@resource.Kind</p>
                </div>
            </div>
            <dl class="detail-list">
                <dt>@L["Resource ID"]</dt>
                <dd>@resource.Id</dd>
                @if (DisplaySelection.ShouldShowDisplayName(resource))
                {
                    <dt>@L["Display name"]</dt>
                    <dd>@resource.Name</dd>
                }
                <dt>@L["Group"]</dt>
                <dd>@(group?.Name ?? L["Default group"])</dd>
                <dt>@L["Provider"]</dt>
                <dd>@resource.Provider</dd>
            </dl>
        }

        @if (tabs.Count > 0)
        {
            <div class="resource-tab-list" role="tablist" aria-label="@L["Resource views"]">
                @foreach (var tabGroup in BuildTabGroups(tabs))
                {
                    <div class="resource-tab-group"
                         role="group"
                         aria-label="@tabGroup.Title">
                        @if (!string.IsNullOrWhiteSpace(tabGroup.Title))
                        {
                            <span class="resource-tab-group-title">@tabGroup.Title</span>
                        }
                        @foreach (var tab in tabGroup.Tabs)
                        {
                            <button class="@GetTabButtonClass(tab, selectedTab)"
                                    type="button"
                                    role="tab"
                                    aria-selected="@(selectedTab?.Id == tab.Id)"
                                    @onclick="() => SelectTab(tab.Id)">
                                @tab.Title
                            </button>
                        }
                    </div>
                }
            </div>
        }
    </aside>

    <div class="panel registration-host">
        @if (resource is null)
        {
            <EmptyState Title="@L["Resource not found"].Value"
                        Message="@L["The resource may have been removed or is no longer visible."].Value" />
        }
        else if (selectedTab is null)
        {
            <EmptyState Title="@L["No resource selected"].Value"
                        Message="@L["Select a resource to inspect its projected details."].Value" />
        }
        else
        {
            <div class="panel-header">
                <div>
                    <h2>@selectedTab.Title</h2>
                    <p>@(resourceType?.DisplayName ?? resource.EffectiveTypeId)</p>
                </div>
            </div>
            @if (isGeneratedOverview)
            {
                <GeneratedResourceOverview Resource="resource"
                                           ResourceGroup="group"
                                           ResourceType="resourceType"
                                           ResourceUpdated="HandleResourceUpdated" />
            }
            else
            {
                <CascadingValue Value="ConfigurationContext">
                    <CascadingValue Name="@ResourceManagerCascadingParameterNames.ReadOnly" Value="IsReadOnly">
                        <DynamicComponent Type="selectedTab.ComponentType"
                                          @key="GetContentKey(resource, selectedTab)"
                                          Parameters="@BuildComponentParameters(resource, selectedTab)" />
                    </CascadingValue>
                </CascadingValue>
            }
        }
    </div>
</section>

@code {
    private const string GeneratedOverviewTabId = "overview";
    private const string GeneratedIdentityTabId = "identity";
    private const string GeneratedStorageVolumesTabId = "volumes";
    private const string GeneratedActivityTabId = "activity";
    private const string OverviewTabGroup = "Overview";
    private const string ConfigurationTabGroup = "Configuration";
    private const string StorageTabGroup = "Storage";
    private const string EnvironmentTabGroup = "Environment";
    private const string ManagementTabGroup = "Management";

    [Parameter]
    public string? ResourceId { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    private string? RequestedQueryTabId { get; set; }

    [SupplyParameterFromQuery(Name = "traceId")]
    private string? RequestedTraceId { get; set; }

    private ResourceConfigurationContext? ConfigurationContext { get; set; }
    private Resource? Resource { get; set; }
    private ResourceGroup? ResourceGroup { get; set; }
    private IReadOnlyList<LogDescriptor> ResourceLogs { get; set; } = [];
    private ResourceOperationCapabilities OperationCapabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private HashSet<string> ExecutingActionIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private string? SelectedTabId { get; set; }
    private string? ProcedureMessage { get; set; }
    private PendingResourceRestart? PendingRestart { get; set; }
    private bool IsApplying { get; set; }
    private bool IsRestarting { get; set; }
    private int ResourceContentVersion { get; set; }

    protected override void OnInitialized()
    {
        ResourceManager.ResourcesChanged += OnResourcesChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        ResourceGroup = Resource is null
            ? null
            : await ResourceManager.GetResourceGroupForResourceAsync(Resource.Id);

        if (Resource is not null &&
            !ResourceManagerUiAccess.CanReadResource(Authorization, Resource, ResourceGroup?.Id))
        {
            Navigation.NavigateTo("/account/access-denied");
        }

        if (Resource is null)
        {
            ResourceLogs = [];
            OperationCapabilities = ResourceOperationCapabilities.None(string.Empty);
        }
        else
        {
            await LoadResourceAffordancesAsync(Resource);
        }

        if (!string.IsNullOrWhiteSpace(RequestedQueryTabId))
        {
            SelectedTabId = RequestedQueryTabId;
        }

        if (Resource is not null && ConfigurationContext?.ResourceId != Resource.Id)
        {
            if (ConfigurationContext is not null)
            {
                ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
            }

            ConfigurationContext = new ResourceConfigurationContext(Resource.Id);
            ConfigurationContext.StateChanged += HandleConfigurationStateChanged;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private void SelectTab(string tabId)
    {
        SelectedTabId = tabId;
        ProcedureMessage = null;
        PendingRestart = null;
        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            Navigation.NavigateTo(
                $"/resources/{Uri.EscapeDataString(ResourceId)}/details?tab={Uri.EscapeDataString(tabId)}",
                replace: true);
        }

        if (ConfigurationContext is not null)
        {
            ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
            ConfigurationContext = new ResourceConfigurationContext(ConfigurationContext.ResourceId);
            ConfigurationContext.StateChanged += HandleConfigurationStateChanged;
        }
    }

    private async Task ApplyChanges()
    {
        if (ConfigurationContext is null || !CanApplyResourceChanges())
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        IsApplying = true;
        try
        {
            var result = await ConfigurationContext.ApplyAsync();
            ProcedureMessage = result.Message;
            PendingRestart = CreatePendingRestart(result);
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = L["Apply failed: {0}", exception.Message].Value;
            PendingRestart = null;
        }
        finally
        {
            IsApplying = false;
        }
    }

    private PendingResourceRestart? CreatePendingRestart(ResourceProcedureResult result)
    {
        if (!result.RestartRequired)
        {
            return null;
        }

        var resourceId = string.IsNullOrWhiteSpace(result.RestartResourceId)
            ? Resource?.Id
            : result.RestartResourceId;
        if (string.IsNullOrWhiteSpace(resourceId))
        {
            return null;
        }

        var resourceName = Resource is not null &&
            string.Equals(resourceId, Resource.Id, StringComparison.OrdinalIgnoreCase)
            ? GetResourceLabel(Resource)
            : resourceId;
        var message = string.IsNullOrWhiteSpace(result.RestartMessage)
            ? L["This change requires a restart before it takes effect."].Value
            : result.RestartMessage;

        return new PendingResourceRestart(resourceId, resourceName, message);
    }

    private async Task RestartPendingResource()
    {
        if (PendingRestart is null || IsReadOnly)
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        IsRestarting = true;
        try
        {
            var result = await ResourceManager.RestartResourceAsync(
                PendingRestart.ResourceId,
                ignoreDependentWarning: true);
            ProcedureMessage = result.Message;
            PendingRestart = null;

            await ReloadResourceAsync();
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            IsRestarting = false;
        }
    }

    private void DismissRestartPrompt() => PendingRestart = null;

    private void HandleConfigurationStateChanged() => InvokeAsync(StateHasChanged);

    private void OnResourcesChanged(object? sender, ResourceChangeNotification notification)
    {
        var currentResourceId = Resource?.Id ?? ResourceId;
        if (string.IsNullOrWhiteSpace(currentResourceId) ||
            !AffectsResource(notification, currentResourceId))
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            await ReloadResourceAsync();
            ResourceContentVersion++;
            StateHasChanged();
        });
    }

    private async Task HandleResourceUpdated(Resource resource)
    {
        Resource = resource;
        ResourceGroup = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);
        await LoadResourceAffordancesAsync(resource);
        ResourceContentVersion++;
    }

    private async Task ReloadResourceAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            return;
        }

        Resource = await ResourceManager.GetResourceAsync(ResourceId);
        ResourceGroup = Resource is null
            ? null
            : await ResourceManager.GetResourceGroupForResourceAsync(Resource.Id);
        if (Resource is not null)
        {
            await LoadResourceAffordancesAsync(Resource);
        }
    }

    private async Task LoadResourceAffordancesAsync(Resource resource)
    {
        ResourceLogs = await LogManager.ListLogsAsync(new LogQuery(ResourceId: resource.Id));
        OperationCapabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(resource);
    }

    private static bool AffectsResource(
        ResourceChangeNotification notification,
        string resourceId) =>
        string.Equals(notification.ResourceId, resourceId, StringComparison.OrdinalIgnoreCase) ||
        notification.Resources.Any(affectedResourceId =>
            string.Equals(affectedResourceId, resourceId, StringComparison.OrdinalIgnoreCase));

    private string GetContentKey(Resource resource, ResourceTabContribution selectedTab) =>
        $"{resource.Id}:{selectedTab.Id}:{ResourceContentVersion}";

    private Dictionary<string, object?> BuildComponentParameters(
        Resource resource,
        ResourceTabContribution selectedTab)
    {
        var parameters = new Dictionary<string, object?>
        {
            ["ResourceId"] = resource.Id
        };

        if (string.Equals(selectedTab.Id, GeneratedActivityTabId, StringComparison.OrdinalIgnoreCase))
        {
            parameters["TraceId"] = RequestedTraceId;
        }

        return parameters;
    }

    private static IReadOnlyList<ResourceTabContribution> BuildTabs(
        Resource? resource,
        ResourceTypeContribution? resourceType)
    {
        var contributedTabs = resourceType?.ResourceTabs ?? [];
        var tabs = new List<ResourceTabContribution>();
        if (!contributedTabs.Any(tab =>
                string.Equals(tab.Id, GeneratedOverviewTabId, StringComparison.OrdinalIgnoreCase)))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedOverviewTabId,
                "Overview",
                -100,
                typeof(GeneratedResourceOverview),
                GroupTitle: OverviewTabGroup));
        }

        if (resource?.IdentityBinding is not null &&
            !contributedTabs.Any(tab =>
                string.Equals(tab.Id, GeneratedIdentityTabId, StringComparison.OrdinalIgnoreCase)))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedIdentityTabId,
                "Identity",
                -90,
                typeof(GeneratedResourceIdentity),
                GroupTitle: ManagementTabGroup));
        }

        if (resource?.HasCapability(ResourceCapabilityIds.StorageProvider) == true &&
            !contributedTabs.Any(tab =>
                string.Equals(tab.Id, GeneratedStorageVolumesTabId, StringComparison.OrdinalIgnoreCase)))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedStorageVolumesTabId,
                "Volumes",
                20,
                typeof(StorageVolumes),
                GroupTitle: StorageTabGroup));
        }

        if (!contributedTabs.Any(tab =>
                string.Equals(tab.Id, GeneratedActivityTabId, StringComparison.OrdinalIgnoreCase)))
        {
            tabs.Add(new ResourceTabContribution(
                GeneratedActivityTabId,
                "Activity",
                90,
                typeof(ResourceActivity),
                GroupTitle: ManagementTabGroup));
        }

        if (resourceType?.UpdateComponentType is not null &&
            !contributedTabs.Any(tab =>
                string.Equals(tab.Id, "configuration", StringComparison.OrdinalIgnoreCase)))
        {
            tabs.Add(new ResourceTabContribution(
                "configuration",
                "Configuration",
                0,
                resourceType.UpdateComponentType,
                ShowsApplyButton: true,
                GroupTitle: ConfigurationTabGroup));
        }

        if (resource?.HasCapability(ResourceCapabilityIds.EnvironmentVariables) == true &&
            !contributedTabs.Any(tab =>
                string.Equals(tab.Id, "environment", StringComparison.OrdinalIgnoreCase)))
        {
            tabs.Add(new ResourceTabContribution(
                "environment",
                "Environment",
                80,
                typeof(ResourceEnvironmentVariables),
                ShowsApplyButton: true,
                GroupTitle: EnvironmentTabGroup));
        }

        return tabs
            .Concat(contributedTabs)
            .OrderBy(GetResourceTabOrder)
            .ThenBy(tab => tab.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static int GetResourceTabOrder(ResourceTabContribution tab)
    {
        if (string.Equals(tab.Id, GeneratedOverviewTabId, StringComparison.OrdinalIgnoreCase))
        {
            return int.MinValue;
        }

        if (string.Equals(tab.Id, GeneratedIdentityTabId, StringComparison.OrdinalIgnoreCase))
        {
            return int.MaxValue - 1;
        }

        if (string.Equals(tab.Id, GeneratedActivityTabId, StringComparison.OrdinalIgnoreCase))
        {
            return int.MaxValue;
        }

        if (string.Equals(tab.Id, "environment", StringComparison.OrdinalIgnoreCase))
        {
            return int.MaxValue - 2;
        }

        return tab.Order;
    }

    private static IReadOnlyList<ResourceTabGroup> BuildTabGroups(
        IReadOnlyList<ResourceTabContribution> tabs)
    {
        var groups = new List<ResourceTabGroup>();
        foreach (var tab in tabs)
        {
            var groupTitle = string.IsNullOrWhiteSpace(tab.GroupTitle)
                ? string.Empty
                : tab.GroupTitle;
            var currentGroup = groups.LastOrDefault();
            if (currentGroup is null ||
                !string.Equals(currentGroup.Title, groupTitle, StringComparison.OrdinalIgnoreCase))
            {
                currentGroup = new ResourceTabGroup(groupTitle, []);
                groups.Add(currentGroup);
            }

            currentGroup.Tabs.Add(tab);
        }

        return groups;
    }

    private string GetTabButtonClass(
        ResourceTabContribution tab,
        ResourceTabContribution? selectedTab)
    {
        var classes = new List<string> { "resource-tab-button" };
        if (selectedTab?.Id == tab.Id)
        {
            classes.Add("active");
        }

        return string.Join(" ", classes);
    }

    private RenderFragment ResourceActionControls(Resource resource) => builder =>
    {
        if (resource.ResourceActions.Count == 0)
        {
            return;
        }

        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "inline-actions");

        foreach (var action in resource.ResourceActions.Where(IsInlineAction))
        {
            builder.OpenComponent<FluentButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-icon-button");
            builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "Title", action.DisplayName);
            builder.AddAttribute(sequence++, "Disabled", !CanExecuteAction(action) || IsExecutingAction(action));
            builder.AddAttribute(sequence++, "OnClick",
                EventCallback.Factory.Create<MouseEventArgs>(this, () => ExecuteAction(action)));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
            {
                buttonBuilder.OpenElement(0, "span");
                buttonBuilder.AddAttribute(1, "class", $"action-icon {GetActionIconClass(action)}");
                buttonBuilder.AddAttribute(2, "aria-hidden", "true");
                buttonBuilder.CloseElement();
            }));
            builder.CloseComponent();
        }

        var overflowActions = resource.ResourceActions
            .Where(action => !IsInlineAction(action))
            .ToArray();
        if (overflowActions.Length > 0)
        {
            builder.OpenComponent<FluentMenuButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-overflow-button");
            builder.AddAttribute(sequence++, "UseMenuService", true);
            builder.AddAttribute(sequence++, "ButtonAppearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "ButtonContent", (RenderFragment)(buttonBuilder =>
            {
                buttonBuilder.OpenElement(0, "span");
                buttonBuilder.AddAttribute(1, "class", "action-overflow-label");
                buttonBuilder.AddAttribute(2, "aria-label", L["More actions"]);
                buttonBuilder.AddContent(3, "...");
                buttonBuilder.CloseElement();
            }));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(menuBuilder =>
            {
                var menuSequence = 0;
                foreach (var action in overflowActions)
                {
                    menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                    menuBuilder.AddAttribute(menuSequence++, "Disabled", !CanExecuteAction(action) || IsExecutingAction(action));
                    menuBuilder.AddAttribute(menuSequence++, "OnClick",
                        EventCallback.Factory.Create<MouseEventArgs>(this, () => ExecuteAction(action)));
                    menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                    {
                        itemBuilder.OpenElement(0, "span");
                        itemBuilder.AddAttribute(1, "class", "menu-action-content");
                        itemBuilder.OpenElement(2, "span");
                        itemBuilder.AddAttribute(3, "class", $"action-icon {GetActionIconClass(action)}");
                        itemBuilder.AddAttribute(4, "aria-hidden", "true");
                        itemBuilder.CloseElement();
                        itemBuilder.OpenElement(5, "span");
                        itemBuilder.AddContent(6, IsExecutingAction(action) ? L["Working"] : action.DisplayName);
                        itemBuilder.CloseElement();
                        itemBuilder.CloseElement();
                    }));
                    menuBuilder.CloseComponent();
                }
            }));
            builder.CloseComponent();
        }

        builder.CloseElement();
    };

    private static bool IsInlineAction(ResourceAction action) =>
        action.EffectivePresentation.DisplayStyle == ResourceActionDisplayStyle.Inline;

    private bool CanExecuteAction(ResourceAction action) =>
        !IsReadOnly && OperationCapabilities.CanExecuteAction(action.Id);

    private bool CanApplyResourceChanges() =>
        !IsReadOnly && OperationCapabilities.CanManage;

    private bool IsExecutingAction(ResourceAction action) =>
        ExecutingActionIds.Contains(action.Id);

    private async Task ExecuteAction(ResourceAction action)
    {
        if (Resource is null || !CanExecuteAction(action) || IsExecutingAction(action))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        if (action.RequiresConfirmation)
        {
            var confirmed = await JS.InvokeAsync<bool>(
                "confirm",
                action.Description ??
                L["Start {0} for {1}?", action.DisplayName, GetResourceLabel(Resource)].Value);
            if (!confirmed)
            {
                return;
            }
        }

        ExecutingActionIds.Add(action.Id);
        ProcedureMessage = null;
        PendingRestart = null;
        try
        {
            var result = await ResourceManager.ExecuteResourceActionAsync(
                new ExecuteResourceActionCommand(
                    Resource.Id,
                    action.Id,
                    StartDependencies: ShouldStartDependencies(action),
                    IgnoreDependentWarning: true));
            ProcedureMessage = result.Message;
            await ReloadResourceAsync();
            ResourceContentVersion++;
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            ExecutingActionIds.Remove(action.Id);
        }
    }

    private void OpenLogs()
    {
        if (Resource is null || ResourceLogs.Count == 0)
        {
            return;
        }

        var query = new Dictionary<string, string?>
        {
            ["resourceId"] = Resource.Id
        };

        if (ResourceLogs.Count == 1)
        {
            query["logId"] = ResourceLogs[0].Id;
        }

        Navigation.NavigateTo(Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString("/logs", query));
    }

    private string GetLogsActionLabel(int logCount) =>
        logCount == 1 ? L["Logs"].Value : L["Logs ({0})", logCount].Value;

    private static bool ShouldStartDependencies(ResourceAction action) =>
        action.Kind is ResourceActionKind.Start or ResourceActionKind.Restart;

    private static string GetActionIconClass(ResourceAction action) => action.EffectivePresentation.Icon switch
    {
        ResourceActionIcon.Start => "action-icon-start",
        ResourceActionIcon.Stop => "action-icon-stop",
        ResourceActionIcon.Pause => "action-icon-pause",
        ResourceActionIcon.Restart => "action-icon-restart",
        _ => "action-icon-custom"
    };

    private static string GetStateClass(ResourceState? state) => state switch
    {
        ResourceState.Running => "state-running",
        ResourceState.Starting => "state-starting",
        ResourceState.Paused => "state-paused",
        ResourceState.Degraded => "state-degraded",
        ResourceState.Stopped => "state-stopped",
        _ => "state-unknown"
    };

    public void Dispose()
    {
        ResourceManager.ResourcesChanged -= OnResourcesChanged;

        if (ConfigurationContext is not null)
        {
            ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
        }
    }

    private static string GetTypeGlyph(Resource resource) =>
        resource.Kind.Contains("Docker", StringComparison.OrdinalIgnoreCase) ? "D" :
        resource.Name[..1].ToUpperInvariant();

    private string GetResourceLabel(Resource resource) => DisplaySelection.GetResourceLabel(resource);

    private string GetResourceSubtitle(Resource resource) =>
        DisplaySelection.EnableDisplayNames
            ? L["{0} / {1}", resource.Kind, resource.Id].Value
            : resource.Kind;

    private sealed record PendingResourceRestart(
        string ResourceId,
        string ResourceName,
        string Message);

    private sealed record ResourceTabGroup(
        string Title,
        List<ResourceTabContribution> Tabs);
}
