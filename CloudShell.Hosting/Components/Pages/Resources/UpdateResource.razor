@page "/resources/{ResourceId}/edit"
@page "/resources/{ResourceId}/details"
@page "/resources/{ResourceId}"
@page "/resources/{ResourceId}/{RequestedRouteView}"
@rendermode InteractiveServer
@inject IResourceManager ResourceManager
@inject ILogManager LogManager
@inject IResourceMonitoringManager MonitoringManager
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@inject ICloudShellAuthorizationService Authorization
@inject IJSRuntime JS
@inject IResourceHealthManager HealthChecks
@inject IResourceEventManager ResourceEvents
@inject IResourceOrchestrationSettings OrchestrationSettings
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions
@inject ResourceManagerDisplaySettings DisplaySettings
@inject IStringLocalizer<SharedResource> L
@inject IServiceProvider Services
@inject ICoreShellRouteService ShellRoutes
@inject ILogger<UpdateResource> Logger
@implements IDisposable
@using CloudShell.Abstractions.Authorization
@using Microsoft.Extensions.Logging

<PageTitle>@L["Resource details"]</PageTitle>
<FluentMenuProvider />

@{
    var resource = Resource;
    var group = ResourceGroup;
    var resourceType = resource is null
        ? null
        : FindResourceTypeContribution(resource);
    var hasDefaultIdentityProvider = HasDefaultIdentityProvider();
    var canReadUsage = Authorization.CanReadUsage();
    var tabs = BuildTabs(
        resource,
        resourceType,
        ResourceLogSources.Count > 0,
        HasResourceMonitoring,
        canReadUsage,
        hasDefaultIdentityProvider);
    var selectedTab = GetSelectedTab(tabs);
    var selectedTabIssue = GetSelectedTabIssue(tabs);
    var isGeneratedOverview = selectedTabIssue is null &&
        selectedTab?.ComponentType == typeof(GeneratedResourceOverview);
    var isReadOnly = ResourceManagerUiOptions.Value.ReadOnly;
    var canApplyResourceChanges = selectedTab?.ShowsApplyButton == true &&
        CanApplyResourceChanges();
}

<section class="page-heading compact">
    <div class="resource-page-title">
        <span class="eyebrow">@L["Resource Manager"]</span>
        <div class="resource-title-line">
            @if (resource is not null)
            {
                <ResourceKindIcon Resource="resource" Class="resource-kind-icon resource-title-icon" />
            }
            <div class="resource-title-name">
                <h1>@(resource is null ? L["Resource"] : GetResourceLabel(resource))</h1>
            </div>
        </div>
        <p>@(resource is null ? L["Generated details and provider-contributed views for this resource."] :
                                                                                    GetResourceSubtitle(resource))</p>
        </div>
        <div class="heading-actions resource-detail-actions">
            @if (resource is not null)
            {
                @ResourceActionControls(resource)
                @if (ResourceLogSources.Count > 0)
                {
                    <FluentButton Appearance="Appearance.Neutral" Title="@GetLogsActionLabel(ResourceLogSources.Count)"
                                  IconStart="new Icons.Regular.Size20.DocumentText()" OnClick="OpenLogs">
                        @GetLogsActionLabel(ResourceLogSources.Count)
                    </FluentButton>
                }
                @if (CanDeleteResource(resource))
                {
                    <FluentButton Appearance="Appearance.Neutral" Disabled="@IsDeleting"
                                  IconStart="new Icons.Regular.Size20.Delete()" OnClick="() => PromptDelete(resource)">
                        @L["Delete"]
                    </FluentButton>
                }
            }
            <FluentButton Appearance="Appearance.Neutral" IconStart="new Icons.Regular.Size20.Dismiss()" OnClick="Cancel">
                @L["Close"]
            </FluentButton>
            @if (canApplyResourceChanges)
            {
                <FluentButton Appearance="Appearance.Accent" Disabled="@(ConfigurationContext?.CanApply != true || IsApplying)"
                              IconStart="new Icons.Regular.Size20.Checkmark()" OnClick="ApplyChanges">
                    @(IsApplying ? L["Applying"] : L["Apply"])
                </FluentButton>
            }
        </div>
    </section>

    @if (resource is not null)
    {
        <ResourceStartupDeclarationAlert Resource="resource" />
    }

    @if (ProcedureMessage is not null)
    {
        <ProcedureMessage Message="@ProcedureMessage" />
    }
    <ResourceProcedureSignals Signals="ProcedureSignals" />

    @if (isReadOnly)
    {
        <ProcedureMessage>
            @L["Resource Manager is in read-only mode. Resource lifecycle actions and updates are disabled in this UI."]
        </ProcedureMessage>
    }

    @if (ConfirmDelete && resource is not null)
    {
        <div class="procedure-confirmation">
            <strong>@L["Delete registration?"]</strong>
            <span>@L["The provider will commit the delete procedure for this resource."]</span>
            <FormActions>
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsDeleting" OnClick="CancelDelete">
                    @L["Cancel"]
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" Disabled="@IsDeleting" OnClick="DeleteResource">
                    @(IsDeleting ? L["Deleting"] : L["Delete"])
                </FluentButton>
            </FormActions>
        </div>
    }

    @if (PendingRestart is not null)
    {
        <div class="procedure-confirmation" role="alert">
            <strong>@L["Restart {0}?", PendingRestart.ResourceName]</strong>
            <span>@PendingRestart.Message</span>
            <FormActions>
                <FluentButton Appearance="Appearance.Accent" Disabled="@(IsRestarting || IsReadOnly)"
                              OnClick="RestartPendingResource">
                    @(IsRestarting ? L["Restarting"] : L["Restart now"])
                </FluentButton>
                <FluentButton Appearance="Appearance.Neutral" Disabled="@IsRestarting" OnClick="DismissRestartPrompt">
                    @L["Later"]
                </FluentButton>
            </FormActions>
        </div>
    }

    <CloudShellTabbedLayout Items="@ResourceTabLayoutProjection.CreateItems(tabs, ShellRoutes, ResourceId)"
                            SelectedItemId="@selectedTab?.Id.Value"
                            SelectedItemChanged="SelectLayoutTab"
                            SelectFirstItemWhenSelectedMissing="@(selectedTabIssue is null)"
                            AriaLabel="@L["Resource views"].Value"
                            IconResolver="ResourceViewIcons.FromName">
        <SummaryContent>
            @if (resource is not null)
            {
                <ResourceStatusSummary Resource="resource"
                                       HealthSummary="HealthSummary"
                                       IsCheckingHealth="IsCheckingHealth"
                                       LifecycleProgressLabel="@GetLifecycleProgressLabel(resource)" />
                <ResourceFailureSummary Resource="resource" />
            }
        </SummaryContent>
        <EmptyContent>
            @if (resource is null)
            {
                <EmptyState Title="@L["Resource not found"].Value"
                            Message="@L["The resource may have been removed or is no longer visible."].Value" />
            }
            else if (selectedTabIssue is not null)
            {
                <EmptyState Title="@selectedTabIssue.Title"
                            Message="@selectedTabIssue.Message">
                    <FluentAnchor Appearance="Appearance.Neutral" Href="@selectedTabIssue.RecoveryHref">
                        @selectedTabIssue.RecoveryLabel
                    </FluentAnchor>
                </EmptyState>
            }
            else if (selectedTab is null)
            {
                <EmptyState Title="@L["No resource selected"].Value"
                            Message="@L["Select a resource to inspect its details."].Value" />
            }
        </EmptyContent>
        <HeaderContent Context="item">
            @if (selectedTab is not null && resource is not null)
            {
                <ShellPanelHeader Title="@selectedTab.Title"
                                  Description="@(resourceType?.DisplayName ?? resource.EffectiveTypeId)" />
            }
        </HeaderContent>
        <ChildContent Context="item">
            @if (resource is not null && selectedTab is not null)
            {
                @if (isGeneratedOverview)
                {
                    <GeneratedResourceOverview Resource="resource" ResourceGroup="group" ResourceType="resourceType"
                                               ResourceLogSources="ResourceLogSources"
                                               ResourceUpdated="HandleResourceUpdated" />
                }
                else
                {
                    <CascadingValue Value="ConfigurationContext">
                        <CascadingValue Name="@ResourceManagerCascadingParameterNames.ReadOnly" Value="IsReadOnly">
                            <DynamicComponent Type="selectedTab.ComponentType" @key="GetContentKey(resource, selectedTab)"
                                              Parameters="@BuildComponentParameters(resource, resourceType, selectedTab)" />
                        </CascadingValue>
                    </CascadingValue>
                }
            }
        </ChildContent>
    </CloudShellTabbedLayout>

@code {
    private static readonly ResourceViewId GeneratedOverviewTabId = ResourcePredefinedViewIds.Overview;
    private static readonly ResourceViewId GeneratedEndpointsTabId = ResourcePredefinedViewIds.Endpoints;
    private static readonly ResourceViewId GeneratedDnsTabId = ResourcePredefinedViewIds.Dns;
    private static readonly ResourceViewId GeneratedIdentityTabId = ResourcePredefinedViewIds.Identity;
    private static readonly ResourceViewId GeneratedAccessControlTabId = ResourcePredefinedViewIds.AccessControl;
    private static readonly ResourceViewId GeneratedStorageVolumesTabId = ResourcePredefinedViewIds.Volumes;
    private static readonly ResourceViewId GeneratedActivityTabId = ResourcePredefinedViewIds.Activity;
    private static readonly ResourceViewId GeneratedHealthTabId = ResourcePredefinedViewIds.Health;
    private static readonly ResourceViewId GeneratedMonitoringTabId = ResourcePredefinedViewIds.Monitoring;
    private static readonly ResourceViewId GeneratedUsageTabId = ResourcePredefinedViewIds.Usage;
    private static readonly ResourceViewId GeneratedLogsTabId = ResourcePredefinedViewIds.Logs;
    private static readonly ResourceViewId GeneratedTracesTabId = ResourcePredefinedViewIds.Traces;
    private static readonly ResourceViewId GeneratedMetricsTabId = ResourcePredefinedViewIds.Metrics;
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public string? RequestedRouteView { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    private string? RequestedQueryTabId { get; set; }

    [SupplyParameterFromQuery(Name = "traceId")]
    private string? RequestedTraceId { get; set; }

    [SupplyParameterFromQuery(Name = "spanId")]
    private string? RequestedSpanId { get; set; }

    [SupplyParameterFromQuery(Name = "logSourceId")]
    private string? RequestedLogSourceId { get; set; }

    [SupplyParameterFromQuery(Name = "logView")]
    private string? RequestedLogView { get; set; }

    [SupplyParameterFromQuery(Name = "sourceIds")]
    private string? RequestedLogSourceIds { get; set; }

    [SupplyParameterFromQuery(Name = "scopeResourceId")]
    private string? RequestedScopeResourceId { get; set; }

    private ResourceConfigurationContext? ConfigurationContext { get; set; }
    private Resource? Resource { get; set; }
    private ResourceGroup? ResourceGroup { get; set; }
    private ResourceHealthSummary? HealthSummary { get; set; }
    private IReadOnlyList<LogSource> ResourceLogSources { get; set; } = [];
    private bool HasResourceMonitoring { get; set; }
    private ResourceOperationCapabilities OperationCapabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private HashSet<string> ExecutingActionIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private ResourceManagerDisplaySelection DisplaySelection { get; set; } =
        ResourceManagerDisplaySelection.Default;
    private bool IsReadOnly => ResourceManagerUiOptions.Value.ReadOnly;
    private ResourceViewId? SelectedTabId { get; set; }
    private string? ProcedureMessage { get; set; }
    private IReadOnlyList<ResourceProcedureSignal> ProcedureSignals { get; set; } = [];
    private PendingResourceRestart? PendingRestart { get; set; }
    private bool IsApplying { get; set; }
    private bool IsRestarting { get; set; }
    private bool IsDeleting { get; set; }
    private bool IsCheckingHealth { get; set; }
    private bool ConfirmDelete { get; set; }
    private int ResourceContentVersion { get; set; }

    protected override void OnInitialized()
    {
        ResourceManager.ResourcesChanged += OnResourcesChanged;
    }

    private ResourceTypeContribution? FindResourceTypeContribution(Resource resource)
    {
        return ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase));
    }

    protected override async Task OnParametersSetAsync()
    {
        DisplaySelection = await DisplaySettings.GetAsync();
        Resource = await LoadRouteResourceAsync();
        if (Resource is null)
        {
            NavigateToResourceNotFound();
            return;
        }

        var resource = Resource;
        ResourceGroup = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);

        if (!ResourceManagerUiAccess.CanReadResource(Authorization, resource, ResourceGroup?.Id))
        {
            Navigation.NavigateTo("/account/access-denied");
        }

        await LoadResourceAffordancesAsync(resource);

        var resourceType = FindResourceTypeContribution(resource);
        var tabs = BuildTabs(
            resource,
            resourceType,
            ResourceLogSources.Count > 0,
            HasResourceMonitoring,
            Authorization.CanReadUsage(),
            HasDefaultIdentityProvider());
        SelectedTabId = ResolveRequestedTabId(tabs);

        if (ConfigurationContext?.ResourceId != resource.Id)
        {
            if (ConfigurationContext is not null)
            {
                ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
            }

            ConfigurationContext = new ResourceConfigurationContext(resource.Id);
            ConfigurationContext.StateChanged += HandleConfigurationStateChanged;
        }
    }

    private async Task<Resource?> LoadRouteResourceAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            return null;
        }

        var resource = await ResourceManager.GetResourceAsync(ResourceId);
        if (resource is not null)
        {
            return resource;
        }

        if (!string.IsNullOrWhiteSpace(RequestedRouteView) ||
            !TrySplitCombinedResourceRoute(ResourceId, out var routeResourceId, out var routeView))
        {
            return null;
        }

        resource = await ResourceManager.GetResourceAsync(routeResourceId);
        if (resource is null)
        {
            return null;
        }

        ResourceId = routeResourceId;
        RequestedRouteView = routeView;
        return resource;
    }

    private static bool TrySplitCombinedResourceRoute(
        string routeResourceId,
        out string resourceId,
        out string routeView)
    {
        resourceId = string.Empty;
        routeView = string.Empty;

        var separator = routeResourceId.LastIndexOf('/');
        if (separator <= 0 || separator == routeResourceId.Length - 1)
        {
            return false;
        }

        resourceId = routeResourceId[..separator];
        routeView = Uri.UnescapeDataString(routeResourceId[(separator + 1)..].Trim());
        return !string.IsNullOrWhiteSpace(resourceId) &&
            ResourceViewId.TryParse(routeView, out _);
    }

    private void Cancel() => Navigation.NavigateTo("/resources");

    private void NavigateToResourceNotFound()
    {
        ResourceLogSources = [];
        HealthSummary = null;
        IsCheckingHealth = false;
        HasResourceMonitoring = false;
        OperationCapabilities = ResourceOperationCapabilities.None(string.Empty);
        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            Navigation.NavigateTo(ResourceManagerRoutes.ResourceNotFound(ResourceId), replace: true);
        }
    }

    private void SelectTab(ResourceViewId tabId)
    {
        SelectedTabId = tabId;
        ProcedureMessage = null;
        ProcedureSignals = [];
        PendingRestart = null;
        if (!string.IsNullOrWhiteSpace(ResourceId))
        {
            Navigation.NavigateTo(
                ResourceManagerShellLinks.ResourceDetails(ShellRoutes, ResourceId, tabId),
                replace: true);
        }

        if (ConfigurationContext is not null)
        {
            ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
            ConfigurationContext = new ResourceConfigurationContext(ConfigurationContext.ResourceId);
            ConfigurationContext.StateChanged += HandleConfigurationStateChanged;
        }
    }

    private void SelectLayoutTab(CloudShellTabbedLayoutItem item)
    {
        if (ResourceViewId.TryParse(item.Id, out var tabId))
        {
            SelectTab(tabId);
        }
    }

    private ResourceTabContribution? GetSelectedTab(IReadOnlyList<ResourceTabContribution> tabs)
    {
        if (GetSelectedTabIssue(tabs) is not null)
        {
            return null;
        }

        if (SelectedTabId is { } selectedTabId)
        {
            return tabs.FirstOrDefault(tab => tab.Id == selectedTabId);
        }

        return tabs.FirstOrDefault();
    }

    private ResourceViewSelectionIssue? GetSelectedTabIssue(IReadOnlyList<ResourceTabContribution> tabs)
    {
        var requested = GetRequestedTabDisplayValue();
        if (string.IsNullOrWhiteSpace(requested))
        {
            return null;
        }

        if (!TryResolveRequestedTabId(tabs, out var requestedTabId))
        {
            if (HasRequestedRouteViewSegment())
            {
                return CreateResourceViewSelectionIssue(
                    L["Resource view '{0}' is not available for this resource.", requested].Value);
            }

            return CreateResourceViewSelectionIssue(
                L["Resource view '{0}' is not a valid view ID.", requested].Value);
        }

        return tabs.Any(tab => tab.Id == requestedTabId)
            ? null
            : CreateResourceViewSelectionIssue(
                L["Resource view '{0}' is not available for this resource.", requested].Value);
    }

    private ResourceViewId? ResolveRequestedTabId(IReadOnlyList<ResourceTabContribution> tabs) =>
        TryResolveRequestedTabId(tabs, out var requestedTabId)
            ? requestedTabId
            : null;

    private bool TryResolveRequestedTabId(
        IReadOnlyList<ResourceTabContribution> tabs,
        out ResourceViewId requestedTabId)
    {
        requestedTabId = default;
        var requested = GetRequestedTabDisplayValue();
        if (string.IsNullOrWhiteSpace(requested))
        {
            return false;
        }

        var normalized = Uri.UnescapeDataString(requested.Trim());
        if (ResourceViewId.TryParse(normalized, out requestedTabId))
        {
            return true;
        }

        var matchingTabs = tabs
            .Where(tab => string.Equals(
                ResourceManagerRoutes.GetResourceViewSegment(tab.Id),
                normalized,
                StringComparison.OrdinalIgnoreCase))
            .ToArray();
        if (matchingTabs.Length == 1)
        {
            requestedTabId = matchingTabs[0].Id;
            return true;
        }

        return false;
    }

    private string? GetRequestedTabDisplayValue()
    {
        if (HasRequestedRouteViewSegment())
        {
            return RequestedRouteView;
        }

        return RequestedQueryTabId;
    }

    private bool HasRequestedRouteViewSegment() =>
        !string.IsNullOrWhiteSpace(RequestedRouteView) &&
        !IsLegacyResourceDetailsSegment(RequestedRouteView);

    private static bool IsLegacyResourceDetailsSegment(string value) =>
        string.Equals(value.Trim(), "details", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(value.Trim(), "edit", StringComparison.OrdinalIgnoreCase);

    private ResourceViewSelectionIssue CreateResourceViewSelectionIssue(string message) =>
        new(
            L["Resource view not found"].Value,
            message,
            L["Open overview"].Value,
            string.IsNullOrWhiteSpace(ResourceId)
                ? ResourceManagerShellLinks.ResourceManagerPage(
                    ShellRoutes,
                    ResourceManagerShellIds.ResourcesPage,
                    ResourceManagerRoutes.Resources)
                : ResourceManagerShellLinks.ResourceDetails(ShellRoutes, ResourceId));

    private async Task ApplyChanges()
    {
        if (ConfigurationContext is null || !CanApplyResourceChanges())
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
                ProcedureSignals = [];
            }

            return;
        }

        IsApplying = true;
        ProcedureSignals = [];
        try
        {
            var result = await ConfigurationContext.ApplyAsync();
            ProcedureMessage = result.Message;
            ProcedureSignals = result.Signals;
            PendingRestart = CreatePendingRestart(result);
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = FormatResourceOperationFailure(exception, "apply resource changes");
            ProcedureSignals = [];
            PendingRestart = null;
        }
        finally
        {
            IsApplying = false;
        }
    }

    private PendingResourceRestart? CreatePendingRestart(ResourceProcedureResult result)
    {
        if (!result.RestartRequired)
        {
            return null;
        }

        var resourceId = string.IsNullOrWhiteSpace(result.RestartResourceId)
            ? Resource?.Id
            : result.RestartResourceId;
        if (string.IsNullOrWhiteSpace(resourceId))
        {
            return null;
        }

        var resourceName = Resource is not null &&
            string.Equals(resourceId, Resource.Id, StringComparison.OrdinalIgnoreCase)
            ? GetResourceLabel(Resource)
            : ResourceDisplayLabels.GetName(resourceId);
        var message = string.IsNullOrWhiteSpace(result.RestartMessage)
            ? L["This change requires a restart before it takes effect."].Value
            : result.RestartMessage;

        return new PendingResourceRestart(resourceId, resourceName, message);
    }

    private async Task RestartPendingResource()
    {
        if (PendingRestart is null || IsReadOnly)
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
            }

            return;
        }

        IsRestarting = true;
        ProcedureSignals = [];
        try
        {
            var result = await ResourceManager.RestartResourceAsync(
                PendingRestart.ResourceId,
                ignoreDependentWarning: true);
            ProcedureMessage = result.Message;
            ProcedureSignals = result.Signals;
            PendingRestart = null;

            await ReloadResourceAsync();
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = FormatResourceOperationFailure(exception, "restart the resource");
            ProcedureSignals = [];
        }
        finally
        {
            IsRestarting = false;
        }
    }

    private void DismissRestartPrompt() => PendingRestart = null;

    private void PromptDelete(Resource resource)
    {
        if (!CanDeleteResource(resource))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
                ProcedureSignals = [];
            }

            return;
        }

        ProcedureMessage = null;
        ProcedureSignals = [];
        PendingRestart = null;
        ConfirmDelete = true;
    }

    private void CancelDelete() => ConfirmDelete = false;

    private async Task DeleteResource()
    {
        if (Resource is null)
        {
            ConfirmDelete = false;
            return;
        }

        if (!CanDeleteResource(Resource))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
                ProcedureSignals = [];
            }

            ConfirmDelete = false;
            return;
        }

        IsDeleting = true;
        ProcedureMessage = null;
        ProcedureSignals = [];
        try
        {
            await ResourceManager.DeleteResourceAsync(Resource.Id);
            ConfirmDelete = false;
            Navigation.NavigateTo("/resources");
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = FormatResourceOperationFailure(exception, "delete the resource");
            ProcedureSignals = [];
        }
        finally
        {
            IsDeleting = false;
        }
    }

    private void HandleConfigurationStateChanged() => InvokeAsync(StateHasChanged);

    private void OnResourcesChanged(object? sender, ResourceChangeNotification notification)
    {
        var currentResourceId = Resource?.Id ?? ResourceId;
        if (string.IsNullOrWhiteSpace(currentResourceId) ||
            !AffectsResource(notification, currentResourceId))
        {
            return;
        }

        TrackResourceActionNotification(notification);
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            await ReloadResourceAsync();
            ResourceContentVersion++;
            StateHasChanged();
        });
    }

    private async Task HandleResourceUpdated(Resource resource)
    {
        Resource = resource;
        ResourceGroup = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);
        await LoadResourceAffordancesAsync(resource);
        ResourceContentVersion++;
    }

    private async Task ReloadResourceAsync()
    {
        if (string.IsNullOrWhiteSpace(ResourceId))
        {
            return;
        }

        Resource = await ResourceManager.GetResourceAsync(ResourceId);
        ResourceGroup = Resource is null
            ? null
            : await ResourceManager.GetResourceGroupForResourceAsync(Resource.Id);
        if (Resource is not null)
        {
            await LoadResourceAffordancesAsync(Resource);
        }
    }

    private async Task LoadResourceAffordancesAsync(Resource resource)
    {
        ResourceLogSources = Authorization.CanReadLogs()
            ? await LogManager.ListLogSourcesAsync(new LogQuery(ResourceId: resource.Id))
            : [];
        HasResourceMonitoring = resource.HasCapability(ResourceCapabilityIds.Monitoring) &&
            await MonitoringManager.HasResourceMonitoringAsync(resource.Id);
        OperationCapabilities = await ResourceManager.GetResourceOperationCapabilitiesAsync(resource);
        await RestoreActiveLifecycleTransitionAsync(resource);
        await RefreshResourceHealthAsync(resource);
    }

    private async Task RestoreActiveLifecycleTransitionAsync(Resource resource)
    {
        try
        {
            foreach (var action in resource.ResourceActions.Where(action =>
                ResourceLifecycleTransitionResolver.IsLifecycleAction(action.Id)))
            {
                ExecutingActionIds.Remove(action.Id);
            }

            var events = await ResourceEvents.ListResourceEventsAsync(new ResourceEventQuery(
                ResourceId: resource.Id,
                MaxEvents: 20));
            var transition = ResourceLifecycleTransitionResolver.GetActiveTransitions(events).FirstOrDefault();
            if (transition is not null)
            {
                ExecutingActionIds.Add(transition.ActionId);
            }
        }
        catch (Exception exception)
        {
            Logger.LogWarning(exception, "Failed to restore active resource lifecycle transition.");
        }
    }

    private async Task RefreshResourceHealthAsync(Resource resource)
    {
        HealthSummary = null;
        if (resource.ResourceHealthChecks.Count == 0)
        {
            IsCheckingHealth = false;
            return;
        }

        IsCheckingHealth = true;
        try
        {
            HealthSummary = await HealthChecks.GetResourceHealthAsync(resource.Id);
        }
        finally
        {
            IsCheckingHealth = false;
        }
    }

    private static bool AffectsResource(
        ResourceChangeNotification notification,
        string resourceId) =>
        string.Equals(notification.ResourceId, resourceId, StringComparison.OrdinalIgnoreCase) ||
        notification.Resources.Any(affectedResourceId =>
            string.Equals(affectedResourceId, resourceId, StringComparison.OrdinalIgnoreCase));

    private void TrackResourceActionNotification(ResourceChangeNotification notification)
    {
        if (string.IsNullOrWhiteSpace(notification.ActionId))
        {
            return;
        }

        if (notification.Kind == ResourceChangeKind.ResourceActionStarted)
        {
            ExecutingActionIds.Add(notification.ActionId);
        }
        else if (notification.Kind is ResourceChangeKind.ResourceActionExecuted
            or ResourceChangeKind.ResourceActionFailed)
        {
            ExecutingActionIds.Remove(notification.ActionId);
        }
    }

    private string GetContentKey(Resource resource, ResourceTabContribution selectedTab) =>
        $"{resource.Id}:{selectedTab.Id}:{ResourceContentVersion}";

    private Dictionary<string, object?> BuildComponentParameters(
        Resource resource,
        ResourceTypeContribution? resourceType,
        ResourceTabContribution selectedTab)
    {
        var parameters = new Dictionary<string, object?>
        {
            ["ResourceId"] = resource.Id
        };

        if (resourceType is not null && IsGeneratedPredefinedView(selectedTab))
        {
            parameters["ResourceType"] = resourceType;
        }

        if (selectedTab.Id == GeneratedActivityTabId)
        {
            parameters["TraceId"] = RequestedTraceId;
            parameters["SpanId"] = RequestedSpanId;
        }
        else if (selectedTab.Id == GeneratedLogsTabId)
        {
            parameters["LogSourceId"] = RequestedLogSourceId;
            parameters["TraceId"] = RequestedTraceId;
            parameters["View"] = RequestedLogView;
            parameters["SourceIds"] = RequestedLogSourceIds;
            parameters["LogSources"] = ResourceLogSources;
        }
        else if (selectedTab.Id == GeneratedTracesTabId)
        {
            parameters["TraceId"] = RequestedTraceId;
            parameters["ScopeResourceId"] = RequestedScopeResourceId;
        }
        else if (selectedTab.Id == GeneratedMetricsTabId)
        {
            parameters["ScopeResourceId"] = RequestedScopeResourceId;
        }

        return parameters;
    }

