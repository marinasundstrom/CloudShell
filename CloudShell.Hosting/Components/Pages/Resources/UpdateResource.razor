    private bool HasDefaultIdentityProvider()
    {
        var configuredProviders = Services.GetService(typeof(ResourceIdentityProviderCatalog)) as ResourceIdentityProviderCatalog ??
            new ResourceIdentityProviderCatalog();
        var declarations = Services.GetService(typeof(ResourceDeclarationStore)) as ResourceDeclarationStore;
        var effectiveProviders = declarations?.CreateIdentityProviderCatalog(configuredProviders) ?? configuredProviders;

        return effectiveProviders.DefaultProvider is not null;
    }

    private static string? GetPredefinedViewIcon(ResourceViewId id) =>
        ResourcePredefinedViews.TryGet(id, out var definition)
            ? definition.Icon
            : null;

    private RenderFragment ResourceActionControls(Resource resource) => builder =>
    {
        if (resource.ResourceActions.Count == 0)
        {
            return;
        }

        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "inline-actions");

        foreach (var action in resource.ResourceActions.Where(IsInlineAction))
        {
            builder.OpenComponent<FluentButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-icon-button");
            builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "Title", GetActionTitle(action));
            builder.AddAttribute(sequence++, "Disabled", !CanExecuteAction(action) || IsExecutingAction(action));
            builder.AddAttribute(sequence++, "OnClick",
                EventCallback.Factory.Create<MouseEventArgs>(this, () => ExecuteAction(action)));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
            {
                AddActionIconButtonContent(buttonBuilder, action, GetActionLabel(action));
            }));
            builder.CloseComponent();
        }

        var overflowActions = resource.ResourceActions
            .Where(action => !IsInlineAction(action))
            .ToArray();
        if (overflowActions.Length > 0)
        {
            builder.OpenComponent<FluentMenuButton>(sequence++);
            builder.AddAttribute(sequence++, "Class", "action-overflow-button");
            builder.AddAttribute(sequence++, "UseMenuService", true);
            builder.AddAttribute(sequence++, "ButtonAppearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "ButtonContent", (RenderFragment)(buttonBuilder =>
            {
                AddIcon(buttonBuilder, new Icons.Regular.Size20.MoreVertical());
            }));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(menuBuilder =>
            {
                var menuSequence = 0;
                foreach (var action in overflowActions)
                {
                    menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                    menuBuilder.AddAttribute(menuSequence++, "Disabled", !CanExecuteAction(action) || IsExecutingAction(action));
                    menuBuilder.AddAttribute(menuSequence++, "OnClick",
                        EventCallback.Factory.Create<MouseEventArgs>(this, () => ExecuteAction(action)));
                    menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                    {
                        itemBuilder.OpenElement(0, "span");
                        itemBuilder.AddAttribute(1, "class", "menu-action-content");
                        AddActionIcon(itemBuilder, action.EffectivePresentation.Icon, 2);
                        itemBuilder.OpenElement(5, "span");
                        itemBuilder.AddContent(6, IsExecutingAction(action) ? L["Working"] : action.DisplayName);
                        itemBuilder.CloseElement();
                        itemBuilder.CloseElement();
                    }));
                    menuBuilder.CloseComponent();
                }
            }));
            builder.CloseComponent();
        }

        builder.CloseElement();
    };

    private static bool IsInlineAction(ResourceAction action) =>
        action.EffectivePresentation.DisplayStyle == ResourceActionDisplayStyle.Inline;

    private bool CanExecuteAction(ResourceAction action) =>
        !IsReadOnly && OperationCapabilities.CanExecuteAction(action.Id);

    private string GetActionTitle(ResourceAction action)
    {
        if (IsReadOnly)
        {
            return $"{action.DisplayName} unavailable. Resource Manager is in read-only mode.";
        }

        var reason = OperationCapabilities.GetActionUnavailableReason(action.Id);
        if (!string.IsNullOrWhiteSpace(reason))
        {
            return $"{action.DisplayName} unavailable. {reason}";
        }

        return action.DisplayName;
    }

    private string GetActionLabel(ResourceAction action) =>
        IsExecutingAction(action) ? L["Working"].Value : action.DisplayName;

    private bool CanApplyResourceChanges() =>
        !IsReadOnly && OperationCapabilities.CanManage;

    private bool CanDeleteResource(Resource resource) =>
        !IsReadOnly &&
        resource.IsNormalResource &&
        resource.Source == ResourceSource.User &&
        resource.ManagementMode == ResourceManagementMode.UserManaged &&
        OperationCapabilities.CanDelete;

    private bool IsExecutingAction(ResourceAction action) =>
        ExecutingActionIds.Contains(action.Id);

    private string GetLifecycleStatusLabel(Resource resource) =>
        GetLifecycleProgressLabel(resource) ?? FormatResourceState(resource.State);

    private string FormatResourceState(ResourceState? state) =>
        state switch
        {
            ResourceState.Running => L["Running"].Value,
            ResourceState.Starting => L["Starting"].Value,
            ResourceState.Stopping => L["Stopping"].Value,
            ResourceState.Paused => L["Paused"].Value,
            ResourceState.Degraded => L["Degraded"].Value,
            ResourceState.Stopped => L["Stopped"].Value,
            _ => L["Unknown"].Value
        };

    private string? GetLifecycleProgressLabel(Resource resource)
    {
        var action = resource.ResourceActions.FirstOrDefault(IsExecutingAction);
        return action?.Kind switch
        {
            ResourceActionKind.Start => L["Starting"].Value,
            ResourceActionKind.Stop => L["Stopping"].Value,
            ResourceActionKind.Pause => L["Pausing"].Value,
            ResourceActionKind.Restart => L["Restarting"].Value,
            _ => null
        };
    }

    private async Task ExecuteAction(ResourceAction action)
    {
        if (Resource is null || !CanExecuteAction(action) || IsExecutingAction(action))
        {
            if (IsReadOnly)
            {
                ProcedureMessage = L["Resource Manager is in read-only mode."].Value;
                ProcedureSignals = [];
            }

            return;
        }

        if (action.RequiresConfirmation)
        {
            var confirmed = await JS.InvokeAsync<bool>(
                "confirm",
                action.Description ??
                L["Start {0} for {1}?", action.DisplayName, GetResourceLabel(Resource)].Value);
            if (!confirmed)
            {
                return;
            }
        }

        ExecutingActionIds.Add(action.Id);
        ProcedureMessage = null;
        ProcedureSignals = [];
        PendingRestart = null;
        try
        {
            var result = await ResourceManager.ExecuteResourceActionAsync(
                new ExecuteResourceActionCommand(
                    Resource.Id,
                    action.Id,
                    StartDependencies: ShouldStartDependencies(action),
                    IgnoreDependentWarning: true,
                    DependencyStartFailureBehavior: GetDependencyStartFailureBehavior()));
            ProcedureMessage = result.Message;
            ProcedureSignals = result.Signals;
            await ReloadResourceAsync();
            ResourceContentVersion++;
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ProcedureMessage = FormatResourceOperationFailure(exception, "run the resource operation");
            ProcedureSignals = [];
        }
        finally
        {
            ExecutingActionIds.Remove(action.Id);
        }
    }

    private void OpenLogs()
    {
        if (Resource is null || ResourceLogSources.Count == 0)
        {
            return;
        }

        var query = new Dictionary<string, string?>();

        if (ResourceLogSources.Count == 1)
        {
            query["logSourceId"] = ResourceLogSources[0].Id;
        }

        Navigation.NavigateTo(Microsoft.AspNetCore.WebUtilities.QueryHelpers.AddQueryString(
            ResourceManagerShellLinks.ResourceDetails(ShellRoutes, Resource.Id, ResourcePredefinedViewIds.Logs),
            query));
    }

    private string FormatResourceOperationFailure(Exception exception, string operation)
    {
        Logger.LogWarning(
            exception,
            "Resource operation failed for {ResourceId}: {Operation}",
            Resource?.Id ?? ResourceId ?? "unknown",
            operation);

        return exception switch
        {
            HttpRequestException => L["CloudShell could not reach the Control Plane while trying to {0}. Check connectivity and try again.", operation].Value,
            _ => L["CloudShell could not {0}. Check the resource state and try again.", operation].Value
        };
    }

    private string GetLogsActionLabel(int logCount) =>
        logCount == 1 ? L["Logs"].Value : L["Logs ({0})", logCount].Value;

    private static bool ShouldStartDependencies(ResourceAction action) =>
        action.Kind is ResourceActionKind.Start or ResourceActionKind.Restart;

    private DependencyStartFailureBehavior GetDependencyStartFailureBehavior() =>
        OrchestrationSettings.GetDependencyStartFailureSettings().Behavior;

    private static void AddActionIconButtonContent(
        RenderTreeBuilder builder,
        ResourceAction action,
        string label)
    {
        AddActionIcon(builder, action.EffectivePresentation.Icon);
        builder.OpenElement(10, "span");
        builder.AddAttribute(11, "class", "visually-hidden");
        builder.AddContent(12, label);
        builder.CloseElement();
    }

    private static void AddActionIcon(
        RenderTreeBuilder builder,
        ResourceActionIcon actionIcon,
        int sequence = 0) =>
        AddIcon(builder, GetActionIcon(actionIcon), sequence);

    private static void AddIcon(
        RenderTreeBuilder builder,
        Icon icon,
        int sequence = 0)
    {
        builder.OpenComponent<FluentIcon<Icon>>(sequence);
        builder.AddAttribute(sequence + 1, "Class", "action-icon");
        builder.AddAttribute(sequence + 2, "Value", icon);
        builder.CloseComponent();
    }

    private static Icon GetActionIcon(ResourceActionIcon actionIcon) => actionIcon switch
    {
        ResourceActionIcon.Start => new Icons.Regular.Size20.PlayCircle(),
        ResourceActionIcon.Stop => new Icons.Regular.Size20.RecordStop(),
        ResourceActionIcon.Pause => new Icons.Regular.Size20.PauseCircle(),
        ResourceActionIcon.Restart => new Icons.Regular.Size20.ArrowSync(),
        _ => new Icons.Regular.Size20.AppsListDetail()
    };

    public void Dispose()
    {
        ResourceManager.ResourcesChanged -= OnResourcesChanged;

        if (ConfigurationContext is not null)
        {
            ConfigurationContext.StateChanged -= HandleConfigurationStateChanged;
        }
    }

    private string GetResourceLabel(Resource resource) => DisplaySelection.GetResourceLabel(resource);

    private string GetResourceSubtitle(Resource resource) =>
        DisplaySelection.EnableDisplayNames
            ? L["{0} / {1}", resource.Kind, DisplaySelection.GetResourceName(resource)].Value
            : resource.Kind;

    private sealed record PendingResourceRestart(
        string ResourceId,
        string ResourceName,
        string Message);

    private sealed record ResourceViewSelectionIssue(
        string Title,
        string Message,
        string RecoveryLabel,
        string RecoveryHref);

}
