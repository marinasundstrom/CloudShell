@inject IResourceManager ResourceManager
@inject IResourceOrchestrationCatalog OrchestrationCatalog
@inject ICoreShellRouteService ShellRoutes
@inject IStringLocalizer<SharedResource> L
@using System.Globalization

@if (Volume is null)
{
    <EmptyState Title="Volume unavailable"
                Message="The volume resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <h3>Volume</h3>
        <dl class="detail-list">
            <dt>Provider</dt>
            <dd>@GetAttribute(ResourceAttributeNames.VolumeProvider, StorageProviderNames.LocalStorage)</dd>
            <dt>Storage medium</dt>
            <dd>@GetAttribute(ResourceAttributeNames.VolumeStorageMedium, "provider managed")</dd>
            @if (TryGetStorageResourceId(out var storageResourceId))
            {
                <dt>Storage resource</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceRoute(storageResourceId)">
                        @GetStorageResourceLabel(storageResourceId)
                    </a>
                </dd>
                <dt>Volume subpath</dt>
                <dd>@GetAttribute(ResourceAttributeNames.VolumeSubPath, "provider default")</dd>
            }
            <dt>Volume path</dt>
            <dd>@GetAttribute(ResourceAttributeNames.VolumeLocation, "provider managed")</dd>
            <dt>Access mode</dt>
            <dd>@ResourceVolumeDisplay.GetAccessModeLabel(GetAttribute(ResourceAttributeNames.VolumeAccessMode, VolumeAccessMode.ReadWriteOnce.ToString()), Localize)</dd>
            <dt>Persistent</dt>
            <dd>@GetAttribute(ResourceAttributeNames.VolumePersistent, "true")</dd>
            <dt>Max size</dt>
            <dd>@FormatMaxSize()</dd>
            <dt>Usage</dt>
            <dd><VolumeUsagePreview ResourceId="@Volume.Id" Compact="false" /></dd>
            <dt>Max size enforcement</dt>
            <dd>@GetAttribute(ResourceAttributeNames.VolumeMaxSizeEnforcement, "advisory")</dd>
            <dt>Delete status</dt>
            <dd>@(Consumers.Count == 0 ? "not in use" : "blocked while in use")</dd>
        </dl>
    </section>

    <section class="blade-section">
        <h3>Consumers</h3>
        @if (Consumers.Count == 0)
        {
            <p class="muted">No resources currently depend on this volume.</p>
        }
        else
        {
            <ProcedureMessage Compact="true">
                This volume cannot be deleted while another resource depends on it. Detach the volume from each consumer first.
            </ProcedureMessage>
            <div class="generated-list">
                @foreach (var consumer in Consumers)
                {
                    <ResourceListItem Resource="consumer.Resource">
                        <TitleContent>
                            <a class="resource-link" href="@BuildResourceRoute(consumer.Resource.Id)">
                                @ResourceDisplayLabels.GetQualifiedLabel(consumer.Resource)
                            </a>
                        </TitleContent>
                        <ChildContent>
                            @if (consumer.Mounts.Count == 0)
                            {
                                <span>@consumer.Resource.Kind</span>
                                <small>@consumer.Resource.EffectiveTypeId</small>
                            }
                            else
                            {
                                @foreach (var mount in consumer.Mounts)
                                {
                                    <span>@ResourceVolumeMountDisplay.GetMountSummary(mount, Localize)</span>
                                    <small>@GetConsumerMountMetadata(consumer.Resource)</small>
                                }
                            }
                        </ChildContent>
                    </ResourceListItem>
                }
            </div>
        }
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Volume { get; set; }
    private Resource? StorageResource { get; set; }
    private IReadOnlyList<VolumeConsumerView> Consumers { get; set; } = [];

    protected override async Task OnParametersSetAsync()
    {
        Volume = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        if (Volume is null)
        {
            StorageResource = null;
            Consumers = [];
            return;
        }

        StorageResource = TryGetStorageResourceId(out var storageResourceId)
            ? await ResourceManager.GetResourceAsync(storageResourceId)
            : null;
        var orchestrationSnapshot = await OrchestrationCatalog.GetSnapshotAsync();
        Consumers = (await ResourceManager.ListResourcesAsync())
            .Where(resource => !string.Equals(resource.Id, Volume.Id, StringComparison.OrdinalIgnoreCase))
            .Select(resource => new VolumeConsumerView(
                resource,
                GetMountsForVolume(resource, Volume.Id, orchestrationSnapshot)))
            .Where(consumer =>
                consumer.Mounts.Count > 0 ||
                consumer.Resource.DependsOn.Any(dependency =>
                    string.Equals(dependency, Volume.Id, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(consumer => ResourceDisplayLabels.GetQualifiedLabel(consumer.Resource), StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static IReadOnlyList<ResourceVolumeMount> GetMountsForVolume(
        Resource resource,
        string volumeId,
        ResourceOrchestrationCatalogSnapshot orchestrationSnapshot) =>
        orchestrationSnapshot.Workloads.TryGetValue(resource.Id, out var workload)
            ? workload.WorkloadVolumeMounts
                .Where(mount => string.Equals(
                    mount.NormalizedVolumeReference,
                    volumeId,
                    StringComparison.OrdinalIgnoreCase))
                .OrderBy(mount => mount.NormalizedTargetPath, StringComparer.OrdinalIgnoreCase)
                .ToArray()
            : [];

    private string GetConsumerMountMetadata(Resource consumer)
    {
        var parts = new List<string>
        {
            consumer.Kind,
            consumer.EffectiveTypeId
        };

        if (ResourceVolumeMountDisplay.GetMaterializationSummary(consumer, Localize) is { } materialization)
        {
            parts.Add($"Storage: {materialization}");
        }

        return string.Join(" - ", parts);
    }

    private string GetAttribute(string name, string fallback) =>
        Volume?.ResourceAttributes.TryGetValue(name, out var value) == true &&
        !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private string FormatMaxSize()
    {
        if (Volume?.ResourceAttributes.TryGetValue(ResourceAttributeNames.VolumeMaxSizeBytes, out var value) != true ||
            !long.TryParse(value, out var maxSizeBytes) ||
            maxSizeBytes <= 0)
        {
            return "unbounded";
        }

        return $"{FormatBytes(maxSizeBytes)} ({maxSizeBytes.ToString(CultureInfo.InvariantCulture)} bytes)";
    }

    private static string FormatBytes(double value)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var unitIndex = 0;
        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return $"{value.ToString(unitIndex == 0 ? "0" : "0.##", CultureInfo.InvariantCulture)} {units[unitIndex]}";
    }

    private string GetStorageResourceLabel(string storageResourceId) =>
        StorageResource is null
            ? ResourceDisplayLabels.GetName(storageResourceId)
            : ResourceDisplayLabels.GetQualifiedLabel(StorageResource);

    private bool TryGetStorageResourceId(out string storageResourceId)
    {
        storageResourceId = string.Empty;
        if (Volume?.ResourceAttributes.TryGetValue(ResourceAttributeNames.VolumeStorageResourceId, out var value) != true ||
            string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        storageResourceId = value;
        return true;
    }

    private string BuildResourceRoute(string resourceId) =>
        ResourceManagerShellLinks.ResourceDetails(ShellRoutes, resourceId);

    private string Localize(string value) => L[value].Value;

    private sealed record VolumeConsumerView(
        Resource Resource,
        IReadOnlyList<ResourceVolumeMount> Mounts);
}
