@page "/settings"
@page "/settings/{Section}"
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResource> L
@using CloudShell.UI.Composition

<PageTitle>@L["Settings"]</PageTitle>

<section class="page-heading compact">
    <div>
        <span class="eyebrow">@L["Platform"]</span>
        <h1>@L["Settings"]</h1>
        <p>@L["Configure CloudShell shell behavior and platform extension surfaces from one place."]</p>
    </div>
</section>

<CloudShellCompositionSectionTabbedLayout Page="@ShellCompositionIds.SettingsPage"
                                          Outlet="@ShellCompositionIds.SettingsMainOutlet"
                                          AriaLabel="@L["Settings sections"].Value"
                                          Group="Settings"
                                          RouteSegment="@Section"
                                          IconSelector="GetIcon">
    <SummaryContent Context="sections">
        <div class="selected-type-card">
            <span class="resource-kind-icon" aria-hidden="true">
                <FluentIcon Value="@(new Icons.Regular.Size20.SettingsCogMultiple())" />
            </span>
            <div>
                <strong>@L["CloudShell"]</strong>
                <p>@L["Common settings"]</p>
            </div>
        </div>
        <div class="selected-type-card">
            <span class="resource-kind-icon" aria-hidden="true">
                <FluentIcon Value="@(new Icons.Regular.Size20.AppsListDetail())" />
            </span>
            <div>
                <strong>@L["{0} section(s)", sections.Count]</strong>
                <p>@L["Composition-backed"]</p>
            </div>
        </div>
    </SummaryContent>
    <EmptyContent>
        <EmptyState Title="@L["No settings sections"].Value"
                    Message="@L["No settings sections are registered for this CloudShell host."].Value" />
    </EmptyContent>
    <HeaderContent Context="section">
        <div class="panel-header">
            <div>
                <h2>@L[section.Section.Title]</h2>
                <p>@L["Settings section"]</p>
            </div>
        </div>
    </HeaderContent>
</CloudShellCompositionSectionTabbedLayout>

@code {
    [Parameter]
    public string? Section { get; set; }

    private static string GetIcon(CompositionSectionProjection section) =>
        section.Section.Id == ShellCompositionIds.SettingsPlatformSection
            ? "extensions"
            : section.Section.Id == ResourceManagerCompositionIds.SettingsSection
                ? "resources"
                : "settings";
}
