@page "/settings"
@page "/settings/{Section}"
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResource> L
@using CoreShell.Blazor

<PageTitle>@L["Settings"]</PageTitle>

<PageHeading Eyebrow="@L["Platform"].Value"
             Title="@L["Settings"].Value"
             Description="@L["Configure CloudShell shell behavior and platform extension surfaces from one place."].Value" />

<CloudShellCoreShellSectionTabbedLayout Page="@ShellIds.SettingsPage"
                                        Outlet="@ShellIds.SettingsMainOutlet"
                                        AriaLabel="@L["Settings sections"].Value"
                                        Group="Settings"
                                        RouteSegment="@Section"
                                        IconSelector="GetIcon">
    <SummaryContent Context="sections">
        <ShellSummaryTile Title="@L["CloudShell"].Value"
                          Description="@L["Common settings"].Value">
            <Icon>
                <FluentIcon Value="@(new Icons.Regular.Size20.SettingsCogMultiple())" />
            </Icon>
        </ShellSummaryTile>
        <ShellSummaryTile Title="@L["{0} section(s)", sections.Count].Value"
                          Description="@L["CoreShell-backed"].Value">
            <Icon>
                <FluentIcon Value="@(new Icons.Regular.Size20.AppsListDetail())" />
            </Icon>
        </ShellSummaryTile>
    </SummaryContent>
    <EmptyContent>
        <EmptyState Title="@L["No settings sections"].Value"
                    Message="@L["No settings sections are registered for this CloudShell host."].Value" />
    </EmptyContent>
    <HeaderContent Context="section">
        <ShellPanelHeader Title="@L[section.Title].Value"
                          Description="@L["Settings section"].Value" />
    </HeaderContent>
</CloudShellCoreShellSectionTabbedLayout>

@code {
    [Parameter]
    public string? Section { get; set; }

    private static string GetIcon(CoreShellBlazorSection section) =>
        section.Section.Id == ShellIds.SettingsUsersSection
            ? "users"
            : section.Section.Id == ShellIds.SettingsExtensionsSection
                ? "extensions"
            : section.Section.Id == ResourceManagerShellIds.SettingsGeneralSection
                ? "resources"
            : section.Section.Id == ResourceManagerShellIds.SettingsOrchestrationSection
                ? "dependencies"
                : "settings";
}
