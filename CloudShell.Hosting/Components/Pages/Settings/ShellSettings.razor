@page "/settings"
@page "/settings/{Section}"
@rendermode InteractiveServer
@inject IStringLocalizer<SharedResource> L
@using CoreShell.Composition

<PageTitle>@L["Settings"]</PageTitle>

<PageHeading Eyebrow="@L["Platform"].Value"
             Title="@L["Settings"].Value"
             Description="@L["Configure CloudShell shell behavior and platform extension surfaces from one place."].Value" />

<CloudShellCompositionSectionTabbedLayout Page="@ShellCompositionIds.SettingsPage"
                                          Outlet="@ShellCompositionIds.SettingsMainOutlet"
                                          AriaLabel="@L["Settings sections"].Value"
                                          Group="Settings"
                                          RouteSegment="@Section"
                                          IconSelector="GetIcon">
    <SummaryContent Context="sections">
        <ShellSummaryTile Title="@L["CloudShell"].Value"
                          Description="@L["Common settings"].Value">
            <Icon>
                <FluentIcon Value="@(new Icons.Regular.Size20.SettingsCogMultiple())" />
            </Icon>
        </ShellSummaryTile>
        <ShellSummaryTile Title="@L["{0} section(s)", sections.Count].Value"
                          Description="@L["Composition-backed"].Value">
            <Icon>
                <FluentIcon Value="@(new Icons.Regular.Size20.AppsListDetail())" />
            </Icon>
        </ShellSummaryTile>
    </SummaryContent>
    <EmptyContent>
        <EmptyState Title="@L["No settings sections"].Value"
                    Message="@L["No settings sections are registered for this CloudShell host."].Value" />
    </EmptyContent>
    <HeaderContent Context="section">
        <ShellPanelHeader Title="@L[section.Section.Title].Value"
                          Description="@L["Settings section"].Value" />
    </HeaderContent>
</CloudShellCompositionSectionTabbedLayout>

@code {
    [Parameter]
    public string? Section { get; set; }

    private static string GetIcon(CompositionSectionProjection section) =>
        section.Section.Id == ShellCompositionIds.SettingsUsersSection
            ? "users"
            : section.Section.Id == ShellCompositionIds.SettingsExtensionsSection
                ? "extensions"
            : section.Section.Id == ResourceManagerCompositionIds.SettingsGeneralSection
                ? "resources"
            : section.Section.Id == ResourceManagerCompositionIds.SettingsOrchestrationSection
                ? "dependencies"
                : "settings";
}
