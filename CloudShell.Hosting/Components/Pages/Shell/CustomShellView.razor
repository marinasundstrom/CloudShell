@page "/{*ViewRoute:nonfile}"
@rendermode InteractiveServer
@inject ShellCatalog ShellCatalog
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable

@{
    var normalizedRoute = NormalizeRoute(ViewRoute);
    var view = ShellCatalog.CustomViews.FirstOrDefault(candidate =>
        string.Equals(candidate.Route, normalizedRoute, StringComparison.OrdinalIgnoreCase));
    var menuItems = view?.ViewMenuItems
        .OrderBy(item => item.Order)
        .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
        .ToArray() ?? [];
    var selectedItem = GetSelectedItem(menuItems);
}

@if (view is null)
{
    <PageTitle>Not found</PageTitle>
    <EmptyState Title="Page not found"
                Message="The requested shell view is not registered." />
}
else
{
    <PageTitle>@view.Title</PageTitle>

    <PageHeading Eyebrow="@view.Group"
                 Title="@view.Title"
                 Description="@view.Description" />

    <CloudShellTabbedLayout Items="@BuildItems(view.Route, menuItems)"
                            SelectedItemId="@selectedItem?.Id"
                            SelectedItemChanged="item => SelectMenuItem(view.Route, item.Id)"
                            AriaLabel="@($"{view.Title} views")">
        <SummaryContent>
            <ShellSummaryTile Title="@view.Title" Description="@view.Description">
                <Icon>
                    <FluentIcon Value="@ShellNavigationIcons.FromName(view.Icon)" />
                </Icon>
            </ShellSummaryTile>
        </SummaryContent>
        <EmptyContent>
            <EmptyState Title="No view selected"
                        Message="This shell view does not have any registered menu items." />
        </EmptyContent>
        <HeaderContent Context="item">
            <ShellPanelHeader Title="@item.Title"
                              Description="@item.Description" />
        </HeaderContent>
        <ChildContent Context="item">
            @if (selectedItem is not null)
            {
                <DynamicComponent Type="selectedItem.ComponentType" />
            }
        </ChildContent>
    </CloudShellTabbedLayout>
}

@code {
    [Parameter]
    public string? ViewRoute { get; set; }

    private string? SelectedMenuItemId { get; set; }

    protected override void OnInitialized()
    {
        SelectedMenuItemId = ReadRequestedMenuItemId();
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override void OnParametersSet()
    {
        SelectedMenuItemId = ReadRequestedMenuItemId();
    }

    private CustomShellViewMenuItemContribution? GetSelectedItem(
        IReadOnlyList<CustomShellViewMenuItemContribution> menuItems)
    {
        if (!string.IsNullOrWhiteSpace(SelectedMenuItemId))
        {
            var requested = menuItems.FirstOrDefault(item =>
                string.Equals(item.Id, SelectedMenuItemId, StringComparison.OrdinalIgnoreCase));
            if (requested is not null)
            {
                return requested;
            }
        }

        return menuItems.FirstOrDefault();
    }

    private void SelectMenuItem(string route, string menuItemId)
    {
        SelectedMenuItemId = menuItemId;
        Navigation.NavigateTo(
            $"{route}#{Uri.EscapeDataString(menuItemId)}",
            replace: true);
    }

    private static IReadOnlyList<CloudShellTabbedLayoutItem> BuildItems(
        string route,
        IReadOnlyList<CustomShellViewMenuItemContribution> menuItems) =>
        menuItems
            .Select(item => new CloudShellTabbedLayoutItem(
                item.Id,
                item.Title,
                item.Order,
                Description: item.Description,
                Href: $"{route}#{Uri.EscapeDataString(item.Id)}"))
            .ToArray();

    private static string NormalizeRoute(string? route) =>
        string.IsNullOrWhiteSpace(route) ? "/" : "/" + route.Trim('/');

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        var requestedMenuItemId = ReadRequestedMenuItemId(args.Location);
        if (string.Equals(SelectedMenuItemId, requestedMenuItemId, StringComparison.Ordinal))
        {
            return;
        }

        SelectedMenuItemId = requestedMenuItemId;
        _ = InvokeAsync(StateHasChanged);
    }

    private string? ReadRequestedMenuItemId(string? location = null)
    {
        var uri = Navigation.ToAbsoluteUri(location ?? Navigation.Uri);
        if (string.IsNullOrWhiteSpace(uri.Fragment))
        {
            return null;
        }

        var requested = Uri.UnescapeDataString(uri.Fragment.TrimStart('#')).Trim();
        return string.IsNullOrWhiteSpace(requested) ? null : requested;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
