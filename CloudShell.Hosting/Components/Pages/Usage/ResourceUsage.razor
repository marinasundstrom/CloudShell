@inject IStringLocalizer<SharedResource> L

<Usage ResourceId="@ResourceId"
       Inline="true"
       ShowHeading="false"
       ShowResourceFilter="false"
       ShowAllUsageAction="true"
       DashboardTitle="@L["Resource usage"].Value"
       DashboardDescription="@L["Recorded usage samples and forecast trends for this resource."].Value" />

@code {
    [Parameter]
    public string? ResourceId { get; set; }
}
