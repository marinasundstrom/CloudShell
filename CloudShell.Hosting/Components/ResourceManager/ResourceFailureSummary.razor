@using Microsoft.Extensions.Logging
@inject IResourceEventManager ResourceEvents
@inject IStringLocalizer<SharedResource> L
@inject ILogger<ResourceFailureSummary> Logger

@if (Resource is not null && Failure is not null)
{
    <div class="@CssClass" role="alert" aria-live="polite">
        <ResourceFailureIndicator Signal="Failure" Class="resource-failure-summary-icon" />
        <div>
            <strong>@ResourceFailureSignalDisplay.GetTitle(Failure, L)</strong>
            <span>@ResourceFailureSignalDisplay.GetMessage(Failure, L)</span>
            <FluentAnchor Href="@BuildActivityRoute(Resource.Id)">
                @L["View activity"]
            </FluentAnchor>
        </div>
    </div>
}

@code {
    private const int MaxEvents = 50;

    [Parameter]
    public Resource? Resource { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private ResourceFailureSignal? Failure { get; set; }

    private string CssClass => string.IsNullOrWhiteSpace(Class)
        ? "resource-failure-summary"
        : $"resource-failure-summary {Class}";

    protected override async Task OnParametersSetAsync()
    {
        if (Resource is null)
        {
            Failure = null;
            return;
        }

        try
        {
            var events = await ResourceEvents.ListResourceEventsAsync(
                new ResourceEventQuery(
                    ResourceId: Resource.Id,
                    MaxEvents: MaxEvents));

            Failure = ResourceFailureSignalResolver.GetActiveFailure(events);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Failed to load resource activity for failure summary on resource {ResourceId}.",
                Resource.Id);
            Failure = null;
        }
    }

    private static string BuildActivityRoute(string resourceId) =>
        ResourceManagerRoutes.ResourceDetails(resourceId, ResourcePredefinedViewIds.Activity);
}
