@using Microsoft.Extensions.Logging
@inject IResourceEventManager ResourceEvents
@inject IStringLocalizer<SharedResource> L
@inject ILogger<ResourceFailureSummary> Logger
@inject CoreShell.Composition.CompositionRegistry Composition

@if (Resource is not null && Failure is not null)
{
    <ResourceCallout Severity="Failure.Severity"
                     Title="@ResourceFailureSignalDisplay.GetTitle(Failure, L)"
                     Class="@CalloutClass"
                     Role="alert">
        <span>@ResourceFailureSignalDisplay.GetMessage(Failure, L)</span>
        <FluentAnchor Href="@BuildActivityRoute(Resource.Id)">
            @L["View activity"]
        </FluentAnchor>
    </ResourceCallout>
}

@code {
    private const int MaxEvents = 50;

    [Parameter]
    public Resource? Resource { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private ResourceFailureSignal? Failure { get; set; }

    private string CalloutClass => string.IsNullOrWhiteSpace(Class)
        ? "resource-failure-summary"
        : $"resource-failure-summary {Class}";

    protected override async Task OnParametersSetAsync()
    {
        if (Resource is null)
        {
            Failure = null;
            return;
        }

        try
        {
            var events = await ResourceEvents.ListResourceEventsAsync(
                new ResourceEventQuery(
                    ResourceId: Resource.Id,
                    MaxEvents: MaxEvents));

            Failure = ResourceFailureSignalResolver.GetActiveFailure(Resource, events);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Failed to load resource activity for failure summary on resource {ResourceId}.",
                Resource.Id);
            Failure = null;
        }
    }

    private string BuildActivityRoute(string resourceId) =>
        ResourceManagerCompositionLinks.ResourceDetails(Composition, resourceId, ResourcePredefinedViewIds.Activity);
}
