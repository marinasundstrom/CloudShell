@using System.Globalization
@inject IStringLocalizer<SharedResource> L

<div class="@CssClass">
    <div class="health-history-header">
        <div>
            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <strong>@Title</strong>
            }
            <span>@GetSnapshotCountLabel()</span>
        </div>
        @if (OrderedSnapshots.Count > 0)
        {
            <div class="health-history-legend" aria-hidden="true">
                <span><i class="health-healthy"></i>@L["Healthy"]</span>
                <span><i class="health-unhealthy"></i>@L["Unhealthy"]</span>
                <span><i class="health-unknown"></i>@L["Unknown"]</span>
            </div>
        }
    </div>

    @if (OrderedSnapshots.Count == 0)
    {
        <div class="health-history-empty">
            @L["No retained health polling history yet."]
        </div>
    }
    else
    {
        <div class="health-history-timelines">
            @foreach (var row in TimelineRows)
            {
                var degradationEvents = GetDegradationEvents(row);
                var latestDegradation = degradationEvents.LastOrDefault();
                <div class="@GetTimelineCardClass(degradationEvents)">
                    <div class="health-history-timeline-heading">
                        <strong>@row.Label</strong>
                        <span>@GetTimelineSummary(row, latestDegradation)</span>
                    </div>
                    <svg class="health-history-timeline"
                         role="img"
                         viewBox="@ViewBox"
                         preserveAspectRatio="none"
                         aria-label="@L["{0} health polling history", row.Label]">
                        <title>@L["{0} health polling history", row.Label]</title>
                        @foreach (var snapshot in OrderedSnapshots.Select((value, index) => new { value, index }))
                        {
                            var status = GetRowStatus(row, snapshot.value);
                            var title = BuildCellTitle(row, snapshot.value, status);
                            <g>
                                <title>@title</title>
                                <rect class="health-history-cell @GetHealthClass(status)"
                                      x="@Svg(GetCellX(snapshot.index))"
                                      y="@Svg(LaneTop)"
                                      width="@Svg(CellWidth)"
                                      height="@Svg(LaneHeight)"
                                      rx="3"
                                      ry="3" />
                            </g>
                        }
                        @foreach (var degradation in degradationEvents)
                        {
                            var x = GetCellCenterX(degradation.Index);
                            <g>
                                <title>@L["{0} degraded at {1}", row.Label, degradation.CheckedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.CurrentCulture)]</title>
                                <line class="health-history-degradation-line"
                                      x1="@Svg(x)"
                                      y1="@Svg(LaneTop - 5)"
                                      x2="@Svg(x)"
                                      y2="@Svg(LaneTop + LaneHeight + 5)" />
                                <circle class="health-history-degradation-point"
                                        cx="@Svg(x)"
                                        cy="@Svg(LaneTop + LaneHeight / 2)"
                                        r="4" />
                                @if (degradation == latestDegradation)
                                {
                                    <g>
                                        <text class="health-history-degradation-label"
                                              text-anchor="@GetDegradationLabelAnchor(degradation.Index)"
                                              x="@Svg(GetDegradationLabelX(degradation.Index))"
                                              y="@Svg(LaneTop - 8)">
                                            @FormatTime(degradation.CheckedAt)
                                        </text>
                                    </g>
                                }
                            </g>
                        }
                        <line class="health-history-axis"
                              x1="0"
                              y1="@Svg(AxisY)"
                              x2="@Svg(ChartWidth)"
                              y2="@Svg(AxisY)" />
                        <text class="health-history-axis-label"
                              x="0"
                              y="@Svg(AxisLabelY)">
                            @FormatTime(OrderedSnapshots[0].CheckedAt)
                        </text>
                        <text class="health-history-axis-label"
                              text-anchor="end"
                              x="@Svg(ChartWidth)"
                              y="@Svg(AxisLabelY)">
                            @FormatTime(OrderedSnapshots[^1].CheckedAt)
                        </text>
                    </svg>
                </div>
            }
        </div>
    }
</div>

@code {
    private const double ChartWidth = 900;
    private const double LaneTop = 18;
    private const double LaneHeight = 14;
    private const double AxisY = 42;
    private const double AxisLabelY = 58;
    private const double ChartHeight = 64;

    [Parameter]
    public IReadOnlyList<ResourceHealthSummary> Snapshots { get; set; } = [];

    [Parameter]
    public IReadOnlyList<ResourceHealthCheck> Checks { get; set; } = [];

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public int MaxSnapshots { get; set; } = 20;

    [Parameter]
    public bool Compact { get; set; }

    private IReadOnlyList<ResourceHealthSummary> OrderedSnapshots =>
        Snapshots
            .OrderByDescending(snapshot => snapshot.CheckedAt)
            .Take(Math.Clamp(MaxSnapshots, 1, 100))
            .OrderBy(snapshot => snapshot.CheckedAt)
            .ToArray();

    private IReadOnlyList<ResourceHealthCheck> ConfiguredChecks =>
        Checks.Count > 0
            ? Checks
            : OrderedSnapshots
                .SelectMany(snapshot => snapshot.Checks.Select(result => result.Check))
                .Distinct()
                .ToArray();

    private IReadOnlyList<HealthHistoryRow> TimelineRows =>
        ConfiguredChecks.Count > 0
            ? ConfiguredChecks.Select(check => new HealthHistoryRow(check.Name, check)).ToArray()
            : [new HealthHistoryRow(L["Resource"].Value, null)];

    private string CssClass => Compact
        ? "health-history-chart compact"
        : "health-history-chart";

    private double PlotWidth => ChartWidth;

    private double CellStep => PlotWidth / Math.Max(1, OrderedSnapshots.Count);

    private double CellWidth => Math.Max(5, CellStep - 2);

    private string ViewBox =>
        FormattableString.Invariant($"0 0 {ChartWidth} {ChartHeight}");

    private string GetSnapshotCountLabel() =>
        OrderedSnapshots.Count == 0
            ? L["No history"].Value
            : L["{0} recent polling result(s)", OrderedSnapshots.Count].Value;

    private double GetCellX(int snapshotIndex) =>
        snapshotIndex * CellStep;

    private double GetCellCenterX(int snapshotIndex) =>
        GetCellX(snapshotIndex) + (CellWidth / 2);

    private double GetDegradationLabelX(int snapshotIndex)
    {
        var x = GetCellCenterX(snapshotIndex);
        if (snapshotIndex == 0)
        {
            return x + 4;
        }

        return snapshotIndex == OrderedSnapshots.Count - 1
            ? x - 4
            : x;
    }

    private string GetDegradationLabelAnchor(int snapshotIndex) =>
        snapshotIndex == 0
            ? "start"
            : snapshotIndex == OrderedSnapshots.Count - 1
                ? "end"
                : "middle";

    private IReadOnlyList<HealthDegradationMarker> GetDegradationEvents(HealthHistoryRow row) =>
        OrderedSnapshots
            .Select((snapshot, snapshotIndex) => new
            {
                Snapshot = snapshot,
                SnapshotIndex = snapshotIndex,
                Status = GetRowStatus(row, snapshot)
            })
            .Where(item =>
                item.Status == ResourceHealthStatus.Unhealthy &&
                (item.SnapshotIndex == 0 ||
                 GetRowStatus(row, OrderedSnapshots[item.SnapshotIndex - 1]) != ResourceHealthStatus.Unhealthy))
            .Select(item => new HealthDegradationMarker(item.SnapshotIndex, item.Snapshot.CheckedAt))
            .ToArray();

    private string GetTimelineCardClass(IReadOnlyCollection<HealthDegradationMarker> degradationEvents) =>
        degradationEvents.Count > 0
            ? "health-history-timeline-card has-degradation"
            : "health-history-timeline-card";

    private string GetTimelineSummary(
        HealthHistoryRow row,
        HealthDegradationMarker? latestDegradation)
    {
        var latest = OrderedSnapshots.Count == 0
            ? null
            : GetRowStatus(row, OrderedSnapshots[^1]);
        var latestLabel = latest is null
            ? L["No result"].Value
            : GetHealthLabel(latest.Value);

        return latestDegradation is null
            ? L["Latest: {0}", latestLabel].Value
            : L["Latest: {0}; last degraded {1}", latestLabel, FormatTime(latestDegradation.CheckedAt)].Value;
    }

    private string BuildCellTitle(
        HealthHistoryRow row,
        ResourceHealthSummary snapshot,
        ResourceHealthStatus? status)
    {
        var checkedAt = snapshot.CheckedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.CurrentCulture);
        return status is null
            ? L["{0} at {1}: no result", row.Label, checkedAt].Value
            : L["{0} at {1}: {2}", row.Label, checkedAt, GetHealthLabel(status.Value)].Value;
    }

    private static ResourceHealthStatus? GetRowStatus(
        HealthHistoryRow row,
        ResourceHealthSummary snapshot) =>
        row.Check is null
            ? snapshot.Status
            : FindCheckResult(snapshot, row.Check)?.Status;

    private static string FormatTime(DateTimeOffset value) =>
        value.ToLocalTime().ToString("HH:mm", CultureInfo.CurrentCulture);

    private static string Svg(double value) =>
        value.ToString("0.###", CultureInfo.InvariantCulture);

    private static ResourceHealthCheckResult? FindCheckResult(
        ResourceHealthSummary snapshot,
        ResourceHealthCheck check) =>
        snapshot.Checks.FirstOrDefault(result =>
            ReferenceEquals(result.Check, check) ||
            result.Check == check ||
            string.Equals(result.Check.Name, check.Name, StringComparison.OrdinalIgnoreCase));

    private string GetHealthLabel(ResourceHealthStatus status) =>
        status switch
        {
            ResourceHealthStatus.Healthy => L["Healthy"].Value,
            ResourceHealthStatus.Unhealthy => L["Unhealthy"].Value,
            _ => L["Unknown"].Value
        };

    private static string GetHealthClass(ResourceHealthStatus? status) =>
        status switch
        {
            ResourceHealthStatus.Healthy => "health-healthy",
            ResourceHealthStatus.Unhealthy => "health-unhealthy",
            ResourceHealthStatus.Unknown => "health-unknown",
            _ => "health-pending"
        };

    private sealed record HealthHistoryRow(
        string Label,
        ResourceHealthCheck? Check);

    private sealed record HealthDegradationMarker(
        int Index,
        DateTimeOffset CheckedAt);
}
