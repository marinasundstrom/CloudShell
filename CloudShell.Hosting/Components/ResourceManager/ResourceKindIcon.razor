@inject ShellCatalog ShellCatalog

<ResourceIcon Resource="Resource"
              IconName="@ResolveIconName()"
              Class="@CssClass"
              Title="@TitleText" />

@code {
    [Parameter, EditorRequired]
    public Resource Resource { get; set; } = default!;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Title { get; set; }

    private string CssClass =>
        $"{(string.IsNullOrWhiteSpace(Class) ? "resource-kind-icon" : Class)} resource-class-{Resource.ResourceClass.ToString().ToLowerInvariant()}";

    private string TitleText =>
        string.IsNullOrWhiteSpace(Title) ? Resource.Kind : Title;

    private string? ResolveIconName()
    {
        var resourceType = ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, Resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(resourceType?.Icon))
        {
            return resourceType.Icon;
        }

        return FirstNonEmpty(Resource.EffectiveTypeId, Resource.ResourceClass.ToString(), Resource.Kind);
    }

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
}
