@inject ShellCatalog ShellCatalog

<ResourceReferenceListItem Resource="Resource"
                           IconName="@ResolveIconName()"
                           Title="@Title"
                           TitleContent="@TitleContent"
                           Summary="@Summary"
                           SummaryContent="@SummaryContent"
                           Metadata="@Metadata"
                           SecondaryMetadata="@SecondaryMetadata"
                           MetadataContent="@MetadataContent"
                           ChildContent="@ChildContent"
                           Class="@Class" />

@code {
    [Parameter, EditorRequired]
    public Resource Resource { get; set; } = default!;

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public RenderFragment? TitleContent { get; set; }

    [Parameter]
    public string? Summary { get; set; }

    [Parameter]
    public RenderFragment? SummaryContent { get; set; }

    [Parameter]
    public string? Metadata { get; set; }

    [Parameter]
    public string? SecondaryMetadata { get; set; }

    [Parameter]
    public RenderFragment? MetadataContent { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private string? ResolveIconName()
    {
        var resourceType = ShellCatalog.ResourceTypes.FirstOrDefault(type =>
            string.Equals(type.Id, Resource.EffectiveTypeId, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(resourceType?.Icon))
        {
            return resourceType.Icon;
        }

        return Resource.EffectiveTypeId;
    }
}
