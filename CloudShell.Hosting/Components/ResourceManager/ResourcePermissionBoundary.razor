@namespace CloudShell.Hosting.Components.ResourceManager
@inject ICloudShellAuthorizationService Authorization
@inject IOptions<ResourceManagerUiOptions> ResourceManagerUiOptions

@if (IsAuthorized())
{
    @ChildContent
}
else if (NotAuthorized is not null)
{
    @NotAuthorized
}

@code {
    [Parameter]
    public Resource? Resource { get; set; }

    [Parameter]
    public string? ResourceGroupId { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, ResourceGroup>? ResourceGroupsByResourceId { get; set; }

    [Parameter]
    public string? Permission { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? Permissions { get; set; }

    [Parameter]
    public string? GlobalPermission { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? GlobalPermissions { get; set; }

    [Parameter]
    public bool RequireAll { get; set; } = true;

    [Parameter]
    public bool RequireWritableResourceManager { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? NotAuthorized { get; set; }

    private bool IsAuthorized()
    {
        if (ChildContent is null)
        {
            return false;
        }

        if (RequireWritableResourceManager && ResourceManagerUiOptions.Value.ReadOnly)
        {
            return false;
        }

        var resourcePermissions = GetResourcePermissions();
        var globalPermissions = GetGlobalPermissions();
        if (resourcePermissions.Count == 0 && globalPermissions.Count == 0)
        {
            return false;
        }

        if (resourcePermissions.Count > 0 && Resource is null)
        {
            return false;
        }

        var groupId = Resource is null
            ? ResourceGroupId
            : ResourceGroupId ??
                (ResourceGroupsByResourceId is null
                    ? null
                    : ResourceManagerUiAccess.GetResourceGroupId(ResourceGroupsByResourceId, Resource.Id));

        return RequireAll
            ? globalPermissions.All(Authorization.HasPermission) &&
                resourcePermissions.All(permission => CanAccessResource(Resource!, permission, groupId))
            : globalPermissions.Any(Authorization.HasPermission) ||
                resourcePermissions.Any(permission => CanAccessResource(Resource!, permission, groupId));
    }

    private bool CanAccessResource(Resource resource, string permission, string? resourceGroupId) =>
        string.Equals(permission, CloudShellPermissions.Resources.Read, StringComparison.OrdinalIgnoreCase)
            ? ResourceManagerUiAccess.CanReadResource(Authorization, resource, resourceGroupId)
            : Authorization.CanAccessResource(resource.Id, resourceGroupId, permission);

    private IReadOnlyList<string> GetResourcePermissions() =>
        GetPermissions(Permissions, Permission);

    private IReadOnlyList<string> GetGlobalPermissions() =>
        GetPermissions(GlobalPermissions, GlobalPermission);

    private static IReadOnlyList<string> GetPermissions(
        IReadOnlyCollection<string>? permissions,
        string? permission)
    {
        var configuredPermissions = permissions?
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .ToArray();
        if (configuredPermissions is { Length: > 0 })
        {
            return configuredPermissions;
        }

        return string.IsNullOrWhiteSpace(permission)
            ? []
            : [permission];
    }
}
