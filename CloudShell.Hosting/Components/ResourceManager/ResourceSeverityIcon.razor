<span class="@CssClass" aria-hidden="true">
    <FluentIcon Value="@ResolveIcon()" />
</span>

@code {
    [Parameter]
    public ResourceSignalSeverity Severity { get; set; } = ResourceSignalSeverity.Info;

    [Parameter]
    public string? Class { get; set; }

    private string CssClass =>
        string.Join(
            ' ',
            new[]
            {
                "resource-severity-icon",
                Severity.ToString().ToLowerInvariant(),
                Class
            }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private Icon ResolveIcon() =>
        Severity switch
        {
            ResourceSignalSeverity.Success => new Icons.Regular.Size20.CheckmarkCircle(),
            ResourceSignalSeverity.Info => new Icons.Regular.Size20.InfoShield(),
            ResourceSignalSeverity.Error => new Icons.Regular.Size20.ErrorCircle(),
            _ => new Icons.Regular.Size20.Important()
        };
}
