@using Microsoft.AspNetCore.Components.Web

<label class="@CssClass" for="@Id">
    <span>@Label</span>
    <select id="@Id"
            class="@SelectClass"
            value="@(SelectedResourceId ?? string.Empty)"
            @onchange="SelectResource">
        @if (!string.IsNullOrWhiteSpace(AllOptionLabel))
        {
            <option value="">@AllOptionLabel</option>
        }
        @if (Options.Count > 0)
        {
            @foreach (var option in Options)
            {
                <option value="@option.ResourceId">@option.Name</option>
            }
        }
        else
        {
            @foreach (var resource in Resources)
            {
                <option value="@resource.Id">@GetResourceLabel(resource)</option>
            }
        }
    </select>
</label>

@code {
    [Parameter, EditorRequired]
    public string Id { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<Resource> Resources { get; set; } = [];

    [Parameter]
    public IReadOnlyList<ResourceSourceSelectOption> Options { get; set; } = [];

    [Parameter]
    public string? SelectedResourceId { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedResourceIdChanged { get; set; }

    [Parameter]
    public string? AllOptionLabel { get; set; }

    [Parameter]
    public Func<Resource, string>? ResourceLabel { get; set; }

    [Parameter]
    public string CssClass { get; set; } = "trace-source-filter";

    [Parameter]
    public string SelectClass { get; set; } = "trace-source-select";

    private Task SelectResource(ChangeEventArgs args)
    {
        var resourceId = args.Value?.ToString();
        return SelectedResourceIdChanged.InvokeAsync(
            string.IsNullOrWhiteSpace(resourceId) ? null : resourceId);
    }

    private string GetResourceLabel(Resource resource) =>
        ResourceLabel?.Invoke(resource) ?? resource.EffectiveDisplayName;
}
