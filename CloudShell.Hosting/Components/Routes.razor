@inject ShellCatalog ShellCatalog

<Router AppAssembly="typeof(Routes).Assembly" AdditionalAssemblies="ShellCatalog.ViewAssemblies" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        @if (routeData.PageType.Assembly == typeof(Routes).Assembly ||
            ShellCatalog.IsActiveRouteComponent(routeData.PageType))
        {
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        }
        else
        {
            <LayoutView Layout="typeof(Layout.MainLayout)">
                <EmptyState Title="Extension disabled"
                            Message="The extension that owns this page is not active." />
            </LayoutView>
        }
    </Found>
</Router>
