@using Microsoft.JSInterop
@using System.Globalization
@inject ApplicationResourceService ApplicationProvider
@inject IResourceManager ResourceManager
@inject IJSRuntime JS

@if (Resource is null)
{
    <EmptyState Title="Container app deployment is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <h3>Runtime projection</h3>
        <dl class="detail-list">
            <dt>Image</dt>
            <dd>@GetCurrentContainerImage(Resource)</dd>
            <dt>App revision</dt>
            <dd>@GetDeploymentRevision(Resource)</dd>
            <dt>Status</dt>
            <dd>@GetDeploymentStatusLabel(Resource)</dd>
            <dt>Orchestrator service</dt>
            <dd>@GetDeploymentService(Resource)</dd>
            <dt>Scaling</dt>
            <dd>@GetScalingMode(Resource)</dd>
            <dt>Requested replicas</dt>
            <dd>@GetDeploymentRequestedReplicas(Resource)</dd>
            <dt>Materialized replicas</dt>
            <dd>@GetDeploymentMaterializedReplicas(Resource)</dd>
        </dl>

        @if (GetDeploymentStatusDescription(Resource) is { Length: > 0 } statusDescription)
        {
            <ProcedureMessage Message="@statusDescription"
                              Compact="true" />
        }
    </section>

    <section class="blade-section">
        <h3>Create deployment</h3>
        <div class="generated-deploy-form">
            <label for="application-deploy-image">New image</label>
            <FluentTextField Id="application-deploy-image"
                             @bind-Value="DeploymentImage"
                             Immediate="true"
                             Placeholder="example/api:20260608"
                             Disabled="@(!CanEditDeployment)" />
            @if (Resource is not null && IsReplicaModeEnabled(Resource))
            {
                <label for="application-deploy-replicas">Requested replicas</label>
                <FluentNumberField TValue="int"
                                   Id="application-deploy-replicas"
                                   Min="1"
                                   Disabled="@(!CanEditDeployment)"
                                   @bind-Value="DeploymentRequestedReplicas" />
            }

            @if (GetDeploymentReadiness() is { } readiness)
            {
                <div class="generated-list">
                    <div class="@readiness.CssClass">
                        <strong>@readiness.Status</strong>
                        <span>@readiness.Message</span>
                        <small>@readiness.Context</small>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(ImageDeploymentMessage))
            {
                <ProcedureMessage Message="@ImageDeploymentMessage"
                                  Compact="true" />
            }

            <FormPrimaryAction Text="@(IsDeploying ? "Deploying" : "Deploy")"
                               Disabled="@(!CanSubmitImageDeployment)"
                               OnClick="DeployImage" />
        </div>
    </section>

    @if (Deployments.Count > 0)
    {
        <section class="blade-section">
            <h3>Container app deployments</h3>
            <div class="generated-list">
                @foreach (var deployment in Deployments)
                {
                    <div class="generated-diagnostic-info">
                        <strong>@deployment.Id</strong>
                        <span>@deployment.Image</span>
                        <small>
                            @FormatDeploymentMetadata(deployment)
                        </small>
                    </div>
                }
            </div>
        </section>
    }

    @if (Application?.ContainerRevisions.Count > 0)
    {
        <section class="blade-section">
            <h3>Container app revisions</h3>
            <div class="generated-list">
                @foreach (var revision in Application.ContainerRevisions
                    .OrderByDescending(revision => revision.CreatedAt))
                {
                    <div class="generated-diagnostic-info">
                        <strong>@revision.Id</strong>
                        <span>@revision.Image</span>
                        <small>
                            @FormatRevisionMetadata(revision)
                        </small>
                    </div>
                }
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private ApplicationResourceDefinition? Application { get; set; }
    private IReadOnlyList<ApplicationContainerDeployment> Deployments { get; set; } = [];
    private Resource? Resource { get; set; }
    private ResourceOperationCapabilities Capabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private string? CurrentDeploymentResourceId { get; set; }
    private string? DeploymentImage { get; set; }
    private int DeploymentRequestedReplicas { get; set; } = 1;
    private string? ImageDeploymentMessage { get; set; }
    private bool IsDeploying { get; set; }

    private bool CanEditDeployment =>
        Resource is not null &&
        Capabilities.CanManage &&
        !IsDeploying;

    private bool CanSubmitImageDeployment =>
        CanEditDeployment &&
        !string.IsNullOrWhiteSpace(DeploymentImage) &&
        GetDeploymentReadiness()?.BlocksSubmit != true;

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        Application = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ApplicationProvider.GetApplication(ResourceId);
        Deployments = string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : ApplicationProvider.GetContainerDeployments(ResourceId);
        Capabilities = Resource is null
            ? ResourceOperationCapabilities.None(ResourceId ?? string.Empty)
            : await ResourceManager.GetResourceOperationCapabilitiesAsync(Resource);
        InitializeDeploymentImage();
    }

    private void InitializeDeploymentImage()
    {
        if (Resource is null)
        {
            CurrentDeploymentResourceId = null;
            DeploymentImage = null;
            DeploymentRequestedReplicas = 1;
            ImageDeploymentMessage = null;
            return;
        }

        if (string.Equals(CurrentDeploymentResourceId, Resource.Id, StringComparison.OrdinalIgnoreCase) &&
            !string.IsNullOrWhiteSpace(DeploymentImage))
        {
            return;
        }

        CurrentDeploymentResourceId = Resource.Id;
        DeploymentImage = GetCurrentContainerImage(Resource);
        DeploymentRequestedReplicas = GetDeploymentRequestedReplicasValue(Resource);
        ImageDeploymentMessage = null;
    }

    private async Task DeployImage()
    {
        if (!CanSubmitImageDeployment || Resource is null)
        {
            if (!Capabilities.CanManage)
            {
                ImageDeploymentMessage = "You do not have permission to deploy images for this resource.";
            }

            return;
        }

        var requestedImage = await ReadDeploymentImageAsync();
        if (string.IsNullOrWhiteSpace(requestedImage))
        {
            return;
        }

        DeploymentImage = requestedImage;
        IsDeploying = true;
        ImageDeploymentMessage = null;
        try
        {
            var result = await ResourceManager.UpdateResourceImageAsync(
                Resource,
                requestedImage,
                restartIfRunning: false,
                triggeredBy: "Resource Manager",
                requestedReplicas: IsReplicaModeEnabled(Resource) ? DeploymentRequestedReplicas : null);
            ImageDeploymentMessage = result.Message;

            var updatedResource = await ResourceManager.GetResourceAsync(Resource.Id);
            if (updatedResource is not null)
            {
                Resource = updatedResource;
                Application = ApplicationProvider.GetApplication(updatedResource.Id);
                Deployments = ApplicationProvider.GetContainerDeployments(updatedResource.Id);
                DeploymentImage = GetCurrentContainerImage(Resource);
                DeploymentRequestedReplicas = GetDeploymentRequestedReplicasValue(Resource);
                CurrentDeploymentResourceId = Resource.Id;
            }
        }
        catch (Exception exception)
        {
            ImageDeploymentMessage = exception.Message;
        }
        finally
        {
            IsDeploying = false;
        }
    }

    private static string GetCurrentContainerImage(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerImage) ?? string.Empty;

    private static string FormatRevisionMetadata(ApplicationContainerRevision revision)
    {
        var parts = new List<string>
        {
            $"Requested replicas: {revision.RequestedReplicas.ToString(CultureInfo.InvariantCulture)}",
            $"Change: {revision.ChangeKind}",
            $"Created: {revision.CreatedAt.LocalDateTime:g}"
        };
        if (!string.IsNullOrWhiteSpace(revision.SourceRevisionId))
        {
            parts.Add($"From: {revision.SourceRevisionId}");
        }
        if (!string.IsNullOrWhiteSpace(revision.TriggeredBy))
        {
            parts.Add($"By: {revision.TriggeredBy}");
        }

        return string.Join(" | ", parts);
    }

    private static string FormatDeploymentMetadata(ApplicationContainerDeployment deployment)
    {
        var parts = new List<string>
        {
            $"Revision: {deployment.RevisionId}",
            $"Status: {deployment.Status}",
            $"Requested replicas: {deployment.RequestedReplicas.ToString(CultureInfo.InvariantCulture)}",
            $"Change: {deployment.ChangeKind}",
            $"Created: {deployment.CreatedAt.LocalDateTime:g}"
        };
        if (!string.IsNullOrWhiteSpace(deployment.SourceRevisionId))
        {
            parts.Add($"From: {deployment.SourceRevisionId}");
        }
        if (!string.IsNullOrWhiteSpace(deployment.OrchestratorDeploymentId))
        {
            parts.Add($"Orchestrator deployment: {deployment.OrchestratorDeploymentId}");
        }
        if (!string.IsNullOrWhiteSpace(deployment.TriggeredBy))
        {
            parts.Add($"By: {deployment.TriggeredBy}");
        }

        return string.Join(" | ", parts);
    }

    private static string GetDeploymentRevision(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentRevision) ??
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerRevision) ??
        "unrevisioned";

    private static string GetDeploymentService(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentServiceId) ?? "not projected";

    private static string GetScalingMode(Resource resource) =>
        IsReplicaModeEnabled(resource) ? "Replicated" : "Single instance";

    private static string GetDeploymentRequestedReplicas(Resource resource) =>
        IsReplicaModeEnabled(resource)
            ? GetDeploymentRequestedReplicasValue(resource).ToString(CultureInfo.InvariantCulture)
            : "not enabled";

    private static int GetDeploymentRequestedReplicasValue(Resource resource) =>
        TryGetReplicaCount(resource, ResourceAttributeNames.DeploymentDesiredReplicas) ??
        TryGetReplicaCount(resource, ResourceAttributeNames.ContainerReplicas) ??
        1;

    private static int? TryGetReplicaCount(Resource resource, string attributeName) =>
        resource.ResourceAttributes.TryGetValue(attributeName, out var value) &&
        int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var replicas)
            ? Math.Max(1, replicas)
            : null;

    private static string GetDeploymentMaterializedReplicas(Resource resource) =>
        IsReplicaModeEnabled(resource)
            ? resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentMaterializedReplicas) ??
                resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentProjectedReplicas) ??
                "0"
            : "not enabled";

    private static bool IsReplicaModeEnabled(Resource resource) =>
        string.Equals(
            resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerReplicasEnabled),
            "true",
            StringComparison.OrdinalIgnoreCase);

    private static string GetDeploymentStatusLabel(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus) switch
        {
            "active" => "Active",
            "applying" => "Applying",
            "failed" => "Failed",
            "deleted" => "Deleted",
            "pending" => "Pending",
            _ => "Not projected"
        };

    private static string GetDeploymentStatusDescription(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus) switch
        {
            "active" => string.Empty,
            "applying" => "CloudShell is applying this deployment to the selected container host.",
            "failed" => "The latest deployment projection failed. Check resource activity and logs for details.",
            "pending" => "The deployment is projected but not currently active. Start the app to materialize runtime replicas.",
            "deleted" => "This deployment has been deleted by the orchestrator.",
            _ => "No orchestrator deployment projection is available for this resource."
        };

    private DeploymentReadinessView? GetDeploymentReadiness()
    {
        if (Resource is null)
        {
            return null;
        }

        if (!Capabilities.CanManage)
        {
            return DeploymentReadinessView.Blocked(
                "Update readiness",
                "The current user cannot deploy images for this resource.",
                "Missing resource manage permission");
        }

        var requestedImage = DeploymentImage?.Trim();
        if (string.IsNullOrWhiteSpace(requestedImage))
        {
            return DeploymentReadinessView.Blocked(
                "Update readiness",
                "Enter a container image before deploying.",
                "Image update preflight");
        }

        var currentImage = GetCurrentContainerImage(Resource);
        var replicaChangeRequested =
            IsReplicaModeEnabled(Resource) &&
            DeploymentRequestedReplicas != GetDeploymentRequestedReplicasValue(Resource);
        if (string.Equals(currentImage, requestedImage, StringComparison.Ordinal) &&
            !replicaChangeRequested)
        {
            return DeploymentReadinessView.Blocked(
                "No deployment change",
                $"This resource already uses image '{currentImage}'.",
                "Container app deployment preflight");
        }

        if (IsReplicaModeEnabled(Resource) && DeploymentRequestedReplicas < 1)
        {
            return DeploymentReadinessView.Blocked(
                "Replica count unavailable",
                "Requested replicas must be greater than or equal to 1.",
                "Container app deployment preflight");
        }

        return DeploymentReadinessView.Ready(
            "Container app deployment readiness",
            "The container app deployment can be created and will produce a new app revision.",
            "Container app deployment preflight");
    }

    private async Task<string> ReadDeploymentImageAsync()
    {
        var fieldValue = await JS.InvokeAsync<string?>(
            "cloudShellForms.getValue",
            "application-deploy-image");
        return (string.IsNullOrWhiteSpace(fieldValue)
            ? DeploymentImage
            : fieldValue)?.Trim() ?? string.Empty;
    }

    private sealed record DeploymentReadinessView(
        string Status,
        string Message,
        string Context,
        bool BlocksSubmit,
        string CssClass)
    {
        public static DeploymentReadinessView Ready(
            string status,
            string message,
            string context) =>
            new(status, message, context, false, "generated-diagnostic-info");

        public static DeploymentReadinessView Blocked(
            string status,
            string message,
            string context) =>
            new(status, message, context, true, "generated-diagnostic-warning");
    }
}
