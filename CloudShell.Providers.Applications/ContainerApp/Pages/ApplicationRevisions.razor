@using System.Globalization
@inject ApplicationResourceService ApplicationProvider
@inject IResourceManager ResourceManager

@if (Resource is null)
{
    <EmptyState Title="Container app revisions are unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (Revisions.Count == 0)
{
    <EmptyState Title="No revisions recorded"
                Message="Revisions will appear after the app is deployed or materialized." />
}
else
{
    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Current revision</h3>
                <p>The active materialized state produced by the latest successful deployment.</p>
            </div>
            <span class="@GetRevisionStatusCssClass(CurrentRevision)">
                @GetRevisionStatus(CurrentRevision)
            </span>
        </div>

        @if (CurrentRevision is null)
        {
            <ProcedureMessage Message="No active revision is currently recorded for this app."
                              Compact="true" />
        }
        else
        {
            <div class="container-app-deployment-summary">
                <div class="container-app-deployment-primary">
                    <small>Image</small>
                    <strong>@CurrentRevision.Image</strong>
                    <span>@FormatRevisionCreated(CurrentRevision)</span>
                </div>
                <dl class="container-app-deployment-metrics">
                    <div>
                        <dt>Requested replicas</dt>
                        <dd>@CurrentRevision.RequestedReplicas.ToString(CultureInfo.InvariantCulture)</dd>
                    </div>
                    <div>
                        <dt>Change</dt>
                        <dd>@FormatChangeKind(CurrentRevision.ChangeKind)</dd>
                    </div>
                    <div>
                        <dt>Revision</dt>
                        <dd>@Shorten(CurrentRevision.Id)</dd>
                    </div>
                </dl>
            </div>
        }
    </section>

    <section class="blade-section">
        <div class="blade-section-header">
            <div>
                <h3>Revision history</h3>
                <p>Current and previous materialized app states.</p>
            </div>
        </div>
        <div class="generated-list">
            @foreach (var revision in Revisions)
            {
                <div class="@GetRevisionCssClass(revision)">
                    <FluentIcon Value="@GetSeverityIcon(GetRevisionSeverity(revision))" />
                    <div class="generated-diagnostic-content">
                        <strong>@revision.Image</strong>
                        <span>@FormatRevisionHeadline(revision)</span>
                        <small>@FormatRevisionMetadata(revision)</small>
                    </div>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private IReadOnlyList<ApplicationContainerRevisionHistoryEntry> Revisions { get; set; } = [];

    private ApplicationContainerRevisionHistoryEntry? CurrentRevision =>
        Revisions.FirstOrDefault(revision =>
            string.Equals(revision.Status, ApplicationContainerRevisionStatuses.Active, StringComparison.OrdinalIgnoreCase)) ??
        Revisions.FirstOrDefault(revision =>
            string.Equals(revision.Id, GetDeploymentRevision(Resource), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        Revisions = string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : ApplicationProvider.GetContainerRevisions(ResourceId);
    }

    private static string GetDeploymentRevision(Resource? resource) =>
        resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentRevision) ??
        resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerRevision) ??
        string.Empty;

    private static string FormatRevisionHeadline(ApplicationContainerRevisionHistoryEntry revision) =>
        string.Create(
            CultureInfo.CurrentCulture,
            $"{GetRevisionStatus(revision)} revision from {revision.CreatedAt.ToLocalTime():g}");

    private static string FormatRevisionMetadata(ApplicationContainerRevisionHistoryEntry revision)
    {
        var parts = new List<string>
        {
            $"Requested replicas: {revision.RequestedReplicas.ToString(CultureInfo.InvariantCulture)}",
            $"Change: {FormatChangeKind(revision.ChangeKind)}",
            $"Revision: {revision.Id}"
        };
        if (!string.IsNullOrWhiteSpace(revision.SourceRevisionId))
        {
            parts.Add($"From: {revision.SourceRevisionId}");
        }
        if (!string.IsNullOrWhiteSpace(revision.TriggeredBy))
        {
            parts.Add($"By: {revision.TriggeredBy}");
        }
        if (!string.IsNullOrWhiteSpace(revision.DeploymentId))
        {
            parts.Add($"Deployment: {revision.DeploymentId}");
        }

        return string.Join(" | ", parts);
    }

    private static string FormatRevisionCreated(ApplicationContainerRevisionHistoryEntry revision)
    {
        var actor = string.IsNullOrWhiteSpace(revision.TriggeredBy)
            ? "system"
            : revision.TriggeredBy;
        return string.Create(
            CultureInfo.CurrentCulture,
            $"Created {revision.CreatedAt.ToLocalTime():g} by {actor}.");
    }

    private static string FormatChangeKind(string changeKind) =>
        string.Equals(changeKind, ApplicationContainerRevisionChangeKinds.ImageDeployment, StringComparison.OrdinalIgnoreCase)
            ? "Image deployment"
            : changeKind;

    private static string GetRevisionStatus(ApplicationContainerRevisionHistoryEntry? revision) =>
        revision?.Status switch
        {
            ApplicationContainerRevisionStatuses.Active => "Active",
            ApplicationContainerRevisionStatuses.Superseded => "Previous",
            ApplicationContainerRevisionStatuses.Failed => "Failed",
            null => "Unavailable",
            _ => revision.Status
        };

    private static string GetRevisionCssClass(ApplicationContainerRevisionHistoryEntry revision) =>
        revision.Status switch
        {
            ApplicationContainerRevisionStatuses.Active => "generated-diagnostic success",
            ApplicationContainerRevisionStatuses.Failed => "generated-diagnostic error",
            _ => "generated-diagnostic info"
        };

    private static string GetRevisionStatusCssClass(ApplicationContainerRevisionHistoryEntry? revision) =>
        revision?.Status switch
        {
            ApplicationContainerRevisionStatuses.Active => "container-app-status-pill success",
            ApplicationContainerRevisionStatuses.Failed => "container-app-status-pill error",
            ApplicationContainerRevisionStatuses.Superseded => "container-app-status-pill info",
            _ => "container-app-status-pill"
        };

    private static ResourceSignalSeverity GetRevisionSeverity(ApplicationContainerRevisionHistoryEntry revision) =>
        revision.Status switch
        {
            ApplicationContainerRevisionStatuses.Active => ResourceSignalSeverity.Success,
            ApplicationContainerRevisionStatuses.Failed => ResourceSignalSeverity.Error,
            _ => ResourceSignalSeverity.Info
        };

    private static Icon GetSeverityIcon(ResourceSignalSeverity severity) =>
        severity switch
        {
            ResourceSignalSeverity.Success => new Icons.Regular.Size20.CheckmarkCircle(),
            ResourceSignalSeverity.Error => new Icons.Regular.Size20.ErrorCircle(),
            ResourceSignalSeverity.Warning => new Icons.Regular.Size20.Warning(),
            _ => new Icons.Regular.Size20.Info()
        };

    private static string Shorten(string value) =>
        value.Length <= 18
            ? value
            : string.Concat(value.AsSpan(0, 15), "...");
}
