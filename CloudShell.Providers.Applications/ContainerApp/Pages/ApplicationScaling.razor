@using System.Globalization
@inject ApplicationResourceService ApplicationProvider
@inject IResourceHealthManager HealthManager
@inject IResourceDeploymentManager Deployments
@inject IResourceManager ResourceActions
@inject IResourceManagerStore ResourceManager
@inject IResourceRegistrationStore Registrations

@if (Application is null)
{
    <EmptyState Title="Scaling is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else if (!ApplicationResourceTypes.IsContainerApp(Application.ResourceType))
{
    <EmptyState Title="Scale and replicas are not supported"
                Message="This resource type does not expose container app scale controls." />
}
else
{
    <section class="blade-section">
        <h3>Scale and replicas</h3>
        <dl class="detail-list">
            <dt>Mode</dt>
            <dd>@(EnableReplicas ? "Replicated" : "Single instance")</dd>
            <dt>Configured replicas</dt>
            <dd>@(EnableReplicas ? Replicas.ToString(CultureInfo.InvariantCulture) : "not enabled")</dd>
            <dt>Materialized replicas</dt>
            <dd>@(EnableReplicas ? MaterializedReplicas.Count.ToString(CultureInfo.InvariantCulture) : "not enabled")</dd>
        </dl>

        <FluentCheckbox Disabled="@IsReadOnly" @bind-Value="EnableReplicas">
            Enable replicas
        </FluentCheckbox>

        @if (EnableReplicas)
        {
            <label for="application-scaling-replicas">Replicas</label>
            <FluentNumberField TValue="int"
                               Id="application-scaling-replicas"
                               Min="1"
                               Disabled="@IsReadOnly"
                               @bind-Value="Replicas" />
            <GeneratedRowActions>
                <FluentButton Appearance="Appearance.Accent"
                              IconStart="@(new Icons.Regular.Size20.ArrowSyncCircle())"
                              Disabled="@(!CanUpdateReplicaCount)"
                              OnClick="UpdateReplicasAsync">
                    @(IsUpdatingReplicas ? "Updating replicas" : "Update replicas")
                </FluentButton>
            </GeneratedRowActions>

            @if (!string.IsNullOrWhiteSpace(ReplicaUpdateMessage))
            {
                <ProcedureMessage Compact="true"
                                  Severity="@ReplicaUpdateSeverity"
                                  Role="status">
                    @ReplicaUpdateMessage
                </ProcedureMessage>
            }

            @if (Application is not null &&
                ApplicationVolumeMountReplicaWarning.ShouldShow(EnableReplicas, Application.VolumeMounts, GetVolumeResources()))
            {
                <ProcedureMessage Compact="true">
                    @ApplicationVolumeMountReplicaWarning.Message
                </ProcedureMessage>
            }

            @if (HasInboundEndpoint)
            {
                <ProcedureMessage Compact="true">
                    Replicated container apps with inbound endpoints need ingress or a load balancer for one stable address. Apply scaling, then create a route for this app endpoint.
                    @if (!IsReadOnly)
                    {
                        <GeneratedRowActions>
                            <FluentAnchor Appearance="Appearance.Neutral"
                                          IconStart="@(new Icons.Regular.Size20.ArrowRouting())"
                                          Href="@BuildAddLoadBalancerRoute()">
                                Add load-balancer route
                            </FluentAnchor>
                        </GeneratedRowActions>
                    }
                </ProcedureMessage>
            }
        }
        else
        {
            <ProcedureMessage Compact="true">
                Single-instance container apps bind their own endpoint directly. Enable replicas when this app should scale out.
            </ProcedureMessage>
        }
    </section>

    @if (EnableReplicas)
    {
        <section class="blade-section">
            <h3>Replica set</h3>
            @if (ProjectedResource is null)
            {
                <EmptyState Title="Replicas are unavailable"
                            Message="The projected resource may have been removed or is no longer visible." />
            }
            else
            {
                <dl class="detail-list">
                    <dt>Deployment</dt>
                    <dd>@GetAttribute(ProjectedResource, ResourceAttributeNames.DeploymentId, "not projected")</dd>
                    <dt>Service</dt>
                    <dd>@GetAttribute(ProjectedResource, ResourceAttributeNames.DeploymentServiceId, "not projected")</dd>
                    <dt>Revision</dt>
                    <dd>@GetAttribute(ProjectedResource, ResourceAttributeNames.DeploymentRevision, ProjectedResource.Version)</dd>
                    <dt>Image</dt>
                    <dd>@GetAttribute(ProjectedResource, ResourceAttributeNames.ContainerImage, "none")</dd>
                </dl>
            }
        </section>

        <section class="blade-section">
            <h3>Replicas</h3>
            @if (MaterializedReplicas.Count == 0)
            {
                <EmptyState Title="No replicas are materialized"
                            Message="The provider has not materialized runtime replica resources for this app." />
            }
            else
            {
                <ResourceTable>
                        <thead>
                            <tr>
                                <th>Replica</th>
                                <th>State</th>
                                <th>Health</th>
                                <th>Revision</th>
                                <th>Container</th>
                                <th>Materialization</th>
                                <th>Host</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var replica in MaterializedReplicas)
                            {
                                <tr>
                                    <td>
                                        <ResourceTableIdentity IconName="replica"
                                                               IconTitle="Replica"
                                                               Title="@replica.Name"
                                                               Summary="@FormatReplicaOrdinal(replica)" />
                                    </td>
                                    <td>
                                        <ResourceStateIndicator State="replica.State" Variant="pill" />
                                    </td>
                                    <td>
                                        @{
                                            var health = GetReplicaHealth(replica);
                                        }
                                        <div class="replica-health-assessment">
                                            <HealthPill Status="health?.Status" />
                                            <span>@GetHealthDetail(replica, health)</span>
                                            @if (health is not null && health.Checks.Count > 0)
                                            {
                                                <small>@GetHealthBreakdown(health)</small>
                                                <small>@FormatCheckedAt(health.CheckedAt)</small>
                                            }
                                        </div>
                                    </td>
                                    <td>@GetAttribute(replica, ResourceAttributeNames.RuntimeRevision, replica.Version)</td>
                                    <td>
                                        <strong>@GetAttribute(replica, ResourceAttributeNames.RuntimeContainerName, replica.Name)</strong>
                                    </td>
                                    <td>@GetMaterializationLabel(replica)</td>
                                    <td>@GetAttribute(replica, ResourceAttributeNames.ContainerHostId, "default host")</td>
                                </tr>
                            }
                        </tbody>
                </ResourceTable>
            }
        </section>

        <section class="blade-section">
            <h3>Deployment trace</h3>
            @if (DeploymentRecords.Count == 0)
            {
                <EmptyState Title="No deployment records"
                            Message="Replica scaling deployments will appear here after Resource Manager materializes runtime capacity." />
            }
            else
            {
                <ResourceTable>
                    <thead>
                        <tr>
                            <th>Deployment</th>
                            <th>Runtime revision</th>
                            <th>Environment revision</th>
                            <th>Replica group</th>
                            <th>Replicas</th>
                            <th>Status</th>
                            <th>Completed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in DeploymentRecords)
                        {
                            <tr>
                                <td>
                                    <strong class="deployment-trace-identifier">@record.DeploymentId</strong>
                                    <div class="table-subtext">@GetOptional(record.Cause)</div>
                                </td>
                                <td><span class="deployment-trace-identifier">@GetRuntimeRevisionLabel(record)</span></td>
                                <td>
                                    <span class="deployment-trace-identifier">@GetEnvironmentRevisionLabel(record)</span>
                                    <div class="table-subtext">@GetOptional(record.BasedOnEnvironmentRevisionId)</div>
                                </td>
                                <td><span class="deployment-trace-identifier">@GetReplicaGroupLabel(record)</span></td>
                                <td>@GetDeploymentReplicaSummary(record)</td>
                                <td>
                                    @record.Status
                                    <div class="table-subtext">@GetOptional(record.Error ?? record.Message)</div>
                                </td>
                                <td>@GetCompletionLabel(record)</td>
                            </tr>
                        }
                    </tbody>
                </ResourceTable>
            }
        </section>
    }
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [CascadingParameter(Name = ResourceManagerCascadingParameterNames.ReadOnly)]
    public bool IsReadOnly { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private ApplicationResourceDefinition? Application { get; set; }
    private Resource? ProjectedResource { get; set; }
    private IReadOnlyList<Resource> MaterializedReplicas { get; set; } = [];
    private IReadOnlyList<ResourceDeploymentRecord> DeploymentRecords { get; set; } = [];
    private IReadOnlyDictionary<string, ResourceHealthSummary> HealthResults { get; set; } =
        new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase);
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private bool EnableReplicas { get; set; }
    private int Replicas { get; set; } = 2;
    private bool IsUpdatingReplicas { get; set; }
    private string? ReplicaUpdateMessage { get; set; }
    private ResourceSignalSeverity? ReplicaUpdateSeverity { get; set; }
    private static readonly ResourceViewId ScalingViewId =
        new(ResourceTabGroupIds.Application, "scale-replicas");

    private bool HasInboundEndpoint =>
        Application?.EndpointPorts.Count > 0;

    private bool CanUpdateReplicaCount =>
        !IsReadOnly &&
        !IsUpdatingReplicas &&
        EnableReplicas &&
        Application is not null &&
        ApplicationResourceTypes.IsContainerApp(Application.ResourceType) &&
        Math.Max(1, Replicas) != Math.Max(1, Application.Replicas);

    private string BuildAddLoadBalancerRoute() =>
        Application is null
            ? ResourceManagerRoutes.Resources
            : ApplicationResourceExposureRoutes.BuildAddLoadBalancerRoute(
                Application,
                ScalingViewId);

    protected override async Task OnParametersSetAsync()
    {
        Application = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ApplicationProvider.GetApplication(ResourceId);
        ProjectedResource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ResourceManager.GetResource(ResourceId);
        MaterializedReplicas = ProjectedResource is null
            ? []
            : ResourceManager.GetChildren(ProjectedResource.Id)
                .Where(IsReplicaResource)
                .OrderBy(GetReplicaOrdinal)
                .ThenBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        HealthResults = MaterializedReplicas.Count == 0
            ? new Dictionary<string, ResourceHealthSummary>(StringComparer.OrdinalIgnoreCase)
            : await HealthManager.ListResourceHealthAsync();
        DeploymentRecords = string.IsNullOrWhiteSpace(ResourceId)
            ? []
            : await Deployments.ListResourceDeploymentsAsync(new ResourceDeploymentQuery(
                SourceResourceId: ResourceId,
                MaxRecords: 10));

        if (Application is not null)
        {
            EnableReplicas = Application.ReplicasEnabled;
            Replicas = EnableReplicas
                ? Math.Max(1, Application.Replicas)
                : Math.Max(2, Application.Replicas);
        }

        if (Configuration is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (IsReadOnly)
        {
            return ResourceManagerUiState.ReadOnlyResult();
        }

        if (Application is null)
        {
            return ResourceProcedureResult.Completed("Application resource is unavailable.");
        }

        if (!ApplicationResourceTypes.IsContainerApp(Application.ResourceType))
        {
            return ResourceProcedureResult.Completed("Scaling is not supported for this resource type.");
        }

        var updated = Application with
        {
            ReplicasEnabled = EnableReplicas,
            Replicas = EnableReplicas ? Math.Max(1, Replicas) : 1
        };

        if (Application.ReplicasEnabled == updated.ReplicasEnabled &&
            Application.Replicas == updated.Replicas)
        {
            return ResourceProcedureResult.Completed("Scaling configuration is already up to date.");
        }

        if (EnableReplicas)
        {
            return ResourceProcedureResult.Completed("Use Update replicas to apply replica count changes.");
        }

        var wasRunning = ApplicationProvider.IsRunning(Application.Id);
        await ApplicationProvider.UpdateApplicationAsync(
            updated,
            ResourceManager.GetGroupForResource(Application.Id)?.Id,
            Registrations,
            cancellationToken);

        return wasRunning
            ? ResourceProcedureResult.CompletedWithRestartRequired(
                "Scaling configuration updated.",
                Application.Id,
                "The container app is running. Restart it to apply scaling changes.")
            : ResourceProcedureResult.Completed("Scaling configuration updated.");
    }

    private async Task UpdateReplicasAsync()
    {
        if (IsUpdatingReplicas)
        {
            return;
        }

        if (IsReadOnly)
        {
            ReplicaUpdateSeverity = ResourceSignalSeverity.Warning;
            ReplicaUpdateMessage = "Resource Manager is in read-only mode.";
            return;
        }

        if (Application is null ||
            !ApplicationResourceTypes.IsContainerApp(Application.ResourceType))
        {
            ReplicaUpdateSeverity = ResourceSignalSeverity.Warning;
            ReplicaUpdateMessage = "Scaling is not supported for this resource.";
            return;
        }

        IsUpdatingReplicas = true;
        ReplicaUpdateMessage = null;
        ReplicaUpdateSeverity = null;
        try
        {
            var applicationId = Application.Id;
            var result = await ResourceActions.UpdateResourceReplicasAsync(
                applicationId,
                Math.Max(1, Replicas),
                restartIfRunning: false);

            ReplicaUpdateSeverity = result.RestartRequired
                ? ResourceSignalSeverity.Warning
                : ResourceSignalSeverity.Success;
            ReplicaUpdateMessage = result.RestartRequired &&
                !string.IsNullOrWhiteSpace(result.RestartMessage)
                    ? $"{result.Message} {result.RestartMessage}"
                    : result.Message;

            Application = ApplicationProvider.GetApplication(applicationId);
            ProjectedResource = ResourceManager.GetResource(applicationId);
            MaterializedReplicas = ProjectedResource is null
                ? []
                : ResourceManager.GetChildren(ProjectedResource.Id)
                    .Where(IsReplicaResource)
                    .OrderBy(GetReplicaOrdinal)
                    .ThenBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
                    .ToArray();
            DeploymentRecords = await Deployments.ListResourceDeploymentsAsync(new ResourceDeploymentQuery(
                SourceResourceId: applicationId,
                MaxRecords: 10));
        }
        catch (Exception exception) when (exception is not OperationCanceledException)
        {
            ReplicaUpdateSeverity = ResourceSignalSeverity.Error;
            ReplicaUpdateMessage = $"Replica update failed: {exception.Message}";
        }
        finally
        {
            IsUpdatingReplicas = false;
        }
    }

    private static bool IsReplicaResource(Resource resource) =>
        string.Equals(resource.EffectiveTypeId, "runtime.container", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(
            GetAttribute(resource, ResourceAttributeNames.RuntimeKind, string.Empty),
            "containerReplica",
            StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<Resource> GetVolumeResources() =>
        ResourceManager.GetResources()
            .Where(ApplicationVolumeResourceDisplay.IsMountableVolumeResource)
            .ToArray();

    private static int GetReplicaOrdinal(Resource resource) =>
        int.TryParse(
            GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, string.Empty),
            out var ordinal)
            ? ordinal
            : int.MaxValue;

    private static string FormatReplicaOrdinal(Resource resource)
    {
        var ordinal = GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaOrdinal, "?");
        var count = GetAttribute(resource, ResourceAttributeNames.RuntimeReplicaCount, "?");
        return $"{ordinal} of {count}";
    }

    private static string GetMaterializationLabel(Resource resource) =>
        GetAttribute(resource, ResourceAttributeNames.RuntimeMaterialization, "unknown") switch
        {
            "orchestratorMaterialized" => "materialized by orchestrator",
            "orchestratorProjection" => "projected by orchestrator",
            { Length: > 0 } value => value,
            _ => "unknown"
        };

    private static string GetAttribute(Resource resource, string key, string fallback) =>
        resource.ResourceAttributes.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value)
            ? value
            : fallback;

    private static string GetRuntimeRevisionLabel(ResourceDeploymentRecord record) =>
        GetOptional(record.ReplicaGroup?.RuntimeRevisionId ?? record.RuntimeRevisionId);

    private static string GetReplicaGroupLabel(ResourceDeploymentRecord record) =>
        GetOptional(record.ReplicaGroup?.Id);

    private static string GetDeploymentReplicaSummary(ResourceDeploymentRecord record) =>
        record.ReplicaGroup is null
            ? "not projected"
            : string.Create(
                CultureInfo.InvariantCulture,
                $"{record.ReplicaGroup.OccupiedReplicaSlots} of {record.ReplicaGroup.RequestedReplicaSlots} slots");

    private static string GetEnvironmentRevisionLabel(ResourceDeploymentRecord record) =>
        record.EnvironmentRevisionNumber is { } revisionNumber
            ? string.Create(CultureInfo.InvariantCulture, $"Revision {revisionNumber}")
            : GetOptional(record.EnvironmentRevisionId);

    private static string GetCompletionLabel(ResourceDeploymentRecord record)
    {
        var timestamp = record.CompletedAt ?? record.StartedAt;
        return timestamp.ToLocalTime().ToString("g", CultureInfo.CurrentCulture);
    }

    private static string GetOptional(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "not projected" : value;

    private ResourceHealthSummary? GetReplicaHealth(Resource replica) =>
        HealthResults.GetValueOrDefault(replica.Id);

    private static string GetHealthDetail(
        Resource replica,
        ResourceHealthSummary? health)
    {
        if (health is null)
        {
            return replica.ResourceHealthChecks.Count > 0
                ? "No health result"
                : "No health checks";
        }

        var detail = health.Checks
            .OrderBy(GetHealthRank)
            .FirstOrDefault();
        if (detail is not null)
        {
            return $"{detail.Check.Name}: {detail.Detail}";
        }

        return "No health checks";
    }

    private static int GetHealthRank(ResourceHealthCheckResult result) =>
        result.Status switch
        {
            ResourceHealthStatus.Unhealthy => 0,
            ResourceHealthStatus.Unknown => 1,
            ResourceHealthStatus.Healthy => 2,
            _ => 3
        };

    private static string GetHealthBreakdown(ResourceHealthSummary health)
    {
        var unhealthy = health.Checks.Count(check => check.Status == ResourceHealthStatus.Unhealthy);
        var unknown = health.Checks.Count(check => check.Status == ResourceHealthStatus.Unknown);
        var healthy = health.Checks.Count(check => check.Status == ResourceHealthStatus.Healthy);

        return string.Create(
            CultureInfo.InvariantCulture,
            $"{health.Checks.Count} check(s): {healthy} healthy, {unknown} unknown, {unhealthy} unhealthy");
    }

    private static string FormatCheckedAt(DateTimeOffset checkedAt) =>
        string.Create(
            CultureInfo.InvariantCulture,
            $"Checked {checkedAt.LocalDateTime:g}");
}
