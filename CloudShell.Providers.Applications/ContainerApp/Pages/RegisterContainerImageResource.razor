@using System.Text.Json
@inject ApplicationResourceService ApplicationProvider
@inject IResourceManager ResourceActions
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject IEnumerable<IContainerHostProvider> ContainerHostProviders
@inject IEnumerable<IResourceOrchestrationDescriptorProvider> DescriptorProviders
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        @if (!HasImplicitContainerHost())
        {
            <div class="procedure-confirmation">
                <strong>No default container host</strong>
                <span>Select a container host for this resource or register a default host with UseDocker().</span>
            </div>
        }

        <ResourceIdentityFields ResourceIdInputId="container-resource-id"
                                ResourceIdPlaceholder="redis"
                                @bind-ResourceId="ResourceId" />

        <label for="container-image">Image</label>
        <FluentTextField Id="container-image" @bind-Value="Image" Placeholder="redis:7.2" />

        <label for="container-registry">Registry</label>
        <FluentTextField Id="container-registry" @bind-Value="Registry" Placeholder="docker.io" />

        <label for="container-registry-username">Registry username</label>
        <FluentTextField Id="container-registry-username" @bind-Value="RegistryUsername" />

        <label for="container-registry-password-environment-variable">Registry password environment variable</label>
        <FluentTextField Id="container-registry-password-environment-variable" @bind-Value="RegistryPasswordEnvironmentVariable" />

        <label for="container-host">Container host</label>
        <FluentSelect TOption="string"
                      Id="container-host"
                      @bind-Value="SelectedHostId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default host</FluentOption>
            @foreach (var host in GetContainerHosts())
            {
                <FluentOption TOption="string" Value="@host.Id">@ApplicationResourceDisplay.GetContainerHostLabel(host)</FluentOption>
            }
        </FluentSelect>

        <EnumValueSelect TEnum="ApplicationLifetime"
                         Id="container-lifetime"
                         Label="Lifetime"
                         LabelSelector="@ApplicationResourceDisplay.GetLifetimeLabel"
                         @bind-Value="SelectedLifetime" />

        <FluentCheckbox @bind-Value="EnableReplicas">
            Enable replicas
        </FluentCheckbox>

        @if (EnableReplicas)
        {
            <label for="container-replicas">Replicas</label>
            <FluentNumberField TValue="int" Id="container-replicas" Min="1" @bind-Value="Replicas" />

            @if (ExposeEndpoint)
            {
                <ProcedureMessage Compact="true">
                    Replicated container apps with inbound endpoints may need ingress or a load balancer. The app keeps its stable endpoint while the provider connects that endpoint to the selected routing implementation.
                </ProcedureMessage>
            }
        }

        <FluentCheckbox @bind-Value="ExposeEndpoint">
            Expose local endpoint
        </FluentCheckbox>

        @if (ExposeEndpoint)
        {
            <label for="container-port-name">Endpoint name</label>
            <FluentTextField Id="container-port-name" @bind-Value="PortName" />

            <label for="container-target-port">Container port</label>
            <FluentNumberField TValue="int" Id="container-target-port" Min="1" @bind-Value="TargetPort" />

            <EndpointAssignmentEditor AssignmentId="container-port-assignment"
                                      PortId="container-local-port"
                                      PortLabel="Local port"
                                      ShowNetwork="true"
                                      NetworkCandidates="GetNetworkCandidates()"
                                      ShowManualAddress="true"
                                      @bind-Assignment="EndpointAssignment"
                                      @bind-NetworkResourceId="SelectedNetworkResourceId"
                                      @bind-ManualAddress="ManualEndpointHost"
                                      @bind-Port="LocalPort" />

            <label for="container-protocol">Protocol</label>
            <FluentSelect TOption="string"
                          Id="container-protocol"
                          @bind-Value="Protocol"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="tcp">TCP</FluentOption>
                <FluentOption TOption="string" Value="http">HTTP</FluentOption>
                <FluentOption TOption="string" Value="https">HTTPS</FluentOption>
                <FluentOption TOption="string" Value="udp">UDP</FluentOption>
            </FluentSelect>
        }

        <ResourceGroupSelect Id="container-group"
                             ResourceGroups="ResourceGroups.GetResourceGroups()"
                             @bind-Value="SelectedGroupId" />

        <ResourceSelectionSection Title="References"
                                  Resources="GetReferenceCandidates()"
                                  SelectedResourceIds="SelectedReferenceIds" />

        <FluentCheckbox @bind-Value="WaitForReferences">
            Start referenced resources first
        </FluentCheckbox>

        <ApplicationVolumeMountsEditor Mounts="VolumeMounts"
                                       VolumeCandidates="GetVolumeCandidates()"
                                       ReplicasEnabled="@EnableReplicas" />

        <FluentCheckbox @bind-Value="EnableObservability">
            Enable observability
        </FluentCheckbox>

        <ApplicationEnvironmentVariablesEditor Variables="EnvironmentVariables" />

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FluentCheckbox @bind-Value="StartAfterCreate">
            Start after create
        </FluentCheckbox>

        <FormPrimaryAction OnClick="Register" />
    </div>
</div>

@code {
    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string Image { get; set; } = string.Empty;
    private string Registry { get; set; } = ContainerRegistryDefaults.Default;
    private string? RegistryUsername { get; set; }
    private string? RegistryPasswordEnvironmentVariable { get; set; }
    private string SelectedHostId { get; set; } = string.Empty;
    private string SelectedLifetime { get; set; } = ApplicationLifetime.Detached.ToString();
    private bool EnableReplicas { get; set; }
    private int Replicas { get; set; } = 2;
    private bool ExposeEndpoint { get; set; }
    private string PortName { get; set; } = "http";
    private int TargetPort { get; set; } = 80;
    private int? LocalPort { get; set; }
    private ResourceEndpointAssignment EndpointAssignment { get; set; } = ResourceEndpointAssignment.Auto;
    private string? SelectedNetworkResourceId { get; set; }
    private string? ManualEndpointHost { get; set; }
    private string Protocol { get; set; } = "http";
    private string SelectedGroupId { get; set; } = string.Empty;
    private bool WaitForReferences { get; set; } = true;
    private bool EnableObservability { get; set; } = true;
    private bool StartAfterCreate { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private bool EndpointDefaultsInitialized { get; set; }
    private List<ApplicationEnvironmentVariableInput> EnvironmentVariables { get; } = [new()];
    private List<ApplicationVolumeMountInput> VolumeMounts { get; } = [new()];
    private HashSet<string> SelectedReferenceIds { get; } = new(StringComparer.OrdinalIgnoreCase);

    [CascadingParameter]
    public ResourceTypeContribution? ResourceType { get; set; }

    [CascadingParameter]
    public ResourceRegistrationNavigationContext? RegistrationNavigation { get; set; }

    private bool IsManualEndpointAssignment =>
        EndpointAssignment == ResourceEndpointAssignment.Manual;

    protected override void OnParametersSet()
    {
        if (EndpointDefaultsInitialized)
        {
            return;
        }

        var descriptor = GetEndpointDescriptor();
        PortName = descriptor.Name;
        TargetPort = descriptor.TargetPort;
        Protocol = descriptor.Protocol;
        EndpointAssignment = descriptor.DefaultAssignment == ResourceEndpointAssignment.ProviderDefault
            ? ResourceEndpointAssignment.Auto
            : descriptor.DefaultAssignment;
        EndpointDefaultsInitialized = true;
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(ResourceId) || string.IsNullOrWhiteSpace(Image))
        {
            ErrorMessage = "Name and image are required.";
            return;
        }

        if (!ValidateContainerHost())
        {
            return;
        }

        if (!ValidateRegistryCredentials())
        {
            return;
        }

        if (ExposeEndpoint &&
            (string.IsNullOrWhiteSpace(PortName) || TargetPort <= 0))
        {
            ErrorMessage = "Endpoint name and container port are required.";
            return;
        }

        if (ExposeEndpoint && IsManualEndpointAssignment && LocalPort is null)
        {
            ErrorMessage = "Manual endpoint assignment requires a local port.";
            return;
        }

        var normalizedResourceId = ResourceNameNormalizer.Normalize(ResourceId, "application");
        if (!string.IsNullOrWhiteSpace(normalizedResourceId) &&
            IsResourceIdInUse(normalizedResourceId))
        {
            ErrorMessage = $"Name '{ResourceId.Trim()}' resolves to existing resource '{normalizedResourceId}'.";
            return;
        }

        var displayName = ResourceDisplayNameDefaults.Resolve(ResourceId);
        var references = SelectedReferenceIds.ToArray();
        var volumeMounts = BuildVolumeMounts();
        var volumeReferences = volumeMounts
            .Where(mount => IsManagedVolumeReference(mount.VolumeReference))
            .Select(mount => mount.VolumeReference)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var definition = new ApplicationResourceDefinition(
            normalizedResourceId,
            displayName,
            executablePath: string.Empty,
            environmentVariables: BuildEnvironmentVariables(),
            lifetime: ParseLifetime(),
            dependsOn: WaitForReferences
                ? references.Concat(volumeReferences).Distinct(StringComparer.OrdinalIgnoreCase).ToArray()
                : volumeReferences,
            references: references,
            useServiceDiscovery: references.Length > 0,
            containerImage: Image.Trim(),
            containerRegistry: NormalizeRegistry(Registry),
            containerRegistryCredentials: BuildRegistryCredentials(),
            containerHostId: NormalizeNullable(SelectedHostId),
            replicas: EnableReplicas ? Math.Max(1, Replicas) : 1,
            replicasEnabled: EnableReplicas,
            endpointPorts: BuildEndpointPorts(),
            resourceType: ApplicationResourceTypes.ContainerApp,
            observability: EnableObservability ? ResourceObservability.Default : ResourceObservability.None,
            volumeMounts: volumeMounts);

        await ApplicationProvider.SetupApplicationAsync(definition, SelectedGroupId, Registrations);
        if (StartAfterCreate)
        {
            await ResourceActions.StartResourceAsync(definition.Id, startDependencies: true);
        }

        Navigation.NavigateTo(GetReturnUrl());
    }

    private string GetReturnUrl() =>
        RegistrationNavigation?.GetReturnUrlOrDefault() ??
        ResourceRegistrationNavigationContext.DefaultReturnUrl;

    private bool ValidateContainerHost()
    {
        var hosts = GetContainerHosts();
        if (!string.IsNullOrWhiteSpace(SelectedHostId))
        {
            if (hosts.Any(host => string.Equals(host.Id, SelectedHostId, StringComparison.OrdinalIgnoreCase)))
            {
                return true;
            }

            ErrorMessage = $"Container host '{SelectedHostId}' is not registered.";
            return false;
        }

        if (hosts.Any(host => host.IsDefault))
        {
            return true;
        }

        ErrorMessage = "A default container host is required unless this resource selects an explicit host.";
        return false;
    }

    private IReadOnlyList<ServicePort> BuildEndpointPorts() =>
        ExposeEndpoint
            ? [new ServicePort(
                PortName,
                TargetPort,
                IsManualEndpointAssignment ? LocalPort : null,
                Protocol,
                ResourceExposureScope.Local,
                EndpointAssignment,
                NormalizeNullable(SelectedNetworkResourceId),
                NormalizeNullable(ManualEndpointHost))]
            : [];

    private ResourceEndpointDescriptor GetEndpointDescriptor() =>
        ResourceType?.ResourceEndpointDescriptors.FirstOrDefault() ??
        ResourceEndpointDescriptor.Http(defaultAssignment: ResourceEndpointAssignment.Auto);

    private IReadOnlyList<EnvironmentVariableAssignment> BuildEnvironmentVariables() =>
        EnvironmentVariables
            .Where(variable => !string.IsNullOrWhiteSpace(variable.Name))
            .Select(variable => new EnvironmentVariableAssignment(variable.Name!.Trim(), variable.Value ?? string.Empty))
            .ToArray();

    private IReadOnlyList<ResourceVolumeMount> BuildVolumeMounts() =>
        VolumeMounts
            .Where(mount =>
                !string.IsNullOrWhiteSpace(mount.VolumeReference) &&
                !string.IsNullOrWhiteSpace(mount.TargetPath))
            .Select(mount => new ResourceVolumeMount(
                mount.VolumeReference!.Trim(),
                mount.TargetPath!.Trim(),
                mount.ReadOnly))
            .ToArray();

    private IReadOnlyList<Resource> GetReferenceCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => !string.Equals(resource.Id, GetCurrentResourceId(), StringComparison.OrdinalIgnoreCase))
            .Where(IsInSelectedGroup)
            .Where(resource => !string.Equals(resource.EffectiveTypeId, "cloudshell.network", StringComparison.OrdinalIgnoreCase))
            .Where(resource => !IsVolumeResource(resource))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetVolumeCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => !string.Equals(resource.Id, GetCurrentResourceId(), StringComparison.OrdinalIgnoreCase))
            .Where(IsInSelectedGroup)
            .Where(IsVolumeResource)
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetNetworkCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => resource.ResourceClass == ResourceClass.Network)
            .Where(IsInSelectedGroup)
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private static bool IsVolumeResource(Resource resource) =>
        ApplicationVolumeResourceDisplay.IsMountableVolumeResource(resource);

    private bool IsManagedVolumeReference(string volumeReference) =>
        GetVolumeCandidates().Any(volume =>
            string.Equals(volume.Id, volumeReference, StringComparison.OrdinalIgnoreCase));

    private bool IsInSelectedGroup(Resource resource)
    {
        var group = ResourceManager.GetGroupForResource(resource.Id);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private string? GetCurrentResourceId() =>
        string.IsNullOrWhiteSpace(ResourceId) ? null : ResourceId.Trim();

    private bool IsResourceIdInUse(string resourceId) =>
        ResourceManager.GetAvailableResources().Any(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase)) ||
        Registrations.GetRegistration(resourceId) is not null ||
        ApplicationProvider.GetApplication(resourceId) is not null;

    private bool HasImplicitContainerHost() =>
        GetContainerHosts().Any(host => host.IsDefault);

    private IReadOnlyList<ContainerHostDescriptor> GetContainerHosts()
    {
        var configuredHosts = ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id));
        var resourceHosts = ResourceManager
            .GetResources()
            .Select(TryReadContainerHost)
            .Where(host => host is not null)
            .Select(host => host!);

        return configuredHosts
            .Concat(resourceHosts)
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .OrderByDescending(host => host.IsDefault)
            .ThenBy(host => host.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private ContainerHostDescriptor? TryReadContainerHost(Resource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            if (!descriptor.ResourceType.Equals(ContainerHostResourceTypes.ContainerHost, StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            return descriptor.Configuration.Deserialize<ContainerHostDescriptor>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private ApplicationLifetime ParseLifetime() =>
        Enum.TryParse<ApplicationLifetime>(SelectedLifetime, out var lifetime)
            ? lifetime
            : ApplicationLifetime.Detached;

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private bool ValidateRegistryCredentials()
    {
        if (string.IsNullOrWhiteSpace(RegistryUsername) &&
            string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable))
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(RegistryUsername) &&
            !string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable))
        {
            return true;
        }

        ErrorMessage = "Registry username and password environment variable are required together.";
        return false;
    }

    private ContainerRegistryCredentials? BuildRegistryCredentials() =>
        string.IsNullOrWhiteSpace(RegistryUsername) ||
        string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable)
            ? null
            : new ContainerRegistryCredentials(
                RegistryUsername,
                RegistryPasswordEnvironmentVariable);

}
