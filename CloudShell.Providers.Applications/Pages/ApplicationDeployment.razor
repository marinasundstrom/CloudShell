@using Microsoft.JSInterop
@inject IResourceManager ResourceManager
@inject IJSRuntime JS

@if (Resource is null)
{
    <EmptyState Title="Deployment is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <section class="blade-section">
        <h3>Current deployment</h3>
        <dl class="detail-list">
            <dt>Image</dt>
            <dd>@GetCurrentContainerImage(Resource)</dd>
            <dt>Revision</dt>
            <dd>@GetDeploymentRevision(Resource)</dd>
            <dt>Status</dt>
            <dd>@GetDeploymentStatusLabel(Resource)</dd>
            <dt>Service</dt>
            <dd>@GetDeploymentService(Resource)</dd>
            <dt>Desired replicas</dt>
            <dd>@GetDeploymentDesiredReplicas(Resource)</dd>
            <dt>Projected replicas</dt>
            <dd>@GetDeploymentProjectedReplicas(Resource)</dd>
        </dl>

        @if (GetDeploymentStatusDescription(Resource) is { Length: > 0 } statusDescription)
        {
            <div class="procedure-message compact">@statusDescription</div>
        }
    </section>

    <section class="blade-section">
        <h3>Deploy image</h3>
        <div class="generated-deploy-form">
            <label for="application-deploy-image">New image</label>
            <FluentTextField Id="application-deploy-image"
                             @bind-Value="DeploymentImage"
                             Immediate="true"
                             Placeholder="example/api:20260608"
                             Disabled="@(!CanEditDeployment)" />
            <FluentCheckbox @bind-Value="RestartIfRunning" Disabled="@(!CanEditDeployment)">
                Restart if running
            </FluentCheckbox>

            @if (!Capabilities.CanManage)
            {
                <div class="procedure-message compact">You do not have permission to deploy images for this resource.</div>
            }

            @if (!string.IsNullOrWhiteSpace(ImageDeploymentMessage))
            {
                <div class="procedure-message compact">@ImageDeploymentMessage</div>
            }

            <FormPrimaryAction Text="@(IsDeploying ? "Deploying" : "Deploy")"
                               Disabled="@(!CanSubmitImageDeployment)"
                               OnClick="DeployImage" />
        </div>
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private ResourceOperationCapabilities Capabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private string? CurrentDeploymentResourceId { get; set; }
    private string? DeploymentImage { get; set; }
    private string? ImageDeploymentMessage { get; set; }
    private bool RestartIfRunning { get; set; } = true;
    private bool IsDeploying { get; set; }

    private bool CanEditDeployment =>
        Resource is not null &&
        Capabilities.CanManage &&
        !IsDeploying;

    private bool CanSubmitImageDeployment =>
        CanEditDeployment &&
        !string.IsNullOrWhiteSpace(DeploymentImage);

    protected override async Task OnParametersSetAsync()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : await ResourceManager.GetResourceAsync(ResourceId);
        Capabilities = Resource is null
            ? ResourceOperationCapabilities.None(ResourceId ?? string.Empty)
            : await ResourceManager.GetResourceOperationCapabilitiesAsync(Resource);
        InitializeDeploymentImage();
    }

    private void InitializeDeploymentImage()
    {
        if (Resource is null)
        {
            CurrentDeploymentResourceId = null;
            DeploymentImage = null;
            ImageDeploymentMessage = null;
            return;
        }

        if (string.Equals(CurrentDeploymentResourceId, Resource.Id, StringComparison.OrdinalIgnoreCase) &&
            !string.IsNullOrWhiteSpace(DeploymentImage))
        {
            return;
        }

        CurrentDeploymentResourceId = Resource.Id;
        DeploymentImage = GetCurrentContainerImage(Resource);
        ImageDeploymentMessage = null;
    }

    private async Task DeployImage()
    {
        if (!CanSubmitImageDeployment || Resource is null)
        {
            if (!Capabilities.CanManage)
            {
                ImageDeploymentMessage = "You do not have permission to deploy images for this resource.";
            }

            return;
        }

        var requestedImage = await ReadDeploymentImageAsync();
        if (string.IsNullOrWhiteSpace(requestedImage))
        {
            return;
        }

        DeploymentImage = requestedImage;
        IsDeploying = true;
        ImageDeploymentMessage = null;
        try
        {
            var result = await ResourceManager.UpdateResourceImageAsync(
                Resource,
                requestedImage,
                RestartIfRunning,
                triggeredBy: "Resource Manager");
            ImageDeploymentMessage = result.Message;

            var updatedResource = await ResourceManager.GetResourceAsync(Resource.Id);
            if (updatedResource is not null)
            {
                Resource = updatedResource;
                DeploymentImage = GetCurrentContainerImage(Resource);
                CurrentDeploymentResourceId = Resource.Id;
            }
        }
        catch (Exception exception)
        {
            ImageDeploymentMessage = exception.Message;
        }
        finally
        {
            IsDeploying = false;
        }
    }

    private static string GetCurrentContainerImage(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerImage) ?? string.Empty;

    private static string GetDeploymentRevision(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentRevision) ??
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerRevision) ??
        "unrevisioned";

    private static string GetDeploymentService(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentServiceId) ?? "not projected";

    private static string GetDeploymentDesiredReplicas(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentDesiredReplicas) ??
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerReplicas) ??
        "1";

    private static string GetDeploymentProjectedReplicas(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentProjectedReplicas) ?? "0";

    private static string GetDeploymentStatusLabel(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus) switch
        {
            "active" => "Active",
            "applying" => "Applying",
            "failed" => "Failed",
            "deleted" => "Deleted",
            "pending" => "Pending",
            _ => "Not projected"
        };

    private static string GetDeploymentStatusDescription(Resource resource) =>
        resource.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.DeploymentStatus) switch
        {
            "active" => string.Empty,
            "applying" => "CloudShell is applying this deployment to the selected container host.",
            "failed" => "The latest deployment projection failed. Check resource activity and logs for details.",
            "pending" => "The deployment is projected but not currently active. Start the app to materialize runtime replicas.",
            "deleted" => "This deployment has been deleted by the orchestrator.",
            _ => "No orchestrator deployment projection is available for this resource."
        };

    private async Task<string> ReadDeploymentImageAsync()
    {
        var fieldValue = await JS.InvokeAsync<string?>(
            "cloudShellForms.getValue",
            "application-deploy-image");
        return (string.IsNullOrWhiteSpace(fieldValue)
            ? DeploymentImage
            : fieldValue)?.Trim() ?? string.Empty;
    }
}
