@inject IResourceManager ResourceManager

@if (Resource is null)
{
    <p class="muted">This application resource is unavailable.</p>
}
else if (!HasExposureTarget(Resource))
{
    <p class="muted">This application does not declare an endpoint that can be exposed.</p>
}
else
{
    <div class="generated-list">
        <div>
            <strong>Expose through load balancer</strong>
            <span>Create a provider-backed route to this application's endpoint.</span>
            <small>@FormatTarget(Resource)</small>
            <GeneratedRowActions>
                <FluentAnchor Appearance="Appearance.Neutral"
                              IconStart="@(new Icons.Regular.Size20.ArrowRouting())"
                              Href="@BuildAddLoadBalancerRoute(Resource)">
                    @GetLoadBalancerActionLabel()
                </FluentAnchor>
            </GeneratedRowActions>
        </div>
        <div>
            <strong>Add DNS name</strong>
            <span>Create a name mapping for this application's endpoint.</span>
            <small>@FormatTarget(Resource)</small>
            <GeneratedRowActions>
                <FluentAnchor Appearance="Appearance.Neutral"
                              IconStart="@(new Icons.Regular.Size20.Globe())"
                              Href="@BuildAddNameMappingRoute(Resource)">
                    Add name mapping
                </FluentAnchor>
            </GeneratedRowActions>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    [Parameter]
    public string? ViewId { get; set; }

    [Parameter]
    public string? SectionId { get; set; }

    [Parameter]
    public Resource? Resource { get; set; }

    private IReadOnlyList<Resource> LoadBalancers { get; set; } = [];

    protected override async Task OnParametersSetAsync()
    {
        LoadBalancers = Resource is null
            ? []
            : await LoadLoadBalancersAsync(Resource);
    }

    private static bool HasExposureTarget(Resource resource) =>
        resource.Endpoints.Count > 0;

    private static string FormatTarget(Resource resource)
    {
        var endpoint = GetTargetEndpoint(resource);
        var endpointName = endpoint?.Name ?? "default";
        var endpointSummary = endpoint is null ? null : FormatEndpointSummary(endpoint);
        return string.IsNullOrWhiteSpace(endpointSummary)
            ? $"Target: {resource.Name}/{endpointName}"
            : $"Target: {resource.Name}/{endpointName} ({endpointSummary})";
    }

    private static string FormatEndpointSummary(ResourceEndpoint endpoint)
    {
        if (endpoint.TargetPort is { } targetPort)
        {
            return string.IsNullOrWhiteSpace(endpoint.Protocol)
                ? targetPort.ToString()
                : $"{endpoint.Protocol}:{targetPort}";
        }

        return string.IsNullOrWhiteSpace(endpoint.Protocol)
            ? endpoint.Name
            : endpoint.Protocol;
    }

    private static string BuildAddNameMappingRoute(Resource resource) =>
        ApplicationResourceExposureRoutes.BuildAddNameMappingRoute(
            resource,
            ResourcePredefinedViewIds.Endpoints);

    private string BuildAddLoadBalancerRoute(Resource resource)
    {
        if (LoadBalancers.Count == 1)
        {
            return ApplicationResourceExposureRoutes.BuildUpdateLoadBalancerRoute(
                LoadBalancers[0].Id,
                resource,
                ResourcePredefinedViewIds.Endpoints);
        }

        return ApplicationResourceExposureRoutes.BuildAddLoadBalancerRoute(
            resource,
            ResourcePredefinedViewIds.Endpoints);
    }

    private string GetLoadBalancerActionLabel() =>
        LoadBalancers.Count == 1
            ? "Add route to load balancer"
            : "Add load-balancer route";

    private static ResourceEndpoint? GetTargetEndpoint(Resource resource) =>
        resource.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Protocol, "http", StringComparison.OrdinalIgnoreCase)) ??
        resource.Endpoints.FirstOrDefault();

    private async Task<IReadOnlyList<Resource>> LoadLoadBalancersAsync(Resource resource)
    {
        var resourceGroup = await ResourceManager.GetResourceGroupForResourceAsync(resource.Id);
        var candidates = await ResourceManager.ListResourcesAsync(new ResourceQuery(ResourceClass: ResourceClass.Network));
        var result = new List<Resource>();
        foreach (var candidate in candidates.Where(IsLoadBalancerResource))
        {
            var candidateGroup = await ResourceManager.GetResourceGroupForResourceAsync(candidate.Id);
            if (resourceGroup is null
                    ? candidateGroup is null
                    : string.Equals(candidateGroup?.Id, resourceGroup.Id, StringComparison.OrdinalIgnoreCase))
            {
                result.Add(candidate);
            }
        }

        return result
            .OrderBy(candidate => candidate.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static bool IsLoadBalancerResource(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.NetworkingLoadBalancer) ||
        resource.ResourceLoadBalancerRoutes.Count > 0 ||
        resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.LoadBalancerProvider);
}
