@using Microsoft.JSInterop
@inject ApplicationResourceProvider ApplicationProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceManager ResourceManagerClient
@inject ApplicationRuntimeStateStore RuntimeStates
@inject IJSRuntime JS

@if (Application is null)
{
    <div class="empty-state">
        <strong>Application is unavailable</strong>
        <span>The resource may have been removed or is no longer visible.</span>
    </div>
}
else
{
    <section class="blade-section">
        <h3>@GetConfigurationHeading(Application)</h3>
        <dl class="detail-list">
            @if (IsAspNetCoreProject(Application))
            {
                <dt>Project path</dt>
                <dd>@(Application.ProjectPath ?? "none")</dd>
                <dt>Application arguments</dt>
                <dd>@(Application.ProjectArguments ?? "none")</dd>
                <dt>Hot reload</dt>
                <dd>@(Application.AspNetCoreHotReload ? "enabled" : "disabled")</dd>
            }
            else if (IsContainerBacked(Application))
            {
                <dt>Image</dt>
                <dd>@(Application.ContainerImage ?? "none")</dd>
                <dt>Registry</dt>
                <dd>@NormalizeRegistry(Application.ContainerRegistry)</dd>
                <dt>Revision</dt>
                <dd>@(Application.ContainerRevision ?? "unrevisioned")</dd>
                <dt>Container host</dt>
                <dd>@(Application.ContainerHostId ?? "default")</dd>
                <dt>Replicas</dt>
                <dd>@Math.Max(1, Application.Replicas)</dd>
            }
            else
            {
                <dt>Executable</dt>
                <dd>@Application.ExecutablePath</dd>
                <dt>Arguments</dt>
                <dd>@(Application.Arguments ?? "none")</dd>
                <dt>Working directory</dt>
                <dd>@(Application.WorkingDirectory ?? "executable directory")</dd>
            }
            <dt>Endpoint</dt>
            <dd>@EndpointLink(GetEndpointAddress(Application))</dd>
            @if (IsSqlServer(Application) && GetSqlServerConnectionString(Application) is { } connectionString)
            {
                <dt>Connection string</dt>
                <dd>
                    <span>@connectionString</span>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Title="Copy connection string"
                                  OnClick="() => CopyText(connectionString)">
                        Copy
                    </FluentButton>
                </dd>
                <dt>SA password</dt>
                <dd>
                    <SensitiveLiteralValue Value="@GetSqlServerPassword(Application)"
                                           RevealTitle="Reveal password"
                                           HideTitle="Hide password"
                                           CopyTitle="Copy password" />
                </dd>
            }
            <dt>Lifetime</dt>
            <dd>@GetLifetimeLabel(Application.Lifetime)</dd>
            <dt>Dependencies</dt>
            <dd>@(EffectiveDependencies.Count == 0 ? "none" : string.Join(", ", EffectiveDependencies))</dd>
            <dt>Observability</dt>
            <dd>@GetObservabilityLabel(Application.Observability)</dd>
        </dl>
    </section>

    @if (ServiceDiscoveryReferences.Count > 0)
    {
        <section class="blade-section">
            <h3>Developer service discovery</h3>
            <div class="generated-list">
                @foreach (var reference in ServiceDiscoveryReferences)
                {
                    <div>
                        <strong>
                            @if (reference.Resource is null)
                            {
                                @reference.ResourceId
                            }
                            else
                            {
                                <a class="resource-link" href="@BuildResourceRoute(reference.Resource.Id)">
                                    @reference.Resource.Name
                                </a>
                            }
                        </strong>
                        <span>@FormatServiceDiscoveryReference(reference)</span>
                        <small>@FormatServiceDiscoveryBindings(reference)</small>
                    </div>
                }
            </div>
        </section>
    }

    @if (InboundNetworkMappings.Count > 0)
    {
        <section class="blade-section">
            <h3>Network exposure</h3>
            <div class="generated-list">
                @foreach (var exposure in InboundNetworkMappings)
                {
                    <div>
                        <strong>
                            <a class="resource-link" href="@BuildResourceRoute(exposure.Network.Id)">
                                @exposure.Network.Name
                            </a>
                        </strong>
                        <span>@FormatMappingSummary(exposure.Mapping, exposure.Network, Application.Id)</span>
                        <small>@FormatMappingProvider(exposure.Mapping)</small>
                    </div>
                }
            </div>
        </section>
    }

    @if (InboundLoadBalancerRoutes.Count > 0)
    {
        <section class="blade-section">
            <h3>Load balancer exposure</h3>
            <div class="generated-list">
                @foreach (var exposure in InboundLoadBalancerRoutes)
                {
                    <div>
                        <strong>
                            <a class="resource-link" href="@BuildResourceRoute(exposure.LoadBalancer.Id)">
                                @exposure.LoadBalancer.Name
                            </a>
                        </strong>
                        <span>@FormatLoadBalancerRoute(exposure.Route)</span>
                        <small>Entrypoint: @exposure.Route.EntrypointName</small>
                    </div>
                }
            </div>
        </section>
    }

    @if (InboundNameMappings.Count > 0)
    {
        <section class="blade-section">
            <h3>DNS and domain names</h3>
            <div class="generated-list">
                @foreach (var exposure in InboundNameMappings)
                {
                    <div>
                        <strong>
                            <a class="resource-link" href="@BuildResourceRoute(exposure.Mapping.Id)">
                                @ApplicationNameMappingDisplay.GetHostName(exposure.Mapping)
                            </a>
                        </strong>
                        <span>@ApplicationNameMappingDisplay.GetSummary(exposure.Mapping, Application.Name)</span>
                        <small>@FormatNameMappingMetadata(exposure)</small>
                    </div>
                }
            </div>
        </section>
    }

    @if (VolumeMounts.Count > 0)
    {
        <section class="blade-section">
            <h3>Storage mounts</h3>
            <div class="generated-list">
                @foreach (var volumeMount in VolumeMounts)
                {
                    <div>
                        <strong>
                            @if (volumeMount.Volume is null)
                            {
                                @ApplicationVolumeResourceDisplay.GetMountSourceLabel(volumeMount.Mount, null)
                            }
                            else
                            {
                                <a class="resource-link" href="@BuildResourceRoute(volumeMount.Volume.Id)">
                                    @ApplicationVolumeResourceDisplay.GetMountSourceLabel(volumeMount.Mount, volumeMount.Volume)
                                </a>
                            }
                        </strong>
                        <span>@ApplicationVolumeResourceDisplay.GetMountSummary(volumeMount.Mount, volumeMount.Volume)</span>
                        <small>@GetMountRuntimeLabel(volumeMount)</small>
                    </div>
                }
            </div>
        </section>
    }

    <section class="blade-section">
        <h3>App settings</h3>
        @if (Application.AppSettings.Count == 0)
        {
            <p class="muted">No app settings are configured.</p>
        }
        else
        {
            <table class="settings-reference-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Source</th>
                        <th>Status</th>
                        <th>Value or reference</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Application.AppSettings.Select(CreateSettingRow))
                {
                    <tr>
                        <td><strong>@row.Name</strong></td>
                        <td>@row.Source</td>
                        <td><span class="@row.StatusCssClass">@row.Status</span></td>
                        <td>
                            <ApplicationSettingValueCell Row="row" />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section class="blade-section">
        <h3>Environment variables</h3>
        @if (Application.EnvironmentVariables.Count == 0)
        {
            <p class="muted">No environment variables are configured.</p>
        }
        else
        {
            <table class="settings-reference-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Source</th>
                        <th>Status</th>
                        <th>Value or reference</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Application.EnvironmentVariables.Select(CreateSettingRow))
                {
                    <tr>
                        <td><strong>@row.Name</strong></td>
                        <td>@row.Source</td>
                        <td><span class="@row.StatusCssClass">@row.Status</span></td>
                        <td>
                            <ApplicationSettingValueCell Row="row" />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private ApplicationResourceDefinition? Application { get; set; }
    private Resource? ProjectedResource { get; set; }
    private ApplicationRuntimeState? RuntimeState { get; set; }
    private ResourcePermissionGrantEvaluator? PermissionGrantEvaluator { get; set; }
    private IReadOnlyList<string> EffectiveDependencies { get; set; } = [];
    private IReadOnlyList<NetworkEndpointMappingView> InboundNetworkMappings { get; set; } = [];
    private IReadOnlyList<LoadBalancerRouteView> InboundLoadBalancerRoutes { get; set; } = [];
    private IReadOnlyList<NameMappingView> InboundNameMappings { get; set; } = [];
    private IReadOnlyList<VolumeMountView> VolumeMounts { get; set; } = [];
    private IReadOnlyList<ServiceDiscoveryReferenceView> ServiceDiscoveryReferences { get; set; } = [];

    protected override async Task OnParametersSetAsync()
    {
        Application = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ApplicationProvider.GetApplication(ResourceId);
        ProjectedResource = Application is null
            ? null
            : ResourceManager.GetResource(Application.Id);
        RuntimeState = Application is null
            ? null
            : RuntimeStates.Get(Application.Id);
        EffectiveDependencies = Application is null
            ? []
            : ProjectedResource?.DependsOn ?? Application.DependsOn;
        InboundNetworkMappings = Application is null
            ? []
            : GetInboundNetworkMappings(Application.Id);
        InboundLoadBalancerRoutes = Application is null
            ? []
            : GetInboundLoadBalancerRoutes(Application.Id);
        InboundNameMappings = Application is null
            ? []
            : GetInboundNameMappings(Application.Id);
        VolumeMounts = Application is null
            ? []
            : GetVolumeMounts(Application.VolumeMounts);
        ServiceDiscoveryReferences = Application is null
            ? []
            : GetServiceDiscoveryReferences(Application);
        PermissionGrantEvaluator = new ResourcePermissionGrantEvaluator(
            await ResourceManagerClient.ListResourcePermissionGrantsAsync());
    }

    private static string GetLifetimeLabel(ApplicationLifetime lifetime) =>
        lifetime switch
        {
            ApplicationLifetime.ControlPlaneScoped => "Control plane scoped",
            _ => "Detached"
        };

    private static string GetConfigurationHeading(ApplicationResourceDefinition application) =>
        IsAspNetCoreProject(application)
            ? "Project"
            : IsContainerBacked(application)
                ? "Container"
            : "Command";

    private static bool IsAspNetCoreProject(ApplicationResourceDefinition application) =>
        string.Equals(
            application.ResourceType,
            ApplicationResourceTypes.AspNetCoreProject,
            StringComparison.OrdinalIgnoreCase);

    private static bool IsContainerBacked(ApplicationResourceDefinition application) =>
        !string.IsNullOrWhiteSpace(application.ContainerImage) ||
        !string.IsNullOrWhiteSpace(application.ContainerBuildContext);

    private static bool IsSqlServer(ApplicationResourceDefinition application) =>
        string.Equals(
            application.ResourceType,
            ApplicationResourceTypes.SqlServer,
            StringComparison.OrdinalIgnoreCase);

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private IReadOnlyList<NetworkEndpointMappingView> GetInboundNetworkMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => resource.ResourceClass == ResourceClass.Network)
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => mapping.Network.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<LoadBalancerRouteView> GetInboundLoadBalancerRoutes(string resourceId) =>
        ResourceManager.GetResources()
            .Where(IsLoadBalancerResource)
            .SelectMany(loadBalancer => loadBalancer.ResourceLoadBalancerRoutes
                .Where(route => string.Equals(
                    route.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(route => new LoadBalancerRouteView(loadBalancer, route)))
            .OrderBy(route => route.LoadBalancer.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Route.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<NameMappingView> GetInboundNameMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => ApplicationNameMappingDisplay.IsNameMappingResource(resource))
            .Where(resource => ApplicationNameMappingDisplay.TargetsResource(resource, resourceId))
            .Select(resource => new NameMappingView(ResolveParentResource(resource), resource))
            .OrderBy(mapping => ApplicationNameMappingDisplay.GetHostName(mapping.Mapping), StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<VolumeMountView> GetVolumeMounts(IReadOnlyList<ResourceVolumeMount> mounts) =>
        mounts
            .Where(mount =>
                !string.IsNullOrWhiteSpace(mount.VolumeReference) &&
                !string.IsNullOrWhiteSpace(mount.TargetPath))
            .Select(mount => new VolumeMountView(
                mount,
                ResolveVolumeResource(mount.NormalizedVolumeReference),
                ResolveRuntimeVolumeMount(mount)))
            .OrderBy(mount => mount.Mount.NormalizedTargetPath, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<ServiceDiscoveryReferenceView> GetServiceDiscoveryReferences(
        ApplicationResourceDefinition application) =>
        application.References
            .Where(reference => !string.IsNullOrWhiteSpace(reference))
            .Select(reference => reference.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select(reference =>
            {
                var resource = ResourceManager.GetResource(reference);
                return new ServiceDiscoveryReferenceView(
                    reference,
                    resource,
                    resource is not null && application.UseServiceDiscovery
                        ? ApplicationServiceDiscoveryDisplay.GetServiceNames(resource)
                        : [],
                    resource is not null && application.UseServiceDiscovery
                        ? ApplicationServiceDiscoveryDisplay.GetEndpointBindings(resource)
                        : []);
            })
            .OrderBy(reference => reference.Resource?.Name ?? reference.ResourceId, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string FormatServiceDiscoveryReference(ServiceDiscoveryReferenceView reference)
    {
        if (Application?.UseServiceDiscovery != true)
        {
            return "Reference is not projected because developer service discovery is disabled.";
        }

        if (reference.Resource is null)
        {
            return "Referenced resource is unavailable.";
        }

        if (reference.ServiceNames.Count == 0)
        {
            return "No developer service discovery aliases are available.";
        }

        return $"Aliases: {string.Join(", ", reference.ServiceNames)}";
    }

    private string FormatServiceDiscoveryBindings(ServiceDiscoveryReferenceView reference)
    {
        if (Application?.UseServiceDiscovery != true)
        {
            return "Enable developer service discovery to inject referenced endpoints.";
        }

        if (reference.Resource is null)
        {
            return "The reference will not be injected until the resource can be resolved.";
        }

        if (reference.EndpointBindings.Count == 0)
        {
            return "No reachable endpoints are available for developer service discovery.";
        }

        var firstAddress = reference.EndpointBindings[0].Address;
        var keys = reference.EndpointBindings
            .Where(binding => string.Equals(binding.Address, firstAddress, StringComparison.OrdinalIgnoreCase))
            .Select(binding => binding.EnvironmentVariableName)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToArray();
        var more = reference.EndpointBindings.Count - keys.Length;
        var suffix = more > 0
            ? $" (+{more} more)"
            : string.Empty;

        return $"{string.Join(", ", keys)}{suffix} -> {firstAddress}";
    }

    private ResourceVolumeMountMaterialization? ResolveRuntimeVolumeMount(ResourceVolumeMount mount) =>
        RuntimeState?.RuntimeVolumeMounts.FirstOrDefault(runtimeMount =>
            string.Equals(
                runtimeMount.VolumeReference,
                mount.NormalizedVolumeReference,
                StringComparison.OrdinalIgnoreCase) &&
            string.Equals(
                runtimeMount.TargetPath,
                mount.NormalizedTargetPath,
                StringComparison.OrdinalIgnoreCase));

    private static string GetMountRuntimeLabel(VolumeMountView volumeMount)
    {
        var parts = new List<string>
        {
            ApplicationVolumeResourceDisplay.GetMountAccessLabel(volumeMount.Mount)
        };

        if (volumeMount.RuntimeMount is null)
        {
            parts.Add("Materialization: not observed");
        }
        else
        {
            parts.Add($"Materialization: {GetVolumeMountStatusLabel(volumeMount.RuntimeMount.Status)}");
            if (!string.IsNullOrWhiteSpace(volumeMount.RuntimeMount.Source))
            {
                parts.Add($"Source: {volumeMount.RuntimeMount.Source}");
            }
        }

        return string.Join(" - ", parts);
    }

    private static string GetVolumeMountStatusLabel(string status) =>
        status switch
        {
            ResourceVolumeMountMaterializationStatus.Materialized => "materialized",
            ResourceVolumeMountMaterializationStatus.NotActive => "not active",
            _ => string.IsNullOrWhiteSpace(status) ? "unknown" : status
        };

    private string FormatMappingSummary(
        ResourceEndpointMappingDefinition mapping,
        Resource network,
        string targetResourceId) =>
        $"{FormatEndpointReference(mapping.Source, network)} -> {FormatEndpointReference(mapping.Target, targetResourceId)}";

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        Resource? fallbackResource = null)
    {
        var resource = ResolveMappingResource(reference.ResourceId, fallbackResource);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var address = string.IsNullOrWhiteSpace(endpoint?.Address)
            ? null
            : $" ({endpoint.Address})";
        return $"{resource?.Name ?? reference.ResourceId}/{reference.EndpointName}{address}";
    }

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        string targetResourceId)
    {
        var resource = ResolveMappingResource(reference.ResourceId);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var label = string.Equals(reference.ResourceId, targetResourceId, StringComparison.OrdinalIgnoreCase)
            ? Application?.Name ?? reference.ResourceId
            : resource?.Name ?? reference.ResourceId;
        var address = string.IsNullOrWhiteSpace(endpoint?.Address)
            ? null
            : $" ({endpoint.Address})";
        return $"{label}/{reference.EndpointName}{address}";
    }

    private string FormatMappingProvider(ResourceEndpointMappingDefinition mapping)
    {
        var providerId = FirstNonEmpty(mapping.ProviderResourceId, mapping.NetworkResourceId, mapping.Source.ResourceId);
        if (string.IsNullOrWhiteSpace(providerId))
        {
            return "Provider: network";
        }

        var provider = ResolveMappingResource(providerId);
        return provider is null
            ? $"Provider: {providerId}"
            : $"Provider: {provider.Name}";
    }

    private string FormatLoadBalancerRoute(LoadBalancerRoute route) =>
        $"{FormatLoadBalancerRouteMatch(route)} -> {FormatLoadBalancerRouteTarget(route.Target)}";

    private string FormatLoadBalancerRouteMatch(LoadBalancerRoute route)
    {
        if (route.Kind == LoadBalancerRouteKind.Tcp)
        {
            return $"TCP {route.Match.Port?.ToString() ?? route.EntrypointName}";
        }

        var host = string.IsNullOrWhiteSpace(route.Match.Host)
            ? "any host"
            : route.Match.Host;
        return string.IsNullOrWhiteSpace(route.Match.PathPrefix)
            ? host
            : $"{host}{route.Match.PathPrefix}";
    }

    private string FormatLoadBalancerRouteTarget(LoadBalancerRouteTarget target)
    {
        var resource = ResolveMappingResource(target.ResourceId);
        var label = string.Equals(target.ResourceId, Application?.Id, StringComparison.OrdinalIgnoreCase)
            ? Application?.Name ?? target.ResourceId
            : resource?.Name ?? target.ResourceId;
        if (!string.IsNullOrWhiteSpace(target.EndpointName))
        {
            return $"{label}/{target.EndpointName}";
        }

        return target.Port is null
            ? label
            : $"{label}:{target.Port.Value}";
    }

    private string FormatNameMappingMetadata(NameMappingView view)
    {
        var parts = new List<string>
        {
            $"Exposure: {ApplicationNameMappingDisplay.GetExposureLabel(view.Mapping)}",
            FormatNameMappingProvider(view.Mapping),
            $"Materialization: {ApplicationNameMappingDisplay.GetMaterializationLabel(view.Mapping)}"
        };

        if (view.Zone is not null)
        {
            parts.Insert(0, $"Zone: {view.Zone.Name}");
        }

        return string.Join(" · ", parts);
    }

    private string FormatNameMappingProvider(Resource mapping)
    {
        var providerResourceId = ApplicationNameMappingDisplay.GetProviderResourceId(mapping);
        if (!string.IsNullOrWhiteSpace(providerResourceId))
        {
            var provider = ResolveMappingResource(providerResourceId);
            return provider is null
                ? $"Provider: {providerResourceId}"
                : $"Provider: {provider.Name}";
        }

        return $"Provider: {ApplicationNameMappingDisplay.GetProviderLabel(mapping)}";
    }

    private static bool IsLoadBalancerResource(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.NetworkingLoadBalancer) ||
        resource.ResourceLoadBalancerRoutes.Count > 0 ||
        resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.LoadBalancerProvider);

    private Resource? ResolveMappingResource(string resourceId, Resource? fallbackResource = null)
    {
        if (fallbackResource is not null &&
            string.Equals(fallbackResource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return fallbackResource;
        }

        return ResourceManager.GetResource(resourceId);
    }

    private Resource? ResolveVolumeResource(string resourceId)
    {
        var resource = ResourceManager.GetResource(resourceId);
        return resource is not null &&
            ApplicationVolumeResourceDisplay.IsMountableVolumeResource(resource)
                ? resource
                : null;
    }

    private Resource? ResolveParentResource(Resource resource) =>
        string.IsNullOrWhiteSpace(resource.ParentResourceId)
            ? null
            : ResourceManager.GetResource(resource.ParentResourceId);

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private ApplicationSettingDisplayRow CreateSettingRow(AppSetting setting) =>
        ApplicationSettingReferenceDisplay.Create(
            setting,
            Application?.Id ?? ResourceId ?? string.Empty,
            ProjectedResource?.IdentityBinding,
            resourceId => ResolveMappingResource(resourceId),
            PermissionGrantEvaluator);

    private ApplicationSettingDisplayRow CreateSettingRow(EnvironmentVariableAssignment assignment) =>
        ApplicationSettingReferenceDisplay.Create(
            assignment,
            Application?.Id ?? ResourceId ?? string.Empty,
            ProjectedResource?.IdentityBinding,
            resourceId => ResolveMappingResource(resourceId),
            PermissionGrantEvaluator);

    private static string BuildResourceRoute(string resourceId) =>
        $"/resources/{Uri.EscapeDataString(resourceId)}/details?tab=overview";

    private static string? GetEndpointAddress(ApplicationResourceDefinition application)
    {
        if (IsSqlServer(application))
        {
            return GetSqlServerEndpointAddress(application);
        }

        if (!IsAspNetCoreProject(application))
        {
            return application.Endpoint;
        }

        var port = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "http", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return port?.Port is null
            ? null
            : $"{port.Protocol}://localhost:{port.Port.Value}";
    }

    private static string? GetSqlServerConnectionString(ApplicationResourceDefinition application)
    {
        var address = GetSqlServerEndpointAddress(application);
        if (string.IsNullOrWhiteSpace(address) ||
            !Uri.TryCreate(address, UriKind.Absolute, out var uri))
        {
            return null;
        }

        var server = uri.Port > 0
            ? $"{uri.Host},{uri.Port}"
            : uri.Host;
        var password = GetSqlServerPassword(application) ?? "<SA password>";
        return $"Server={server};User Id=sa;Password={password};TrustServerCertificate=True;";
    }

    private static string? GetSqlServerEndpointAddress(ApplicationResourceDefinition application)
    {
        var endpoint = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "tds", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return endpoint?.Port is null
            ? null
            : $"{endpoint.Protocol}://localhost:{endpoint.Port.Value}";
    }

    private static string? GetSqlServerPassword(ApplicationResourceDefinition application) =>
        application.EnvironmentVariables.FirstOrDefault(variable =>
            string.Equals(variable.Name, "MSSQL_SA_PASSWORD", StringComparison.OrdinalIgnoreCase))?.Value;

    private static string GetObservabilityLabel(ResourceObservability? observability)
    {
        var effective = observability ?? ResourceObservability.Default;
        if (!effective.HasAnySignal)
        {
            return "disabled";
        }

        var signals = new[]
            {
                effective.Logs ? "logs" : null,
                effective.Traces ? "traces" : null,
                effective.Metrics ? "metrics" : null
            }
            .Where(signal => signal is not null);
        var exporter = string.IsNullOrWhiteSpace(effective.OtlpEndpoint)
            ? "default OTLP endpoint"
            : effective.OtlpEndpoint;

        return $"{string.Join(", ", signals)} to {exporter}";
    }

    private static RenderFragment EndpointLink(string? address) => builder =>
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            builder.AddContent(0, "none");
            return;
        }

        if (!IsLinkEndpoint(address))
        {
            builder.AddContent(1, address);
            return;
        }

        builder.OpenElement(2, "a");
        builder.AddAttribute(3, "class", "endpoint-link");
        builder.AddAttribute(4, "href", address);
        builder.AddAttribute(5, "target", "_blank");
        builder.AddAttribute(6, "rel", "noopener noreferrer");
        builder.AddContent(7, address);
        builder.CloseElement();
    };

    private static bool IsLinkEndpoint(string address) =>
        Uri.TryCreate(address, UriKind.Absolute, out var uri) &&
        (uri.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
         uri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase));

    private async Task CopyText(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
        }
    }

    private sealed record NetworkEndpointMappingView(
        Resource Network,
        ResourceEndpointMappingDefinition Mapping);

    private sealed record LoadBalancerRouteView(
        Resource LoadBalancer,
        LoadBalancerRoute Route);

    private sealed record NameMappingView(
        Resource? Zone,
        Resource Mapping);

