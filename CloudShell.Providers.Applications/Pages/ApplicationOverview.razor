@using System.Text.Json
@using Microsoft.JSInterop
@inject ApplicationResourceProvider ApplicationProvider
@inject ILogManager LogManager
@inject IResourceManagerStore ResourceManager
@inject IResourceManager ResourceManagerClient
@inject IResourceRegistrationStore Registrations
@inject ApplicationRuntimeStateStore RuntimeStates
@inject IEnumerable<IContainerHostProvider> ContainerHostProviders
@inject IEnumerable<IResourceOrchestrationDescriptorProvider> DescriptorProviders
@inject IJSRuntime JS
@inject NavigationManager Navigation

@if (Application is null)
{
    <EmptyState Title="Application is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    var startReadiness = GetStartReadiness();

    <section class="blade-section">
        <h3>Essentials</h3>
        <dl class="detail-list">
            @if (IsAspNetCoreProject(Application))
            {
                <dt>Project path</dt>
                <dd>@(Application.ProjectPath ?? "none")</dd>
                <dt>Application arguments</dt>
                <dd>@(Application.ProjectArguments ?? "none")</dd>
                <dt>Hot reload</dt>
                <dd>@(Application.AspNetCoreHotReload ? "enabled" : "disabled")</dd>
            }
            else if (IsContainerBacked(Application))
            {
                <dt>Image</dt>
                <dd>@(Application.ContainerImage ?? "none")</dd>
                <dt>Registry</dt>
                <dd>@NormalizeRegistry(Application.ContainerRegistry)</dd>
                <dt>Revision</dt>
                <dd>@(Application.ContainerRevision ?? "unrevisioned")</dd>
                <dt>Container host</dt>
                <dd>@ContainerHostPlacementSummary()</dd>
                <dt>Replicas</dt>
                <dd>@Math.Max(1, Application.Replicas)</dd>
            }
            else
            {
                <dt>Executable</dt>
                <dd>@Application.ExecutablePath</dd>
                <dt>Arguments</dt>
                <dd>@(Application.Arguments ?? "none")</dd>
                <dt>Working directory</dt>
                <dd>@(Application.WorkingDirectory ?? "executable directory")</dd>
            }
            @{
                var overviewEndpoint = GetOverviewEndpoint(Application);
            }
            <dt>Endpoint</dt>
            <dd>
                @EndpointLink(overviewEndpoint.Address)
                @if (!string.IsNullOrWhiteSpace(overviewEndpoint.Source))
                {
                    <small>@overviewEndpoint.Source</small>
                }
            </dd>
            @if (IsSqlServer(Application) && GetSqlServerConnectionString(Application) is { } connectionString)
            {
                <dt>Connection string</dt>
                <dd>
                    <span>@connectionString</span>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Title="Copy connection string"
                                  OnClick="() => CopyText(connectionString)">
                        Copy
                    </FluentButton>
                </dd>
                <dt>SA password</dt>
                <dd>
                    <SensitiveLiteralValue Value="@GetSqlServerPassword(Application)"
                                           RevealTitle="Reveal password"
                                           HideTitle="Hide password"
                                           CopyTitle="Copy password" />
                </dd>
            }
            <dt>Lifetime</dt>
            <dd>@GetLifetimeLabel(Application.Lifetime)</dd>
            @if (EffectiveDependencies.Count > 0)
            {
                <dt>Dependencies</dt>
                <dd>@FormatCount(EffectiveDependencies.Count, "dependency", "dependencies")</dd>
            }
            @if (VolumeMounts.Count > 0)
            {
                <dt>Storage</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, GetStorageTabId(Application))">
                        @FormatCount(VolumeMounts.Count, "mount", "mounts")
                    </a>
                </dd>
            }
            @if (Application.AppSettings.Count > 0 || Application.EnvironmentVariables.Count > 0)
            {
                <dt>Environment</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, ResourcePredefinedViewIds.Environment)">
                        @FormatEnvironmentSummary()
                    </a>
                </dd>
            }
            <dt>Observability</dt>
            <dd>@GetObservabilityLabel(Application.Observability)</dd>
        </dl>
    </section>

    @if (Application.AppSettings.Count > 0 || Application.EnvironmentVariables.Count > 0)
    {
        <section class="blade-section">
            <h3>Environment references</h3>
            <div class="generated-list">
                @foreach (var row in GetEnvironmentRows())
                {
                    <div>
                        <strong>@row.Name</strong>
                        <span>@row.Source</span>
                        <ApplicationSettingValueCell Row="row" />
                        <small>
                            <span class="@row.StatusCssClass">@row.Status</span>
                        </small>
                    </div>
                }
            </div>
        </section>
    }

    @if (IsContainerBacked(Application))
    {
        <section class="blade-section">
            <h3>Container host</h3>
            <dl class="detail-list">
                <dt>Status</dt>
                <dd>@GetContainerHostStatusLabel()</dd>
                @if (ContainerHostPlacement?.Host is { } host)
                {
                    <dt>Resolved host</dt>
                    <dd>
                        @if (ContainerHostPlacement.HostResource is { } hostResource)
                        {
                            <a class="resource-link" href="@BuildResourceRoute(hostResource.Id)">
                                @host.Name
                            </a>
                        }
                        else
                        {
                            @host.Name
                        }
                    </dd>
                    <dt>Endpoint</dt>
                    <dd>@host.Endpoint</dd>
                    <dt>Credentials</dt>
                    <dd>@(host.CredentialsAvailable ? "available" : "unavailable")</dd>
                }
            </dl>
        </section>
    }

    @if (startReadiness is not null)
    {
        <section class="blade-section">
            <h3>Start readiness</h3>
            <div class="generated-list">
                <div>
                    <strong>@startReadiness.Status</strong>
                    <span>@startReadiness.Message</span>
                    <small>@startReadiness.ActionLabel preflight</small>
                </div>
            </div>
        </section>
    }

    @if (ServiceDiscoveryReferences.Count > 0)
    {
        <section class="blade-section">
            <h3>Developer service discovery</h3>
            <div class="generated-list">
                @foreach (var reference in ServiceDiscoveryReferences)
                {
                    <div>
                        <strong>
                            @if (reference.Resource is null)
                            {
                                @reference.ResourceId
                            }
                            else
                            {
                                <a class="resource-link" href="@BuildResourceRoute(reference.Resource.Id)">
                                    @reference.Resource.Name
                                </a>
                            }
                        </strong>
                        <span>@FormatServiceDiscoveryReference(reference)</span>
                        <small>@FormatServiceDiscoveryBindings(reference)</small>
                    </div>
                }
            </div>
        </section>
    }

    @if (HasExposureTarget(Application) ||
        InboundNetworkMappings.Count > 0 ||
        InboundLoadBalancerRoutes.Count > 0 ||
        InboundNameMappings.Count > 0)
    {
        <section class="blade-section">
            <h3>Networking</h3>
            <dl class="detail-list">
                @if (InboundNetworkMappings.Count > 0)
                {
                    <dt>Network mappings</dt>
                    <dd>@FormatCount(InboundNetworkMappings.Count, "mapping", "mappings")</dd>
                }
                @if (InboundLoadBalancerRoutes.Count > 0)
                {
                    <dt>Load-balancer routes</dt>
                    <dd>@FormatCount(InboundLoadBalancerRoutes.Count, "route", "routes")</dd>
                }
                @if (InboundNameMappings.Count > 0)
                {
                    <dt>DNS names</dt>
                    <dd>
                        <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, ResourcePredefinedViewIds.Dns)">
                            @FormatNameMappingOverview()
                        </a>
                    </dd>
                }
                <dt>Endpoint details</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, ResourcePredefinedViewIds.Endpoints)">
                        Open Endpoints
                    </a>
                </dd>
            </dl>
        </section>
    }

    <section class="blade-section">
        <h3>Diagnostics</h3>
        <div class="generated-list">
            <div>
                <strong>
                    <a class="resource-link" href="@BuildActivityRoute(Application.Id)">
                        Activity
                    </a>
                </strong>
                <span>Lifecycle and provider events for this application.</span>
                <small>Resource activity</small>
            </div>
            @if (Logs.Count > 0)
            {
                <div>
                    <strong>
                        <a class="resource-link" href="@BuildLogsRoute(Application.Id, Logs)">
                            Logs
                        </a>
                    </strong>
                    <span>@GetLogsSummary(Logs)</span>
                    <small>@GetLogSourcesSummary(Logs)</small>
                </div>
            }
            @if (HasTraceObservability(Application))
            {
                <div>
                    <strong>
                        <a class="resource-link" href="@BuildTraceRoute(Application.Id)">
                            Traces
                        </a>
                    </strong>
                    <span>Distributed traces attributed to this application.</span>
                    <small>Observability signal enabled</small>
                </div>
            }
        </div>
    </section>

}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private ApplicationResourceDefinition? Application { get; set; }
    private Resource? ProjectedResource { get; set; }
    private ApplicationRuntimeState? RuntimeState { get; set; }
    private ResourceOperationCapabilities OperationCapabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private ResourcePermissionGrantEvaluator? PermissionGrantEvaluator { get; set; }
    private IReadOnlyList<string> EffectiveDependencies { get; set; } = [];
    private IReadOnlyList<NetworkEndpointMappingView> InboundNetworkMappings { get; set; } = [];
    private IReadOnlyList<LoadBalancerRouteView> InboundLoadBalancerRoutes { get; set; } = [];
    private IReadOnlyList<NameMappingView> InboundNameMappings { get; set; } = [];
    private IReadOnlyList<VolumeMountView> VolumeMounts { get; set; } = [];
    private IReadOnlyList<ServiceDiscoveryReferenceView> ServiceDiscoveryReferences { get; set; } = [];
    private IReadOnlyList<LogDescriptor> Logs { get; set; } = [];
    private ContainerHostPlacementView? ContainerHostPlacement { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Application = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ApplicationProvider.GetApplication(ResourceId);
        ProjectedResource = Application is null
            ? null
            : ResourceManager.GetResource(Application.Id);
        RuntimeState = Application is null
            ? null
            : RuntimeStates.Get(Application.Id);
        OperationCapabilities = ProjectedResource is null
            ? ResourceOperationCapabilities.None(ResourceId ?? string.Empty)
            : await ResourceManagerClient.GetResourceOperationCapabilitiesAsync(ProjectedResource);
        EffectiveDependencies = Application is null
            ? []
            : ProjectedResource?.DependsOn ?? Application.DependsOn;
        InboundNetworkMappings = Application is null
            ? []
            : GetInboundNetworkMappings(Application.Id);
        InboundLoadBalancerRoutes = Application is null
            ? []
            : GetInboundLoadBalancerRoutes(Application.Id);
        InboundNameMappings = Application is null
            ? []
            : GetInboundNameMappings(Application.Id);
        VolumeMounts = Application is null
            ? []
            : GetVolumeMounts(Application.VolumeMounts);
        ServiceDiscoveryReferences = Application is null
            ? []
            : GetServiceDiscoveryReferences(Application);
        Logs = Application is null
            ? []
            : await GetLogsAsync(Application.Id);
        ContainerHostPlacement = Application is null || !IsContainerBacked(Application)
            ? null
            : GetContainerHostPlacement(Application);
        PermissionGrantEvaluator = new ResourcePermissionGrantEvaluator(
            await ResourceManagerClient.ListResourcePermissionGrantsAsync());
    }

    private static string GetLifetimeLabel(ApplicationLifetime lifetime) =>
        lifetime switch
        {
            ApplicationLifetime.ControlPlaneScoped => "Control plane scoped",
            _ => "Detached"
        };

    private static string GetConfigurationHeading(ApplicationResourceDefinition application) =>
        IsAspNetCoreProject(application)
            ? "Project"
            : IsContainerBacked(application)
                ? "Container"
            : "Command";

    private static bool IsAspNetCoreProject(ApplicationResourceDefinition application) =>
        string.Equals(
            application.ResourceType,
            ApplicationResourceTypes.AspNetCoreProject,
            StringComparison.OrdinalIgnoreCase);

    private static bool IsContainerBacked(ApplicationResourceDefinition application) =>
        !string.IsNullOrWhiteSpace(application.ContainerImage) ||
        !string.IsNullOrWhiteSpace(application.ContainerBuildContext);

    private static bool HasExposureTarget(ApplicationResourceDefinition application) =>
        application.EndpointPorts.Count > 0 ||
        !string.IsNullOrWhiteSpace(GetEndpointAddress(application));

    private static bool IsSqlServer(ApplicationResourceDefinition application) =>
        string.Equals(
            application.ResourceType,
            ApplicationResourceTypes.SqlServer,
            StringComparison.OrdinalIgnoreCase);

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private string ContainerHostPlacementSummary()
    {
        if (Application is null)
        {
            return "unavailable";
        }

        if (ContainerHostPlacement?.Host is null)
        {
            return string.IsNullOrWhiteSpace(Application.ContainerHostId)
                ? "default host unavailable"
                : $"{Application.ContainerHostId} (unavailable)";
        }

        return string.IsNullOrWhiteSpace(Application.ContainerHostId)
            ? $"{ContainerHostPlacement.Host.Name} (default)"
            : ContainerHostPlacement.Host.Name;
    }

    private static string GetContainerHostSelectionLabel(ApplicationResourceDefinition application) =>
        string.IsNullOrWhiteSpace(application.ContainerHostId)
            ? "Default host"
            : application.ContainerHostId;

    private string GetContainerHostStatusLabel()
    {
        if (ContainerHostPlacement?.Host is null)
        {
            return Application is null || string.IsNullOrWhiteSpace(Application.ContainerHostId)
                ? "Default host is not registered"
                : "Selected host is not registered";
        }

        return ContainerHostPlacement.Host.CredentialsAvailable
            ? "Available"
            : "Credentials unavailable";
    }

    private StartReadinessView? GetStartReadiness()
    {
        var action = ProjectedResource?.ResourceActions.FirstOrDefault(action =>
                action.Kind == ResourceActionKind.Start) ??
            ProjectedResource?.ResourceActions.FirstOrDefault(action =>
                action.Kind == ResourceActionKind.Restart);
        if (action is null)
        {
            return null;
        }

        var reason = OperationCapabilities.GetActionUnavailableReason(action.Id);
        if (OperationCapabilities.CanExecuteAction(action.Id) &&
            string.IsNullOrWhiteSpace(reason))
        {
            return new StartReadinessView(
                action.DisplayName,
                "Ready",
                $"{action.DisplayName} preflight checks passed.");
        }

        return new StartReadinessView(
            action.DisplayName,
            "Blocked",
            string.IsNullOrWhiteSpace(reason)
                ? $"{action.DisplayName} is unavailable for this resource."
                : reason);
    }

    private static string GetContainerHostCapabilitiesLabel(ContainerHostDescriptor host) =>
        host.HostCapabilities.Count == 0
            ? "none advertised"
            : string.Join(", ", host.HostCapabilities.Order(StringComparer.OrdinalIgnoreCase));

    private ContainerHostPlacementView GetContainerHostPlacement(ApplicationResourceDefinition application)
    {
        var requestedHostId = NormalizeNullable(application.ContainerHostId);
        var hosts = GetContainerHosts();
        var host = string.IsNullOrWhiteSpace(requestedHostId)
            ? hosts.FirstOrDefault(candidate => candidate.IsDefault)
            : hosts.FirstOrDefault(candidate =>
                string.Equals(candidate.Id, requestedHostId, StringComparison.OrdinalIgnoreCase));
        var hostResource = host is null
            ? null
            : ResourceManager.GetResource(host.Id);

        return new ContainerHostPlacementView(
            requestedHostId,
            host,
            hostResource);
    }

    private IReadOnlyList<ContainerHostDescriptor> GetContainerHosts()
    {
        var configuredHosts = ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id));
        var resourceHosts = ResourceManager
            .GetResources()
            .Select(TryReadContainerHost)
            .Where(host => host is not null)
            .Select(host => host!);

        return configuredHosts
            .Concat(resourceHosts)
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .OrderByDescending(host => host.IsDefault)
            .ThenBy(host => host.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private ContainerHostDescriptor? TryReadContainerHost(Resource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            if (!descriptor.ResourceType.Equals(ContainerHostResourceTypes.ContainerHost, StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            return descriptor.Configuration.Deserialize<ContainerHostDescriptor>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private IReadOnlyList<NetworkEndpointMappingView> GetInboundNetworkMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => resource.ResourceClass == ResourceClass.Network)
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => mapping.Network.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<LoadBalancerRouteView> GetInboundLoadBalancerRoutes(string resourceId) =>
        ResourceManager.GetResources()
            .Where(IsLoadBalancerResource)
            .SelectMany(loadBalancer => loadBalancer.ResourceLoadBalancerRoutes
                .Where(route => string.Equals(
                    route.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(route => new LoadBalancerRouteView(loadBalancer, route)))
            .OrderBy(route => route.LoadBalancer.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Route.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<NameMappingView> GetInboundNameMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => ApplicationNameMappingDisplay.IsNameMappingResource(resource))
            .Where(resource => ApplicationNameMappingDisplay.TargetsResource(resource, resourceId))
            .Select(resource => new NameMappingView(ResolveParentResource(resource), resource))
            .OrderBy(mapping => ApplicationNameMappingDisplay.GetHostName(mapping.Mapping), StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<VolumeMountView> GetVolumeMounts(IReadOnlyList<ResourceVolumeMount> mounts) =>
        mounts
            .Where(mount =>
                !string.IsNullOrWhiteSpace(mount.VolumeReference) &&
                !string.IsNullOrWhiteSpace(mount.TargetPath))
            .Select(mount => new VolumeMountView(
                mount,
                ResolveVolumeResource(mount.NormalizedVolumeReference),
                ResolveRuntimeVolumeMount(mount)))
            .OrderBy(mount => mount.Mount.NormalizedTargetPath, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<ServiceDiscoveryReferenceView> GetServiceDiscoveryReferences(
        ApplicationResourceDefinition application) =>
        application.References
            .Where(reference => !string.IsNullOrWhiteSpace(reference))
            .Select(reference => reference.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Select(reference =>
            {
                var resource = ResourceManager.GetResource(reference);
                return new ServiceDiscoveryReferenceView(
                    reference,
                    resource,
                    resource is not null && application.UseServiceDiscovery
                        ? ApplicationServiceDiscoveryDisplay.GetServiceNames(resource)
                        : [],
                    resource is not null && application.UseServiceDiscovery
                        ? ApplicationServiceDiscoveryDisplay.GetEndpointBindings(resource)
                        : []);
            })
            .OrderBy(reference => reference.Resource?.Name ?? reference.ResourceId, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string FormatServiceDiscoveryReference(ServiceDiscoveryReferenceView reference)
    {
        if (Application?.UseServiceDiscovery != true)
        {
            return "Reference is not projected because developer service discovery is disabled.";
        }

        if (reference.Resource is null)
        {
            return "Referenced resource is unavailable.";
        }

        if (reference.ServiceNames.Count == 0)
        {
            return "No developer service discovery aliases are available.";
        }

        return $"Aliases: {string.Join(", ", reference.ServiceNames)}";
    }

    private string FormatServiceDiscoveryBindings(ServiceDiscoveryReferenceView reference)
    {
        if (Application?.UseServiceDiscovery != true)
        {
            return "Enable developer service discovery to inject referenced endpoints.";
        }

        if (reference.Resource is null)
        {
            return "The reference will not be injected until the resource can be resolved.";
        }

        if (reference.EndpointBindings.Count == 0)
        {
            return "No reachable endpoints are available for developer service discovery.";
        }

        var firstAddress = reference.EndpointBindings[0].Address;
        var keys = reference.EndpointBindings
            .Where(binding => string.Equals(binding.Address, firstAddress, StringComparison.OrdinalIgnoreCase))
            .Select(binding => binding.EnvironmentVariableName)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToArray();
        var more = reference.EndpointBindings.Count - keys.Length;
        var suffix = more > 0
            ? $" (+{more} more)"
            : string.Empty;

        return $"{string.Join(", ", keys)}{suffix} -> {firstAddress}";
    }

    private ResourceVolumeMountMaterialization? ResolveRuntimeVolumeMount(ResourceVolumeMount mount) =>
        RuntimeState?.RuntimeVolumeMounts.FirstOrDefault(runtimeMount =>
            string.Equals(
                runtimeMount.VolumeReference,
                mount.NormalizedVolumeReference,
                StringComparison.OrdinalIgnoreCase) &&
            string.Equals(
                runtimeMount.TargetPath,
                mount.NormalizedTargetPath,
                StringComparison.OrdinalIgnoreCase));

    private static string GetMountRuntimeLabel(VolumeMountView volumeMount)
    {
        var parts = new List<string>
        {
            ApplicationVolumeResourceDisplay.GetMountAccessLabel(volumeMount.Mount)
        };

        if (volumeMount.RuntimeMount is null)
        {
            parts.Add("Materialization: not observed");
        }
        else
        {
            parts.Add($"Materialization: {GetVolumeMountStatusLabel(volumeMount.RuntimeMount.Status)}");
            if (!string.IsNullOrWhiteSpace(volumeMount.RuntimeMount.Source))
            {
                parts.Add($"Source: {volumeMount.RuntimeMount.Source}");
            }
        }

        return string.Join(" - ", parts);
    }

    private static string GetVolumeMountStatusLabel(string status) =>
        status switch
        {
            ResourceVolumeMountMaterializationStatus.Materialized => "materialized",
            ResourceVolumeMountMaterializationStatus.NotActive => "not active",
            _ => string.IsNullOrWhiteSpace(status) ? "unknown" : status
        };

    private string FormatMappingSummary(
        ResourceEndpointMappingDefinition mapping,
        Resource network,
        string targetResourceId) =>
        $"{FormatEndpointReference(mapping.Source, network)} -> {FormatEndpointReference(mapping.Target, targetResourceId)}";

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        Resource? fallbackResource = null)
    {
        var resource = ResolveMappingResource(reference.ResourceId, fallbackResource);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var summary = endpoint is null
            ? null
            : $" ({FormatEndpointSummary(endpoint)})";
        return $"{resource?.Name ?? reference.ResourceId}/{reference.EndpointName}{summary}";
    }

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        string targetResourceId)
    {
        var resource = ResolveMappingResource(reference.ResourceId);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var label = string.Equals(reference.ResourceId, targetResourceId, StringComparison.OrdinalIgnoreCase)
            ? Application?.Name ?? reference.ResourceId
            : resource?.Name ?? reference.ResourceId;
        var summary = endpoint is null
            ? null
            : $" ({FormatEndpointSummary(endpoint)})";
        return $"{label}/{reference.EndpointName}{summary}";
    }

    private static string FormatEndpointSummary(ResourceEndpoint endpoint)
    {
        var protocol = string.IsNullOrWhiteSpace(endpoint.Protocol)
            ? "unspecified"
            : endpoint.Protocol;
        return endpoint.TargetPort is null
            ? protocol
            : $"{protocol}:{endpoint.TargetPort.Value}";
    }

    private string FormatMappingProvider(ResourceEndpointMappingDefinition mapping)
    {
        var providerId = FirstNonEmpty(mapping.ProviderResourceId, mapping.NetworkResourceId, mapping.Source.ResourceId);
        if (string.IsNullOrWhiteSpace(providerId))
        {
            return "Provider: network";
        }

        var provider = ResolveMappingResource(providerId);
        return provider is null
            ? $"Provider: {providerId}"
            : $"Provider: {provider.Name}";
    }

    private string FormatLoadBalancerRoute(LoadBalancerRoute route) =>
        $"{FormatLoadBalancerRouteMatch(route)} -> {FormatLoadBalancerRouteTarget(route.Target)}";

    private string FormatLoadBalancerRouteMatch(LoadBalancerRoute route)
    {
        if (route.Kind == LoadBalancerRouteKind.Tcp)
        {
            return $"TCP {route.Match.Port?.ToString() ?? route.EntrypointName}";
        }

        var host = string.IsNullOrWhiteSpace(route.Match.Host)
            ? "any host"
            : route.Match.Host;
        return string.IsNullOrWhiteSpace(route.Match.PathPrefix)
            ? host
            : $"{host}{route.Match.PathPrefix}";
    }

    private string FormatLoadBalancerRouteTarget(LoadBalancerRouteTarget target)
    {
        var resource = ResolveMappingResource(target.ResourceId);
        var label = string.Equals(target.ResourceId, Application?.Id, StringComparison.OrdinalIgnoreCase)
            ? Application?.Name ?? target.ResourceId
            : resource?.Name ?? target.ResourceId;
        if (!string.IsNullOrWhiteSpace(target.EndpointName))
        {
            return $"{label}/{target.EndpointName}";
        }

        return target.Port is null
            ? label
            : $"{label}:{target.Port.Value}";
    }

    private string FormatNameMappingMetadata(NameMappingView view)
    {
        var parts = new List<string>
        {
            $"Exposure: {ApplicationNameMappingDisplay.GetExposureLabel(view.Mapping)}",
            FormatNameMappingProvider(view.Mapping),
            $"Materialization: {ApplicationNameMappingDisplay.GetMaterializationLabel(view.Mapping)}"
        };

        if (view.Zone is not null)
        {
            parts.Insert(0, $"Zone: {view.Zone.Name}");
        }

        return string.Join(" · ", parts);
    }

    private string FormatNameMappingProvider(Resource mapping)
    {
        var providerResourceId = ApplicationNameMappingDisplay.GetProviderResourceId(mapping);
        if (!string.IsNullOrWhiteSpace(providerResourceId))
        {
            var provider = ResolveMappingResource(providerResourceId);
            return provider is null
                ? $"Provider: {providerResourceId}"
                : $"Provider: {provider.Name}";
        }

        return $"Provider: {ApplicationNameMappingDisplay.GetProviderLabel(mapping)}";
    }

    private static bool IsLoadBalancerResource(Resource resource) =>
        resource.HasCapability(ResourceCapabilityIds.NetworkingLoadBalancer) ||
        resource.ResourceLoadBalancerRoutes.Count > 0 ||
        resource.ResourceAttributes.ContainsKey(ResourceAttributeNames.LoadBalancerProvider);

    private Resource? ResolveMappingResource(string resourceId, Resource? fallbackResource = null)
    {
        if (fallbackResource is not null &&
            string.Equals(fallbackResource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return fallbackResource;
        }

        return ResourceManager.GetResource(resourceId);
    }

    private Resource? ResolveVolumeResource(string resourceId)
    {
        var resource = ResourceManager.GetResource(resourceId);
        return resource is not null &&
            ApplicationVolumeResourceDisplay.IsMountableVolumeResource(resource)
                ? resource
                : null;
    }

    private Resource? ResolveParentResource(Resource resource) =>
        string.IsNullOrWhiteSpace(resource.ParentResourceId)
            ? null
            : ResourceManager.GetResource(resource.ParentResourceId);

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string FormatCount(int count, string singular, string plural) =>
        count == 1 ? $"1 {singular}" : $"{count} {plural}";

    private string FormatEnvironmentSummary()
    {
        var parts = new List<string>();
        if (Application?.AppSettings.Count > 0)
        {
            parts.Add(FormatCount(Application.AppSettings.Count, "app setting", "app settings"));
        }

        if (Application?.EnvironmentVariables.Count > 0)
        {
            parts.Add(FormatCount(Application.EnvironmentVariables.Count, "environment variable", "environment variables"));
        }

        return parts.Count == 0 ? "none" : string.Join(", ", parts);
    }

    private string FormatNameMappingOverview()
    {
        if (InboundNameMappings.Count == 1)
        {
            return ApplicationNameMappingDisplay.GetHostName(InboundNameMappings[0].Mapping);
        }

        return FormatCount(InboundNameMappings.Count, "name mapping", "name mappings");
    }

    private ApplicationSettingDisplayRow CreateSettingRow(AppSetting setting) =>
        ApplicationSettingReferenceDisplay.Create(
            setting,
            Application?.Id ?? ResourceId ?? string.Empty,
            ProjectedResource?.IdentityBinding,
            resourceId => ResolveMappingResource(resourceId),
            PermissionGrantEvaluator);

    private ApplicationSettingDisplayRow CreateSettingRow(EnvironmentVariableAssignment assignment) =>
        ApplicationSettingReferenceDisplay.Create(
            assignment,
            Application?.Id ?? ResourceId ?? string.Empty,
            ProjectedResource?.IdentityBinding,
            resourceId => ResolveMappingResource(resourceId),
            PermissionGrantEvaluator);

    private IEnumerable<ApplicationSettingDisplayRow> GetEnvironmentRows()
    {
        if (Application is null)
        {
            return [];
        }

        return Application.AppSettings
            .Select(CreateSettingRow)
            .Concat(Application.EnvironmentVariables.Select(CreateSettingRow));
    }

    private static string BuildResourceRoute(string resourceId) =>
        ResourceManagerRoutes.ResourceOverview(resourceId);

    private static string BuildResourceTabRoute(string resourceId, ResourceViewId tabId) =>
        ResourceManagerRoutes.ResourceDetails(resourceId, tabId);

    private static ResourceViewId GetStorageTabId(ApplicationResourceDefinition application) =>
        ApplicationResourceTypes.IsContainerApp(application.ResourceType)
            ? new ResourceViewId(ResourceTabGroupIds.Application, "storage")
            : ResourcePredefinedViewIds.Storage;

    private static string BuildAddNameMappingRoute(ApplicationResourceDefinition application) =>
        ApplicationResourceExposureRoutes.BuildAddNameMappingRoute(
            application,
            ResourcePredefinedViewIds.Overview);

    private static string BuildAddLoadBalancerRoute(ApplicationResourceDefinition application) =>
        ApplicationResourceExposureRoutes.BuildAddLoadBalancerRoute(
            application,
            ResourcePredefinedViewIds.Overview);

    private static string? GetEndpointAddress(ApplicationResourceDefinition application)
    {
        if (IsSqlServer(application))
        {
            return GetSqlServerEndpointAddress(application);
        }

        if (!IsAspNetCoreProject(application))
        {
            return application.Endpoint;
        }

        var port = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "http", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return port?.Port is null
            ? null
            : $"{port.Protocol}://localhost:{port.Port.Value}";
    }

    private OverviewEndpoint GetOverviewEndpoint(ApplicationResourceDefinition application)
    {
        if (GetPreferredNameMappingEndpoint() is { } mappedEndpoint)
        {
            return mappedEndpoint;
        }

        var projectedEndpoint = GetPreferredProjectedEndpoint();
        if (projectedEndpoint is not null &&
            ProjectedResource is not null &&
            ProjectedResource.TryGetResolvedEndpointUri(projectedEndpoint, out var endpointUri))
        {
            var address = endpointUri.ToString();
            if (!string.IsNullOrWhiteSpace(address))
            {
                return new OverviewEndpoint(address, $"{projectedEndpoint.Name} endpoint");
            }
        }

        var configuredAddress = GetEndpointAddress(application);
        return new OverviewEndpoint(
            configuredAddress,
            string.IsNullOrWhiteSpace(configuredAddress) ? null : "configured endpoint");
    }

    private OverviewEndpoint? GetPreferredNameMappingEndpoint()
    {
        var mapping = InboundNameMappings
            .Select(view => view.Mapping)
            .OrderBy(GetNameMappingExposureRank)
            .ThenBy(ApplicationNameMappingDisplay.GetHostName, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
        if (mapping is null)
        {
            return null;
        }

        var hostName = ApplicationNameMappingDisplay.GetHostName(mapping);
        if (string.IsNullOrWhiteSpace(hostName))
        {
            return null;
        }

        var endpointName = ApplicationNameMappingDisplay.GetTargetEndpointName(mapping);
        var endpoint = ProjectedResource?.Endpoints.FirstOrDefault(endpoint =>
                string.Equals(endpoint.Name, endpointName, StringComparison.OrdinalIgnoreCase)) ??
            ProjectedResource?.Endpoints.FirstOrDefault();
        Uri? endpointUri = null;
        if (endpoint is not null &&
            ProjectedResource is not null &&
            ProjectedResource.TryGetResolvedEndpointUri(endpoint, out var resolvedUri))
        {
            endpointUri = resolvedUri;
        }

        var address = CreateMappedEndpointAddress(hostName, endpointUri);
        return new OverviewEndpoint(
            address,
            $"{ApplicationNameMappingDisplay.GetExposureLabel(mapping)} DNS name");
    }

    private static int GetNameMappingExposureRank(Resource mapping) =>
        ApplicationNameMappingDisplay.GetExposureLabel(mapping) switch
        {
            nameof(ResourceExposureScope.Public) => 0,
            nameof(ResourceExposureScope.Network) => 1,
            nameof(ResourceExposureScope.Private) => 2,
            nameof(ResourceExposureScope.Local) => 3,
            _ => 4
        };

    private static string CreateMappedEndpointAddress(string hostName, Uri? endpointUri)
    {
        if (endpointUri is null)
        {
            return hostName;
        }

        var builder = new UriBuilder(endpointUri)
        {
            Host = hostName
        };
        return builder.Uri.ToString();
    }

    private ResourceEndpoint? GetPreferredProjectedEndpoint()
    {
        if (ProjectedResource?.Endpoints.Count > 0)
        {
            return ProjectedResource.Endpoints
                .OrderBy(endpoint => GetEndpointExposureRank(endpoint.Exposure))
                .ThenBy(endpoint => GetEndpointProtocolRank(endpoint.Protocol))
                .ThenBy(endpoint => endpoint.Name, StringComparer.OrdinalIgnoreCase)
                .FirstOrDefault();
        }

        return null;
    }

    private static int GetEndpointExposureRank(ResourceExposureScope exposure) =>
        exposure switch
        {
            ResourceExposureScope.Public => 0,
            ResourceExposureScope.Network => 1,
            ResourceExposureScope.Private => 2,
            ResourceExposureScope.Local => 3,
            _ => 4
        };

    private static int GetEndpointProtocolRank(string protocol) =>
        protocol switch
        {
            "https" => 0,
            "http" => 1,
            _ => 2
        };

    private static string GetProtocol(string address) =>
        Uri.TryCreate(address, UriKind.Absolute, out var uri) ? uri.Scheme : "tcp";

    private async Task<IReadOnlyList<LogDescriptor>> GetLogsAsync(string resourceId)
    {
        var logs = await LogManager.ListLogsAsync(new LogQuery(ResourceId: resourceId));

        return logs
            .OrderBy(log => log.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(log => log.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static bool HasTraceObservability(ApplicationResourceDefinition application) =>
        (application.Observability ?? ResourceObservability.Default).Traces;

    private static string GetLogsSummary(IReadOnlyList<LogDescriptor> logs) =>
        logs.Count == 1
            ? "1 log source is available for this application."
            : $"{logs.Count} log sources are available for this application.";

    private static string GetLogSourcesSummary(IReadOnlyList<LogDescriptor> logs)
    {
        var sourceKinds = logs
            .Select(log => log.SourceKind.ToString())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return sourceKinds.Length == 0
            ? "No source kind metadata"
            : $"Sources: {string.Join(", ", sourceKinds)}";
    }

    private static string BuildLogsRoute(string resourceId, IReadOnlyList<LogDescriptor> logs)
    {
        var query = new Dictionary<string, string?>
        {
            ["resourceId"] = resourceId
        };

        if (logs.Count == 1)
        {
            query["logId"] = logs[0].Id;
        }

        return BuildRoute("/logs", query);
    }

    private static string BuildTraceRoute(string resourceId) =>
        BuildRoute(
            "/observability/traces",
            new Dictionary<string, string?> { ["resourceId"] = resourceId });

    private static string BuildActivityRoute(string resourceId) =>
        BuildRoute(
            ResourceManagerRoutes.ResourceDetails(resourceId),
            new Dictionary<string, string?> { ["tab"] = ResourcePredefinedViewIds.Activity.Value });

    private static string BuildRoute(string path, Dictionary<string, string?> query)
    {
        var queryString = string.Join(
            "&",
            query
                .Where(parameter => !string.IsNullOrWhiteSpace(parameter.Value))
                .Select(parameter =>
                    $"{Uri.EscapeDataString(parameter.Key)}={Uri.EscapeDataString(parameter.Value!)}"));

        return string.IsNullOrWhiteSpace(queryString)
            ? path
            : $"{path}?{queryString}";
    }

    private RenderFragment DependencyLink(string resourceId) => builder =>
    {
        var resource = ResolveMappingResource(resourceId);
        builder.OpenElement(0, "a");
        builder.AddAttribute(1, "class", "resource-link generated-pill-link");
        builder.AddAttribute(2, "href", BuildResourceRoute(resourceId));
        builder.AddContent(3, resource?.Name ?? resourceId);
        if (resource is not null)
        {
            builder.OpenElement(4, "small");
            builder.AddContent(5, resource.EffectiveTypeId);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string? GetSqlServerConnectionString(ApplicationResourceDefinition application)
    {
        var address = GetSqlServerEndpointAddress(application);
        if (string.IsNullOrWhiteSpace(address) ||
            !Uri.TryCreate(address, UriKind.Absolute, out var uri))
        {
            return null;
        }

        var server = uri.Port > 0
            ? $"{uri.Host},{uri.Port}"
            : uri.Host;
        var password = GetSqlServerPassword(application) ?? "<SA password>";
        return $"Server={server};User Id=sa;Password={password};TrustServerCertificate=True;";
    }

    private static string? GetSqlServerEndpointAddress(ApplicationResourceDefinition application)
    {
        var endpoint = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "tds", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return endpoint?.Port is null
            ? null
            : $"{endpoint.Protocol}://localhost:{endpoint.Port.Value}";
    }

    private static string? GetSqlServerPassword(ApplicationResourceDefinition application) =>
        application.EnvironmentVariables.FirstOrDefault(variable =>
            string.Equals(variable.Name, "MSSQL_SA_PASSWORD", StringComparison.OrdinalIgnoreCase))?.Value;

    private static string GetObservabilityLabel(ResourceObservability? observability)
    {
        var effective = observability ?? ResourceObservability.Default;
        if (!effective.HasAnySignal)
        {
            return "disabled";
        }

        var signals = new[]
            {
                effective.Logs ? "logs" : null,
                effective.Traces ? "traces" : null,
                effective.Metrics ? "metrics" : null
            }
            .Where(signal => signal is not null);
        var exporter = string.IsNullOrWhiteSpace(effective.OtlpEndpoint)
            ? "default OTLP endpoint"
            : effective.OtlpEndpoint;

        return $"{string.Join(", ", signals)} to {exporter}";
    }

    private static RenderFragment EndpointLink(string? address) => builder =>
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            builder.AddContent(0, "none");
            return;
        }

        if (!IsLinkEndpoint(address))
        {
            builder.AddContent(1, address);
            return;
        }

        builder.OpenElement(2, "a");
        builder.AddAttribute(3, "class", "endpoint-link");
        builder.AddAttribute(4, "href", address);
        builder.AddAttribute(5, "target", "_blank");
        builder.AddAttribute(6, "rel", "noopener noreferrer");
        builder.AddContent(7, address);
        builder.CloseElement();
    };

    private static bool IsLinkEndpoint(string address) =>
        Uri.TryCreate(address, UriKind.Absolute, out var uri) &&
        (uri.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
         uri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase));

    private async Task CopyText(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
        }
    }

