@using System.Text.Json
@using CloudShell.Abstractions.Authorization
@using Microsoft.JSInterop
@inject ApplicationResourceService ApplicationProvider
@inject ILogManager LogManager
@inject IResourceManagerStore ResourceManager
@inject IResourceManager ResourceManagerClient
@inject IResourceRegistrationStore Registrations
@inject ApplicationRuntimeStateStore RuntimeStates
@inject IEnumerable<IContainerHostProvider> ContainerHostProviders
@inject IEnumerable<IResourceOrchestrationDescriptorProvider> DescriptorProviders
@inject IJSRuntime JS
@inject NavigationManager Navigation

@if (Application is null)
{
    <EmptyState Title="Application is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    var actionReadiness = GetActionReadiness();

    <section class="blade-section">
        <h3>Essentials</h3>
        <dl class="detail-list">
            @if (IsSqlServer(Application))
            {
                <dt>Service</dt>
                <dd>SQL Server</dd>
                <dt>Databases</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, new ResourceViewId(ResourceTabGroupIds.Application, "databases"))">
                        @FormatSqlDatabaseSummary(Application)
                    </a>
                </dd>
                <dt>Administrator</dt>
                <dd>sa</dd>
            }
            else if (IsAspNetCoreProject(Application))
            {
                <dt>Project path</dt>
                <dd>@(Application.ProjectPath ?? "none")</dd>
                <dt>Application arguments</dt>
                <dd>@(Application.ProjectArguments ?? "none")</dd>
                <dt>Hot reload</dt>
                <dd>@(Application.AspNetCoreHotReload ? "enabled" : "disabled")</dd>
            }
            else if (IsContainerBacked(Application))
            {
                <dt>Image</dt>
                <dd>@(Application.ContainerImage ?? "none")</dd>
                <dt>Registry</dt>
                <dd>@NormalizeRegistry(Application.ContainerRegistry)</dd>
                <dt>Revision</dt>
                <dd>@(Application.ContainerRevision ?? "unrevisioned")</dd>
                <dt>Container host</dt>
                <dd>@ContainerHostPlacementSummary()</dd>
                <dt>Replicas</dt>
                <dd>@Math.Max(1, Application.Replicas)</dd>
            }
            else
            {
                <dt>Executable</dt>
                <dd>@Application.ExecutablePath</dd>
                <dt>Arguments</dt>
                <dd>@(Application.Arguments ?? "none")</dd>
                <dt>Working directory</dt>
                <dd>@(Application.WorkingDirectory ?? "executable directory")</dd>
            }
            @{
                var overviewEndpoint = GetOverviewEndpoint(Application);
            }
            <dt>Endpoint</dt>
            <dd>
                <EndpointLink Address="@overviewEndpoint.Address" />
                @if (!string.IsNullOrWhiteSpace(overviewEndpoint.Source))
                {
                    <small>@overviewEndpoint.Source</small>
                }
            </dd>
            @if (IsSqlServer(Application) && GetSqlServerConnectionString(Application) is { } connectionString)
            {
                <dt>Connection string</dt>
                <dd>
                    <span>@connectionString</span>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Title="Copy connection string"
                                  OnClick="() => CopyText(connectionString)">
                        Copy
                    </FluentButton>
                </dd>
                <dt>SA password</dt>
                <dd>
                    <SensitiveLiteralValue Value="@GetSqlServerPassword(Application)"
                                           RevealTitle="Reveal password"
                                           HideTitle="Hide password"
                                           CopyTitle="Copy password" />
                </dd>
            }
            <dt>Lifetime</dt>
            <dd>@ApplicationResourceDisplay.GetLifetimeLabel(Application.Lifetime)</dd>
            @if (TryFormatDeclarationPersistence(out var declarationPersistence))
            {
                <dt>Declaration</dt>
                <dd>@declarationPersistence</dd>
            }
            @if (EffectiveDependencies.Count > 0)
            {
                <dt>Dependencies</dt>
                <dd>@FormatCount(EffectiveDependencies.Count, "dependency", "dependencies")</dd>
            }
            @if (VolumeMounts.Count > 0)
            {
                <dt>Storage</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, GetStorageTabId(Application))">
                        @FormatCount(VolumeMounts.Count, "mount", "mounts")
                    </a>
                </dd>
            }
            @if (Application.AppSettings.Count > 0 || Application.EnvironmentVariables.Count > 0)
            {
                <dt>Environment</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, ResourcePredefinedViewIds.Environment)">
                        @FormatEnvironmentSummary()
                    </a>
                </dd>
            }
            <dt>Observability</dt>
            <dd>@GetObservabilityLabel(Application.Observability)</dd>
        </dl>
    </section>

    @if (EffectiveDependencies.Count > 0 || DependentResources.Count > 0)
    {
        <section class="blade-section">
            <h3>Dependency graph</h3>
            <ResourceRelationshipGraph CurrentCaption="current"
                                       CurrentLabel="@GetCurrentResourceLabel()"
                                       CurrentMetadata="@Application.ResourceType"
                                       DependsOn="@GetDependencyNodes()"
                                       UsedBy="@GetDependentNodes()" />
        </section>
    }

    @if (ShouldShowSqlAccessGrantNotice())
    {
        <section class="blade-section">
            <h3>Access control</h3>
            <ProcedureMessage Severity="ResourceSignalSeverity.Warning" Role="status">
                Database grants are recorded in CloudShell. SQL Server users and roles are not created yet, so workloads still need configured SQL credentials.
            </ProcedureMessage>
        </section>
    }

    @if (Application.AppSettings.Count > 0 || Application.EnvironmentVariables.Count > 0)
    {
        <section class="blade-section">
            <h3>Environment references</h3>
            <div class="generated-list">
                @foreach (var row in GetEnvironmentRows())
                {
                    <div>
                        <strong>@row.Name</strong>
                        <span>@row.Source</span>
                        <ApplicationSettingValueCell Row="row" />
                        <small>
                            <span class="@row.StatusCssClass">@row.Status</span>
                        </small>
                    </div>
                }
            </div>
        </section>
    }

    @if (ProjectedResource?.IdentityBinding is { } identity)
    {
        <section class="blade-section">
            <h3>Resource identity</h3>
            <div class="generated-list">
                <GeneratedListItem Summary="@FormatIdentitySummary(identity)"
                                   Metadata="@($"Provider: {FormatIdentityProvider(identity)}")">
                    <TitleContent>
                        <a class="resource-link" href="@BuildResourceTabRoute(ProjectedResource.Id, ResourcePredefinedViewIds.Identity)">
                            @FormatIdentityName(identity)
                        </a>
                    </TitleContent>
                </GeneratedListItem>
                @if (!string.IsNullOrWhiteSpace(IdentityProvisioningStatusError))
                {
                    <GeneratedListItem Title="Provisioning"
                                       Summary="@IdentityProvisioningStatusError"
                                       Metadata="Status unavailable" />
                }
                else if (IdentityProvisioningStatus is not null)
                {
                    <GeneratedListItem Title="Provisioning"
                                       Summary="@FormatProvisioningState()"
                                       Metadata="@FormatProvisioningDetail()" />
                }
                @foreach (var grant in OutboundPermissionGrants)
                {
                    var target = ResolveMappingResource(grant.TargetResourceId);
                    <GeneratedListItem Title="Can access"
                                       Metadata="@grant.Permission">
                        <SummaryContent>
                            <ResourcePillLink Label="@(target is null ? grant.TargetResourceId : GetResourceLabel(target))"
                                              Href="@BuildResourceRoute(grant.TargetResourceId)"
                                              Metadata="@target?.EffectiveTypeId" />
                        </SummaryContent>
                    </GeneratedListItem>
                }
            </div>
        </section>
    }

    @if (VolumeMounts.Count > 0)
    {
        <section class="blade-section">
            <h3>Storage mounts</h3>
            <div class="generated-list">
                @foreach (var volumeMount in VolumeMounts)
                {
                    <div>
                        <strong>
                            @if (volumeMount.Volume is null)
                            {
                                @volumeMount.Mount.NormalizedVolumeReference
                            }
                            else
                            {
                                <a class="resource-link" href="@BuildResourceRoute(volumeMount.Volume.Id)">
                                    @ApplicationVolumeResourceDisplay.GetMountSourceLabel(volumeMount.Mount, volumeMount.Volume)
                                </a>
                            }
                        </strong>
                        <span>@volumeMount.Mount.NormalizedTargetPath</span>
                        <small>@GetMountRuntimeLabel(volumeMount)</small>
                    </div>
                }
            </div>
        </section>
    }

    @if (IsContainerBacked(Application) && !IsSqlServer(Application))
    {
        <section class="blade-section">
            <h3>Container host</h3>
            <dl class="detail-list">
                <dt>Status</dt>
                <dd>@GetContainerHostStatusLabel()</dd>
                @if (ContainerHostPlacement?.Host is { } host)
                {
                    <dt>Resolved host</dt>
                    <dd>
                        @if (ContainerHostPlacement.HostResource is { } hostResource)
                        {
                            <a class="resource-link" href="@BuildResourceRoute(hostResource.Id)">
                                @GetResourceLabel(hostResource)
                            </a>
                        }
                        else
                        {
                            @host.Name
                        }
                    </dd>
                    <dt>Endpoint</dt>
                    <dd>@host.Endpoint</dd>
                    <dt>Credentials</dt>
                    <dd>@(host.CredentialsAvailable ? "available" : "unavailable")</dd>
                }
            </dl>
        </section>
    }

    @if (actionReadiness is not null)
    {
        <section class="blade-section">
            <h3>Action readiness</h3>
            <div class="generated-list">
                <GeneratedListItem Title="@actionReadiness.Status"
                                   Summary="@actionReadiness.Message"
                                   Metadata="@($"{actionReadiness.ActionLabel} preflight")" />
            </div>
        </section>
    }

    @if (ServiceDiscoveryReferences.Count > 0)
    {
        <section class="blade-section">
            <h3>Developer service discovery</h3>
            <div class="generated-list">
                @foreach (var reference in ServiceDiscoveryReferences)
                {
                    <GeneratedListItem Summary="@FormatServiceDiscoveryReference(reference)"
                                       Metadata="@FormatServiceDiscoveryBindings(reference)">
                        <TitleContent>
                            @if (reference.Resource is null)
                            {
                                @reference.ResourceId
                            }
                            else
                            {
                                <a class="resource-link" href="@BuildResourceRoute(reference.Resource.Id)">
                                    @GetResourceLabel(reference.Resource)
                                </a>
                            }
                        </TitleContent>
                    </GeneratedListItem>
                }
            </div>
        </section>
    }

    @if (HasExposureTarget(Application) ||
        InboundNetworkMappings.Count > 0 ||
        InboundLoadBalancerRoutes.Count > 0 ||
        InboundNameMappings.Count > 0)
    {
        <section class="blade-section">
            <h3>Networking</h3>
            <dl class="detail-list">
                @if (InboundNetworkMappings.Count > 0)
                {
                    <dt>Network mappings</dt>
                    <dd>@FormatCount(InboundNetworkMappings.Count, "mapping", "mappings")</dd>
                }
                @if (InboundLoadBalancerRoutes.Count > 0)
                {
                    <dt>Load-balancer routes</dt>
                    <dd>@FormatCount(InboundLoadBalancerRoutes.Count, "route", "routes")</dd>
                }
                @if (InboundNameMappings.Count > 0)
                {
                    <dt>DNS names</dt>
                    <dd>
                        <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, ResourcePredefinedViewIds.Dns)">
                            @FormatNameMappingOverview()
                        </a>
                    </dd>
                }
                <dt>Endpoint details</dt>
                <dd>
                    <a class="resource-link" href="@BuildResourceTabRoute(Application.Id, ResourcePredefinedViewIds.Endpoints)">
                        Open Endpoints
                    </a>
                </dd>
            </dl>
            @if (InboundNetworkMappings.Count > 0 ||
                InboundLoadBalancerRoutes.Count > 0 ||
                InboundNameMappings.Count > 0)
            {
                <div class="generated-list">
                    @foreach (var mapping in InboundNetworkMappings)
                    {
                        <GeneratedListItem Summary="@FormatMappingSummary(mapping.Mapping, mapping.Network, Application.Id)"
                                           Metadata="@FormatMappingProvider(mapping.Mapping)">
                            <TitleContent>
                                <a class="resource-link" href="@BuildResourceRoute(mapping.Network.Id)">
                                    @GetResourceLabel(mapping.Network)
                                </a>
                            </TitleContent>
                        </GeneratedListItem>
                    }
                    @foreach (var route in InboundLoadBalancerRoutes)
                    {
                        <GeneratedListItem Summary="@FormatLoadBalancerRoute(route.Route)"
                                           Metadata="Load-balancer route">
                            <TitleContent>
                                <a class="resource-link" href="@BuildResourceRoute(route.LoadBalancer.Id)">
                                    @GetResourceLabel(route.LoadBalancer)
                                </a>
                            </TitleContent>
                        </GeneratedListItem>
                    }
                    @foreach (var mapping in InboundNameMappings)
                    {
                        <GeneratedListItem Summary="@ResourceNameMappingDisplay.GetSummary(mapping.Mapping, Application.Name)"
                                           Metadata="@FormatNameMappingMetadata(mapping)">
                            <TitleContent>
                                <a class="resource-link" href="@BuildResourceRoute(mapping.Mapping.Id)">
                                    @ResourceNameMappingDisplay.GetHostName(mapping.Mapping)
                                </a>
                            </TitleContent>
                        </GeneratedListItem>
                    }
                </div>
            }
        </section>
    }

    <section class="blade-section">
        <h3>Diagnostics</h3>
        <div class="generated-list">
            <GeneratedListItem Summary="Lifecycle and provider events for this application."
                               Metadata="Resource activity">
                <TitleContent>
                    <a class="resource-link" href="@BuildActivityRoute(Application.Id)">
                        Activity
                    </a>
                </TitleContent>
            </GeneratedListItem>
            @if (Logs.Count > 0)
            {
                <GeneratedListItem Summary="@GetLogsSummary(Logs)"
                                   Metadata="@GetLogSourcesSummary(Logs)">
                    <TitleContent>
                        <a class="resource-link" href="@BuildLogsRoute(Application.Id, Logs)">
                            Logs
                        </a>
                    </TitleContent>
                </GeneratedListItem>
            }
            @if (HasTraceObservability(Application))
            {
                <GeneratedListItem Summary="Distributed traces attributed to this application."
                                   Metadata="Observability signal enabled">
                    <TitleContent>
                        <a class="resource-link" href="@BuildTraceRoute(Application.Id)">
                            Traces
                        </a>
                    </TitleContent>
                </GeneratedListItem>
            }
        </div>
    </section>

}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private ApplicationResourceDefinition? Application { get; set; }
    private Resource? ProjectedResource { get; set; }
    private ApplicationRuntimeState? RuntimeState { get; set; }
    private ResourceOperationCapabilities OperationCapabilities { get; set; } =
        ResourceOperationCapabilities.None(string.Empty);
    private ResourcePermissionGrantEvaluator? PermissionGrantEvaluator { get; set; }
    private IReadOnlyList<ResourcePermissionGrant> OutboundPermissionGrants { get; set; } = [];
    private IReadOnlyList<ResourcePermissionGrant> InboundPermissionGrants { get; set; } = [];
    private ResourceIdentityProvisioningStatusResult? IdentityProvisioningStatus { get; set; }
    private string? IdentityProvisioningStatusError { get; set; }
    private IReadOnlyList<string> EffectiveDependencies { get; set; } = [];
    private IReadOnlyList<Resource> DependentResources { get; set; } = [];
    private IReadOnlyList<NetworkEndpointMappingView> InboundNetworkMappings { get; set; } = [];
    private IReadOnlyList<LoadBalancerRouteView> InboundLoadBalancerRoutes { get; set; } = [];
    private IReadOnlyList<NameMappingView> InboundNameMappings { get; set; } = [];
    private IReadOnlyList<VolumeMountView> VolumeMounts { get; set; } = [];
    private IReadOnlyList<ServiceDiscoveryReferenceView> ServiceDiscoveryReferences { get; set; } = [];
    private IReadOnlyList<LogDescriptor> Logs { get; set; } = [];
    private IReadOnlyDictionary<string, IReadOnlyList<LogDescriptor>> RelatedLogsByResourceId { get; set; } =
        new Dictionary<string, IReadOnlyList<LogDescriptor>>(StringComparer.OrdinalIgnoreCase);
    private ContainerHostPlacementView? ContainerHostPlacement { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        Application = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ApplicationProvider.GetApplication(ResourceId);
        ProjectedResource = Application is null
            ? null
            : ResourceManager.GetResource(Application.Id);
        RuntimeState = Application is null
            ? null
            : RuntimeStates.Get(Application.Id);
        OperationCapabilities = ProjectedResource is null
            ? ResourceOperationCapabilities.None(ResourceId ?? string.Empty)
            : await ResourceManagerClient.GetResourceOperationCapabilitiesAsync(ProjectedResource);
        EffectiveDependencies = Application is null
            ? []
            : ProjectedResource?.DependsOn ?? Application.DependsOn;
        DependentResources = Application is null
            ? []
            : GetDependentResources(Application.Id);
        InboundNetworkMappings = Application is null
            ? []
            : GetInboundNetworkMappings(Application.Id);
        InboundLoadBalancerRoutes = Application is null
            ? []
            : GetInboundLoadBalancerRoutes(Application.Id);
        InboundNameMappings = Application is null
            ? []
            : GetInboundNameMappings(Application.Id);
        VolumeMounts = Application is null
            ? []
            : GetVolumeMounts(Application.VolumeMounts);
        ServiceDiscoveryReferences = Application is null
            ? []
            : GetServiceDiscoveryReferences(Application);
        Logs = Application is null
            ? []
            : await GetLogsAsync(Application.Id);
        RelatedLogsByResourceId = Application is null
            ? new Dictionary<string, IReadOnlyList<LogDescriptor>>(StringComparer.OrdinalIgnoreCase)
            : await LoadRelatedLogsAsync(GetRelationshipResourceIds());
        ContainerHostPlacement = Application is null || !IsContainerBacked(Application) || IsSqlServer(Application)
            ? null
            : GetContainerHostPlacement(Application);
        var permissionGrants = await ResourceManagerClient.ListResourcePermissionGrantsAsync();
        PermissionGrantEvaluator = new ResourcePermissionGrantEvaluator(permissionGrants);
        OutboundPermissionGrants = ProjectedResource is null
            ? []
            : GetOutboundPermissionGrants(ProjectedResource, permissionGrants);
        InboundPermissionGrants = ProjectedResource is null
            ? []
            : GetInboundPermissionGrants(ProjectedResource, permissionGrants);
        await LoadIdentityProvisioningStatusAsync();
    }

    private bool TryFormatDeclarationPersistence(out string? persistence)
    {
        persistence = null;
        if (ProjectedResource is null ||
            !ProjectedResource.ResourceAttributes.TryGetValue(
                ResourceAttributeNames.DeclarationPersistence,
                out var value) ||
            !Enum.TryParse<ResourceDeclarationPersistence>(value, ignoreCase: true, out var parsed))
        {
            return false;
        }

        persistence = parsed == ResourceDeclarationPersistence.Persisted
            ? "Persisted declaration"
            : "Startup declaration";
        return true;
    }

    private static string GetConfigurationHeading(ApplicationResourceDefinition application) =>
        IsAspNetCoreProject(application)
            ? "Project"
            : IsContainerBacked(application)
                ? "Container"
            : "Command";

    private static bool IsAspNetCoreProject(ApplicationResourceDefinition application) =>
        string.Equals(
            application.ResourceType,
            ApplicationResourceTypes.AspNetCoreProject,
            StringComparison.OrdinalIgnoreCase);

    private static bool IsContainerBacked(ApplicationResourceDefinition application) =>
        !string.IsNullOrWhiteSpace(application.ContainerImage) ||
        !string.IsNullOrWhiteSpace(application.ContainerBuildContext);

    private static bool HasExposureTarget(ApplicationResourceDefinition application) =>
        application.EndpointPorts.Count > 0 ||
        !string.IsNullOrWhiteSpace(GetEndpointAddress(application));

    private static bool IsSqlServer(ApplicationResourceDefinition application) =>
        string.Equals(
            application.ResourceType,
            ApplicationResourceTypes.SqlServer,
            StringComparison.OrdinalIgnoreCase);

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private static string FormatSqlDatabaseSummary(ApplicationResourceDefinition application) =>
        application.SqlDatabases.Count == 0
            ? "No declared databases"
            : FormatCount(application.SqlDatabases.Count, "declared database", "declared databases");

    private static string FormatIdentityName(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.Name)
            ? "Default identity"
            : identity.Name;

    private static string FormatIdentityProvider(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.ProviderId)
            ? "default provider"
            : identity.ProviderId;

    private static string FormatIdentitySummary(ResourceIdentityBinding identity) =>
        string.IsNullOrWhiteSpace(identity.Subject)
            ? $"{identity.Kind} identity"
            : $"Subject: {identity.Subject}";

    private string FormatProvisioningState()
    {
        if (IdentityProvisioningStatus is null)
        {
            return "Provisioning status unavailable.";
        }

        if (IdentityProvisioningStatus.Statuses.Count == 0)
        {
            return "No provisioning status was reported.";
        }

        var states = IdentityProvisioningStatus.Statuses
            .Select(status => status.State.ToString())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return string.Join(", ", states);
    }

    private string FormatProvisioningDetail()
    {
        var detail = IdentityProvisioningStatus?.Statuses
            .Select(status => status.Detail)
            .FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));
        if (!string.IsNullOrWhiteSpace(detail))
        {
            return detail;
        }

        return string.IsNullOrWhiteSpace(IdentityProvisioningStatus?.ProviderId)
            ? "Provider: not resolved"
            : $"Provider: {IdentityProvisioningStatus.ProviderId}";
    }

    private IReadOnlyList<ResourcePermissionGrant> GetOutboundPermissionGrants(
        Resource resource,
        IEnumerable<ResourcePermissionGrant> grants)
    {
        if (resource.IdentityBinding is not { } identity)
        {
            return [];
        }

        return grants
            .Where(grant =>
                grant.ResourceIdentity is { } grantIdentity &&
                string.Equals(grantIdentity.ResourceId, resource.Id, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(grantIdentity.Name, identity.Name, StringComparison.OrdinalIgnoreCase))
            .OrderBy(grant => ResolveMappingResource(grant.TargetResourceId) is { } target
                ? GetResourceLabel(target)
                : grant.TargetResourceId, StringComparer.OrdinalIgnoreCase)
            .ThenBy(grant => grant.Permission, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static IReadOnlyList<ResourcePermissionGrant> GetInboundPermissionGrants(
        Resource resource,
        IEnumerable<ResourcePermissionGrant> grants) =>
        grants
            .Where(grant => string.Equals(grant.TargetResourceId, resource.Id, StringComparison.OrdinalIgnoreCase))
            .OrderBy(grant => grant.Principal.DisplayName ?? grant.Principal.Id, StringComparer.OrdinalIgnoreCase)
            .ThenBy(grant => grant.Permission, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private bool ShouldShowSqlAccessGrantNotice() =>
        Application is not null &&
        IsSqlServer(Application) &&
        InboundPermissionGrants.Any(grant => string.Equals(
            grant.Permission,
            DatabaseResourceOperationPermissions.ReadWrite,
            StringComparison.OrdinalIgnoreCase));

    private async Task LoadIdentityProvisioningStatusAsync()
    {
        IdentityProvisioningStatus = null;
        IdentityProvisioningStatusError = null;
        if (ProjectedResource?.IdentityBinding is null)
        {
            return;
        }

        try
        {
            IdentityProvisioningStatus =
                await ResourceManagerClient.GetResourceIdentityProvisioningStatusAsync(ProjectedResource.Id);
        }
        catch (Exception exception)
        {
            IdentityProvisioningStatusError = exception.Message;
        }
    }

    private string ContainerHostPlacementSummary()
    {
        if (Application is null)
        {
            return "unavailable";
        }

        if (ContainerHostPlacement?.Host is null)
        {
            return string.IsNullOrWhiteSpace(Application.ContainerHostId)
                ? "default host unavailable"
                : $"{Application.ContainerHostId} (unavailable)";
        }

        var label = ContainerHostPlacement.HostResource is null
            ? ContainerHostPlacement.Host.Name
            : GetResourceLabel(ContainerHostPlacement.HostResource);
        return string.IsNullOrWhiteSpace(Application.ContainerHostId)
            ? $"{label} (default)"
            : label;
    }

    private static string GetContainerHostSelectionLabel(ApplicationResourceDefinition application) =>
        string.IsNullOrWhiteSpace(application.ContainerHostId)
            ? "Default host"
            : application.ContainerHostId;

    private string GetContainerHostStatusLabel()
    {
        if (ContainerHostPlacement?.Host is null)
        {
            return Application is null || string.IsNullOrWhiteSpace(Application.ContainerHostId)
                ? "Default host is not registered"
                : "Selected host is not registered";
        }

        return ContainerHostPlacement.Host.CredentialsAvailable
            ? "Available"
            : "Credentials unavailable";
    }

    private ActionReadinessView? GetActionReadiness()
    {
        var action = GetReadinessAction();
        if (action is null)
        {
            return null;
        }

        var reason = OperationCapabilities.GetActionUnavailableReason(action.Id);
        if (OperationCapabilities.CanExecuteAction(action.Id) &&
            string.IsNullOrWhiteSpace(reason))
        {
            return new ActionReadinessView(
                action.DisplayName,
                "Ready",
                $"{action.DisplayName} preflight checks passed.");
        }

        return new ActionReadinessView(
            action.DisplayName,
            "Blocked",
            string.IsNullOrWhiteSpace(reason)
                ? $"{action.DisplayName} is unavailable for this resource."
                : reason);
    }

    private ResourceAction? GetReadinessAction()
    {
        if (ProjectedResource is null)
        {
            return null;
        }

        var preferredKind = ProjectedResource.State is
            ResourceState.Running or
            ResourceState.Starting or
            ResourceState.Degraded
                ? ResourceActionKind.Restart
                : ResourceActionKind.Start;

        return ProjectedResource.ResourceActions.FirstOrDefault(action => action.Kind == preferredKind) ??
            ProjectedResource.ResourceActions.FirstOrDefault(action =>
                action.Kind is ResourceActionKind.Start or ResourceActionKind.Restart);
    }

    private static string GetContainerHostCapabilitiesLabel(ContainerHostDescriptor host) =>
        host.HostCapabilities.Count == 0
            ? "none advertised"
            : string.Join(", ", host.HostCapabilities.Order(StringComparer.OrdinalIgnoreCase));

    private ContainerHostPlacementView GetContainerHostPlacement(ApplicationResourceDefinition application)
    {
        var requestedHostId = NormalizeNullable(application.ContainerHostId);
        var hosts = GetContainerHosts();
        var host = string.IsNullOrWhiteSpace(requestedHostId)
            ? hosts.FirstOrDefault(candidate => candidate.IsDefault)
            : hosts.FirstOrDefault(candidate =>
                string.Equals(candidate.Id, requestedHostId, StringComparison.OrdinalIgnoreCase));
        var hostResource = host is null
            ? null
            : ResourceManager.GetResource(host.Id);

        return new ContainerHostPlacementView(
            requestedHostId,
            host,
            hostResource);
    }

    private IReadOnlyList<ContainerHostDescriptor> GetContainerHosts()
    {
        var configuredHosts = ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id));
        var resourceHosts = ResourceManager
            .GetResources()
            .Select(TryReadContainerHost)
            .Where(host => host is not null)
            .Select(host => host!);

        return configuredHosts
            .Concat(resourceHosts)
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .OrderByDescending(host => host.IsDefault)
            .ThenBy(host => host.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private ContainerHostDescriptor? TryReadContainerHost(Resource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            if (!descriptor.ResourceType.Equals(ContainerHostResourceTypes.ContainerHost, StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            return descriptor.Configuration.Deserialize<ContainerHostDescriptor>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private IReadOnlyList<NetworkEndpointMappingView> GetInboundNetworkMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => resource.ResourceClass == ResourceClass.Network)
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => GetResourceLabel(mapping.Network), StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<LoadBalancerRouteView> GetInboundLoadBalancerRoutes(string resourceId) =>
        ResourceManager.GetResources()
            .Where(IsLoadBalancerResource)
            .SelectMany(loadBalancer => loadBalancer.ResourceLoadBalancerRoutes
                .Where(route => string.Equals(
                    route.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(route => new LoadBalancerRouteView(loadBalancer, route)))
            .OrderBy(route => GetResourceLabel(route.LoadBalancer), StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Route.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<NameMappingView> GetInboundNameMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => ResourceNameMappingDisplay.IsNameMappingResource(resource))
            .Where(resource => ResourceNameMappingDisplay.TargetsResource(resource, resourceId))
            .Select(resource => new NameMappingView(ResolveParentResource(resource), resource))
            .OrderBy(mapping => ResourceNameMappingDisplay.GetHostName(mapping.Mapping), StringComparer.OrdinalIgnoreCase)
