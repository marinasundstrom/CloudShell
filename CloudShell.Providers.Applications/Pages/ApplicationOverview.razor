        (application.Observability ?? ResourceObservability.Default).Traces;

    private static string GetLogsSummary(IReadOnlyList<LogDescriptor> logs) =>
        logs.Count == 1
            ? "1 log source is available for this application."
            : $"{logs.Count} log sources are available for this application.";

    private static string GetLogSourcesSummary(IReadOnlyList<LogDescriptor> logs)
    {
        var sourceKinds = logs
            .Select(log => log.SourceKind.ToString())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Order(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return sourceKinds.Length == 0
            ? "No source kind metadata"
            : $"Sources: {string.Join(", ", sourceKinds)}";
    }

