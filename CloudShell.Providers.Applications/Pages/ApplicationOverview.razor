    private static string? GetEndpointAddress(ApplicationResourceDefinition application)
    {
        if (IsSqlServer(application))
        {
            return GetSqlServerEndpointAddress(application);
        }

        if (!IsAspNetCoreProject(application))
        {
            return application.Endpoint;
        }

        var port = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "http", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return port?.Port is null
            ? null
            : $"{port.Protocol}://localhost:{port.Port.Value}";
    }

    private OverviewEndpoint GetOverviewEndpoint(ApplicationResourceDefinition application)
    {
        if (GetPreferredNameMappingEndpoint() is { } mappedEndpoint)
        {
            return mappedEndpoint;
        }

        var projectedEndpoint = GetPreferredProjectedEndpoint();
        if (projectedEndpoint is not null &&
            ProjectedResource is not null &&
            ProjectedResource.TryGetResolvedEndpointUri(projectedEndpoint, out var endpointUri))
        {
            var address = endpointUri.ToString();
            if (!string.IsNullOrWhiteSpace(address))
            {
                return new OverviewEndpoint(address, $"{projectedEndpoint.Name} endpoint");
            }
        }

        var configuredAddress = GetEndpointAddress(application);
        return new OverviewEndpoint(
            configuredAddress,
            string.IsNullOrWhiteSpace(configuredAddress) ? null : "configured endpoint");
    }

    private OverviewEndpoint? GetPreferredNameMappingEndpoint()
    {
        var mapping = InboundNameMappings
            .Select(view => view.Mapping)
            .OrderBy(GetNameMappingExposureRank)
            .ThenBy(ResourceNameMappingDisplay.GetHostName, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();
        if (mapping is null)
        {
            return null;
        }

        var hostName = ResourceNameMappingDisplay.GetHostName(mapping);
        if (string.IsNullOrWhiteSpace(hostName))
        {
            return null;
        }

        var endpointName = ResourceNameMappingDisplay.GetTargetEndpointName(mapping);
        var endpoint = ProjectedResource?.Endpoints.FirstOrDefault(endpoint =>
                string.Equals(endpoint.Name, endpointName, StringComparison.OrdinalIgnoreCase)) ??
            ProjectedResource?.Endpoints.FirstOrDefault();
        Uri? endpointUri = null;
        if (endpoint is not null &&
            ProjectedResource is not null &&
            ProjectedResource.TryGetResolvedEndpointUri(endpoint, out var resolvedUri))
        {
            endpointUri = resolvedUri;
        }

        var address = CreateMappedEndpointAddress(hostName, endpointUri);
        return new OverviewEndpoint(
            address,
            $"{ResourceNameMappingDisplay.GetExposureLabel(mapping)} DNS name");
    }

    private static int GetNameMappingExposureRank(Resource mapping) =>
        ResourceNameMappingDisplay.GetExposureLabel(mapping) switch
        {
            nameof(ResourceExposureScope.Public) => 0,
            nameof(ResourceExposureScope.Network) => 1,
            nameof(ResourceExposureScope.Private) => 2,
            nameof(ResourceExposureScope.Local) => 3,
            _ => 4
        };

    private static string CreateMappedEndpointAddress(string hostName, Uri? endpointUri)
    {
        if (endpointUri is null)
        {
            return hostName;
        }

        var builder = new UriBuilder(endpointUri)
        {
            Host = hostName
        };
        return builder.Uri.ToString();
    }

    private ResourceEndpoint? GetPreferredProjectedEndpoint()
    {
        if (ProjectedResource?.Endpoints.Count > 0)
        {
            return ProjectedResource.Endpoints
                .OrderBy(endpoint => GetEndpointExposureRank(endpoint.Exposure))
                .ThenBy(endpoint => GetEndpointProtocolRank(endpoint.Protocol))
                .ThenBy(endpoint => endpoint.Name, StringComparer.OrdinalIgnoreCase)
                .FirstOrDefault();
        }

        return null;
    }

    private static int GetEndpointExposureRank(ResourceExposureScope exposure) =>
        exposure switch
        {
            ResourceExposureScope.Public => 0,
            ResourceExposureScope.Network => 1,
            ResourceExposureScope.Private => 2,
            ResourceExposureScope.Local => 3,
            _ => 4
        };

    private static int GetEndpointProtocolRank(string protocol) =>
        protocol switch
        {
            "https" => 0,
            "http" => 1,
            _ => 2
        };

    private static string GetProtocol(string address) =>
        Uri.TryCreate(address, UriKind.Absolute, out var uri) ? uri.Scheme : "tcp";

    private async Task<IReadOnlyList<LogDescriptor>> GetLogsAsync(string resourceId)
    {
        var logs = await LogManager.ListLogsAsync(new LogQuery(ResourceId: resourceId));

        return logs
            .OrderBy(log => log.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(log => log.Id, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

