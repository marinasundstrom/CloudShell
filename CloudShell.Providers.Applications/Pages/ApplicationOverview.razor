    private static string BuildTraceRoute(string resourceId) =>
        BuildRoute(
            "/observability/traces",
            new Dictionary<string, string?> { ["resourceId"] = resourceId });

    private static string BuildActivityRoute(string resourceId) =>
        BuildRoute(
            ResourceManagerRoutes.ResourceDetails(resourceId),
            new Dictionary<string, string?> { ["tab"] = ResourcePredefinedViewIds.Activity.Value });

    private static string BuildRoute(string path, Dictionary<string, string?> query)
    {
        var queryString = string.Join(
            "&",
            query
                .Where(parameter => !string.IsNullOrWhiteSpace(parameter.Value))
                .Select(parameter =>
                    $"{Uri.EscapeDataString(parameter.Key)}={Uri.EscapeDataString(parameter.Value!)}"));

        return string.IsNullOrWhiteSpace(queryString)
            ? path
            : $"{path}?{queryString}";
    }

    private static string? GetSqlServerConnectionString(ApplicationResourceDefinition application)
    {
        var address = GetSqlServerEndpointAddress(application);
        if (string.IsNullOrWhiteSpace(address) ||
            !Uri.TryCreate(address, UriKind.Absolute, out var uri))
        {
            return null;
        }

        var server = uri.Port > 0
            ? $"{uri.Host},{uri.Port}"
            : uri.Host;
        var password = GetSqlServerPassword(application) ?? "<SA password>";
        return $"Server={server};User Id=sa;Password={password};TrustServerCertificate=True;";
    }

    private static string? GetSqlServerEndpointAddress(ApplicationResourceDefinition application)
    {
        var endpoint = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "tds", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return endpoint?.Port is null
            ? null
            : $"{endpoint.Protocol}://localhost:{endpoint.Port.Value}";
    }

    private static string? GetSqlServerPassword(ApplicationResourceDefinition application) =>
        application.EnvironmentVariables.FirstOrDefault(variable =>
            string.Equals(variable.Name, "MSSQL_SA_PASSWORD", StringComparison.OrdinalIgnoreCase))?.Value;

    private static string GetObservabilityLabel(ResourceObservability? observability)
    {
        var effective = observability ?? ResourceObservability.Default;
        if (!effective.HasAnySignal)
        {
            return "disabled";
        }

        var signals = new[]
            {
                effective.Logs ? "logs" : null,
                effective.Traces ? "traces" : null,
                effective.Metrics ? "metrics" : null
            }
            .Where(signal => signal is not null);
        var exporter = string.IsNullOrWhiteSpace(effective.OtlpEndpoint)
            ? "default OTLP endpoint"
            : effective.OtlpEndpoint;

        return $"{string.Join(", ", signals)} to {exporter}";
    }

    private async Task CopyText(string value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
        }
    }

