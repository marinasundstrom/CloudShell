    private static string BuildResourceLogsRoute(string resourceId, IReadOnlyList<LogDescriptor> logs)
    {
        var query = new Dictionary<string, string?>
        {
            ["tab"] = ResourcePredefinedViewIds.Logs.Value
        };

        if (logs.Count == 1)
        {
            query["logId"] = logs[0].Id;
        }

        return BuildRoute(ResourceManagerRoutes.ResourceDetails(resourceId), query);
