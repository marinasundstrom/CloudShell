        }

        if (Application?.EnvironmentVariables.Count > 0)
        {
            parts.Add(FormatCount(Application.EnvironmentVariables.Count, "environment variable", "environment variables"));
        }

        return parts.Count == 0 ? "none" : string.Join(", ", parts);
    }

