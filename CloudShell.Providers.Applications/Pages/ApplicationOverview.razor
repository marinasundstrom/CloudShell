    private IReadOnlyList<VolumeMountView> GetVolumeMounts(IReadOnlyList<ResourceVolumeMount> mounts) =>
        mounts
            .Where(mount =>
                !string.IsNullOrWhiteSpace(mount.VolumeReference) &&
                !string.IsNullOrWhiteSpace(mount.TargetPath))
            .Select(mount => new VolumeMountView(
                mount,
                ResolveVolumeResource(mount.NormalizedVolumeReference),
                ResolveRuntimeVolumeMount(mount)))
            .OrderBy(mount => mount.Mount.NormalizedTargetPath, StringComparer.OrdinalIgnoreCase)
