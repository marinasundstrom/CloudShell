@if (Row.IsSensitiveLiteral)
{
    <SensitiveLiteralValue Value="@Row.Target" EmptyLabel="empty" />
}
else
{
    <span>@Row.Target</span>
}

@if (!string.IsNullOrWhiteSpace(Row.Detail))
{
    <small>@Row.Detail</small>
}

@code {
    [Parameter, EditorRequired]
    public ApplicationSettingDisplayRow Row { get; set; } = null!;
}
