<ResourceEditorSection Title="Volume mounts">
    <Actions>
        <FluentButton Appearance="Appearance.Neutral"
                      Disabled="@Disabled"
                      OnClick="AddMount">
            Add mount
        </FluentButton>
    </Actions>
    <ChildContent>
        @if (ApplicationVolumeMountReplicaWarning.ShouldShow(ReplicasEnabled, Mounts))
        {
            <div class="procedure-message compact">
                @ApplicationVolumeMountReplicaWarning.Message
            </div>
        }

        @if (VolumeCandidates.Count == 0)
        {
            <span>No volume resources are available in this group.</span>
        }
        else
        {
            @foreach (var mount in Mounts)
            {
                <div class="environment-row" @key="mount">
                    <FluentSelect TOption="string"
                                  AriaLabel="Volume resource"
                                  Disabled="@Disabled"
                                  @bind-Value="mount.VolumeReference"
                                  Appearance="Appearance.Outline">
                        <FluentOption TOption="string" Value="">Select volume</FluentOption>
                        @foreach (var volume in VolumeCandidates)
                        {
                            <FluentOption TOption="string" Value="@volume.Id">@ApplicationVolumeResourceDisplay.GetVolumeOptionLabel(volume)</FluentOption>
                        }
                    </FluentSelect>
                    <FluentTextField AriaLabel="Target path"
                                     Disabled="@Disabled"
                                     @bind-Value="mount.TargetPath"
                                     Placeholder="@TargetPathPlaceholder" />
                    <FluentCheckbox Disabled="@Disabled" @bind-Value="mount.ReadOnly">
                        Read-only
                    </FluentCheckbox>
                    <FluentButton Appearance="Appearance.Neutral"
                                  Disabled="@Disabled"
                                  OnClick="() => RemoveMount(mount)">
                        Remove
                    </FluentButton>
                </div>
            }
        }
    </ChildContent>
</ResourceEditorSection>

@code {
    [Parameter, EditorRequired]
    public List<ApplicationVolumeMountInput> Mounts { get; set; } = [];

    [Parameter]
    public IReadOnlyList<Resource> VolumeCandidates { get; set; } = [];

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool ReplicasEnabled { get; set; }

    [Parameter]
    public string? TargetPathPlaceholder { get; set; } = "/data";

    private void AddMount() => Mounts.Add(new());

    private void RemoveMount(ApplicationVolumeMountInput mount)
    {
        Mounts.Remove(mount);
        if (Mounts.Count == 0)
        {
            Mounts.Add(new());
        }
    }
}
