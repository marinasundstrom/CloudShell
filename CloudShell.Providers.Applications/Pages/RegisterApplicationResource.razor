@inject ApplicationResourceProvider ApplicationProvider
@inject IResourceManager ResourceActions
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <label for="application-template">Configured application</label>
        <FluentSelect TOption="string"
                      Id="application-template"
                      Value="@ApplicationId"
                      ValueChanged="SelectTemplate"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">New application</FluentOption>
            @foreach (var application in ApplicationProvider.GetApplications())
            {
                <FluentOption TOption="string" Value="@application.Id">@application.Name</FluentOption>
            }
        </FluentSelect>

        <ResourceIdentityFields ResourceIdInputId="application-resource-id"
                                DisplayNameInputId="application-display-name"
                                ResourceIdPlaceholder="application:example-api"
                                @bind-ResourceId="ResourceId"
                                @bind-DisplayName="Name" />

        <label for="application-executable">Executable path</label>
        <FluentTextField Id="application-executable" @bind-Value="ExecutablePath" />

        <label for="application-arguments">Arguments</label>
        <FluentTextField Id="application-arguments" @bind-Value="Arguments" />

        <label for="application-working-directory">Working directory</label>
        <FluentTextField Id="application-working-directory" @bind-Value="WorkingDirectory" />

        <EndpointAssignmentEditor AssignmentId="application-endpoint-assignment"
                                  AssignmentLabel="Endpoint assignment"
                                  ShowPort="false"
                                  @bind-Assignment="EndpointAssignment" />

        @if (IsManualEndpointAssignment)
        {
            <label for="application-endpoint">Endpoint</label>
            <FluentTextField Id="application-endpoint" @bind-Value="Endpoint" />
        }

        <EnumValueSelect TEnum="ApplicationLifetime"
                         Id="application-lifetime"
                         Label="Lifetime"
                         LabelSelector="GetLifetimeLabel"
                         @bind-Value="SelectedLifetime" />

        <FluentCheckbox @bind-Value="UseServiceDiscovery">
            Enable service discovery for references
        </FluentCheckbox>

        <FluentCheckbox @bind-Value="EnableObservability">
            Enable observability
        </FluentCheckbox>

        <ResourceGroupSelect Id="application-group"
                             ResourceGroups="ResourceGroups.GetResourceGroups()"
                             @bind-Value="SelectedGroupId" />

        <ResourceSelectionSection Title="Dependencies"
                                  Resources="GetDependencyCandidates()"
                                  SelectedResourceIds="SelectedDependencyIds" />

        <ApplicationEnvironmentVariablesEditor Variables="EnvironmentVariables" />

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FluentCheckbox @bind-Value="StartAfterCreate">
            Start after create
        </FluentCheckbox>

        <FormPrimaryAction OnClick="Register" />
    </div>
</div>

@code {
    private string? ApplicationId { get; set; }
    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string ExecutablePath { get; set; } = string.Empty;
    private string? Arguments { get; set; }
    private string? WorkingDirectory { get; set; }
    private string? Endpoint { get; set; }
    private ResourceEndpointAssignment EndpointAssignment { get; set; } =
        ResourceEndpointAssignment.ProviderDefault;
    private string SelectedLifetime { get; set; } = ApplicationLifetime.Detached.ToString();
    private bool UseServiceDiscovery { get; set; }
    private bool EnableObservability { get; set; } = true;
    private string? ContainerImage { get; set; }
    private string? ContainerBuildContext { get; set; }
    private string? ContainerDockerfile { get; set; }
    private int Replicas { get; set; } = 1;
    private string SelectedGroupId { get; set; } = string.Empty;
    private bool StartAfterCreate { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private List<ApplicationEnvironmentVariableInput> EnvironmentVariables { get; } = [new()];
    private HashSet<string> SelectedDependencyIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<string> ReferenceIds { get; set; } = [];

    private bool IsManualEndpointAssignment =>
        EndpointAssignment == ResourceEndpointAssignment.Manual;

    [CascadingParameter(Name = ResourceIdentityFields.DisplayNamesEnabledCascadingParameterName)]
    private bool EnableDisplayNames { get; set; } = true;

    private void SelectTemplate(string? applicationId)
    {
        if (string.IsNullOrWhiteSpace(applicationId))
        {
            ApplicationId = null;
            ResourceId = string.Empty;
            Name = string.Empty;
            ExecutablePath = string.Empty;
            Arguments = null;
            WorkingDirectory = null;
            Endpoint = null;
            EndpointAssignment = ResourceEndpointAssignment.ProviderDefault;
            SelectedLifetime = ApplicationLifetime.Detached.ToString();
            UseServiceDiscovery = false;
            EnableObservability = true;
            ContainerImage = null;
            ContainerBuildContext = null;
            ContainerDockerfile = null;
            Replicas = 1;
            SelectedDependencyIds.Clear();
            ReferenceIds = [];
            EnvironmentVariables.Clear();
            EnvironmentVariables.Add(new());
            return;
        }

        var application = ApplicationProvider.GetApplication(applicationId);
        if (application is not null)
        {
            LoadApplication(application);
        }
    }

    private void LoadApplication(ApplicationResourceDefinition application)
    {
        ApplicationId = application.Id;
        ResourceId = application.Id;
        Name = application.Name;
        ExecutablePath = application.ExecutablePath;
        Arguments = application.Arguments;
        WorkingDirectory = application.WorkingDirectory;
        Endpoint = application.Endpoint;
        EndpointAssignment = string.IsNullOrWhiteSpace(application.Endpoint)
            ? ResourceEndpointAssignment.ProviderDefault
            : ResourceEndpointAssignment.Manual;
        SelectedLifetime = application.Lifetime.ToString();
        UseServiceDiscovery = application.UseServiceDiscovery;
        EnableObservability = (application.Observability ?? ResourceObservability.Default).HasAnySignal;
        ContainerImage = application.ContainerImage;
        ContainerBuildContext = application.ContainerBuildContext;
        ContainerDockerfile = application.ContainerDockerfile;
        Replicas = application.Replicas;
        ReferenceIds = application.References;
        SelectedGroupId = ResourceManager.GetGroupForResource(application.Id)?.Id ?? string.Empty;
        SelectedDependencyIds.Clear();
        foreach (var dependency in application.DependsOn)
        {
            if (IsInSelectedGroup(dependency))
            {
                SelectedDependencyIds.Add(dependency);
            }
        }

        EnvironmentVariables.Clear();
        EnvironmentVariables.AddRange(application.EnvironmentVariables
            .Select(variable => new ApplicationEnvironmentVariableInput(variable.Name, variable.Value)));
        if (EnvironmentVariables.Count == 0)
        {
            EnvironmentVariables.Add(new());
        }
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(ResourceId) || string.IsNullOrWhiteSpace(ExecutablePath))
        {
            ErrorMessage = "Resource ID and executable path are required.";
            return;
        }

        var normalizedResourceId = ResourceId.Trim();
        if (!string.IsNullOrWhiteSpace(normalizedResourceId) &&
            IsResourceIdInUse(normalizedResourceId, ApplicationId))
        {
            ErrorMessage = $"Resource ID '{normalizedResourceId}' is already in use.";
            return;
        }

        if (IsManualEndpointAssignment && string.IsNullOrWhiteSpace(Endpoint))
        {
            ErrorMessage = "Manual endpoint assignment requires an endpoint.";
            return;
        }

        var displayName = ResourceDisplayNameDefaults.Resolve(EnableDisplayNames, Name, normalizedResourceId);
        var definition = new ApplicationResourceDefinition(
            normalizedResourceId,
            displayName,
            ExecutablePath,
            Arguments,
            WorkingDirectory,
            IsManualEndpointAssignment ? Endpoint : null,
            BuildEnvironmentVariables(),
            ParseLifetime(),
            BuildDependencies(),
            ReferenceIds,
            UseServiceDiscovery,
            NormalizeNullable(ContainerImage),
            NormalizeNullable(ContainerBuildContext),
            NormalizeNullable(ContainerDockerfile),
            null,
            Math.Max(1, Replicas),
            resourceType: ApplicationResourceTypes.ExecutableApplication,
            observability: EnableObservability ? ResourceObservability.Default : ResourceObservability.None);

        await ApplicationProvider.SetupApplicationAsync(definition, SelectedGroupId, Registrations);
        if (StartAfterCreate)
        {
            await ResourceActions.StartResourceAsync(definition.Id, startDependencies: true);
        }

        Navigation.NavigateTo("/resources");
    }

    private IReadOnlyList<EnvironmentVariableAssignment> BuildEnvironmentVariables() =>
        EnvironmentVariables
            .Where(variable => !string.IsNullOrWhiteSpace(variable.Name))
            .Select(variable => new EnvironmentVariableAssignment(variable.Name!.Trim(), variable.Value ?? string.Empty))
            .ToArray();

    private IReadOnlyList<string> BuildDependencies() =>
        SelectedDependencyIds
            .Where(IsInSelectedGroup)
            .Where(dependency => !string.Equals(dependency, GetCurrentResourceId(), StringComparison.OrdinalIgnoreCase))
            .ToArray();

    private IReadOnlyList<Resource> GetDependencyCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => !string.Equals(resource.Id, GetCurrentResourceId(), StringComparison.OrdinalIgnoreCase))
            .Where(resource => IsInSelectedGroup(resource.Id))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string? GetCurrentResourceId() =>
        string.IsNullOrWhiteSpace(ResourceId)
            ? ApplicationId
            : ResourceId.Trim();

    private bool IsResourceIdInUse(string resourceId, string? currentResourceId) =>
        !string.Equals(resourceId, currentResourceId, StringComparison.OrdinalIgnoreCase) &&
        (ResourceManager.GetAvailableResources().Any(resource =>
                string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase)) ||
        Registrations.GetRegistration(resourceId) is not null ||
            ApplicationProvider.GetApplication(resourceId) is not null);

    private bool IsInSelectedGroup(string resourceId)
    {
        var group = ResourceManager.GetGroupForResource(resourceId);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private ApplicationLifetime ParseLifetime() =>
        Enum.TryParse<ApplicationLifetime>(SelectedLifetime, out var lifetime)
            ? lifetime
            : ApplicationLifetime.Detached;

    private static string GetLifetimeLabel(ApplicationLifetime lifetime) =>
        lifetime switch
        {
            ApplicationLifetime.ControlPlaneScoped => "Control plane scoped",
            _ => "Detached"
        };

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

}
