@inject ApplicationResourceProvider ApplicationProvider
@inject IResourceManager ResourceActions
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <ResourceIdentityFields ResourceIdInputId="web-application-resource-id"
                                ResourceIdPlaceholder="example-web-api"
                                @bind-ResourceId="ResourceId" />

        <label for="web-application-project">Project path</label>
        <FluentTextField Id="web-application-project" @bind-Value="ProjectPath" Placeholder="samples/CloudShell.ExampleWebApi/CloudShell.ExampleWebApi.csproj" />

        <label for="web-application-arguments">Application arguments</label>
        <FluentTextField Id="web-application-arguments" @bind-Value="ApplicationArguments" />

        <EndpointAssignmentEditor AssignmentId="web-application-endpoint-assignment"
                                  AssignmentLabel="Endpoint assignment"
                                  PortId="web-application-endpoint-port"
                                  PortLabel="Fixed local port"
                                  Assignments="AspNetCoreEndpointAssignments"
                                  ShowNetwork="true"
                                  NetworkCandidates="GetNetworkCandidates()"
                                  ShowManualAddress="true"
                                  HelpText="@AspNetCoreEndpointHelpText"
                                  @bind-Assignment="EndpointAssignment"
                                  @bind-NetworkResourceId="SelectedNetworkResourceId"
                                  @bind-ManualAddress="ManualEndpointHost"
                                  @bind-Port="EndpointPort" />

        <EnumValueSelect TEnum="ApplicationLifetime"
                         Id="web-application-lifetime"
                         Label="Lifetime"
                         LabelSelector="GetLifetimeLabel"
                         @bind-Value="SelectedLifetime" />

        <FluentCheckbox @bind-Value="UseHotReload">
            Use hot reload
        </FluentCheckbox>

        <FluentCheckbox @bind-Value="UseServiceDiscovery">
            Enable service discovery for references
        </FluentCheckbox>

        <FluentCheckbox @bind-Value="EnableObservability">
            Enable observability
        </FluentCheckbox>

        @if (SupportsHealthChecks)
        {
            <FluentCheckbox @bind-Value="HealthChecksEnabled">
                Enable resource health checks
            </FluentCheckbox>
        }

        <ResourceGroupSelect Id="web-application-group"
                             ResourceGroups="ResourceGroups.GetResourceGroups()"
                             @bind-Value="SelectedGroupId" />

        <ResourceSelectionSection Title="References"
                                  Resources="GetReferenceCandidates()"
                                  SelectedResourceIds="SelectedReferenceIds" />

        <FluentCheckbox @bind-Value="WaitForReferences">
            Start referenced resources first
        </FluentCheckbox>

        <ApplicationEnvironmentVariablesEditor Variables="EnvironmentVariables" />

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FluentCheckbox @bind-Value="StartAfterCreate">
            Start after create
        </FluentCheckbox>

        <FormPrimaryAction OnClick="Register" />
    </div>
</div>

@code {
    [CascadingParameter]
    public ResourceRegistrationProbeContext? ProbeContext { get; set; }

    [CascadingParameter]
    public ResourceRegistrationNavigationContext? RegistrationNavigation { get; set; }

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string ProjectPath { get; set; } = string.Empty;
    private string? ApplicationArguments { get; set; }
    private int? EndpointPort { get; set; }
    private string? SelectedNetworkResourceId { get; set; }
    private string? ManualEndpointHost { get; set; }
    private ResourceEndpointAssignment EndpointAssignment { get; set; } =
        ResourceEndpointAssignment.ProviderDefault;
    private string SelectedLifetime { get; set; } = ApplicationLifetime.Detached.ToString();
    private bool UseHotReload { get; set; }
    private bool UseServiceDiscovery { get; set; } = true;
    private bool EnableObservability { get; set; } = true;
    private bool WaitForReferences { get; set; } = true;
    private bool StartAfterCreate { get; set; } = true;
    private string SelectedGroupId { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private List<ApplicationEnvironmentVariableInput> EnvironmentVariables { get; } = [new()];
    private HashSet<string> SelectedReferenceIds { get; } = new(StringComparer.OrdinalIgnoreCase);

    private static IReadOnlyList<ResourceEndpointAssignment> AspNetCoreEndpointAssignments { get; } =
    [
        ResourceEndpointAssignment.ProviderDefault,
        ResourceEndpointAssignment.Manual
    ];

    private const string AspNetCoreEndpointHelpText =
        "CloudShell assigns a local mapping for development. Use a fixed local port only when callers on this machine need a stable address; private IPs, internal DNS names, and public endpoints are configured through Networking.";

    private bool SupportsHealthChecks => ProbeContext?.SupportsHealthChecks == true;

    private bool IsManualEndpointAssignment =>
        EndpointAssignment == ResourceEndpointAssignment.Manual;

    private bool HealthChecksEnabled
    {
        get => ProbeContext?.EnableHealthChecks == true;
        set
        {
            if (ProbeContext is not null)
            {
                ProbeContext.EnableHealthChecks = value;
            }
        }
    }

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(ResourceId) || string.IsNullOrWhiteSpace(ProjectPath))
        {
            ErrorMessage = "Name and project path are required.";
            return;
        }

        var normalizedResourceId = ResourceNameNormalizer.Normalize(ResourceId, "application");
        if (!string.IsNullOrWhiteSpace(normalizedResourceId) &&
            IsResourceIdInUse(normalizedResourceId))
        {
            ErrorMessage = $"Name '{ResourceId.Trim()}' resolves to existing resource '{normalizedResourceId}'.";
            return;
        }

        if (IsManualEndpointAssignment &&
            (EndpointPort is null || EndpointPort <= 0))
        {
            ErrorMessage = "Manual endpoint assignment requires a fixed local port.";
            return;
        }

        var displayName = ResourceDisplayNameDefaults.Resolve(ResourceId);
        var references = SelectedReferenceIds.ToArray();
        var definition = new ApplicationResourceDefinition(
            normalizedResourceId,
            displayName,
            executablePath: string.Empty,
            environmentVariables: BuildEnvironmentVariables(),
            lifetime: ParseLifetime(),
            dependsOn: WaitForReferences ? references : [],
            references: references,
            useServiceDiscovery: UseServiceDiscovery && references.Length > 0,
            endpointPorts: BuildEndpointPorts(),
            resourceType: ApplicationResourceTypes.AspNetCoreProject,
            healthChecks: ProbeContext?.GetSelectedHealthChecks(),
            observability: EnableObservability ? ResourceObservability.Default : ResourceObservability.None,
            projectPath: ProjectPath,
            projectArguments: ApplicationArguments,
            aspNetCoreHotReload: UseHotReload);

        await ApplicationProvider.SetupApplicationAsync(definition, SelectedGroupId, Registrations);
        if (StartAfterCreate)
        {
            await ResourceActions.StartResourceAsync(definition.Id, startDependencies: true);
        }

        Navigation.NavigateTo(GetReturnUrl());
    }

    private string GetReturnUrl() =>
        RegistrationNavigation?.GetReturnUrlOrDefault() ??
        ResourceRegistrationNavigationContext.DefaultReturnUrl;

    private IReadOnlyList<EnvironmentVariableAssignment> BuildEnvironmentVariables() =>
        EnvironmentVariables
            .Where(variable => !string.IsNullOrWhiteSpace(variable.Name))
            .Select(variable => new EnvironmentVariableAssignment(variable.Name!.Trim(), variable.Value ?? string.Empty))
            .ToArray();

    private IReadOnlyList<ServicePort> BuildEndpointPorts()
    {
        if (IsManualEndpointAssignment && EndpointPort is { } port)
        {
            var fixedPort = Math.Max(1, port);
            return
            [
                new ServicePort(
                    "http",
                    fixedPort,
                    fixedPort,
                    "http",
                    ResourceExposureScope.Local,
                    EndpointAssignment,
                    NormalizeNullable(SelectedNetworkResourceId),
                    NormalizeNullable(ManualEndpointHost))
            ];
        }

        return
        [
            new ServicePort(
                "http",
                80,
                Protocol: "http",
                Exposure: ResourceExposureScope.Local,
                Assignment: EndpointAssignment,
                NetworkResourceId: NormalizeNullable(SelectedNetworkResourceId))
        ];
    }

    private IReadOnlyList<Resource> GetNetworkCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => resource.ResourceClass == ResourceClass.Network)
            .Where(IsInSelectedGroup)
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<Resource> GetReferenceCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => !string.Equals(resource.Id, GetCurrentResourceId(), StringComparison.OrdinalIgnoreCase))
            .Where(IsInSelectedGroup)
            .Where(resource => !string.Equals(resource.EffectiveTypeId, "cloudshell.network", StringComparison.OrdinalIgnoreCase))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private bool IsInSelectedGroup(Resource resource)
    {
        var group = ResourceManager.GetGroupForResource(resource.Id);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private string? GetCurrentResourceId() =>
        string.IsNullOrWhiteSpace(ResourceId) ? null : ResourceId.Trim();

    private bool IsResourceIdInUse(string resourceId) =>
        ResourceManager.GetAvailableResources().Any(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase)) ||
        Registrations.GetRegistration(resourceId) is not null ||
        ApplicationProvider.GetApplication(resourceId) is not null;

    private ApplicationLifetime ParseLifetime() =>
        Enum.TryParse<ApplicationLifetime>(SelectedLifetime, out var lifetime)
            ? lifetime
            : ApplicationLifetime.Detached;

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string GetLifetimeLabel(ApplicationLifetime lifetime) =>
        lifetime switch
        {
            ApplicationLifetime.ControlPlaneScoped => "Control plane scoped",
            _ => "Detached"
        };

}
