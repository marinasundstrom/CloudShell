@using System.Text.Json
@inject ApplicationResourceProvider ApplicationProvider
@inject IResourceManager ResourceActions
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject IEnumerable<IContainerEngineProvider> ContainerEngineProviders
@inject IEnumerable<IResourceOrchestrationDescriptorProvider> DescriptorProviders
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        @if (!HasImplicitContainerEngine())
        {
            <div class="procedure-confirmation">
                <strong>No default container engine</strong>
                <span>Select a container engine for this resource or register a default engine with UseDocker() or UseContainerEngine(...).</span>
            </div>
        }

        <label for="container-name">Name</label>
        <FluentTextField Id="container-name" @bind-Value="Name" />

        <label for="container-resource-id">Resource ID</label>
        <FluentTextField Id="container-resource-id" @bind-Value="ResourceId" Placeholder="application:redis" />

        <label for="container-image">Image</label>
        <FluentTextField Id="container-image" @bind-Value="Image" Placeholder="redis:7.2" />

        <label for="container-engine">Container engine</label>
        <FluentSelect TOption="string"
                      Id="container-engine"
                      @bind-Value="SelectedEngineId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default engine</FluentOption>
            @foreach (var engine in GetContainerEngines())
            {
                <FluentOption TOption="string" Value="@engine.Id">@GetEngineLabel(engine)</FluentOption>
            }
        </FluentSelect>

        <label for="container-lifetime">Lifetime</label>
        <FluentSelect TOption="string"
                      Id="container-lifetime"
                      @bind-Value="SelectedLifetime"
                      Appearance="Appearance.Outline">
            @foreach (var lifetime in Enum.GetValues<ApplicationLifetime>())
            {
                <FluentOption TOption="string" Value="@lifetime.ToString()">@GetLifetimeLabel(lifetime)</FluentOption>
            }
        </FluentSelect>

        <FluentCheckbox @bind-Value="ExposeEndpoint">
            Expose local endpoint
        </FluentCheckbox>

        @if (ExposeEndpoint)
        {
            <label for="container-port-name">Endpoint name</label>
            <FluentTextField Id="container-port-name" @bind-Value="PortName" />

            <label for="container-target-port">Container port</label>
            <FluentNumberField TValue="int" Id="container-target-port" Min="1" @bind-Value="TargetPort" />

            <label for="container-local-port">Local port</label>
            <FluentNumberField TValue="int?" Id="container-local-port" Min="1" @bind-Value="LocalPort" />

            <label for="container-protocol">Protocol</label>
            <FluentSelect TOption="string"
                          Id="container-protocol"
                          @bind-Value="Protocol"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="tcp">TCP</FluentOption>
                <FluentOption TOption="string" Value="udp">UDP</FluentOption>
            </FluentSelect>
        }

        <label for="container-group">Resource group</label>
        <FluentSelect TOption="string"
                      Id="container-group"
                      @bind-Value="SelectedGroupId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default group</FluentOption>
            @foreach (var group in ResourceGroups.GetResourceGroups())
            {
                <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
            }
        </FluentSelect>

        <div class="environment-editor">
            <div class="environment-header">
                <strong>References</strong>
            </div>

            @foreach (var resource in GetReferenceCandidates())
            {
                <FluentCheckbox Value="@SelectedReferenceIds.Contains(resource.Id)"
                                ValueChanged="selected => ToggleReference(resource.Id, selected)">
                    @resource.Name
                </FluentCheckbox>
            }
        </div>

        <FluentCheckbox @bind-Value="WaitForReferences">
            Start referenced resources first
        </FluentCheckbox>

        <FluentCheckbox @bind-Value="EnableObservability">
            Enable observability
        </FluentCheckbox>

        <div class="environment-editor">
            <div class="environment-header">
                <strong>Environment variables</strong>
                <FluentButton Appearance="Appearance.Neutral" OnClick="AddEnvironmentVariable">
                    Add variable
                </FluentButton>
            </div>

            @foreach (var variable in EnvironmentVariables)
            {
                <div class="environment-row">
                    <FluentTextField AriaLabel="Environment variable name" @bind-Value="variable.Name" />
                    <FluentTextField AriaLabel="Environment variable value" @bind-Value="variable.Value" />
                    <FluentButton Appearance="Appearance.Neutral" OnClick="() => RemoveEnvironmentVariable(variable)">
                        Remove
                    </FluentButton>
                </div>
            }
        </div>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FluentCheckbox @bind-Value="StartAfterCreate">
            Start after create
        </FluentCheckbox>

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string Image { get; set; } = string.Empty;
    private string SelectedEngineId { get; set; } = string.Empty;
    private string SelectedLifetime { get; set; } = ApplicationLifetime.ControlPlaneScoped.ToString();
    private bool ExposeEndpoint { get; set; }
    private string PortName { get; set; } = "tcp";
    private int TargetPort { get; set; } = 80;
    private int? LocalPort { get; set; }
    private string Protocol { get; set; } = "tcp";
    private string SelectedGroupId { get; set; } = string.Empty;
    private bool WaitForReferences { get; set; } = true;
    private bool EnableObservability { get; set; } = true;
    private bool StartAfterCreate { get; set; } = true;
    private string? ErrorMessage { get; set; }
    private List<EnvironmentVariableInput> EnvironmentVariables { get; } = [new()];
    private HashSet<string> SelectedReferenceIds { get; } = new(StringComparer.OrdinalIgnoreCase);

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name) || string.IsNullOrWhiteSpace(Image))
        {
            ErrorMessage = "Name and image are required.";
            return;
        }

        if (!ValidateContainerEngine())
        {
            return;
        }

        if (ExposeEndpoint &&
            (string.IsNullOrWhiteSpace(PortName) || TargetPort <= 0))
        {
            ErrorMessage = "Endpoint name and container port are required.";
            return;
        }

        var normalizedResourceId = ResourceId.Trim();
        if (!string.IsNullOrWhiteSpace(normalizedResourceId) &&
            IsResourceIdInUse(normalizedResourceId))
        {
            ErrorMessage = $"Resource ID '{normalizedResourceId}' is already in use.";
            return;
        }

        var references = SelectedReferenceIds.ToArray();
        var definition = new ApplicationResourceDefinition(
            normalizedResourceId,
            Name,
            executablePath: string.Empty,
            environmentVariables: BuildEnvironmentVariables(),
            lifetime: ParseLifetime(),
            dependsOn: WaitForReferences ? references : [],
            references: references,
            useServiceDiscovery: references.Length > 0,
            containerImage: Image.Trim(),
            containerEngineId: NormalizeNullable(SelectedEngineId),
            endpointPorts: BuildEndpointPorts(),
            resourceType: ApplicationResourceTypes.ContainerImage,
            observability: EnableObservability ? ResourceObservability.Default : ResourceObservability.None);

        await ApplicationProvider.SetupApplicationAsync(definition, SelectedGroupId, Registrations);
        if (StartAfterCreate)
        {
            await ResourceActions.RunResourceAsync(definition.Id, startDependencies: true);
        }

        Navigation.NavigateTo("/resources");
    }

    private bool ValidateContainerEngine()
    {
        var engines = GetContainerEngines();
        if (!string.IsNullOrWhiteSpace(SelectedEngineId))
        {
            if (engines.Any(engine => string.Equals(engine.Id, SelectedEngineId, StringComparison.OrdinalIgnoreCase)))
            {
                return true;
            }

            ErrorMessage = $"Container engine '{SelectedEngineId}' is not registered.";
            return false;
        }

        if (engines.Any(engine => engine.IsDefault))
        {
            return true;
        }

        ErrorMessage = "A default container engine is required unless this resource selects an explicit engine.";
        return false;
    }

    private IReadOnlyList<ServicePort> BuildEndpointPorts() =>
        ExposeEndpoint
            ? [new ServicePort(PortName, TargetPort, LocalPort, Protocol, ResourceExposureScope.Local)]
            : [];

    private IReadOnlyList<EnvironmentVariableAssignment> BuildEnvironmentVariables() =>
        EnvironmentVariables
            .Where(variable => !string.IsNullOrWhiteSpace(variable.Name))
            .Select(variable => new EnvironmentVariableAssignment(variable.Name!.Trim(), variable.Value ?? string.Empty))
            .ToArray();

    private IReadOnlyList<Resource> GetReferenceCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => !string.Equals(resource.Id, GetCurrentResourceId(), StringComparison.OrdinalIgnoreCase))
            .Where(IsInSelectedGroup)
            .Where(resource => !string.Equals(resource.EffectiveTypeId, "cloudshell.network", StringComparison.OrdinalIgnoreCase))
            .Where(resource => !string.Equals(resource.EffectiveTypeId, "cloudshell.service", StringComparison.OrdinalIgnoreCase))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private bool IsInSelectedGroup(Resource resource)
    {
        var group = ResourceManager.GetGroupForResource(resource.Id);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private string? GetCurrentResourceId() =>
        string.IsNullOrWhiteSpace(ResourceId) ? null : ResourceId.Trim();

    private bool IsResourceIdInUse(string resourceId) =>
        ResourceManager.GetAvailableResources().Any(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase)) ||
        Registrations.GetRegistration(resourceId) is not null ||
        ApplicationProvider.GetApplication(resourceId) is not null;

    private bool HasImplicitContainerEngine() =>
        GetContainerEngines().Any(engine => engine.IsDefault);

    private IReadOnlyList<ContainerEngineResourceDefinition> GetContainerEngines()
    {
        var configuredEngines = ContainerEngineProviders
            .Select(provider => provider.GetContainerEngine())
            .Where(engine => !string.IsNullOrWhiteSpace(engine.Id));
        var resourceEngines = ResourceManager
            .GetResources()
            .Select(TryReadContainerEngine)
            .Where(engine => engine is not null)
            .Select(engine => engine!);

        return configuredEngines
            .Concat(resourceEngines)
            .GroupBy(engine => engine.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .OrderByDescending(engine => engine.IsDefault)
            .ThenBy(engine => engine.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private ContainerEngineResourceDefinition? TryReadContainerEngine(Resource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            if (!descriptor.ResourceType.Equals(ContainerEngineResourceTypes.ContainerEngine, StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            return descriptor.Configuration.Deserialize<ContainerEngineResourceDefinition>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private static string GetEngineLabel(ContainerEngineResourceDefinition engine) =>
        engine.IsDefault ? $"{engine.Name} (default)" : engine.Name;

    private ApplicationLifetime ParseLifetime() =>
        Enum.TryParse<ApplicationLifetime>(SelectedLifetime, out var lifetime)
            ? lifetime
            : ApplicationLifetime.ControlPlaneScoped;

    private static string GetLifetimeLabel(ApplicationLifetime lifetime) =>
        lifetime switch
        {
            ApplicationLifetime.ControlPlaneScoped => "Control plane scoped",
            _ => "Detached"
        };

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private void AddEnvironmentVariable() => EnvironmentVariables.Add(new());

    private void RemoveEnvironmentVariable(EnvironmentVariableInput variable)
    {
        EnvironmentVariables.Remove(variable);
        if (EnvironmentVariables.Count == 0)
        {
            EnvironmentVariables.Add(new());
        }
    }

    private void ToggleReference(string resourceId, bool selected)
    {
        if (selected)
        {
            SelectedReferenceIds.Add(resourceId);
        }
        else
        {
            SelectedReferenceIds.Remove(resourceId);
        }
    }

    private sealed class EnvironmentVariableInput(
        string? name = null,
        string? value = null)
    {
        public string? Name { get; set; } = name;

        public string? Value { get; set; } = value;
    }
}
