@using System.Text.Json
@inject ApplicationResourceProvider ApplicationProvider
@inject IResourceManager ResourceActions
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject IEnumerable<IContainerHostProvider> ContainerHostProviders
@inject IEnumerable<IResourceOrchestrationDescriptorProvider> DescriptorProviders
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        @if (!HasImplicitContainerHost())
        {
            <div class="procedure-confirmation">
                <strong>No default container host</strong>
                <span>Select a container host for this SQL Server resource or register a default host with UseDocker().</span>
            </div>
        }

        <label for="sql-name">Name</label>
        <FluentTextField Id="sql-name" @bind-Value="Name" />

        <label for="sql-resource-id">Resource ID</label>
        <FluentTextField Id="sql-resource-id" @bind-Value="ResourceId" Placeholder="application:sql-server" />

        <label for="sql-image">Image</label>
        <FluentTextField Id="sql-image" @bind-Value="Image" />

        <label for="sql-password">SA password</label>
        <FluentTextField Id="sql-password" TextFieldType="TextFieldType.Password" @bind-Value="Password" />

        <label for="sql-host">Container host</label>
        <FluentSelect TOption="string"
                      Id="sql-host"
                      @bind-Value="SelectedHostId"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default host</FluentOption>
            @foreach (var host in GetContainerHosts())
            {
                <FluentOption TOption="string" Value="@host.Id">@GetHostLabel(host)</FluentOption>
            }
        </FluentSelect>

        <EndpointAssignmentEditor AssignmentId="sql-port-assignment"
                                  PortId="sql-local-port"
                                  PortLabel="Local port"
                                  @bind-Assignment="EndpointAssignment"
                                  @bind-Port="LocalPort" />

        <ResourceGroupSelect Id="sql-group"
                             ResourceGroups="ResourceGroups.GetResourceGroups()"
                             @bind-Value="SelectedGroupId" />

        <ResourceEditorSection Title="Storage">
            @if (GetVolumeCandidates().Count == 0)
            {
                <div class="procedure-message compact">
                    No volume resources are available in this group. SQL Server data will not be persisted if the container is recreated.
                </div>
            }
            else
            {
                <label for="sql-data-volume">Data volume</label>
                <FluentSelect TOption="string"
                              Id="sql-data-volume"
                              @bind-Value="SelectedDataVolumeId"
                              Appearance="Appearance.Outline">
                    <FluentOption TOption="string" Value="">No data volume</FluentOption>
                    @foreach (var volume in GetVolumeCandidates())
                    {
                        <FluentOption TOption="string" Value="@volume.Id">@ApplicationVolumeResourceDisplay.GetVolumeOptionLabel(volume)</FluentOption>
                    }
                </FluentSelect>
                <small>Mounts the selected volume at /var/opt/mssql.</small>
            }

            @if (string.IsNullOrWhiteSpace(SelectedDataVolumeId))
            {
                <div class="procedure-message compact">
                    Data will not be persisted unless a volume is mounted at /var/opt/mssql.
                </div>
            }
        </ResourceEditorSection>

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <FluentCheckbox @bind-Value="StartAfterCreate">
            Start after create
        </FluentCheckbox>

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private const string DefaultImage = "mcr.microsoft.com/mssql/server:2022-latest";
    private const string DefaultPassword = "CloudShell-Passw0rd!";

    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = "SQL Server";
    private string Image { get; set; } = DefaultImage;
    private string Password { get; set; } = DefaultPassword;
    private string SelectedHostId { get; set; } = string.Empty;
    private ResourceEndpointAssignment EndpointAssignment { get; set; } = ResourceEndpointAssignment.Manual;
    private int? LocalPort { get; set; } = 14333;
    private string SelectedGroupId { get; set; } = string.Empty;
    private string SelectedDataVolumeId { get; set; } = string.Empty;
    private bool StartAfterCreate { get; set; } = true;
    private string? ErrorMessage { get; set; }

    private bool IsManualEndpointAssignment =>
        EndpointAssignment == ResourceEndpointAssignment.Manual;

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name) || string.IsNullOrWhiteSpace(Image))
        {
            ErrorMessage = "Name and image are required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "SA password is required.";
            return;
        }

        if (!ValidateContainerHost())
        {
            return;
        }

        if (IsManualEndpointAssignment && LocalPort is null)
        {
            ErrorMessage = "Manual endpoint assignment requires a local port.";
            return;
        }

        var normalizedResourceId = ResourceId.Trim();
        if (!string.IsNullOrWhiteSpace(normalizedResourceId) &&
            IsResourceIdInUse(normalizedResourceId))
        {
            ErrorMessage = $"Resource ID '{normalizedResourceId}' is already in use.";
            return;
        }

        var volumeMounts = BuildVolumeMounts();
        var definition = new ApplicationResourceDefinition(
            normalizedResourceId,
            Name,
            executablePath: string.Empty,
            environmentVariables:
            [
                new EnvironmentVariableAssignment("ACCEPT_EULA", "Y"),
                new EnvironmentVariableAssignment("MSSQL_SA_PASSWORD", Password)
            ],
            lifetime: ApplicationLifetime.ControlPlaneScoped,
            dependsOn: volumeMounts.Select(mount => mount.VolumeReference).ToArray(),
            containerImage: Image.Trim(),
            containerHostId: NormalizeNullable(SelectedHostId),
            endpointPorts:
            [
                new ServicePort(
                    "tds",
                    1433,
                    IsManualEndpointAssignment ? LocalPort : null,
                    "tcp",
                    ResourceExposureScope.Local)
            ],
            resourceType: ApplicationResourceTypes.SqlServer,
            volumeMounts: volumeMounts);

        await ApplicationProvider.SetupApplicationAsync(definition, SelectedGroupId, Registrations);
        if (StartAfterCreate)
        {
            await ResourceActions.StartResourceAsync(definition.Id, startDependencies: true);
        }

        Navigation.NavigateTo("/resources");
    }

    private bool ValidateContainerHost()
    {
        var hosts = GetContainerHosts();
        if (!string.IsNullOrWhiteSpace(SelectedHostId))
        {
            if (hosts.Any(host => string.Equals(host.Id, SelectedHostId, StringComparison.OrdinalIgnoreCase)))
            {
                return true;
            }

            ErrorMessage = $"Container host '{SelectedHostId}' is not registered.";
            return false;
        }

        if (hosts.Any(host => host.IsDefault))
        {
            return true;
        }

        ErrorMessage = "A default container host is required unless this resource selects an explicit host.";
        return false;
    }

    private bool IsResourceIdInUse(string resourceId) =>
        ResourceManager.GetAvailableResources().Any(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase)) ||
        Registrations.GetRegistration(resourceId) is not null ||
        ApplicationProvider.GetApplication(resourceId) is not null;

    private bool HasImplicitContainerHost() =>
        GetContainerHosts().Any(host => host.IsDefault);

    private IReadOnlyList<ResourceVolumeMount> BuildVolumeMounts() =>
        string.IsNullOrWhiteSpace(SelectedDataVolumeId)
            ? []
            :
            [
                new ResourceVolumeMount(
                    SelectedDataVolumeId.Trim(),
                    "/var/opt/mssql",
                    Name: "data")
            ];

    private IReadOnlyList<Resource> GetVolumeCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => IsInSelectedGroup(resource.Id))
            .Where(IsVolumeResource)
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private static bool IsVolumeResource(Resource resource) =>
        ApplicationVolumeResourceDisplay.IsMountableVolumeResource(resource);

    private bool IsInSelectedGroup(string resourceId)
    {
        var group = ResourceManager.GetGroupForResource(resourceId);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private IReadOnlyList<ContainerHostDescriptor> GetContainerHosts()
    {
        var configuredHosts = ContainerHostProviders
            .Select(provider => provider.GetDefaultHost())
            .Where(host => !string.IsNullOrWhiteSpace(host.Id));
        var resourceHosts = ResourceManager
            .GetResources()
            .Select(TryReadContainerHost)
            .Where(host => host is not null)
            .Select(host => host!);

        return configuredHosts
            .Concat(resourceHosts)
            .GroupBy(host => host.Id, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Last())
            .OrderByDescending(host => host.IsDefault)
            .ThenBy(host => host.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private ContainerHostDescriptor? TryReadContainerHost(Resource resource)
    {
        var provider = DescriptorProviders.FirstOrDefault(provider => provider.CanDescribe(resource));
        if (provider is null)
        {
            return null;
        }

        try
        {
            var descriptor = provider.DescribeAsync(
                    resource,
                    new ResourceOrchestrationDescriptorContext(
                        Registrations.GetRegistration(resource.Id),
                        ResourceManager.GetGroupForResource(resource.Id),
                        ResourceManager))
                .GetAwaiter()
                .GetResult();
            if (!descriptor.ResourceType.Equals(ContainerHostResourceTypes.ContainerHost, StringComparison.OrdinalIgnoreCase))
            {
                return null;
            }

            return descriptor.Configuration.Deserialize<ContainerHostDescriptor>(
                new JsonSerializerOptions(JsonSerializerDefaults.Web));
        }
        catch (JsonException)
        {
            return null;
        }
    }

    private static string GetHostLabel(ContainerHostDescriptor host) =>
        host.IsDefault ? $"{host.Name} (default)" : host.Name;

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();
}
