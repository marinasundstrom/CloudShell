@inject ApplicationResourceProvider ApplicationProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations

@if (Application is null)
{
    <div class="empty-state">
        <strong>Application is unavailable</strong>
        <span>The resource may have been removed or is no longer visible.</span>
    </div>
}
else
{
    <div class="type-registration">
        <div class="form-panel">
            <label for="application-update-name">Name</label>
            <FluentTextField Id="application-update-name" @bind-Value="Name" />

            @if (CanConfigureProcessSettings)
            {
                <label for="application-update-executable">Executable path</label>
                <FluentTextField Id="application-update-executable" @bind-Value="ExecutablePath" />

                <label for="application-update-arguments">Arguments</label>
                <FluentTextField Id="application-update-arguments" @bind-Value="Arguments" />

                <label for="application-update-working-directory">Working directory</label>
                <FluentTextField Id="application-update-working-directory" @bind-Value="WorkingDirectory" />
            }

            @if (CanConfigureProjectSettings)
            {
                <label for="application-update-project-path">Project path</label>
                <FluentTextField Id="application-update-project-path" @bind-Value="ProjectPath" />

                <label for="application-update-project-arguments">Application arguments</label>
                <FluentTextField Id="application-update-project-arguments" @bind-Value="ApplicationArguments" />

                <FluentCheckbox @bind-Value="UseHotReload">
                    Use hot reload
                </FluentCheckbox>
            }

            @if (CanConfigureEndpoint)
            {
                <label for="application-update-endpoint">Endpoint</label>
                <FluentTextField Id="application-update-endpoint" @bind-Value="Endpoint" />
            }

            @if (CanConfigureLifetime)
            {
                <label for="application-update-lifetime">Lifetime</label>
                <FluentSelect TOption="string"
                              Id="application-update-lifetime"
                              @bind-Value="SelectedLifetime"
                              Appearance="Appearance.Outline">
                    @foreach (var lifetime in Enum.GetValues<ApplicationLifetime>())
                    {
                        <FluentOption TOption="string" Value="@lifetime.ToString()">@GetLifetimeLabel(lifetime)</FluentOption>
                    }
                </FluentSelect>
            }

            @if (CanConfigureServiceDiscovery)
            {
                <FluentCheckbox @bind-Value="UseServiceDiscovery">
                    Enable service discovery for references
                </FluentCheckbox>
            }

            <FluentCheckbox @bind-Value="EnableObservability">
                Enable observability
            </FluentCheckbox>

            @if (CanConfigureContainerImage)
            {
                <label for="application-update-container-image">Container image</label>
                <FluentTextField Id="application-update-container-image" @bind-Value="ContainerImage" Placeholder="example/api:dev" />

                <label for="application-update-container-registry">Registry</label>
                <FluentTextField Id="application-update-container-registry" @bind-Value="ContainerRegistry" Placeholder="docker.io" />

                <label for="application-update-registry-username">Registry username</label>
                <FluentTextField Id="application-update-registry-username" @bind-Value="RegistryUsername" />

                <label for="application-update-registry-password-environment-variable">Registry password environment variable</label>
                <FluentTextField Id="application-update-registry-password-environment-variable" @bind-Value="RegistryPasswordEnvironmentVariable" />
            }

            @if (CanConfigureContainerBuildSettings)
            {
                <label for="application-update-build-context">Docker build context</label>
                <FluentTextField Id="application-update-build-context" @bind-Value="ContainerBuildContext" Placeholder="." />

                <label for="application-update-dockerfile">Dockerfile</label>
                <FluentTextField Id="application-update-dockerfile" @bind-Value="ContainerDockerfile" Placeholder="Dockerfile" />
            }

            @if (CanConfigureReplicas)
            {
                <label for="application-update-replicas">Replicas</label>
                <FluentNumberField TValue="int" Id="application-update-replicas" Min="1" @bind-Value="Replicas" />
            }

            <label for="application-update-group">Resource group</label>
            <FluentSelect TOption="string"
                          Id="application-update-group"
                          @bind-Value="SelectedGroupId"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">Default group</FluentOption>
                @foreach (var group in ResourceGroups.GetResourceGroups())
                {
                    <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
                }
            </FluentSelect>

            <div class="environment-editor">
                <div class="environment-header">
                    <strong>Dependencies</strong>
                </div>

                @foreach (var resource in GetDependencyCandidates())
                {
                    <FluentCheckbox Value="@SelectedDependencyIds.Contains(resource.Id)"
                                    ValueChanged="selected => ToggleDependency(resource.Id, selected)">
                        @resource.Name
                    </FluentCheckbox>
                }
            </div>

            @if (Application is not null && GetInboundNetworkMappings(Application.Id).Count > 0)
            {
                <div class="environment-editor">
                    <div class="environment-header">
                        <strong>Network exposure</strong>
                    </div>

                    <div class="generated-list">
                        @foreach (var exposure in GetInboundNetworkMappings(Application.Id))
                        {
                            <div>
                                <strong>
                                    <a class="resource-link" href="@BuildResourceRoute(exposure.Network.Id)">
                                        @exposure.Network.Name
                                    </a>
                                </strong>
                                <span>@FormatMappingSummary(exposure.Mapping, exposure.Network, Application.Id)</span>
                                <small>@FormatMappingProvider(exposure.Mapping)</small>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private ApplicationResourceDefinition? Application { get; set; }
    private string Name { get; set; } = string.Empty;
    private string ExecutablePath { get; set; } = string.Empty;
    private string? Arguments { get; set; }
    private string? WorkingDirectory { get; set; }
    private string ProjectPath { get; set; } = string.Empty;
    private string? ApplicationArguments { get; set; }
    private bool UseHotReload { get; set; } = true;
    private string? Endpoint { get; set; }
    private string SelectedLifetime { get; set; } = ApplicationLifetime.Detached.ToString();
    private bool UseServiceDiscovery { get; set; }
    private bool EnableObservability { get; set; } = true;
    private string? ContainerImage { get; set; }
    private string ContainerRegistry { get; set; } = ContainerRegistryDefaults.Default;
    private string? RegistryUsername { get; set; }
    private string? RegistryPasswordEnvironmentVariable { get; set; }
    private string? ContainerBuildContext { get; set; }
    private string? ContainerDockerfile { get; set; }
    private int Replicas { get; set; } = 1;
    private string SelectedGroupId { get; set; } = string.Empty;
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }
    private HashSet<string> SelectedDependencyIds { get; } = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<string> ReferenceIds { get; set; } = [];

    private bool IsExecutableApplication =>
        IsResourceType(ApplicationResourceTypes.ExecutableApplication);

    private bool IsAspNetCoreProject =>
        IsResourceType(ApplicationResourceTypes.AspNetCoreProject);

    private bool IsContainerApp =>
        Application is not null &&
        ApplicationResourceTypes.IsContainerApp(Application.ResourceType);

    private bool IsSqlServer =>
        IsResourceType(ApplicationResourceTypes.SqlServer);

    private bool CanConfigureProcessSettings =>
        IsExecutableApplication;

    private bool CanConfigureProjectSettings =>
        IsAspNetCoreProject;

    private bool CanConfigureEndpoint =>
        IsExecutableApplication || IsAspNetCoreProject;

    private bool CanConfigureLifetime =>
        !IsSqlServer;

    private bool CanConfigureServiceDiscovery =>
        !IsSqlServer;

    private bool CanConfigureContainerImage =>
        IsContainerApp || IsSqlServer;

    private bool CanConfigureContainerBuildSettings =>
        IsContainerApp;

    private bool CanConfigureReplicas =>
        IsContainerApp;

    private bool IsResourceType(string resourceType) =>
        Application is not null &&
        string.Equals(Application.ResourceType, resourceType, StringComparison.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        Application = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ApplicationProvider.GetApplication(ResourceId);

        if (Application is not null)
        {
            Name = Application.Name;
            ExecutablePath = Application.ExecutablePath;
            Arguments = Application.Arguments;
            WorkingDirectory = Application.WorkingDirectory;
            ProjectPath = Application.ProjectPath ?? string.Empty;
            ApplicationArguments = Application.ProjectArguments;
            UseHotReload = Application.AspNetCoreHotReload;
            Endpoint = GetConfiguredEndpoint(Application);
            SelectedLifetime = Application.Lifetime.ToString();
            UseServiceDiscovery = Application.UseServiceDiscovery;
            EnableObservability = (Application.Observability ?? ResourceObservability.Default).HasAnySignal;
            ContainerImage = Application.ContainerImage;
            ContainerRegistry = NormalizeRegistry(Application.ContainerRegistry);
            RegistryUsername = Application.ContainerRegistryCredentials?.Username;
            RegistryPasswordEnvironmentVariable = Application.ContainerRegistryCredentials?.PasswordEnvironmentVariable;
            ContainerBuildContext = Application.ContainerBuildContext;
            ContainerDockerfile = Application.ContainerDockerfile;
            Replicas = Application.Replicas;
            ReferenceIds = Application.References;
            SelectedGroupId = ResourceManager.GetGroupForResource(Application.Id)?.Id ?? string.Empty;
            SelectedDependencyIds.Clear();
            var resource = ResourceManager.GetResource(Application.Id);
            foreach (var dependency in resource?.DependsOn ?? Application.DependsOn)
            {
                if (IsInSelectedGroup(dependency))
                {
                    SelectedDependencyIds.Add(dependency);
                }
            }
        }

        if (Configuration is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (Application is null)
        {
            return ResourceProcedureResult.Completed("Application resource is unavailable.");
        }

        if (CanConfigureProjectSettings && string.IsNullOrWhiteSpace(ProjectPath))
        {
            return ResourceProcedureResult.Completed("Project path is required.");
        }

        if (!ValidateRegistryCredentials())
        {
            return ResourceProcedureResult.Completed("Registry username and password environment variable are required together.");
        }

        var definition = new ApplicationResourceDefinition(
            Application.Id,
            Name,
            CanConfigureProcessSettings ? ExecutablePath : Application.ExecutablePath,
            CanConfigureProcessSettings ? Arguments : Application.Arguments,
            CanConfigureProcessSettings ? WorkingDirectory : Application.WorkingDirectory,
            CanConfigureEndpoint && !IsAspNetCoreProject ? Endpoint : Application.Endpoint,
            Application.EnvironmentVariables,
            CanConfigureLifetime ? ParseLifetime() : Application.Lifetime,
            BuildDependencies(),
            ReferenceIds,
            CanConfigureServiceDiscovery ? UseServiceDiscovery : Application.UseServiceDiscovery,
            CanConfigureContainerImage ? NormalizeNullable(ContainerImage) : Application.ContainerImage,
            CanConfigureContainerBuildSettings ? NormalizeNullable(ContainerBuildContext) : Application.ContainerBuildContext,
            CanConfigureContainerBuildSettings ? NormalizeNullable(ContainerDockerfile) : Application.ContainerDockerfile,
            Application.ContainerEngineId,
            CanConfigureReplicas ? Math.Max(1, Replicas) : Math.Max(1, Application.Replicas),
            CanConfigureEndpoint ? BuildEndpointPorts(Application.ResourceType, Endpoint) : Application.EndpointPorts,
            resourceType: Application.ResourceType,
            healthChecks: Application.HealthChecks,
            observability: EnableObservability ? ResourceObservability.Default : ResourceObservability.None,
            projectPath: CanConfigureProjectSettings ? ProjectPath : Application.ProjectPath,
            projectArguments: CanConfigureProjectSettings ? ApplicationArguments : Application.ProjectArguments,
            aspNetCoreHotReload: CanConfigureProjectSettings ? UseHotReload : Application.AspNetCoreHotReload,
            containerRevision: Application.ContainerRevision,
            containerRegistry: CanConfigureContainerImage ? NormalizeRegistry(ContainerRegistry) : Application.ContainerRegistry,
            containerRegistryCredentials: CanConfigureContainerImage
                ? BuildRegistryCredentials()
                : Application.ContainerRegistryCredentials);

        var restartRequired =
            ApplicationProvider.IsRunning(Application.Id) &&
            IsRuntimeSensitiveChange(Application, definition);

        await ApplicationProvider.UpdateApplicationAsync(
            definition,
            SelectedGroupId,
            Registrations,
            cancellationToken);

        return restartRequired
            ? ResourceProcedureResult.CompletedWithRestartRequired(
                "Application configuration updated.",
                Application.Id,
                "The resource is running. Restart it now to apply runtime configuration changes.")
            : ResourceProcedureResult.Completed("Application configuration updated.");
    }

    private static bool IsRuntimeSensitiveChange(
        ApplicationResourceDefinition existing,
        ApplicationResourceDefinition updated)
    {
        if (!string.Equals(existing.ExecutablePath, updated.ExecutablePath, StringComparison.Ordinal) ||
            !string.Equals(existing.Arguments, updated.Arguments, StringComparison.Ordinal) ||
            !string.Equals(existing.WorkingDirectory, updated.WorkingDirectory, StringComparison.Ordinal) ||
            !string.Equals(existing.ProjectPath, updated.ProjectPath, StringComparison.Ordinal) ||
            !string.Equals(existing.ProjectArguments, updated.ProjectArguments, StringComparison.Ordinal) ||
            existing.AspNetCoreHotReload != updated.AspNetCoreHotReload ||
            !string.Equals(existing.Endpoint, updated.Endpoint, StringComparison.Ordinal) ||
            existing.Lifetime != updated.Lifetime ||
            existing.UseServiceDiscovery != updated.UseServiceDiscovery ||
            !string.Equals(existing.ContainerImage, updated.ContainerImage, StringComparison.Ordinal) ||
            !string.Equals(existing.ContainerRegistry, updated.ContainerRegistry, StringComparison.Ordinal) ||
            !Equals(existing.ContainerRegistryCredentials, updated.ContainerRegistryCredentials) ||
            !string.Equals(existing.ContainerBuildContext, updated.ContainerBuildContext, StringComparison.Ordinal) ||
            !string.Equals(existing.ContainerDockerfile, updated.ContainerDockerfile, StringComparison.Ordinal) ||
            !string.Equals(existing.ContainerEngineId, updated.ContainerEngineId, StringComparison.Ordinal) ||
            existing.Replicas != updated.Replicas ||
            !HasSameObservabilitySignals(existing.Observability, updated.Observability) ||
            !existing.EnvironmentVariables.SequenceEqual(updated.EnvironmentVariables) ||
            !existing.EndpointPorts.SequenceEqual(updated.EndpointPorts))
        {
            return true;
        }

        return (existing.UseServiceDiscovery || updated.UseServiceDiscovery) &&
            !existing.References.SequenceEqual(updated.References, StringComparer.OrdinalIgnoreCase);
    }

    private static bool HasSameObservabilitySignals(
        ResourceObservability? existing,
        ResourceObservability? updated) =>
        (existing ?? ResourceObservability.Default).HasAnySignal ==
        (updated ?? ResourceObservability.Default).HasAnySignal;

    private static IReadOnlyList<ServicePort> BuildEndpointPorts(
        string resourceType,
        string? endpoint)
    {
        if (!string.Equals(resourceType, ApplicationResourceTypes.AspNetCoreProject, StringComparison.OrdinalIgnoreCase))
        {
            return [];
        }

        if (Uri.TryCreate(endpoint, UriKind.Absolute, out var uri) &&
            uri.Port > 0)
        {
            var protocol = string.IsNullOrWhiteSpace(uri.Scheme) ? "http" : uri.Scheme;
            return [new ServicePort("http", uri.Port, uri.Port, protocol, ResourceExposureScope.Local)];
        }

        return [new ServicePort("http", 80, Protocol: "http", Exposure: ResourceExposureScope.Local)];
    }

    private static string? GetConfiguredEndpoint(ApplicationResourceDefinition application)
    {
        if (!string.Equals(
                application.ResourceType,
                ApplicationResourceTypes.AspNetCoreProject,
                StringComparison.OrdinalIgnoreCase))
        {
            return application.Endpoint;
        }

        var port = application.EndpointPorts.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, "http", StringComparison.OrdinalIgnoreCase)) ??
            application.EndpointPorts.FirstOrDefault();
        return port?.Port is null
            ? null
            : $"{port.Protocol}://localhost:{port.Port.Value}";
    }

    private IReadOnlyList<string> BuildDependencies() =>
        SelectedDependencyIds
            .Where(IsInSelectedGroup)
            .Where(dependency => Application is null ||
                !string.Equals(dependency, Application.Id, StringComparison.OrdinalIgnoreCase))
            .ToArray();

    private IReadOnlyList<Resource> GetDependencyCandidates() =>
        ResourceManager.GetResources()
            .Where(resource => Application is null ||
                !string.Equals(resource.Id, Application.Id, StringComparison.OrdinalIgnoreCase))
            .Where(resource => IsInSelectedGroup(resource.Id))
            .OrderBy(resource => resource.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<NetworkEndpointMappingView> GetInboundNetworkMappings(string resourceId) =>
        ResourceManager.GetResources()
            .Where(resource => resource.ResourceClass == ResourceClass.Network)
            .SelectMany(network => network.ResourceEndpointMappings
                .Where(mapping => string.Equals(
                    mapping.Target.ResourceId,
                    resourceId,
                    StringComparison.OrdinalIgnoreCase))
                .Select(mapping => new NetworkEndpointMappingView(network, mapping)))
            .OrderBy(mapping => mapping.Network.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private string FormatMappingSummary(
        ResourceEndpointMappingDefinition mapping,
        Resource network,
        string targetResourceId) =>
        $"{FormatEndpointReference(mapping.Source, network)} -> {FormatEndpointReference(mapping.Target, targetResourceId)}";

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        Resource? fallbackResource = null)
    {
        var resource = ResolveMappingResource(reference.ResourceId, fallbackResource);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var address = string.IsNullOrWhiteSpace(endpoint?.Address)
            ? null
            : $" ({endpoint.Address})";
        return $"{resource?.Name ?? reference.ResourceId}/{reference.EndpointName}{address}";
    }

    private string FormatEndpointReference(
        ResourceEndpointReference reference,
        string targetResourceId)
    {
        var resource = ResolveMappingResource(reference.ResourceId);
        var endpoint = resource?.Endpoints.FirstOrDefault(endpoint =>
            string.Equals(endpoint.Name, reference.EndpointName, StringComparison.OrdinalIgnoreCase));
        var label = string.Equals(reference.ResourceId, targetResourceId, StringComparison.OrdinalIgnoreCase)
            ? Application?.Name ?? reference.ResourceId
            : resource?.Name ?? reference.ResourceId;
        var address = string.IsNullOrWhiteSpace(endpoint?.Address)
            ? null
            : $" ({endpoint.Address})";
        return $"{label}/{reference.EndpointName}{address}";
    }

    private string FormatMappingProvider(ResourceEndpointMappingDefinition mapping)
    {
        var providerId = FirstNonEmpty(mapping.ProviderResourceId, mapping.NetworkResourceId, mapping.Source.ResourceId);
        if (string.IsNullOrWhiteSpace(providerId))
        {
            return "Provider: network";
        }

        var provider = ResolveMappingResource(providerId);
        return provider is null
            ? $"Provider: {providerId}"
            : $"Provider: {provider.Name}";
    }

    private Resource? ResolveMappingResource(string resourceId, Resource? fallbackResource = null)
    {
        if (fallbackResource is not null &&
            string.Equals(fallbackResource.Id, resourceId, StringComparison.OrdinalIgnoreCase))
        {
            return fallbackResource;
        }

        return ResourceManager.GetResource(resourceId);
    }

    private static string? FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value));

    private static string BuildResourceRoute(string resourceId) =>
        $"/resources/{Uri.EscapeDataString(resourceId)}/details?tab=overview";

    private void ToggleDependency(string resourceId, bool selected)
    {
        if (selected)
        {
            SelectedDependencyIds.Add(resourceId);
        }
        else
        {
            SelectedDependencyIds.Remove(resourceId);
        }
    }

    private bool IsInSelectedGroup(string resourceId)
    {
        var group = ResourceManager.GetGroupForResource(resourceId);
        return string.IsNullOrWhiteSpace(SelectedGroupId)
            ? group is null
            : string.Equals(group?.Id, SelectedGroupId, StringComparison.OrdinalIgnoreCase);
    }

    private ApplicationLifetime ParseLifetime() =>
        Enum.TryParse<ApplicationLifetime>(SelectedLifetime, out var lifetime)
            ? lifetime
            : ApplicationLifetime.Detached;

    private static string GetLifetimeLabel(ApplicationLifetime lifetime) =>
        lifetime switch
        {
            ApplicationLifetime.ControlPlaneScoped => "Control plane scoped",
            _ => "Detached"
        };

    private static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private bool ValidateRegistryCredentials()
    {
        if (!CanConfigureContainerImage)
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(RegistryUsername) &&
            string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable))
        {
            return true;
        }

        return !string.IsNullOrWhiteSpace(RegistryUsername) &&
            !string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable);
    }

    private ContainerRegistryCredentials? BuildRegistryCredentials() =>
        string.IsNullOrWhiteSpace(RegistryUsername) ||
        string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable)
            ? null
            : new ContainerRegistryCredentials(
                RegistryUsername,
                RegistryPasswordEnvironmentVariable);

    private sealed class EnvironmentVariableInput(string? name = null, string? value = null)
    {
        public string? Name { get; set; } = name;

        public string? Value { get; set; } = value;
    }

    private sealed record NetworkEndpointMappingView(
        Resource Network,
        ResourceEndpointMappingDefinition Mapping);
}
