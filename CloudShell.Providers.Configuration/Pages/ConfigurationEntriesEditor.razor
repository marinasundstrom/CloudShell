<ResourceEditorSection Class="configuration-value-editor">
    <HeaderContent>
        <div class="configuration-editor-heading">
            <strong>Configuration entries</strong>
            <span>@GetEntryCountLabel()</span>
        </div>
    </HeaderContent>
    <Actions>
        <FluentButton Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.AddCircle())"
                      Disabled="@Disabled"
                      OnClick="AddEntry">
            Add entry
        </FluentButton>
    </Actions>
    <ChildContent>
        @foreach (var entry in Entries)
        {
            <div class="environment-row configuration-entry-row" @key="entry">
                <FluentTextField AriaLabel="Configuration entry name"
                                 Placeholder="Sample:Message"
                                 Disabled="@Disabled"
                                 @bind-Value="entry.Name" />
                <FluentTextField AriaLabel="Configuration entry value"
                                 Placeholder="Value"
                                 Disabled="@Disabled"
                                 @bind-Value="entry.Value" />
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="@(new Icons.Regular.Size20.DeleteDismiss())"
                              Disabled="@Disabled"
                              OnClick="() => RemoveEntry(entry)">
                    Remove
                </FluentButton>
            </div>
        }
    </ChildContent>
</ResourceEditorSection>

@code {
    [Parameter, EditorRequired]
    public List<ConfigurationEntryInput> Entries { get; set; } = [];

    [Parameter]
    public bool Disabled { get; set; }

    private void AddEntry() => Entries.Add(new());

    private void RemoveEntry(ConfigurationEntryInput entry)
    {
        Entries.Remove(entry);
        if (Entries.Count == 0)
        {
            Entries.Add(new());
        }
    }

    private string GetEntryCountLabel()
    {
        var count = Entries.Count(entry => !string.IsNullOrWhiteSpace(entry.Name));
        return count == 1 ? "1 entry" : $"{count} entries";
    }
}
