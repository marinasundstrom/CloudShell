<div class="configuration-secret-value">
    <span>@DisplayValue</span>
    @if (CanReveal)
    {
        <FluentButton Appearance="Appearance.Neutral"
                      Class="configuration-secret-toggle"
                      Title="@ToggleLabel"
                      AriaLabel="@ToggleLabel"
                      OnClick="Toggle">
            <FluentIcon TIcon="Microsoft.FluentUI.AspNetCore.Components.Icon"
                        Value="@(ToggleIcon)"
                        Color="Color.Neutral" />
        </FluentButton>
    }
</div>

@code {
    [Parameter]
    public string Name { get; set; } = string.Empty;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool CanReveal { get; set; } = true;

    private bool IsRevealed { get; set; }

    private string DisplayValue =>
        IsRevealed && CanReveal
            ? Value ?? string.Empty
            : CreateMask(Value);

    private string ToggleLabel =>
        IsRevealed
            ? $"Hide {Name}"
            : $"Reveal {Name}";

    private Microsoft.FluentUI.AspNetCore.Components.Icon ToggleIcon =>
        IsRevealed
            ? new Icons.Regular.Size16.EyeOff()
            : new Icons.Regular.Size16.Eye();

    protected override void OnParametersSet()
    {
        if (!CanReveal)
        {
            IsRevealed = false;
        }
    }

    private void Toggle() => IsRevealed = !IsRevealed;

    private static string CreateMask(string? value) =>
        new('*', Math.Clamp(value?.Length ?? 0, 8, 24));
}
