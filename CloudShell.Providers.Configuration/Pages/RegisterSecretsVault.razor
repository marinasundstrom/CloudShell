@inject SecretsVaultProvider SecretsVaultProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject NavigationManager Navigation

<div class="type-registration">
    <div class="form-panel">
        <label for="secrets-vault-name">Name</label>
        <FluentTextField Id="secrets-vault-name" @bind-Value="Name" />

        <label for="secrets-vault-resource-id">Resource ID</label>
        <FluentTextField Id="secrets-vault-resource-id" @bind-Value="ResourceId" Placeholder="secrets-vault:app" />

        <ResourceGroupSelect Id="secrets-vault-group"
                             ResourceGroups="ResourceGroups.GetResourceGroups()"
                             @bind-Value="SelectedGroupId" />

        <SecretsVaultSecretsEditor Secrets="Secrets" />

        @if (ErrorMessage is not null)
        {
            <div class="provider-error">@ErrorMessage</div>
        }

        <div class="form-actions">
            <FluentButton Appearance="Appearance.Accent" OnClick="Register">
                Add
            </FluentButton>
        </div>
    </div>
</div>

@code {
    private string ResourceId { get; set; } = string.Empty;
    private string Name { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private List<SecretsVaultSecretInput> Secrets { get; } = [new()];

    private async Task Register()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Name))
        {
            ErrorMessage = "Name is required.";
            return;
        }

        var normalizedResourceId = ResourceId.Trim();
        if (!string.IsNullOrWhiteSpace(normalizedResourceId) &&
            IsResourceIdInUse(normalizedResourceId))
        {
            ErrorMessage = $"Resource ID '{normalizedResourceId}' is already in use.";
            return;
        }

        var definition = new SecretsVaultDefinition(
            normalizedResourceId,
            Name,
            BuildSecrets());

        await SecretsVaultProvider.SetupVaultAsync(definition, SelectedGroupId, Registrations);
        Navigation.NavigateTo("/resources");
    }

    private IReadOnlyList<SecretsVaultSecret> BuildSecrets() =>
        Secrets
            .Where(secret => !string.IsNullOrWhiteSpace(secret.Name))
            .Select(secret => new SecretsVaultSecret(
                secret.Name!.Trim(),
                secret.Value ?? string.Empty,
                string.IsNullOrWhiteSpace(secret.Version) ? null : secret.Version.Trim()))
            .ToArray();

    private bool IsResourceIdInUse(string resourceId) =>
        ResourceManager.GetAvailableResources().Any(resource =>
            string.Equals(resource.Id, resourceId, StringComparison.OrdinalIgnoreCase)) ||
        Registrations.GetRegistration(resourceId) is not null ||
        SecretsVaultProvider.GetVault(resourceId) is not null;

}
