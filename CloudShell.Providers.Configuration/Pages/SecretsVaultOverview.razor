@inject SecretsVaultProvider SecretsVaultProvider

@if (Vault is null)
{
    <div class="empty-state">
        <strong>Secrets Vault is unavailable</strong>
        <span>The resource may have been removed or is no longer visible.</span>
    </div>
}
else
{
    <div class="type-registration">
        <div class="provider-summary compact">
            <div class="provider-status">
                <span class="state-dot state-running"></span>
                <div>
                    <strong>@Vault.Name</strong>
                    <span>@Vault.Secrets.Count secrets available for reference-backed settings.</span>
                </div>
            </div>
        </div>

        <div class="environment-editor">
            <div class="environment-header">
                <strong>Secrets</strong>
            </div>

            @foreach (var secret in Vault.Secrets)
            {
                <div class="configuration-entry-summary">
                    <strong>@secret.Name</strong>
                    <span>@FormatVersion(secret.Version)</span>
                </div>
            }

            @if (Vault.Secrets.Count == 0)
            {
                <div class="empty-state">
                    <strong>No secrets</strong>
                    <span>Add secrets from the Secrets tab.</span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string? ResourceId { get; set; }

    private SecretsVaultDefinition? Vault { get; set; }

    protected override void OnParametersSet()
    {
        Vault = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : SecretsVaultProvider.GetVault(ResourceId);
    }

    private static string FormatVersion(string? version) =>
        string.IsNullOrWhiteSpace(version) ? "Current version" : version;
}
