<ResourceEditorSection Class="configuration-value-editor">
    <HeaderContent>
        <div class="configuration-editor-heading">
            <strong>Vault secrets</strong>
            <span>@GetSecretCountLabel()</span>
        </div>
    </HeaderContent>
    <Actions>
        <FluentButton Appearance="Appearance.Neutral"
                      IconStart="@(new Icons.Regular.Size20.AddCircle())"
                      Disabled="@Disabled"
                      OnClick="AddSecret">
            Add secret
        </FluentButton>
    </Actions>
    <ChildContent>
        @foreach (var secret in Secrets)
        {
            <div class="environment-row configuration-secret-row" @key="secret">
                <FluentTextField AriaLabel="Secret name"
                                 Placeholder="sample-api-key"
                                 Disabled="@Disabled"
                                 @bind-Value="secret.Name" />
                @if (secret.IsExisting)
                {
                    <span class="configuration-secret-placeholder">@CreateMask()</span>
                }
                <FluentTextField AriaLabel="Secret value"
                                 Placeholder="@GetValuePlaceholder(secret)"
                                 TextFieldType="TextFieldType.Password"
                                 Disabled="@Disabled"
                                 @bind-Value="secret.Value" />
                <FluentTextField AriaLabel="Secret version"
                                 Placeholder="Version"
                                 Disabled="@Disabled"
                                 @bind-Value="secret.Version" />
                <FluentButton Appearance="Appearance.Neutral"
                              IconStart="@(new Icons.Regular.Size20.DeleteDismiss())"
                              Disabled="@Disabled"
                              OnClick="() => RemoveSecret(secret)">
                    Remove
                </FluentButton>
            </div>
        }
    </ChildContent>
</ResourceEditorSection>

@code {
    [Parameter, EditorRequired]
    public List<SecretsVaultSecretInput> Secrets { get; set; } = [];

    [Parameter]
    public bool Disabled { get; set; }

    private void AddSecret() => Secrets.Add(new());

    private void RemoveSecret(SecretsVaultSecretInput secret)
    {
        Secrets.Remove(secret);
        if (Secrets.Count == 0)
        {
            Secrets.Add(new());
        }
    }

    private static string? GetValuePlaceholder(SecretsVaultSecretInput secret) =>
        secret.IsExisting ? "Leave unchanged" : null;

    private static string CreateMask() => "************";

    private string GetSecretCountLabel()
    {
        var count = Secrets.Count(secret => !string.IsNullOrWhiteSpace(secret.Name));
        return count == 1 ? "1 secret" : $"{count} secrets";
    }
}
