@inject ConfigurationResourceProvider ConfigurationProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations

@if (Store is null)
{
    <div class="empty-state">
        <strong>Configuration service is unavailable</strong>
        <span>The resource may have been removed or is no longer visible.</span>
    </div>
}
else
{
    <div class="type-registration">
        <div class="form-panel">
            <label for="configuration-update-name">Name</label>
            <FluentTextField Id="configuration-update-name" @bind-Value="Name" />

            <label for="configuration-update-endpoint">Endpoint</label>
            <FluentTextField Id="configuration-update-endpoint" @bind-Value="Endpoint" />

            <label for="configuration-update-group">Resource group</label>
            <FluentSelect TOption="string"
                          Id="configuration-update-group"
                          @bind-Value="SelectedGroupId"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">Default group</FluentOption>
                @foreach (var group in ResourceGroups.GetResourceGroups())
                {
                    <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
                }
            </FluentSelect>

            <div class="environment-editor">
                <div class="environment-header">
                    <strong>Entries</strong>
                    <FluentButton Appearance="Appearance.Neutral" OnClick="AddEntry">
                        Add entry
                    </FluentButton>
                </div>

                @foreach (var entry in Entries)
                {
                    <div class="environment-row configuration-entry-row @(entry.IsLockedSecret ? "locked-secret" : null)">
                        <FluentTextField AriaLabel="Configuration entry name"
                                         Disabled="@entry.IsLockedSecret"
                                         @bind-Value="entry.Name" />
                        @if (entry.IsLockedSecret)
                        {
                            <span class="configuration-secret-placeholder">@CreateMask(entry.Value)</span>
                        }
                        else
                        {
                            <FluentTextField AriaLabel="Configuration entry value" @bind-Value="entry.Value" />
                        }
                        @if (entry.IsLockedSecret)
                        {
                            <span class="configuration-secret-status">Secret</span>
                        }
                        else
                        {
                            <FluentCheckbox @bind-Value="entry.IsSecret">
                                Secret
                            </FluentCheckbox>
                        }
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => RemoveEntry(entry)">
                            Remove
                        </FluentButton>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private ConfigurationStoreDefinition? Store { get; set; }
    private string Name { get; set; } = string.Empty;
    private string? Endpoint { get; set; }
    private string SelectedGroupId { get; set; } = string.Empty;
    private List<ConfigurationEntryInput> Entries { get; } = [];
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }

    protected override void OnParametersSet()
    {
        Store = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ConfigurationProvider.GetStore(ResourceId);

        if (Store is not null)
        {
            Name = Store.Name;
            Endpoint = Store.Endpoint;
            SelectedGroupId = ResourceManager.GetGroupForResource(Store.Id)?.Id ?? string.Empty;
            Entries.Clear();
            Entries.AddRange(Store.Entries
                .Select(ConfigurationEntryInput.FromEntry));
            if (Entries.Count == 0)
            {
                Entries.Add(new());
            }
        }

        if (Configuration is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private void AddEntry() => Entries.Add(new());

    private void RemoveEntry(ConfigurationEntryInput entry)
    {
        Entries.Remove(entry);
        if (Entries.Count == 0)
        {
            Entries.Add(new());
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (Store is null)
        {
            return ResourceProcedureResult.Completed("Configuration service is unavailable.");
        }

        var definition = new ConfigurationStoreDefinition(
            Store.Id,
            Name,
            BuildEntries(),
            endpoint: Endpoint,
            healthChecks: Store.HealthChecks);

        await ConfigurationProvider.UpdateStoreAsync(
            definition,
            SelectedGroupId,
            Registrations,
            cancellationToken);

        return ResourceProcedureResult.Completed("Configuration service updated.");
    }

    private IReadOnlyList<ConfigurationEntry> BuildEntries() =>
        Entries
            .Where(entry => !string.IsNullOrWhiteSpace(entry.Name))
            .Select(entry => new ConfigurationEntry(
                entry.Name!.Trim(),
                entry.Value ?? string.Empty,
                entry.IsSecret))
            .ToArray();

    private static string CreateMask(string? value) =>
        new('*', Math.Clamp(value?.Length ?? 0, 8, 24));

    private sealed class ConfigurationEntryInput(string? name = null, string? value = null, bool isSecret = false)
    {
        public string? Name { get; set; } = name;

        public string? Value { get; set; } = value;

        public bool IsSecret { get; set; } = isSecret;

        public bool IsLockedSecret { get; init; }

        public static ConfigurationEntryInput FromEntry(ConfigurationEntry entry) =>
            new(entry.Name, entry.Value, entry.IsSecret)
            {
                IsLockedSecret = entry.IsSecret
            };
    }
}
