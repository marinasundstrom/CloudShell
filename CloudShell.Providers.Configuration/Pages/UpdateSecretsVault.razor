@inject SecretsVaultProvider SecretsVaultProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations

@if (Vault is null)
{
    <EmptyState Title="Secrets Vault is unavailable"
                Message="The resource may have been removed or is no longer visible." />
}
else
{
    <div class="type-registration">
        <FormPanel>
            <label for="secrets-vault-update-name">Name</label>
            <FluentTextField Id="secrets-vault-update-name" @bind-Value="Name" Disabled="@IsReadOnly" />

            <ResourceGroupSelect Id="secrets-vault-update-group"
                                 ResourceGroups="ResourceGroups.GetResourceGroups()"
                                 Disabled="@IsReadOnly"
                                 @bind-Value="SelectedGroupId" />

        </FormPanel>
    </div>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [CascadingParameter(Name = ResourceManagerCascadingParameterNames.ReadOnly)]
    public bool IsReadOnly { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private SecretsVaultDefinition? Vault { get; set; }
    private string Name { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }

    protected override void OnParametersSet()
    {
        Vault = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : SecretsVaultProvider.GetVault(ResourceId);

        if (Vault is not null)
        {
            Name = Vault.Name;
            SelectedGroupId = ResourceManager.GetGroupForResource(Vault.Id)?.Id ?? string.Empty;
        }

        if (Configuration is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (IsReadOnly)
        {
            return ResourceManagerUiState.ReadOnlyResult();
        }

        if (Vault is null)
        {
            return ResourceProcedureResult.Completed("Secrets Vault is unavailable.");
        }

        var definition = new SecretsVaultDefinition(
            Vault.Id,
            Name,
            Vault.Secrets);

        await SecretsVaultProvider.UpdateVaultAsync(
            definition,
            SelectedGroupId,
            Registrations,
            cancellationToken);

        return ResourceProcedureResult.Completed("Secrets Vault updated.");
    }
}
