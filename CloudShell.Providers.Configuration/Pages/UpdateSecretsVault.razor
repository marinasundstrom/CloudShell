@inject SecretsVaultProvider SecretsVaultProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations

@if (Vault is null)
{
    <div class="empty-state">
        <strong>Secrets Vault is unavailable</strong>
        <span>The resource may have been removed or is no longer visible.</span>
    </div>
}
else
{
    <div class="type-registration">
        <div class="form-panel">
            <label for="secrets-vault-update-name">Name</label>
            <FluentTextField Id="secrets-vault-update-name" @bind-Value="Name" />

            <label for="secrets-vault-update-group">Resource group</label>
            <FluentSelect TOption="string"
                          Id="secrets-vault-update-group"
                          @bind-Value="SelectedGroupId"
                          Appearance="Appearance.Outline">
                <FluentOption TOption="string" Value="">Default group</FluentOption>
                @foreach (var group in ResourceGroups.GetResourceGroups())
                {
                    <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
                }
            </FluentSelect>

            <div class="environment-editor">
                <div class="environment-header">
                    <strong>Secrets</strong>
                    <FluentButton Appearance="Appearance.Neutral" OnClick="AddSecret">
                        Add secret
                    </FluentButton>
                </div>

                @foreach (var secret in Secrets)
                {
                    <div class="environment-row configuration-entry-row">
                        <FluentTextField AriaLabel="Secret name" @bind-Value="secret.Name" />
                        @if (secret.IsExisting)
                        {
                            <span class="configuration-secret-placeholder">@CreateMask(secret.CurrentValue)</span>
                        }
                        <FluentTextField AriaLabel="Secret value"
                                         Placeholder="Leave unchanged"
                                         TextFieldType="TextFieldType.Password"
                                         @bind-Value="secret.Value" />
                        <FluentTextField AriaLabel="Secret version" Placeholder="Version" @bind-Value="secret.Version" />
                        <FluentButton Appearance="Appearance.Neutral" OnClick="() => RemoveSecret(secret)">
                            Remove
                        </FluentButton>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private SecretsVaultDefinition? Vault { get; set; }
    private string Name { get; set; } = string.Empty;
    private string SelectedGroupId { get; set; } = string.Empty;
    private List<SecretInput> Secrets { get; } = [];
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }

    protected override void OnParametersSet()
    {
        Vault = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : SecretsVaultProvider.GetVault(ResourceId);

        if (Vault is not null)
        {
            Name = Vault.Name;
            SelectedGroupId = ResourceManager.GetGroupForResource(Vault.Id)?.Id ?? string.Empty;
            Secrets.Clear();
            Secrets.AddRange(Vault.Secrets.Select(SecretInput.FromSecret));
            if (Secrets.Count == 0)
            {
                Secrets.Add(new());
            }
        }

        if (Configuration is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private void AddSecret() => Secrets.Add(new());

    private void RemoveSecret(SecretInput secret)
    {
        Secrets.Remove(secret);
        if (Secrets.Count == 0)
        {
            Secrets.Add(new());
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (Vault is null)
        {
            return ResourceProcedureResult.Completed("Secrets Vault is unavailable.");
        }

        var definition = new SecretsVaultDefinition(
            Vault.Id,
            Name,
            BuildSecrets());

        await SecretsVaultProvider.UpdateVaultAsync(
            definition,
            SelectedGroupId,
            Registrations,
            cancellationToken);

        return ResourceProcedureResult.Completed("Secrets Vault updated.");
    }

    private IReadOnlyList<SecretsVaultSecret> BuildSecrets() =>
        Secrets
            .Where(secret => !string.IsNullOrWhiteSpace(secret.Name))
            .Select(secret => new SecretsVaultSecret(
                secret.Name!.Trim(),
                string.IsNullOrEmpty(secret.Value) ? secret.CurrentValue ?? string.Empty : secret.Value,
                string.IsNullOrWhiteSpace(secret.Version) ? null : secret.Version.Trim()))
            .ToArray();

    private static string CreateMask(string? value) =>
        new('*', Math.Clamp(value?.Length ?? 0, 8, 24));

    private sealed class SecretInput(string? name = null, string? value = null, string? version = null)
    {
        public string? Name { get; set; } = name;

        public string? Value { get; set; } = value;

        public string? Version { get; set; } = version;

        public string? CurrentValue { get; init; }

        public bool IsExisting { get; init; }

        public static SecretInput FromSecret(SecretsVaultSecret secret) =>
            new(secret.Name, null, secret.Version)
            {
                CurrentValue = secret.Value,
                IsExisting = true
            };
    }
}
