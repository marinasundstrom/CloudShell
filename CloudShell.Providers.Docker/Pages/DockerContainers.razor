@page "/resources/container-hosts"
@rendermode InteractiveServer
@inject DockerContainerResourceProvider DockerProvider
@inject ILogStore LogStore
@inject IResourceManagerStore ResourceManager
@inject IResourceRegistrationStore Registrations
@inject ICloudShellAuthorizationService Authorization
@inject NavigationManager Navigation

<PageTitle>Docker</PageTitle>

@{
    var host = DockerProvider.GetResources()
        .FirstOrDefault(resource => resource.EffectiveTypeId == DockerContainerResourceProvider.HostResourceType);
    var canView = host is not null && ResourceManager.GetResource(host.Id) is not null;
}

@if (!canView)
{
    <section class="empty-state">
        <strong>Access denied</strong>
        <span>You do not have access to this container host.</span>
    </section>
}
else
{
    var status = DockerProvider.ConnectionStatus;
    var containers = ResourceManager.GetChildren(host!.Id);

<section class="page-heading compact">
    <div>
        <span class="eyebrow">Docker resource</span>
        <h1>Container Host</h1>
        <p>Host connection and containers contributed by the Docker extension.</p>
    </div>
    <div class="heading-actions">
        <FluentButton Appearance="Appearance.Neutral" OnClick="Refresh">Refresh</FluentButton>
    </div>
</section>

<section class="provider-summary panel">
    <div class="provider-status">
        <span class="state-dot @(status.IsConnected ? "state-running" : "state-stopped")"></span>
        <div>
            <strong>@(status.IsConnected ? "Connected" : "Unavailable")</strong>
            <span>@EndpointLink(status.Endpoint.ToString())</span>
        </div>
    </div>
    <dl class="provider-facts">
        <dt>Transport</dt>
        <dd>@status.Endpoint.Scheme</dd>
        <dt>Last checked</dt>
        <dd>@FormatLastChecked(status.LastChecked)</dd>
        <dt>Containers</dt>
        <dd>@containers.Count</dd>
    </dl>

    @if (!status.IsConnected && status.Error is not null)
    {
        <div class="provider-error">@status.Error</div>
    }
</section>

@if (ProcedureMessage is not null)
{
    <div class="procedure-message">@ProcedureMessage</div>
}

@if (PendingAction is not null)
{
    <div class="procedure-confirmation">
        <strong>@PendingAction.Action.DisplayName @PendingAction.Resource.Name?</strong>
        <span>@GetConfirmationMessage(PendingAction.Resource, PendingAction.Action)</span>
        <div class="form-actions">
            <FluentButton Appearance="Appearance.Neutral" OnClick="CancelContainerAction">
                Cancel
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmContainerAction">
                @PendingAction.Action.DisplayName
            </FluentButton>
        </div>
    </div>
}

<section class="panel">
    <div class="panel-header">
        <div>
            <h2>Containers</h2>
            <p>@containers.Count discovered from this container host.</p>
        </div>
    </div>

    @if (containers.Count == 0)
    {
        <div class="empty-state">
            <strong>No Docker containers discovered</strong>
            <span>Start Docker and create a container, then refresh this resource.</span>
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table class="resource-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Image</th>
                        <th>State</th>
                        <th>Endpoint</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var container in containers)
                    {
                        <tr>
                            <td>
                                <strong>@container.Name</strong>
                                <span>@ShortId(container.Id)</span>
                            </td>
                            <td>@container.Version</td>
                            <td>
                                <span class="state-pill @GetStateClass(container.State)">@container.State</span>
                            </td>
                            <td class="endpoint">@EndpointLink(container.PrimaryEndpoint)</td>
                            <td>
                                @ContainerActionControls(container)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
}

@code {
    private string? ExecutingActionKey { get; set; }
    private string? ProcedureMessage { get; set; }
    private PendingResourceAction? PendingAction { get; set; }

    private async Task Refresh()
    {
        var refresh = DockerProvider.RefreshAsync();
        await Task.WhenAny(refresh, Task.Delay(TimeSpan.FromSeconds(4)));
    }

    private async Task RequestContainerAction(Resource container, ResourceAction action)
    {
        if (action.RequiresConfirmation)
        {
            PendingAction = new PendingResourceAction(container, action);
            ProcedureMessage = null;
            return;
        }

        await ExecuteContainerAction(container, action);
    }

    private async Task ConfirmContainerAction()
    {
        if (PendingAction is null)
        {
            return;
        }

        var pending = PendingAction;
        PendingAction = null;
        await ExecuteContainerAction(pending.Resource, pending.Action);
    }

    private void CancelContainerAction() => PendingAction = null;

    private async Task ExecuteContainerAction(Resource container, ResourceAction action)
    {
        ExecutingActionKey = GetActionKey(container, action);
        ProcedureMessage = null;
        try
        {
            var group = ResourceManager.GetGroupForResource(container.Id);
            var result = await DockerProvider.ExecuteActionAsync(
                new ResourceProcedureContext(container, null, group?.Id, Registrations),
                action);

            ProcedureMessage = result.Message;
        }
        catch (Exception exception)
        {
            ProcedureMessage = exception.Message;
        }
        finally
        {
            ExecutingActionKey = null;
        }
    }

    private bool CanManage(Resource resource)
    {
        var group = ResourceManager.GetGroupForResource(resource.Id);
        return Authorization.CanAccessResource(
            resource.Id,
            group?.Id,
            CloudShellPermissions.Resources.Manage);
    }

    private bool IsExecutingAction(Resource resource, ResourceAction action) =>
        string.Equals(ExecutingActionKey, GetActionKey(resource, action), StringComparison.Ordinal);

    private void OpenLogs(Resource resource)
    {
        var logs = LogStore.GetLogsForResource(resource.Id);
        var query = new Dictionary<string, string?>
        {
            ["resourceId"] = resource.Id
        };

        if (logs.Count == 1)
        {
            query["logId"] = logs[0].Id;
        }

        Navigation.NavigateTo(BuildLogsRoute(query));
    }

    private RenderFragment ContainerActionControls(Resource container) => builder =>
    {
        var logs = LogStore.GetLogsForResource(container.Id);
        if (container.ResourceActions.Count == 0 && logs.Count == 0)
        {
            return;
        }

        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "inline-actions");

        foreach (var action in container.ResourceActions.Where(IsInlineAction))
        {
            builder.OpenComponent<FluentButton>(sequence++);
            builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
            builder.AddAttribute(sequence++, "Class", "action-icon-button");
            builder.AddAttribute(sequence++, "Style", "width: 2rem; min-width: 2rem;");
            builder.AddAttribute(sequence++, "Title", action.DisplayName);
            builder.AddAttribute(sequence++, "Disabled", !CanManage(container) || IsExecutingAction(container, action));
            builder.AddAttribute(sequence++, "OnClick",
                EventCallback.Factory.Create<MouseEventArgs>(
                    this,
                    () => RequestContainerAction(container, action)));
            builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
            {
                buttonBuilder.OpenElement(0, "span");
                buttonBuilder.AddAttribute(1, "class", $"action-icon {GetActionIconClass(action)}");
                buttonBuilder.AddAttribute(2, "aria-hidden", "true");
                buttonBuilder.CloseElement();
            }));
            builder.CloseComponent();
        }

        var overflowActions = GetOverflowActions(container);
        if (overflowActions.Count == 0)
        {
            if (logs.Count > 0)
            {
                AddLogIconButton(builder, ref sequence, container, logs.Count);
            }

            builder.CloseElement();
            return;
        }

        builder.OpenComponent<FluentMenuButton>(sequence++);
        builder.AddAttribute(sequence++, "Class", "action-overflow-button");
        builder.AddAttribute(sequence++, "ButtonAppearance", Appearance.Neutral);
        builder.AddAttribute(sequence++, "UseMenuService", true);
        builder.AddAttribute(sequence++, "ButtonStyle", "width: 2rem; min-width: 2rem;");
        builder.AddAttribute(sequence++, "ButtonContent", (RenderFragment)(buttonBuilder =>
        {
            buttonBuilder.OpenElement(0, "span");
            buttonBuilder.AddAttribute(1, "class", "action-overflow-label");
            buttonBuilder.AddAttribute(2, "aria-label", "More actions");
            buttonBuilder.AddContent(3, "⋮");
            buttonBuilder.CloseElement();
        }));
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(menuBuilder =>
        {
            var menuSequence = 0;
            foreach (var action in overflowActions)
            {
                menuBuilder.OpenComponent<FluentMenuItem>(menuSequence++);
                menuBuilder.AddAttribute(menuSequence++, "Disabled",
                    !CanManage(container) || IsExecutingAction(container, action));
                menuBuilder.AddAttribute(menuSequence++, "OnClick",
                    EventCallback.Factory.Create<MouseEventArgs>(
                        this,
                        () => RequestContainerAction(container, action)));
                menuBuilder.AddAttribute(menuSequence++, "ChildContent", (RenderFragment)(itemBuilder =>
                {
                    itemBuilder.OpenElement(0, "span");
                    itemBuilder.AddAttribute(1, "class", "menu-action-content");
                    itemBuilder.OpenElement(2, "span");
                    itemBuilder.AddAttribute(3, "class", $"action-icon {GetActionIconClass(action)}");
                    itemBuilder.AddAttribute(4, "aria-hidden", "true");
                    itemBuilder.CloseElement();
                    itemBuilder.OpenElement(5, "span");
                    itemBuilder.AddContent(6, IsExecutingAction(container, action)
                        ? "Working"
                        : action.DisplayName);
                    itemBuilder.CloseElement();
                    itemBuilder.CloseElement();
                }));
                menuBuilder.CloseComponent();
            }

            if (logs.Count > 0)
            {
                AddLogMenuItem(menuBuilder, ref menuSequence, container, logs.Count);
            }
        }));
        builder.CloseComponent();
        builder.CloseElement();
    };

    private void AddLogIconButton(
        RenderTreeBuilder builder,
        ref int sequence,
        Resource resource,
        int logCount)
    {
        builder.OpenComponent<FluentButton>(sequence++);
        builder.AddAttribute(sequence++, "Class", "action-icon-button");
        builder.AddAttribute(sequence++, "Appearance", Appearance.Neutral);
        builder.AddAttribute(sequence++, "Style", "width: 2rem; min-width: 2rem;");
        builder.AddAttribute(sequence++, "Title", GetLogsActionLabel(logCount));
        builder.AddAttribute(sequence++, "OnClick",
            EventCallback.Factory.Create<MouseEventArgs>(
                this,
                () => OpenLogs(resource)));
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(buttonBuilder =>
        {
            buttonBuilder.OpenElement(0, "span");
            buttonBuilder.AddAttribute(1, "class", "action-icon action-icon-logs");
            buttonBuilder.AddAttribute(2, "aria-hidden", "true");
            buttonBuilder.CloseElement();
        }));
        builder.CloseComponent();
    }

    private void AddLogMenuItem(
        RenderTreeBuilder builder,
        ref int sequence,
        Resource resource,
        int logCount)
    {
        builder.OpenComponent<FluentMenuItem>(sequence++);
        builder.AddAttribute(sequence++, "OnClick",
            EventCallback.Factory.Create<MouseEventArgs>(
                this,
                () => OpenLogs(resource)));
        builder.AddAttribute(sequence++, "ChildContent", (RenderFragment)(itemBuilder =>
        {
            itemBuilder.OpenElement(0, "span");
            itemBuilder.AddAttribute(1, "class", "menu-action-content");
            itemBuilder.OpenElement(2, "span");
            itemBuilder.AddAttribute(3, "class", "action-icon action-icon-logs");
            itemBuilder.AddAttribute(4, "aria-hidden", "true");
            itemBuilder.CloseElement();
            itemBuilder.OpenElement(5, "span");
            itemBuilder.AddContent(6, GetLogsActionLabel(logCount));
            itemBuilder.CloseElement();
            itemBuilder.CloseElement();
        }));
        builder.CloseComponent();
    }

    private static IReadOnlyList<ResourceAction> GetOverflowActions(Resource resource) =>
        resource.ResourceActions
            .Where(action => !IsInlineAction(action))
            .ToArray();

    private static bool IsInlineAction(ResourceAction action) =>
        action.EffectivePresentation.DisplayStyle == ResourceActionDisplayStyle.Inline;

    private static string GetActionIconClass(ResourceAction action) => action.EffectivePresentation.Icon switch
    {
        ResourceActionIcon.Start => "action-icon-start",
        ResourceActionIcon.Stop => "action-icon-stop",
        ResourceActionIcon.Pause => "action-icon-pause",
        ResourceActionIcon.Restart => "action-icon-restart",
        _ => "action-icon-custom"
    };

    private static string GetConfirmationMessage(Resource resource, ResourceAction action) =>
        action.Description ??
        $"This will request the {action.DisplayName} action for {resource.Name}.";

    private static string GetLogsActionLabel(int logCount) =>
        logCount == 1 ? "Logs" : $"Logs ({logCount})";

    private static RenderFragment EndpointLink(string? address) => builder =>
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            builder.AddContent(0, "none");
            return;
        }

        if (!IsLinkEndpoint(address))
        {
            builder.AddContent(1, address);
            return;
        }

        builder.OpenElement(2, "a");
        builder.AddAttribute(3, "class", "endpoint-link");
        builder.AddAttribute(4, "href", address);
        builder.AddAttribute(5, "target", "_blank");
        builder.AddAttribute(6, "rel", "noopener noreferrer");
        builder.AddContent(7, address);
        builder.CloseElement();
    };

    private static bool IsLinkEndpoint(string address) =>
        Uri.TryCreate(address, UriKind.Absolute, out var uri) &&
        (uri.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
         uri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase));

    private static string BuildLogsRoute(Dictionary<string, string?> query) =>
        "/logs?" + string.Join(
            "&",
            query
                .Where(item => !string.IsNullOrWhiteSpace(item.Value))
                .Select(item => $"{Uri.EscapeDataString(item.Key)}={Uri.EscapeDataString(item.Value!)}"));

    private static string GetActionKey(Resource resource, ResourceAction action) =>
        $"{resource.Id}:{action.Id}";

    private static string FormatLastChecked(DateTimeOffset value) =>
        value == DateTimeOffset.MinValue
            ? "Not yet checked"
            : value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private static string ShortId(string value) =>
        value.Length <= 24 ? value : value[^12..];

    private static string GetStateClass(ResourceState state) => state switch
    {
        ResourceState.Running => "state-running",
        ResourceState.Starting => "state-starting",
        ResourceState.Paused => "state-paused",
        ResourceState.Degraded => "state-degraded",
        ResourceState.Stopped => "state-stopped",
        _ => "state-unknown"
    };

    private sealed record PendingResourceAction(Resource Resource, ResourceAction Action);
}
