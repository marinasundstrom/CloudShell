@inject DockerContainerResourceProvider DockerProvider
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject NavigationManager Navigation

@{
    var status = DockerProvider.ConnectionStatus;
    var engine = DockerProvider.GetResources().FirstOrDefault(resource => resource.EffectiveTypeId == "docker.engine");
    var groups = ResourceGroups.GetResourceGroups();
}

<div class="type-registration">
    @if (!status.IsConnected && status.Error is not null)
    {
        <div class="provider-error">@status.Error</div>
    }

    <label for="docker-group">Resource group</label>
    <FluentSelect TOption="string"
                  Id="docker-group"
                  @bind-Value="SelectedGroupId"
                  Appearance="Appearance.Outline">
        <FluentOption TOption="string" Value="">Default group</FluentOption>
        @foreach (var group in groups)
        {
            <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
        }
    </FluentSelect>

    <label for="docker-registry">Registry</label>
    <FluentTextField Id="docker-registry" @bind-Value="Registry" Placeholder="docker.io" />

    <label for="docker-registry-username">Registry username</label>
    <FluentTextField Id="docker-registry-username" @bind-Value="RegistryUsername" />

    <label for="docker-registry-password-environment-variable">Registry password environment variable</label>
    <FluentTextField Id="docker-registry-password-environment-variable" @bind-Value="RegistryPasswordEnvironmentVariable" />

    @if (ErrorMessage is not null)
    {
        <div class="provider-error">@ErrorMessage</div>
    }

    <div class="candidate-row single">
        <span class="resource-kind-icon">D</span>
        <div>
            <strong>@(engine?.Name ?? "Local Docker Engine")</strong>
            <span>Docker Engine · local</span>
            <small>@DockerProvider.GetContainers().Count discovered containers will appear as sub-resources.</small>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      Disabled="@(engine is null)"
                      OnClick="Register">
            Add
        </FluentButton>
    </div>
</div>

@code {
    [CascadingParameter]
    public ResourceRegistrationProbeContext? ProbeContext { get; set; }

    private string SelectedGroupId { get; set; } = string.Empty;
    private string Registry { get; set; } = ContainerRegistryDefaults.Default;
    private string? RegistryUsername { get; set; }
    private string? RegistryPasswordEnvironmentVariable { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task Register()
    {
        ErrorMessage = null;
        if (!ValidateRegistryCredentials())
        {
            return;
        }

        await DockerProvider.SetupEngineAsync(
            SelectedGroupId,
            Registrations,
            ProbeContext?.GetSelectedHealthChecks(),
            NormalizeRegistry(Registry),
            BuildRegistryCredentials());
        Navigation.NavigateTo("/resources");
    }

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private bool ValidateRegistryCredentials()
    {
        if (string.IsNullOrWhiteSpace(RegistryUsername) &&
            string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable))
        {
            return true;
        }

        if (!string.IsNullOrWhiteSpace(RegistryUsername) &&
            !string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable))
        {
            return true;
        }

        ErrorMessage = "Registry username and password environment variable are required together.";
        return false;
    }

    private ContainerRegistryCredentials? BuildRegistryCredentials() =>
        string.IsNullOrWhiteSpace(RegistryUsername) ||
        string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable)
            ? null
            : new ContainerRegistryCredentials(
                RegistryUsername,
                RegistryPasswordEnvironmentVariable);
}
