@inject DockerContainerResourceProvider DockerProvider
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations
@inject NavigationManager Navigation

@{
    var status = DockerProvider.ConnectionStatus;
    var engine = DockerProvider.GetResources().FirstOrDefault(resource => resource.EffectiveTypeId == "docker.engine");
    var groups = ResourceGroups.GetResourceGroups();
}

<div class="type-registration">
    @if (!status.IsConnected && status.Error is not null)
    {
        <div class="provider-error">@status.Error</div>
    }

    <label for="docker-group">Resource group</label>
    <FluentSelect TOption="string"
                  Id="docker-group"
                  @bind-Value="SelectedGroupId"
                  Appearance="Appearance.Outline">
        <FluentOption TOption="string" Value="">Default group</FluentOption>
        @foreach (var group in groups)
        {
            <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
        }
    </FluentSelect>

    <div class="candidate-row single">
        <span class="resource-kind-icon">D</span>
        <div>
            <strong>@(engine?.Name ?? "Local Docker Engine")</strong>
            <span>Docker Engine · local</span>
            <small>@DockerProvider.GetContainers().Count discovered containers will appear as sub-resources.</small>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      Disabled="@(engine is null)"
                      OnClick="Register">
            Add
        </FluentButton>
    </div>
</div>

@code {
    [CascadingParameter]
    public ResourceRegistrationProbeContext? ProbeContext { get; set; }

    private string SelectedGroupId { get; set; } = string.Empty;

    private async Task Register()
    {
        await DockerProvider.SetupEngineAsync(
            SelectedGroupId,
            Registrations,
            ProbeContext?.GetSelectedHealthChecks());
        Navigation.NavigateTo("/resources");
    }
}
