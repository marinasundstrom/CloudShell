@inject DockerContainerResourceProvider DockerProvider
@inject IResourceManagerStore ResourceManager
@inject IResourceGroupStore ResourceGroups
@inject IResourceRegistrationStore Registrations

@if (Resource is null)
{
    <div class="empty-state">
        <strong>Container host is unavailable</strong>
        <span>The resource may have been removed or is no longer visible.</span>
    </div>
}
else
{
    <div class="type-registration">
        <div class="provider-summary compact">
            <div class="provider-status">
                <span class="state-dot @(DockerProvider.ConnectionStatus.IsConnected ? "state-running" : "state-stopped")"></span>
                <div>
                    <strong>@Resource.Name</strong>
                    <span>@EndpointLink(Resource.PrimaryEndpoint)</span>
                </div>
            </div>
        </div>

        <label for="docker-update-group">Resource group</label>
        <FluentSelect TOption="string"
                      Id="docker-update-group"
                      @bind-Value="SelectedGroupId"
                      Disabled="@IsReadOnly"
                      Appearance="Appearance.Outline">
            <FluentOption TOption="string" Value="">Default group</FluentOption>
            @foreach (var group in ResourceGroups.GetResourceGroups())
            {
                <FluentOption TOption="string" Value="@group.Id">@group.Name</FluentOption>
            }
        </FluentSelect>

        <label for="docker-update-registry">Registry</label>
        <FluentTextField Id="docker-update-registry" @bind-Value="Registry" Disabled="@IsReadOnly" Placeholder="docker.io" />

        <label for="docker-update-registry-username">Registry username</label>
        <FluentTextField Id="docker-update-registry-username" @bind-Value="RegistryUsername" Disabled="@IsReadOnly" />

        <label for="docker-update-registry-password-environment-variable">Registry password environment variable</label>
        <FluentTextField Id="docker-update-registry-password-environment-variable" @bind-Value="RegistryPasswordEnvironmentVariable" Disabled="@IsReadOnly" />
    </div>
}

@code {
    [CascadingParameter]
    public ResourceConfigurationContext? Configuration { get; set; }

    [CascadingParameter(Name = ResourceManagerCascadingParameterNames.ReadOnly)]
    public bool IsReadOnly { get; set; }

    [Parameter]
    public string? ResourceId { get; set; }

    private Resource? Resource { get; set; }
    private string SelectedGroupId { get; set; } = string.Empty;
    private string Registry { get; set; } = ContainerRegistryDefaults.Default;
    private string? RegistryUsername { get; set; }
    private string? RegistryPasswordEnvironmentVariable { get; set; }
    private ResourceConfigurationContext? RegisteredConfiguration { get; set; }

    protected override void OnParametersSet()
    {
        Resource = string.IsNullOrWhiteSpace(ResourceId)
            ? null
            : ResourceManager.GetResource(ResourceId);

        SelectedGroupId = Resource is null
            ? string.Empty
            : ResourceManager.GetGroupForResource(Resource.Id)?.Id ?? string.Empty;
        Registry = Resource?.ResourceAttributes.GetValueOrDefault(ResourceAttributeNames.ContainerRegistry) ??
            ContainerRegistryDefaults.Default;
        RegistryUsername = DockerProvider.RegistryCredentials?.Username;
        RegistryPasswordEnvironmentVariable = DockerProvider.RegistryCredentials?.PasswordEnvironmentVariable;

        if (Configuration is not null &&
            !ReferenceEquals(Configuration, RegisteredConfiguration))
        {
            Configuration.SetApplyHandler(ApplyAsync);
            RegisteredConfiguration = Configuration;
        }
    }

    private async Task<ResourceProcedureResult> ApplyAsync(CancellationToken cancellationToken)
    {
        if (IsReadOnly)
        {
            return ResourceProcedureResult.Completed("Resource Manager is in read-only mode.");
        }

        if (!ValidateRegistryCredentials())
        {
            return ResourceProcedureResult.Completed("Registry username and password environment variable are required together.");
        }

        await DockerProvider.UpdateHostAsync(
            Resource?.Id ?? DockerContainerResourceProvider.DefaultHostResourceId,
            SelectedGroupId,
            Registrations,
            NormalizeRegistry(Registry),
            BuildRegistryCredentials(),
            cancellationToken);
        return ResourceProcedureResult.Completed("Container host configuration updated.");
    }

    private static string NormalizeRegistry(string? value) =>
        string.IsNullOrWhiteSpace(value) ? ContainerRegistryDefaults.Default : value.Trim();

    private bool ValidateRegistryCredentials()
    {
        if (string.IsNullOrWhiteSpace(RegistryUsername) &&
            string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable))
        {
            return true;
        }

        return !string.IsNullOrWhiteSpace(RegistryUsername) &&
            !string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable);
    }

    private ContainerRegistryCredentials? BuildRegistryCredentials() =>
        string.IsNullOrWhiteSpace(RegistryUsername) ||
        string.IsNullOrWhiteSpace(RegistryPasswordEnvironmentVariable)
            ? null
            : new ContainerRegistryCredentials(
                RegistryUsername,
                RegistryPasswordEnvironmentVariable);

    private static RenderFragment EndpointLink(string? address) => builder =>
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            builder.AddContent(0, "none");
            return;
        }

        if (!IsLinkEndpoint(address))
        {
            builder.AddContent(1, address);
            return;
        }

        builder.OpenElement(2, "a");
        builder.AddAttribute(3, "class", "endpoint-link");
        builder.AddAttribute(4, "href", address);
        builder.AddAttribute(5, "target", "_blank");
        builder.AddAttribute(6, "rel", "noopener noreferrer");
        builder.AddContent(7, address);
        builder.CloseElement();
    };

    private static bool IsLinkEndpoint(string address) =>
        Uri.TryCreate(address, UriKind.Absolute, out var uri) &&
        (uri.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase) ||
         uri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase));
}
