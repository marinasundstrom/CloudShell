@inject CompositionRegistry Composition

@{
    var resolvedTarget = ResolvedTarget;
    var resolvedHref = Composition.ResolveHref(resolvedTarget, RouteParams);
    var resolved = IsResolvedHref(resolvedTarget, resolvedHref);
}

@if (!resolved)
{
    if (Unresolved is not null)
    {
        @Unresolved
    }
    else
    {
        <span class="composite-anchor-unresolved" data-composition-target="@resolvedTarget.Value">
            Failed to resolve link
        </span>
    }
}
else
{
    <a @attributes="AdditionalAttributes" href="@resolvedHref">
    @if (ChildContent is null)
    {
        @ResolveTitle(resolvedTarget)
    }
    else
    {
        @ChildContent
    }
    </a>
}

@code {
    [Parameter]
    public PageId? Page { get; set; }

    [Parameter]
    public CompositionTarget? Target { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, object?>? RouteParams { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment? Unresolved { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private CompositionTarget ResolvedTarget =>
        Target ?? (Page.HasValue
            ? CompositionTarget.ForPage(Page.Value)
            : throw new InvalidOperationException("CompositeAnchor requires Page or Target."));

    private string ResolveTitle(CompositionTarget target)
    {
        if (target.Kind == CompositionTargetKind.Href)
        {
            return target.Value;
        }

        if (Composition.GetMenuItemProjection(new MenuItemId(target.Value)) is { } menuItem)
        {
            return menuItem.Item.Title;
        }

        if (Composition.GetPageProjection(new PageId(target.Value)) is { } page)
        {
            return page.Page.Title;
        }

        if (Composition.GetSectionProjection(new SectionId(target.Value)) is { } section)
        {
            return section.Section.Title;
        }

        return target.Value;
    }

    private static bool IsResolvedHref(CompositionTarget target, string href) =>
        href != "#" ||
        (target.Kind == CompositionTargetKind.Href &&
            string.Equals(target.Value, "#", StringComparison.Ordinal));
}
