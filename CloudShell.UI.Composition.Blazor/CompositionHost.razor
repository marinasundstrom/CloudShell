@inject CompositionRegistry Composition
@inject NavigationManager Navigation

@if (Context is null && RequireRegisteredPage)
{
    <div class="composition-empty-state">
        <strong>Composition page not registered</strong>
        <span>The current routed page is not available in the composition registry.</span>
    </div>
}
else if (Context is null)
{
    @ChildContent
}
else
{
    <CascadingValue Value="Context" IsFixed="true">
        @ChildContent
    </CascadingValue>
}

@code {
    [Parameter]
    public PageId? Id { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool RequireRegisteredPage { get; set; } = true;

    private CompositionContext? Context
    {
        get
        {
            return CompositionPageContextResolver.Resolve(
                Composition,
                Navigation,
                context: null,
                Id);
        }
    }
}
