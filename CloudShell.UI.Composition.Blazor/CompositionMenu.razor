@inject CompositionRegistry Composition

@if (MenuProjection is not null)
{
    var menu = MenuProjection.Menu;
    <nav @attributes="AdditionalAttributes"
         class="@Class"
         aria-label="@menu.Title"
         data-composition-module="@MenuProjection.ModuleId.Value">
        @foreach (var item in GetRootItems(menu.Items))
        {
            <div class="@ItemClass" data-composition-menu-item="@item.Id.Value">
                <CompositeAnchor Target="@item.Target">@item.Title</CompositeAnchor>
                @if (GetChildren(menu.Items, item).Count > 0)
                {
                    <div class="@SubItemsClass">
                        @foreach (var child in GetChildren(menu.Items, item))
                        {
                            <CompositeAnchor Target="@child.Target">@child.Title</CompositeAnchor>
                        }
                    </div>
                }
            </div>
        }

        @foreach (var group in menu.Groups)
        {
            <div class="@GroupClass" data-composition-menu-group="@group.Id.Value">
                <strong>@group.Title</strong>
                @foreach (var item in GetRootItems(group.Items))
                {
                    <div class="@ItemClass" data-composition-menu-item="@item.Id.Value">
                        <CompositeAnchor Target="@item.Target">@item.Title</CompositeAnchor>
                        @if (GetChildren(group.Items, item).Count > 0)
                        {
                            <div class="@SubItemsClass">
                                @foreach (var child in GetChildren(group.Items, item))
                                {
                                    <CompositeAnchor Target="@child.Target">@child.Title</CompositeAnchor>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </nav>
}

@code {
    [Parameter, EditorRequired]
    public MenuId Id { get; set; }

    [Parameter]
    public string Class { get; set; } = "composition-menu";

    [Parameter]
    public string GroupClass { get; set; } = "composition-menu-group";

    [Parameter]
    public string ItemClass { get; set; } = "composition-menu-item";

    [Parameter]
    public string SubItemsClass { get; set; } = "composition-menu-subitems";

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private CompositionMenuProjection? MenuProjection => Composition.GetMenuProjection(Id);

    private static IReadOnlyList<CompositionMenuItemRegistration> GetRootItems(
        IReadOnlyList<CompositionMenuItemRegistration> items) =>
        items
            .Where(item => item.ParentId is null)
            .OrderBy(item => item.Order)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private static IReadOnlyList<CompositionMenuItemRegistration> GetChildren(
        IReadOnlyList<CompositionMenuItemRegistration> items,
        CompositionMenuItemRegistration parent) =>
        items
            .Where(item => item.ParentId == parent.Id)
            .OrderBy(item => item.Order)
            .ThenBy(item => item.Title, StringComparer.OrdinalIgnoreCase)
            .ToArray();
}
