@inject CompositionRegistry Composition

@if (MenuProjection is not null)
{
    var menu = MenuProjection.Menu;
    <nav class="composition-menu" aria-label="@menu.Title" data-composition-module="@MenuProjection.ModuleId.Value">
        @foreach (var item in menu.Items)
        {
            <CompositionLink Target="@item.Target">@item.Title</CompositionLink>
        }

        @foreach (var section in menu.Sections)
        {
            <div class="composition-menu-section">
                <strong>@section.Title</strong>
                @foreach (var item in section.Items)
                {
                    <CompositionLink Target="@item.Target">@item.Title</CompositionLink>
                }
            </div>
        }
    </nav>
}

@code {
    [Parameter, EditorRequired]
    public MenuId Id { get; set; }

    private CompositionMenuProjection? MenuProjection => Composition.GetMenuProjection(Id);
}
