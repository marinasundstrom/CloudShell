@inject CompositionRegistry Composition

@if (Context is null)
{
    <div class="composition-empty-state">
        <strong>Composition context missing</strong>
        <span>The section outlet must be rendered under a composition host.</span>
    </div>
}
else if (ResolvedOutletId is null)
{
    <div class="composition-empty-state">
        <strong>Section outlet missing</strong>
        <span>The section outlet needs an ID or a containing section container.</span>
    </div>
}
else
{
    var sections = Composition.GetSectionProjections(Context.PageId, ResolvedOutletId.Value);
    @foreach (var projection in sections)
    {
        var section = projection.Section;
        <article class="composition-section"
                 id="@section.Id.Value"
                 data-composition-module="@projection.ModuleId.Value">
            <header class="composition-section-header">
                <h2>@section.Title</h2>
            </header>
            <DynamicComponent Type="section.ComponentType" />
        </article>
    }
}

@code {
    [CascadingParameter]
    public CompositionContext? Context { get; set; }

    [CascadingParameter]
    public SectionOutletId? ContainerId { get; set; }

    [Parameter]
    public SectionOutletId? Id { get; set; }

    private SectionOutletId? ResolvedOutletId => Id ?? ContainerId;
}
