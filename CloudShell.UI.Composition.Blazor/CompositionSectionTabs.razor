@inject CompositionRegistry Composition
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable

@if (ResolvedContext is null)
{
    <div class="@EmptyStateClass">
        <strong>Composition context missing</strong>
        <span>The tab outlet needs a composition host, an explicit page, or a registered route.</span>
    </div>
}
else if (ResolvedOutletId is null)
{
    <div class="@EmptyStateClass">
        <strong>Section outlet missing</strong>
        <span>The tab outlet needs an ID or a containing section container.</span>
    </div>
}
else if (Sections.Count == 0)
{
    <div class="@EmptyStateClass">
        <strong>No sections registered</strong>
        <span>The current outlet has no sections for this page.</span>
    </div>
}
else
{
    <div class="@ContainerClass" @attributes="AdditionalAttributes">
        <div class="@TabListContainerClass">
            <nav class="@TabListClass" aria-label="@AriaLabel" role="tablist">
                @foreach (var section in Sections)
                {
                    <a class="@GetTabClass(section)"
                       href="@GetTabHref(section)"
                       role="tab"
                       aria-selected="@(section.Section.Id == SelectedSection.Section.Id)"
                       data-composition-module="@section.ModuleId.Value">
                        @section.Section.Title
                    </a>
                }
            </nav>
        </div>

        <div class="@ContentClass"
             role="tabpanel"
             id="@SelectedSection.Section.Id.Value"
             data-composition-module="@SelectedSection.ModuleId.Value">
            <DynamicComponent Type="SelectedSection.Section.ComponentType" />
        </div>
    </div>
}

@code {
    [CascadingParameter]
    public CompositionContext? Context { get; set; }

    [CascadingParameter]
    public SectionOutletId? ContainerId { get; set; }

    [Parameter]
    public PageId? Page { get; set; }

    [Parameter]
    public SectionOutletId? Id { get; set; }

    [Parameter]
    public string AriaLabel { get; set; } = "Sections";

    [Parameter]
    public string ContainerClass { get; set; } = "composition-tabs";

    [Parameter]
    public string TabListContainerClass { get; set; } = "composition-tab-list-container";

    [Parameter]
    public string TabListClass { get; set; } = "composition-tab-list";

    [Parameter]
    public string TabClass { get; set; } = "composition-tab";

    [Parameter]
    public string SelectedTabClass { get; set; } = "is-selected";

    [Parameter]
    public string ContentClass { get; set; } = "composition-tab-panel";

    [Parameter]
    public string EmptyStateClass { get; set; } = "composition-empty-state";

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string? SelectedSectionId { get; set; }

    protected override void OnInitialized()
    {
        SelectedSectionId = ReadSelectedSectionId();
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private CompositionContext? ResolvedContext =>
        CompositionPageContextResolver.Resolve(
            Composition,
            Navigation,
            Context,
            Page);

    private SectionOutletId? ResolvedOutletId => Id ?? ContainerId;

    private IReadOnlyList<CompositionSectionProjection> Sections =>
        ResolvedContext is null || ResolvedOutletId is null
            ? []
            : Composition.GetSectionProjections(ResolvedContext.PageId, ResolvedOutletId.Value);

    private CompositionSectionProjection SelectedSection =>
        Sections.FirstOrDefault(section => section.Section.Id.Value == SelectedSectionId) ?? Sections[0];

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        var selectedSectionId = ReadSelectedSectionId(args.Location);
        if (string.Equals(SelectedSectionId, selectedSectionId, StringComparison.Ordinal))
        {
            return;
        }

        SelectedSectionId = selectedSectionId;
        _ = InvokeAsync(StateHasChanged);
    }

    private string? ReadSelectedSectionId(string? location = null)
    {
        var uri = Navigation.ToAbsoluteUri(location ?? Navigation.Uri);
        if (ResolvedContext is not null &&
            ResolvedOutletId is not null &&
            Composition.GetSectionOutlet(ResolvedOutletId.Value)?.AddressMode == CompositionSectionAddressMode.Child &&
            TryReadChildAddress(uri, out var childAddress) &&
            TryResolveSectionRequest(childAddress, out var childSection))
        {
            return childSection.Section.Id.Value;
        }

        if (!string.IsNullOrWhiteSpace(uri.Fragment))
        {
            var fragment = Uri.UnescapeDataString(uri.Fragment.TrimStart('#'));
            if (TryResolveSectionRequest(fragment, out var fragmentSection))
            {
                return fragmentSection.Section.Id.Value;
            }
        }

        return null;
    }

    private string GetTabClass(CompositionSectionProjection section) =>
        section.Section.Id == SelectedSection.Section.Id
            ? JoinClasses(TabClass, SelectedTabClass)
            : TabClass;

    private string GetTabHref(CompositionSectionProjection section) =>
        Composition.ResolveHref(section.Section.Id);

    private bool TryReadChildAddress(Uri uri, out string childAddress)
    {
        childAddress = string.Empty;
        if (ResolvedContext is null)
        {
            return false;
        }

        var pageHref = Composition.ResolveHref(ResolvedContext.PageId);
        if (pageHref == "#")
        {
            return false;
        }

        var pagePath = Navigation.ToAbsoluteUri(pageHref).AbsolutePath.TrimEnd('/');
        var currentPath = uri.AbsolutePath.TrimEnd('/');
        if (!currentPath.StartsWith(pagePath + "/", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var remaining = currentPath[(pagePath.Length + 1)..];
        if (remaining.Length == 0 || remaining.Contains('/', StringComparison.Ordinal))
        {
            return false;
        }

        childAddress = Uri.UnescapeDataString(remaining);
        return true;
    }

    private bool TryResolveSectionRequest(
        string requested,
        out CompositionSectionProjection section)
    {
        section = null!;
        if (string.IsNullOrWhiteSpace(requested))
        {
            return false;
        }

        var trimmed = requested.Trim();
        var matchingSections = Sections
            .Where(candidate =>
                string.Equals(candidate.Section.Id.Value, trimmed, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(
                    Composition.GetSectionAddressValue(candidate.Section.Id),
                    trimmed,
                    StringComparison.OrdinalIgnoreCase))
            .ToArray();
        if (matchingSections.Length != 1)
        {
            return false;
        }

        section = matchingSections[0];
        return true;
    }

    private static string JoinClasses(params string[] values) =>
        string.Join(' ', values.Where(value => !string.IsNullOrWhiteSpace(value)));

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
