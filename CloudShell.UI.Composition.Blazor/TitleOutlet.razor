@inject CompositionRegistry Composition
@inject NavigationManager Navigation

@ResolvedTitle

@code {
    [CascadingParameter]
    public CompositionContext? Context { get; set; }

    [Parameter]
    public PageId? Page { get; set; }

    [Parameter]
    public string? FallbackTitle { get; set; }

    private CompositionContext? ResolvedContext =>
        CompositionPageContextResolver.Resolve(
            Composition,
            Navigation,
            Context,
            Page);

    private string? ResolvedTitle =>
        ResolvedContext is null
            ? FallbackTitle
            : Composition.GetPage(ResolvedContext.PageId)?.Title ?? FallbackTitle;
}
