{
  "Authentication": {
    "Enabled": false
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-application-topology-sample.db"
  },
  "Identity": {
    "BuiltIn": {
      "Persistence": {
        "Provider": "Sqlite",
        "ConnectionString": "Data Source=Data/identity-application-topology-sample.db"
      }
    }
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CloudShell.ControlPlane.ResourceManager.ProgrammaticResourceStartup": "Information",
      "CloudShell.ControlPlane.ResourceManager.HostScopedResourceShutdown": "Information",
      "CloudShell.ControlPlane.ResourceManager.ResourceHealth.Polling": "Warning",
      "System.Net.Http.HttpClient.CloudShell.ControlPlane.ResourceManager.ResourceHealth.Probes": "Warning",
      "CloudShell.ControlPlane.ResourceManager.Lifecycle": "Information",
      "CloudShell.ControlPlane.ResourceManager.LocalProcess": "Debug",
      "CloudShell.ControlPlane.ResourceManager.DockerHost": "Debug"
    }
  },
  "AllowedHosts": "*"
}
