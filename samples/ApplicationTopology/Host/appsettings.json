{
  "Authentication": {
    "Enabled": false
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-application-topology-sample.db"
  },
  "Identity": {
    "BuiltIn": {
      "Persistence": {
        "Provider": "Sqlite",
        "ConnectionString": "Data Source=Data/identity-application-topology-sample.db"
      }
    }
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf",
    "Telemetry": {
      "Store": "Database",
      "RetainedSpansPerResource": 5000,
      "RetainedMetricPointsPerResource": 10000
    },
    "Metrics": {
      "Resources": [
        {
          "ResourceName": "application-topology-api",
          "Panels": [
            {
              "Title": "Request count",
              "Description": "Recent HTTP request points",
              "MetricName": "http.server.requests",
              "Kind": "Indicator",
              "Aggregation": "Sum",
              "Unit": "count",
              "MaxPoints": 100
            },
            {
              "Title": "Request duration",
              "Description": "Latest retained request timings",
              "MetricName": "http.server.duration",
              "Kind": "Line",
              "Aggregation": "Latest",
              "Unit": "ms",
              "MaxPoints": 60
            }
          ]
        },
        {
          "ResourceName": "application-topology-frontend",
          "Panels": [
            {
              "Title": "Request count",
              "Description": "Recent HTTP request points",
              "MetricName": "http.server.requests",
              "Kind": "Indicator",
              "Aggregation": "Sum",
              "Unit": "count",
              "MaxPoints": 100
            },
            {
              "Title": "Request duration",
              "Description": "Latest retained request timings",
              "MetricName": "http.server.duration",
              "Kind": "Line",
              "Aggregation": "Latest",
              "Unit": "ms",
              "MaxPoints": 60
            }
          ]
        }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CloudShell.ControlPlane.ResourceManager.ProgrammaticResourceStartup": "Information",
      "CloudShell.ControlPlane.ResourceManager.HostScopedResourceShutdown": "Information",
      "CloudShell.ControlPlane.ResourceManager.ResourceHealth.Polling": "Warning",
      "System.Net.Http.HttpClient.CloudShell.ControlPlane.ResourceManager.ResourceHealth.Probes": "Warning",
      "CloudShell.ControlPlane.ResourceManager.Lifecycle": "Information",
      "CloudShell.ControlPlane.ResourceManager.LocalProcess": "Debug",
      "CloudShell.ControlPlane.ResourceManager.DockerHost": "Debug"
    }
  },
  "AllowedHosts": "*"
}
