{
  "Authentication": {
    "Enabled": false
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-application-topology-sample.db",
    "IdentityConnectionString": "Data Source=Data/identity-application-topology-sample.db"
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
