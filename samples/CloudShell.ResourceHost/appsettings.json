{
  "Authentication": {
    "Enabled": true,
    "Mode": "Identity",
    "AllowLocalSetup": false,
    "BuiltInIdentity": {
      "AllowUserNameSignIn": false
    }
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-resource-sample.db"
  },
  "Identity": {
    "BuiltIn": {
      "Persistence": {
        "Provider": "Sqlite",
        "ConnectionString": "Data Source=Data/identity-resource-sample.db"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
