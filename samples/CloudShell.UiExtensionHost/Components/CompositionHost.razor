@using CloudShell.UiExtensionHost.Composition
@inject SampleCompositionRegistry Composition
@inject NavigationManager Navigation

@if (Context is null)
{
    <div class="empty-state">
        <strong>Composition page not registered</strong>
        <span>The current routed page is not available in the sample composition registry.</span>
    </div>
}
else
{
    <CascadingValue Value="Context" IsFixed="true">
        @ChildContent
    </CascadingValue>
}

@code {
    [Parameter]
    public PageId? Id { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private CompositionContext? Context
    {
        get
        {
            var page = Id.HasValue
                ? Composition.GetPage(Id.Value)
                : Composition.GetPageByRoute(Navigation.ToBaseRelativePath(Navigation.Uri));
            return page is null
                ? null
                : new CompositionContext(page.Id, page.Route);
        }
    }
}
