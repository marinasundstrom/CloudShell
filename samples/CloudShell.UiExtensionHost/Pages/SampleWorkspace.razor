@page "/sample-workspace"

<section class="page-heading">
    <div>
        <span class="eyebrow">UI extension</span>
        <h1>Sample workspace</h1>
        <p>This page is contributed by the sample host application and runs without mapping the CloudShell control-plane API.</p>
    </div>
</section>

<section class="dashboard-grid">
    <article class="panel panel-wide">
        <div class="panel-header">
            <div>
                <h2>Embedded shell surface</h2>
                <p>The extension contributes navigation, routing, and a component from the sample assembly.</p>
            </div>
        </div>

        <div class="activity-list">
            <div class="activity-row">
                <span class="resource-kind-icon">U</span>
                <div>
                    <strong>CloudShell UI</strong>
                    <span>Hosted without persistence, resource stores, or control-plane endpoints.</span>
                </div>
            </div>

            <div class="activity-row">
                <span class="resource-kind-icon">E</span>
                <div>
                    <strong>Sample extension</strong>
                    <span>Registered through the same extension model used by full CloudShell hosts.</span>
                </div>
            </div>
        </div>
    </article>
</section>
