@page "/sample-workspace"

<section class="page-heading">
    <div>
        <span class="eyebrow">UI extension</span>
        <h1>Sample workspace</h1>
        <p>This page is contributed by the sample host application and runs without mapping the CloudShell control-plane API.</p>
    </div>
</section>

<section class="registration-layout">
    <div class="panel registration-options">
        <div class="selected-type-card">
            <span class="resource-kind-icon">U</span>
            <div>
                <strong>UI-only host</strong>
                <p>The sample proves a CloudShell UI extension can be hosted without Resource Manager or Control Plane endpoints.</p>
            </div>
        </div>
    </div>

    <div class="registration-host">
        <article class="panel">
            <div class="panel-header">
                <div>
                    <h2>Extension surface</h2>
                </div>
            </div>
            <div class="activity-list">
                <div class="activity-row">
                    <span class="resource-kind-icon">S</span>
                    <div>
                        <strong>Shell navigation</strong>
                        <span>The extension contributes the selected sidebar item through the composition graph.</span>
                    </div>
                </div>
                <div class="activity-row">
                    <span class="resource-kind-icon">R</span>
                    <div>
                        <strong>Razor page</strong>
                        <span>The workspace is a normal routed Razor component rendered inside CloudShell UI.</span>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>
