@page "/dashboard"

<PageTitleOutlet />

<main class="container-fluid py-4 px-3 px-md-4">
    <header class="mb-4">
        <span class="eyebrow text-secondary">Layout patterns</span>
        <h1 class="display-6 fw-semibold mb-2"><TitleOutlet /></h1>
        <p class="text-secondary mb-3">
            This page uses a sandbox-owned Bootstrap grid outlet over the same
            composition registry. The engine provides graph data; the app owns
            the layout pattern.
        </p>
        <div class="d-flex flex-wrap gap-2">
            <CompositeAnchor Page="@CompositionIds.WorkspacePage" />
            <span>/</span>
            <CompositeAnchor Page="@CompositionIds.ReportsPage" />
            <span>/</span>
            <CompositeAnchor Page="@CompositionIds.DashboardPage" />
            <span>/</span>
            <CompositeAnchor Page="@CompositionIds.SettingsPage" />
        </div>
    </header>

    <CompositionSectionContainer Id="@CompositionIds.DashboardMainOutlet">
        <BootstrapSectionGridOutlet />
    </CompositionSectionContainer>
</main>
