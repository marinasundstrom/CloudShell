@page "/"

<PageTitleOutlet />

<main class="container-fluid py-4 px-3 px-md-4">
    <header class="mb-4">
        <span class="eyebrow text-secondary">Composition engine</span>
        <h1 class="display-6 fw-semibold mb-2"><TitleOutlet /></h1>
        <p class="text-secondary mb-3">
            A clean Blazor application can use the composition engine without
            referencing CloudShell Hosting, Resource Manager, or extension APIs.
        </p>
        <div class="d-flex flex-wrap gap-2">
            <CompositeAnchor Page="@CompositionIds.WorkspacePage" />
            <span>/</span>
            <CompositeAnchor Page="@CompositionIds.ReportsPage" />
            <span>/</span>
            <CompositeAnchor Page="@CompositionIds.DashboardPage" />
            <span>/</span>
            <CompositeAnchor Page="@CompositionIds.SettingsPage" />
            <span>/</span>
            <CompositeAnchor Target="@CompositionIds.ExtensionContributionSection">Open contributed section</CompositeAnchor>
        </div>
    </header>

    <section class="alert alert-info border-info-subtle">
        <h2 class="h6">Section deep links</h2>
        <p class="mb-2">
            Parent-addressed sections render with stable IDs, and section
            targets resolve to hash links on the page.
        </p>
        <div class="d-flex flex-wrap gap-2">
            <CompositeAnchor Target="@CompositionIds.OverviewSection"
                             class="alert-link" />
            <span>/</span>
            <CompositeAnchor Target="@CompositionIds.ExtensionContributionSection"
                             class="alert-link" />
        </div>
    </section>

    <CompositionSectionContainer Id="@CompositionIds.WorkspaceMainOutlet">
        <CompositionSectionNavigation ListClass=""
                                      ContainerClass="d-flex flex-wrap gap-2 mb-3"
                                      LinkClass="btn btn-outline-secondary btn-sm" />
        <CompositionSectionOutlet />
    </CompositionSectionContainer>
</main>
