@page "/settings"
@page "/settings/{Section}"

<CompositionTabbedPageLayout Page="@CompositionIds.SettingsPage"
                             Outlet="@CompositionIds.SettingsMainOutlet"
                             ContainerClass="container-fluid py-4 px-3 px-md-4"
                             HeaderClass="mb-4"
                             EyebrowClass="eyebrow text-secondary"
                             TitleClass="display-6 fw-semibold mb-2"
                             SummaryClass="text-secondary mb-3"
                             NavigationClass="d-flex flex-wrap gap-2"
                             TabsAriaLabel="Settings sections"
                             TabsContainerClass="card shadow-sm"
                             TabListContainerClass="card-header bg-body p-0"
                             TabListClass="nav nav-tabs card-header-tabs px-3 pt-3"
                             TabClass="nav-link"
                             SelectedTabClass="active"
                             TabContentClass="card-body">
    <EyebrowContent>Layout patterns</EyebrowContent>
    <SummaryContent>
        This page uses the reusable composition tabbed page layout styled with
        plain Bootstrap classes. Its section outlet opts into child addresses,
        so each tab is a normal link under the page route.
    </SummaryContent>
    <NavigationContent>
        <CompositeAnchor Page="@CompositionIds.WorkspacePage" />
        <span>/</span>
        <CompositeAnchor Page="@CompositionIds.ReportsPage" />
        <span>/</span>
        <CompositeAnchor Page="@CompositionIds.DashboardPage" />
        <span>/</span>
        <CompositeAnchor Page="@CompositionIds.SettingsPage" />
    </NavigationContent>
</CompositionTabbedPageLayout>

@code {
    [Parameter]
    public string? Section { get; set; }
}
