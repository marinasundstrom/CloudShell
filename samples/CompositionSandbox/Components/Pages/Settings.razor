@page "/settings"

<main class="container-fluid py-4 px-3 px-md-4">
    <header class="mb-4">
        <span class="eyebrow text-secondary">Layout patterns</span>
        <h1 class="display-6 fw-semibold mb-2"><TitleOutlet Page="@CompositionIds.SettingsPage" /></h1>
        <p class="text-secondary mb-3">
            This page uses the reusable composition tab outlet styled with
            plain Bootstrap classes. It selects a named section through a
            normal query string instead of a framework-specific tab component.
        </p>
        <div class="d-flex flex-wrap gap-2">
            <CompositionLink Page="@CompositionIds.WorkspacePage" />
            <span>/</span>
            <CompositionLink Page="@CompositionIds.ReportsPage" />
            <span>/</span>
            <CompositionLink Page="@CompositionIds.DashboardPage" />
            <span>/</span>
            <CompositionLink Page="@CompositionIds.SettingsPage" />
        </div>
    </header>

    <CompositionSectionContainer Id="@CompositionIds.SettingsMainOutlet">
        <CompositionSectionTabs AriaLabel="Settings sections"
                                Page="@CompositionIds.SettingsPage"
                                ContainerClass="card shadow-sm"
                                TabListContainerClass="card-header bg-body p-0"
                                TabListClass="nav nav-tabs card-header-tabs px-3 pt-3"
                                TabClass="nav-link"
                                SelectedTabClass="active"
                                ContentClass="card-body" />
    </CompositionSectionContainer>
</main>
