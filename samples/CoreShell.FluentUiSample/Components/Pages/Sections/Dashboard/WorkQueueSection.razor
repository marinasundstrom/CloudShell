@inject ICoreShellNotificationProducer Notifications
@inject ICoreShellToastService Toasts

<div class="section-actions">
    <FluentButton Appearance="Appearance.Accent"
                  Disabled="@IsCreating"
                  IconStart="@(new Icons.Regular.Size20.AddCircle())"
                  OnClick="CommitCreateResourceAsync">
        @(IsCreating ? "Creating resource" : "Commit create resource")
    </FluentButton>
    <FluentButton Appearance="Appearance.Neutral"
                  Disabled="@IsRunningToastTask"
                  IconStart="@(new Icons.Regular.Size20.Flash())"
                  OnClick="RunToastOnlyTaskAsync">
        @(IsRunningToastTask ? "Running toast task" : "Run toast-only task")
    </FluentButton>
    <span>Compares notification-backed operation feedback with a toast-only transient task.</span>
</div>

<FluentDataGrid Items="@Rows.AsQueryable()" GridTemplateColumns="1fr 120px 120px">
    <PropertyColumn Property="@(row => row.Name)" Title="Work item" />
    <PropertyColumn Property="@(row => row.Owner)" Title="Owner" />
    <TemplateColumn Title="State">
        <FluentBadge Appearance="@GetAppearance(context.State)">@context.State</FluentBadge>
    </TemplateColumn>
</FluentDataGrid>

@code {
    private bool IsCreating { get; set; }

    private bool IsRunningToastTask { get; set; }

    private static readonly IReadOnlyList<Row> Rows =
    [
        new("Navigation presenter", "CoreShell", "Ready"),
        new("Settings outlet", "CoreShell", "Ready"),
        new("CloudShell adapters", "CloudShell", "Next")
    ];

    private static Appearance GetAppearance(string state) =>
        state == "Ready" ? Appearance.Accent : Appearance.Neutral;

    private async Task CommitCreateResourceAsync()
    {
        if (IsCreating)
        {
            return;
        }

        IsCreating = true;
        var notification = await Notifications.PublishAsync(new CoreShellNotificationRequest(
            "Creating sample resource",
            "The request was committed and is running in the background.",
            CoreShellNotificationSeverity.Info,
            CoreShellNotificationStatus.InProgress,
            Source: "CoreShell sample",
            Target: new CoreShellNotificationTarget("/operations", "View operations"),
            Actions:
            [
                new CoreShellNotificationAction(
                    "view-operations",
                    "View operations",
                    new CoreShellNotificationTarget("/operations", "View operations"),
                    IsPrimary: true)
            ],
            ToastTimeToLive: TimeSpan.FromSeconds(6)));

        try
        {
            await Task.Delay(1400);
            await Notifications.UpdateAsync(notification.Id, new CoreShellNotificationUpdate(
                Message: "Sample resource is ready.",
                Severity: CoreShellNotificationSeverity.Success,
                Status: CoreShellNotificationStatus.Succeeded,
                Target: new CoreShellNotificationTarget("/operations", "View operations")));
        }
        finally
        {
            IsCreating = false;
        }
    }

    private async Task RunToastOnlyTaskAsync()
    {
        if (IsRunningToastTask)
        {
            return;
        }

        IsRunningToastTask = true;
        var toast = await Toasts.PublishAsync(new CoreShellToastRequest(
            "Running sample check",
            "This transient task is toast-only and will not appear in notification history.",
            CoreShellNotificationSeverity.Info,
            CoreShellNotificationStatus.InProgress,
            Source: "CoreShell sample",
            AutoDismiss: CoreShellToastAutoDismissBehavior.Never));

        try
        {
            await Task.Delay(1200);
            await Toasts.DismissAsync(toast.Id);
            await Toasts.PublishAsync(new CoreShellToastRequest(
                "Sample check completed",
                "The progress toast was closed by ID and replaced with this completion toast.",
                Severity: CoreShellNotificationSeverity.Success,
                Status: CoreShellNotificationStatus.Succeeded,
                Source: "CoreShell sample",
                Target: new CoreShellNotificationTarget("/operations", "Open operations"),
                TimeToLive: TimeSpan.FromSeconds(5)));
        }
        finally
        {
            IsRunningToastTask = false;
        }
    }

    private sealed record Row(string Name, string Owner, string State);
}
