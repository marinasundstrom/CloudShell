@implements IDisposable
@inject ICoreShellNotificationService Notifications
@inject NavigationManager Navigation

<div class="notification-host">
    <FluentButton Appearance="Appearance.Neutral"
                  Class="notification-trigger"
                  IconStart="@(new Icons.Regular.Size20.Alert())"
                  OnClick="TogglePanel">
        Notifications
        @if (UnreadCount > 0)
        {
            <span class="notification-count">@UnreadCount</span>
        }
    </FluentButton>

    @if (IsPanelOpen)
    {
        <section class="notification-panel" aria-label="Notifications">
            <div class="notification-panel-header">
                <strong>Notifications</strong>
                <FluentButton Appearance="Appearance.Stealth"
                              IconStart="@(new Icons.Regular.Size20.Dismiss())"
                              OnClick="ClosePanel">
                    Close
                </FluentButton>
            </div>

            @if (Items.Count == 0)
            {
                <div class="notification-empty">No notifications</div>
            }
            else
            {
                <div class="notification-list">
                    @foreach (var item in Items)
                    {
                        <article class="@GetItemClass(item)">
                            <div>
                                <strong>
                                    @if (IsLoading(item))
                                    {
                                        <span class="loading-indicator" aria-label="In progress"></span>
                                    }
                                    @item.Title
                                </strong>
                                <span>@item.Message</span>
                            </div>
                            <div class="notification-meta">
                                <span>@GetStatusText(item)</span>
                                @if (GetActions(item).Count > 0)
                                {
                                    @foreach (var action in GetActions(item))
                                    {
                                        <FluentButton Appearance="@(action.IsPrimary ? Appearance.Accent : Appearance.Stealth)"
                                                      OnClick="@(() => HandleActionAsync(item, action))">
                                            @action.Label
                                        </FluentButton>
                                    }
                                }
                                else if (item.Target is not null)
                                {
                                    <FluentAnchor Href="@item.Target.Href" Appearance="Appearance.Stealth">
                                        @(item.Target.Label ?? "Open")
                                    </FluentAnchor>
                                }
                                @if (item.AcknowledgedAt is null)
                                {
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  OnClick="@(() => AcknowledgeAsync(item.Id))">
                                        Acknowledge
                                    </FluentButton>
                                }
                                <FluentButton Appearance="Appearance.Stealth"
                                              IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                              OnClick="@(() => DismissAsync(item.Id))">
                                    Dismiss
                                </FluentButton>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@if (ToastItems.Count > 0)
{
    <div class="toast-stack" aria-live="polite">
        @foreach (var item in ToastItems)
        {
            <article class="@GetToastClass(item)">
                <strong>
                    @if (IsLoading(item))
                    {
                        <span class="loading-indicator" aria-label="In progress"></span>
                    }
                    @item.Title
                </strong>
                <span>@item.Message</span>
                <div class="toast-actions">
                    @foreach (var action in GetActions(item))
                    {
                        <FluentButton Appearance="@(action.IsPrimary ? Appearance.Accent : Appearance.Stealth)"
                                      OnClick="@(() => HandleActionAsync(item, action))">
                            @action.Label
                        </FluentButton>
                    }
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                  OnClick="@(() => DismissAsync(item.Id))">
                        Dismiss
                    </FluentButton>
                </div>
            </article>
        }
    </div>
}

@code {
    private IReadOnlyList<CoreShellNotificationInstance> Items { get; set; } = [];

    private bool IsPanelOpen { get; set; }

    private int UnreadCount => Items.Count(item => item.AcknowledgedAt is null);

    private IReadOnlyList<CoreShellNotificationInstance> ToastItems =>
        Items
            .Where(ShouldToast)
            .Take(2)
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        Notifications.NotificationsChanged += OnNotificationsChanged;
        await LoadAsync();
    }

    public void Dispose() =>
        Notifications.NotificationsChanged -= OnNotificationsChanged;

    private async Task LoadAsync()
    {
        Items = await Notifications.GetNotificationsAsync(new CoreShellNotificationQuery(Limit: 8));
        await InvokeAsync(StateHasChanged);
    }

    private async Task TogglePanel()
    {
        IsPanelOpen = !IsPanelOpen;
        await LoadAsync();
    }

    private void ClosePanel() =>
        IsPanelOpen = false;

    private async Task AcknowledgeAsync(string id)
    {
        await Notifications.AcknowledgeAsync(id);
        await LoadAsync();
    }

    private async Task DismissAsync(string id)
    {
        await Notifications.DismissAsync(id);
        await LoadAsync();
    }

    private async Task HandleActionAsync(
        CoreShellNotificationInstance item,
        CoreShellNotificationAction action)
    {
        await Notifications.HandleActionAsync(item.Id, action.Id);
        await LoadAsync();

        if (action.Target is not null)
        {
            Navigation.NavigateTo(action.Target.Href);
        }
    }

    private void OnNotificationsChanged(object? sender, CoreShellNotificationsChangedEventArgs args) =>
        _ = InvokeAsync(LoadAsync);

    private static string GetItemClass(CoreShellNotificationInstance item) =>
        $"notification-item {GetToneClass(item)}";

    private static string GetToastClass(CoreShellNotificationInstance item) =>
        $"toast-card {GetToneClass(item)}";

    private static string GetToneClass(CoreShellNotificationInstance item) =>
        item.Severity switch
        {
            CoreShellNotificationSeverity.Success => "is-success",
            CoreShellNotificationSeverity.Warning => "is-warning",
            CoreShellNotificationSeverity.Error => "is-error",
            _ when item.Status == CoreShellNotificationStatus.InProgress => "is-progress",
            _ => "is-info"
        };

    private static string GetStatusText(CoreShellNotificationInstance item) =>
        item.Status switch
        {
            CoreShellNotificationStatus.InProgress => "In progress",
            CoreShellNotificationStatus.Succeeded => "Succeeded",
            CoreShellNotificationStatus.Failed => "Failed",
            CoreShellNotificationStatus.NeedsAttention => "Needs attention",
            _ => item.Source ?? "Notification"
        };

    private static IReadOnlyList<CoreShellNotificationAction> GetActions(CoreShellNotificationInstance item) =>
        item.Actions ?? [];

    private static bool IsLoading(CoreShellNotificationInstance item) =>
        item.Status == CoreShellNotificationStatus.InProgress;

    private static bool ShouldToast(CoreShellNotificationInstance item) =>
        item.AcknowledgedAt is null
        && item.ToastBehavior != CoreShellNotificationToastBehavior.Suppressed;
}
