@implements IDisposable
@inject ICoreShellNotificationService Notifications
@inject ICoreShellToastService Toasts
@inject NavigationManager Navigation

<div class="notification-host">
    <FluentButton Appearance="Appearance.Neutral"
                  Class="notification-trigger"
                  IconStart="@(new Icons.Regular.Size20.Alert())"
                  OnClick="TogglePanel">
        Notifications
        @if (UnreadCount > 0)
        {
            <span class="notification-count">@UnreadCount</span>
        }
    </FluentButton>

    @if (IsPanelOpen)
    {
        <section class="notification-panel" aria-label="Notifications">
            <div class="notification-panel-header">
                <strong>Notifications</strong>
                <FluentButton Appearance="Appearance.Stealth"
                              IconStart="@(new Icons.Regular.Size20.Dismiss())"
                              OnClick="ClosePanel">
                    Close
                </FluentButton>
            </div>

            @if (Items.Count == 0)
            {
                <div class="notification-empty">No notifications</div>
            }
            else
            {
                <div class="notification-list">
                    @foreach (var item in Items)
                    {
                        <article class="@GetItemClass(item)">
                            @if (GetActions(item).Count == 0)
                            {
                                <button type="button"
                                        class="notification-body-button"
                                        @onclick="@(() => HandleDefaultAsync(item))">
                                    @RenderNotificationBody(item)
                                </button>
                            }
                            else
                            {
                                <div class="notification-body">
                                    @RenderNotificationBody(item)
                                </div>
                            }
                            <div class="notification-meta">
                                <span>@GetStatusText(item)</span>
                                @if (GetActions(item).Count > 0)
                                {
                                    @foreach (var action in GetActions(item))
                                    {
                                        <FluentButton Appearance="@(action.IsPrimary ? Appearance.Accent : Appearance.Stealth)"
                                                      OnClick="@(() => HandleActionAsync(item, action))">
                                            @action.Label
                                        </FluentButton>
                                    }
                                }
                                <FluentButton Appearance="Appearance.Stealth"
                                              IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                              OnClick="@(() => DismissAsync(item.Id))">
                                    Dismiss
                                </FluentButton>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@if (ToastOnlyItems.Count > 0 || ToastItems.Count > 0)
{
    <div class="toast-stack" aria-live="polite">
        @foreach (var item in ToastItems)
        {
            <article class="@GetToastClass(item)">
                @if (GetActions(item).Count == 0)
                {
                    <button type="button"
                            class="toast-body-button"
                            @onclick="@(() => HandleDefaultAsync(item))">
                        @RenderNotificationBody(item)
                    </button>
                }
                else
                {
                    <div class="toast-body">
                        @RenderNotificationBody(item)
                    </div>
                }
                <div class="toast-actions">
                    @foreach (var action in GetActions(item))
                    {
                        <FluentButton Appearance="@(action.IsPrimary ? Appearance.Accent : Appearance.Stealth)"
                                      OnClick="@(() => HandleActionAsync(item, action))">
                            @action.Label
                        </FluentButton>
                    }
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                  OnClick="@(() => DismissAsync(item.Id))">
                        Dismiss
                    </FluentButton>
                </div>
            </article>
        }

        @foreach (var item in ToastOnlyItems)
        {
            <article class="@GetToastClass(item)">
                @if (GetActions(item).Count == 0)
                {
                    <button type="button"
                            class="toast-body-button"
                            @onclick="@(() => HandleToastDefaultAsync(item))">
                        @RenderToastBody(item)
                    </button>
                }
                else
                {
                    <div class="toast-body">
                        @RenderToastBody(item)
                    </div>
                }
                <div class="toast-actions">
                    @foreach (var action in GetActions(item))
                    {
                        <FluentButton Appearance="@(action.IsPrimary ? Appearance.Accent : Appearance.Stealth)"
                                      OnClick="@(() => HandleToastActionAsync(item, action))">
                            @action.Label
                        </FluentButton>
                    }
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size16.Dismiss())"
                                  OnClick="@(() => DismissToastAsync(item.Id))">
                        Dismiss
                    </FluentButton>
                </div>
            </article>
        }
    </div>
}

@code {
    private const int NotificationCenterItemLimit = 8;
    private const int NotificationToastCandidateLimit = 100;
    private const int NotificationToastLimit = 2;

    private IReadOnlyList<CoreShellNotificationInstance> Items { get; set; } = [];

    private IReadOnlyList<CoreShellNotificationInstance> ToastCandidates { get; set; } = [];

    private IReadOnlyList<CoreShellToast> ToastOnlyCandidates { get; set; } = [];

    private bool IsPanelOpen { get; set; }

    private PeriodicTimer? RefreshTimer { get; set; }

    private CancellationTokenSource? RefreshTimerCancellation { get; set; }

    private int UnreadCount => Items.Count(NeedsUserAttention);

    private IReadOnlyList<CoreShellNotificationInstance> ToastItems =>
        CoreShellNotificationPresentation.SelectToastItems(
            ToastCandidates,
            DateTimeOffset.UtcNow,
            NotificationToastLimit);

    private IReadOnlyList<CoreShellToast> ToastOnlyItems =>
        CoreShellNotificationPresentation.SelectToastItems(
            ToastOnlyCandidates,
            DateTimeOffset.UtcNow,
            Math.Max(0, NotificationToastLimit - ToastItems.Count));

    protected override async Task OnInitializedAsync()
    {
        Notifications.NotificationsChanged += OnNotificationsChanged;
        Toasts.ToastsChanged += OnToastsChanged;
        RefreshTimerCancellation = new CancellationTokenSource();
        RefreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = RunRefreshTimerAsync(RefreshTimer, RefreshTimerCancellation.Token);
        await LoadAsync();
    }

    public void Dispose()
    {
        RefreshTimerCancellation?.Cancel();
        RefreshTimer?.Dispose();
        RefreshTimerCancellation?.Dispose();
        Notifications.NotificationsChanged -= OnNotificationsChanged;
        Toasts.ToastsChanged -= OnToastsChanged;
    }

    private async Task LoadAsync()
    {
        var notifications = await Notifications.GetNotificationsAsync(
            new CoreShellNotificationQuery(Limit: NotificationToastCandidateLimit));
        ToastCandidates = notifications;
        Items = notifications
            .Take(NotificationCenterItemLimit)
            .ToArray();
        ToastOnlyCandidates = await Toasts.GetToastsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RunRefreshTimerAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(LoadAsync);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task TogglePanel()
    {
        IsPanelOpen = !IsPanelOpen;
        await LoadAsync();
    }

    private void ClosePanel() =>
        IsPanelOpen = false;

    private async Task AcknowledgeAsync(string id)
    {
        await Notifications.AcknowledgeAsync(id);
        await LoadAsync();
    }

    private async Task DismissAsync(string id)
    {
        await Notifications.DismissAsync(id);
        await LoadAsync();
    }

    private async Task DismissToastAsync(string id)
    {
        await Toasts.DismissAsync(id);
        await LoadAsync();
    }

    private async Task HandleDefaultAsync(CoreShellNotificationInstance item)
    {
        if (item.Target is not null)
        {
            await Notifications.AcknowledgeAsync(item.Id);
            await LoadAsync();
            Navigation.NavigateTo(item.Target.Href);
            return;
        }

        await DismissAsync(item.Id);
    }

    private async Task HandleToastDefaultAsync(CoreShellToast item)
    {
        if (item.Target is not null)
        {
            await Toasts.DismissAsync(item.Id);
            await LoadAsync();
            Navigation.NavigateTo(item.Target.Href);
            return;
        }

        await DismissToastAsync(item.Id);
    }

    private async Task HandleActionAsync(
        CoreShellNotificationInstance item,
        CoreShellNotificationAction action)
    {
        await Notifications.HandleActionAsync(item.Id, action.Id);
        await LoadAsync();

        if (action.Target is not null)
        {
            Navigation.NavigateTo(action.Target.Href);
        }
    }

    private async Task HandleToastActionAsync(
        CoreShellToast item,
        CoreShellNotificationAction action)
    {
        await Toasts.HandleActionAsync(item.Id, action.Id);
        await LoadAsync();

        if (action.Target is not null)
        {
            Navigation.NavigateTo(action.Target.Href);
        }
    }

    private void OnNotificationsChanged(object? sender, CoreShellNotificationsChangedEventArgs args) =>
        _ = InvokeAsync(LoadAsync);

    private void OnToastsChanged(object? sender, CoreShellToastsChangedEventArgs args) =>
        _ = InvokeAsync(LoadAsync);

    private static string GetItemClass(CoreShellNotificationInstance item) =>
        $"notification-item {GetToneClass(item)}";

    private static string GetToastClass(CoreShellNotificationInstance item) =>
        $"toast-card {GetToneClass(item)}";

    private static string GetToastClass(CoreShellToast item) =>
        $"toast-card {GetToneClass(item)}";

    private static string GetToneClass(CoreShellNotificationInstance item) =>
        item.Severity switch
        {
            CoreShellNotificationSeverity.Success => "is-success",
            CoreShellNotificationSeverity.Warning => "is-warning",
            CoreShellNotificationSeverity.Error => "is-error",
            _ when item.Status == CoreShellNotificationStatus.InProgress => "is-progress",
            _ => "is-info"
        };

    private static string GetToneClass(CoreShellToast item) =>
        item.Severity switch
        {
            CoreShellNotificationSeverity.Success => "is-success",
            CoreShellNotificationSeverity.Warning => "is-warning",
            CoreShellNotificationSeverity.Error => "is-error",
            _ when item.Status == CoreShellNotificationStatus.InProgress => "is-progress",
            _ => "is-info"
        };

    private static string GetStatusText(CoreShellNotificationInstance item) =>
        item.Status switch
        {
            CoreShellNotificationStatus.InProgress => "In progress",
            CoreShellNotificationStatus.Succeeded => "Succeeded",
            CoreShellNotificationStatus.Failed => "Failed",
            CoreShellNotificationStatus.NeedsAttention => "Needs attention",
            _ => item.Source ?? "Notification"
        };

    private static IReadOnlyList<CoreShellNotificationAction> GetActions(CoreShellNotificationInstance item) =>
        item.Actions ?? [];

    private static IReadOnlyList<CoreShellNotificationAction> GetActions(CoreShellToast item) =>
        item.Actions ?? [];

    private static bool IsLoading(CoreShellNotificationInstance item) =>
        item.Status == CoreShellNotificationStatus.InProgress;

    private static bool NeedsUserAttention(CoreShellNotificationInstance item) =>
        item.AcknowledgedAt is null &&
        item.DismissedAt is null &&
        (GetActions(item).Count > 0 ||
            item.Status is CoreShellNotificationStatus.NeedsAttention
                or CoreShellNotificationStatus.Failed ||
            item.Severity is CoreShellNotificationSeverity.Warning
                or CoreShellNotificationSeverity.Error);

    private static bool IsLoading(CoreShellToast item) =>
        item.Status == CoreShellNotificationStatus.InProgress;

    private RenderFragment RenderNotificationBody(CoreShellNotificationInstance item) => @<div>
        <strong>
            @if (IsLoading(item))
            {
                <span class="loading-indicator" aria-label="In progress"></span>
            }
            @item.Title
        </strong>
        <span>@item.Message</span>
        @if (item.Target is not null && GetActions(item).Count == 0)
        {
            <small>@(item.Target.Label ?? "Open")</small>
        }
    </div>;

    private RenderFragment RenderToastBody(CoreShellToast item) => @<div>
        <strong>
            @if (IsLoading(item))
            {
                <span class="loading-indicator" aria-label="In progress"></span>
            }
            @item.Title
        </strong>
        <span>@item.Message</span>
        @if (item.Target is not null && GetActions(item).Count == 0)
        {
            <small>@(item.Target.Label ?? "Open")</small>
        }
    </div>;
}
