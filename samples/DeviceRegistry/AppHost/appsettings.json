{
  "Authentication": {
    "Enabled": false
  },
  "CloudShell": {
    "Launcher": {
      "ControlPlaneUrl": "http://localhost:5000"
    },
    "DataDirectory": "../.cloudshell/data"
  },
  "ResourceIdentity": {
    "BuiltIn": {
      "ProviderName": "Local Development Identity",
      "Users": [
        {
          "UserName": "device-admin",
          "Password": "CloudShell123!",
          "DisplayName": "Device Registry Administrator",
          "Email": "device-admin@example.test",
          "Roles": [
            "CloudShell.Administrator"
          ]
        }
      ]
    }
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
