<Project>
  <ItemGroup Condition="'$(UsingMicrosoftNETSdkWeb)' == 'true'">
    <Compile Include="$(MSBuildThisFileDirectory)SampleHostSettings.cs" Link="SampleHostSettings.cs" />
    <Content Update="hostsettings.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Condition="Exists('hostsettings.json')" />
  </ItemGroup>
</Project>
