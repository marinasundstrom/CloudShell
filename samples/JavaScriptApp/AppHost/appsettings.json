{
  "Authentication": {
    "Enabled": false
  },
  "CloudShell": {
    "Launcher": {
      "ControlPlaneUrl": "http://127.0.0.1:5097"
    },
    "DataDirectory": "../.cloudshell/data"
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
