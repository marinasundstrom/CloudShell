{
  "Authentication": {
    "Enabled": false
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-project-reference-sample.db",
    "IdentityConnectionString": "Data Source=Data/identity-project-reference-sample.db"
  },
  "Observability": {
    "OtlpEndpoint": "http://localhost:5104",
    "OtlpProtocol": "http/protobuf",
    "TraceIngestEndpoint": "http://localhost:5104/api/control-plane/v1/traces/ingest"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
