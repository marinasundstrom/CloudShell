{
  "Authentication": {
    "Enabled": false
  },
  "CloudShell": {
    "Launcher": {
      "ControlPlaneUrl": "http://127.0.0.1:5112"
    },
    "DataDirectory": "../.cloudshell/data"
  },
  "RabbitMQMessaging": {
    "RabbitMQPort": "5678",
    "ManagementEndpoint": "http://localhost:15678",
    "DotNetEndpoint": "http://localhost:5281",
    "JavaEndpoint": "http://localhost:5282"
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
