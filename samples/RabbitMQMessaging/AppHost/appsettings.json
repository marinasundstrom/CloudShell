{
  "Authentication": {
    "Enabled": false
  },
  "CloudShell": {
    "Launcher": {
      "ControlPlaneUrl": "http://127.0.0.1:5112"
    },
    "DataDirectory": "../.cloudshell/data"
  },
  "ResourceIdentity": {
    "BuiltIn": {
      "ProviderName": "Local Development Identity",
      "Users": [
        {
          "UserName": "rabbitmq-operator",
          "DisplayName": "RabbitMQ Operator",
          "Email": "rabbitmq-operator@example.test"
        },
        {
          "UserName": "rabbitmq-reader",
          "DisplayName": "RabbitMQ Reader",
          "Email": "rabbitmq-reader@example.test"
        }
      ]
    }
  },
  "RabbitMQMessaging": {
    "RabbitMQPort": "5678",
    "ManagementEndpoint": "http://localhost:15678",
    "DotNetEndpoint": "http://localhost:5281",
    "JavaEndpoint": "http://localhost:5282",
    "VirtualHost": "cloudshell_sample"
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
