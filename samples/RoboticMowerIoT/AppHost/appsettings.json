{
  "Authentication": {
    "Enabled": false
  },
  "CloudShell": {
    "Launcher": {
      "ControlPlaneUrl": "http://127.0.0.1:7165"
    },
    "DataDirectory": "../.cloudshell/data",
    "DeviceRegistryService": {
      "EnrollmentToken": "local-development-mower-enrollment-token"
    }
  },
  "RoboticMowerIoT": {
    "BackendPort": "7161",
    "FrontendEndpoint": "http://localhost:7162",
    "DeviceRegistryEndpoint": "http://localhost:7160",
    "BackendDeviceRegistryEndpoint": "http://host.docker.internal:7160",
    "DeviceRegistryMqttEndpoint": "mqtt://localhost:7163",
    "RegistryManagementClientId": "device-registry-admin",
    "RegistryManagementClientSecret": "local-development-device-registry-admin-secret"
  },
  "Observability": {
    "OtlpProtocol": "http/protobuf"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
