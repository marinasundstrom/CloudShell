{
  "Authentication": {
    "Enabled": true,
    "Mode": "Identity",
    "BuiltInAuthority": {
      "Enabled": true,
      "Issuer": "http://localhost:5095",
      "Audience": "cloudshell-control-plane",
      "Clients": {
        "cloudshell-split-ui": {
          "Secret": "local-development-client-secret",
          "Scopes": [ "ControlPlane.Access" ],
          "Roles": [ "CloudShell.Administrator" ]
        }
      }
    }
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-split-control-plane.db"
  },
  "Identity": {
    "BuiltIn": {
      "Persistence": {
        "Provider": "Sqlite",
        "ConnectionString": "Data Source=Data/identity-split-control-plane.db"
      }
    }
  },
  "SplitHosting": {
    "GraphOnly": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
