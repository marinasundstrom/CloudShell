{
  "CloudShell": {
    "ControlPlane": {
      "BaseAddress": "http://localhost:5095",
      "Credential": {
        "Mode": "ClientCredentials",
        "ClientId": "cloudshell-split-ui",
        "ClientSecret": "local-development-client-secret",
        "Scopes": [ "ControlPlane.Access" ]
      }
    }
  },
  "Authentication": {
    "Enabled": false
  },
  "Shell": {
    "EnvironmentSettings": {
      "Storage": "ControlPlane"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
