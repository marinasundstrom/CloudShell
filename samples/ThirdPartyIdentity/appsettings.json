{
  "Authentication": {
    "Enabled": true,
    "Mode": "OpenIdConnect",
    "DefaultScheme": "CloudShell.Cookie",
    "ChallengeScheme": "CloudShell.OpenIdConnect",
    "RoleClaimType": "roles",
    "AdministratorRole": "CloudShell.Administrator",
    "RolePermissions": {
      "CloudShell.Administrator": [ "*" ],
      "CloudShell.Contributor": [
        "resource-groups.read",
        "resource-groups.create",
        "resource-groups.manage",
        "resources.read",
        "resources.create",
        "resources.manage"
      ],
      "CloudShell.Reader": [
        "resource-groups.read",
        "resources.read"
      ]
    },
    "RoleResourceGroups": {
      "CloudShell.Administrator": [ "*" ],
      "CloudShell.Contributor": [ "*" ],
      "CloudShell.Reader": [ "*" ]
    },
    "OpenIdConnect": {
      "Authority": "http://localhost:8080/realms/cloudshell",
      "ClientId": "cloudshell-ui",
      "ClientSecret": "local-development-cloudshell-ui-secret",
      "CallbackPath": "/signin-oidc",
      "RequireHttpsMetadata": false,
      "GetClaimsFromUserInfoEndpoint": true,
      "Scopes": [ "openid", "profile", "email" ]
    }
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=Data/cloudshell-third-party-identity.db",
    "IdentityConnectionString": "Data Source=Data/identity-third-party-identity.db"
  },
  "Localization": {
    "DefaultCulture": "en",
    "SupportedCultures": [ "en" ]
  },
  "Shell": {
    "ApplicationName": "CloudShell"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
