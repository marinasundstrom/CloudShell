{
  "name": "@cloudshell/configuration-client",
  "version": "0.0.0-poc",
  "description": "Experimental TypeScript clients for CloudShell Configuration Store and Secrets Vault.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
